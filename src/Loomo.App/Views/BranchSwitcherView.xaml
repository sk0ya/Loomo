<UserControl x:Class="sk0ya.Loomo.App.Views.BranchSwitcherView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <!-- 同期帯のボタン。アイコン＋名前＋件数を1行に載せるので可変幅。
             件数の色分けは中の TextBlock 側で行うので、ここでは前景色を触らない。 -->
        <Style x:Key="SyncOpButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Margin" Value="0,0,2,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource BgAlt}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="b" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SyncOpLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource Fg}" />
            <Setter Property="Margin" Value="5,0,0,0" />
        </Style>

        <!-- 対象があるとき（件数>0）だけ出るアクセント色の件数 -->
        <Style x:Key="SyncOpCount" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource Fs11}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="Foreground" Value="{DynamicResource Accent}" />
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Border}"
            BorderThickness="1" CornerRadius="4" Padding="4"
            MinWidth="300" MaxWidth="420" Margin="0,2,8,8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.3" />
        </Border.Effect>

        <DockPanel>
            <!-- ===== 同期帯（リポジトリ全体の操作）=====
                 フェッチはリモートに、プル／プッシュは現在ブランチと上流に効く操作で、一覧で選んだ
                 ブランチとは関係がない。だから一覧の外＝この固定帯に置く（以前は行の右クリック
                 メニューに紛れていて、選んだ行に効くように見えていた）。 -->
            <Border DockPanel.Dock="Top" Background="{DynamicResource Bg}" CornerRadius="4"
                    Padding="8,6" Margin="0,0,0,4">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="{Binding RemoteLabel}" FontSize="{DynamicResource Fs12}"
                                   FontWeight="SemiBold" Foreground="{DynamicResource Fg}"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding HasRemote, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Text="{Binding SyncTargetLabel}" FontSize="{DynamicResource Fs11}"
                                   Foreground="{DynamicResource FgDim}" VerticalAlignment="Center"
                                   Margin="6,1,0,0" TextTrimming="CharacterEllipsis"
                                   ToolTip="プル／プッシュの相手（現在ブランチの上流）"
                                   Visibility="{Binding HasRemote, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Text="リモートがありません" FontSize="{DynamicResource Fs11}"
                                   Foreground="{DynamicResource FgDim}" VerticalAlignment="Center"
                                   Visibility="{Binding HasRemote, Converter={StaticResource InverseBoolToVis}}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <!-- マルチルート（ワークスペースフォルダーが2つ以上）のときだけ：Git 操作の対象フォルダーを
                             選ぶ。Git ペイン・サイドバー Git パネルと同じ GitRootSwitchViewModel を共有するので、
                             どこで切り替えても全部に反映される。 -->
                        <ComboBox MinHeight="26" Margin="0,0,6,0"
                                  ItemsSource="{Binding RootSwitch.RootOptions}"
                                  SelectedItem="{Binding RootSwitch.SelectedRootOption, Mode=TwoWay}"
                                  DisplayMemberPath="Label"
                                  ToolTip="{Binding RootSwitch.SelectedRootOption.FullPath}"
                                  Visibility="{Binding RootSwitch.IsMultiRoot, Converter={StaticResource BoolToVis}}" />
                        <StackPanel Orientation="Horizontal"
                                    IsEnabled="{Binding HasRemote}">
                        <Button Style="{StaticResource SyncOpButton}"
                                ToolTip="フェッチ（リモートの最新を取得する。作業ツリーは変えない）"
                                Command="{Binding FetchCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⭮" FontSize="{DynamicResource Fs14}"
                                           Foreground="{DynamicResource FgDim}" VerticalAlignment="Center" />
                                <TextBlock Text="フェッチ" Style="{StaticResource SyncOpLabel}" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SyncOpButton}"
                                ToolTip="プル（上流の変更を現在ブランチへ取り込む）"
                                Command="{Binding PullCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="↓" FontSize="{DynamicResource Fs14}" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Behind, Converter={StaticResource CountToVis}}" Value="Visible">
                                                    <Setter Property="Foreground" Value="{DynamicResource Accent}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="プル" Style="{StaticResource SyncOpLabel}" />
                                <TextBlock Text="{Binding Behind}" Style="{StaticResource SyncOpCount}"
                                           Visibility="{Binding Behind, Converter={StaticResource CountToVis}}" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SyncOpButton}"
                                ToolTip="プッシュ（現在ブランチのコミットを上流へ送る。上流未設定なら作成する）"
                                Command="{Binding PushCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="↑" FontSize="{DynamicResource Fs14}" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Ahead, Converter={StaticResource CountToVis}}" Value="Visible">
                                                    <Setter Property="Foreground" Value="{DynamicResource Accent}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="プッシュ" Style="{StaticResource SyncOpLabel}" />
                                <TextBlock Text="{Binding Ahead}" Style="{StaticResource SyncOpCount}"
                                           Visibility="{Binding Ahead, Converter={StaticResource CountToVis}}" />
                            </StackPanel>
                        </Button>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== フッター：一覧に無いものを作る＋この場発の操作が失敗した理由 ===== -->
            <StackPanel DockPanel.Dock="Bottom">
                <Border Height="1" Background="{DynamicResource Border}" Margin="2,4" />
                <Button Style="{StaticResource BranchMenuItem}" FontSize="{DynamicResource Fs12}"
                        Content="＋ 新しいブランチ" Click="OnNewBranchClick" />
                <TextBlock x:Name="StatusText" Margin="10,2,10,4" FontSize="{DynamicResource Fs11}"
                           Foreground="#FFE57373" TextWrapping="Wrap"
                           MaxHeight="80" Visibility="Collapsed" />
            </StackPanel>

            <!-- ===== 絞り込み（ブランチが増えるとツリーのスクロールが辛い）===== -->
            <Grid DockPanel.Dock="Top" Margin="2,0,2,4">
                <TextBox x:Name="FilterBox" MinHeight="24" Padding="6,3"
                         VerticalContentAlignment="Center"
                         Text="{Binding BranchFilter, UpdateSourceTrigger=PropertyChanged, Delay=120}"
                         PreviewKeyDown="OnFilterKeyDown" />
                <TextBlock Text="🔍 ブランチを絞り込み" Foreground="{DynamicResource FgDim}"
                           FontSize="{DynamicResource Fs12}" Margin="8,0,0,0" IsHitTestVisible="False"
                           VerticalAlignment="Center"
                           Visibility="{Binding BranchFilter, Converter={StaticResource EmptyToVis}}" />
            </Grid>

            <!-- ===== ブランチ一覧 =====
                 クリック＝リーフは選択のみ（チェックアウトは右クリックメニューから）、
                 フォルダ／見出しは開閉（OnTreeClick）。 -->
            <TreeView x:Name="Tree" MaxHeight="360"
                      Background="Transparent" BorderThickness="0"
                      Foreground="{DynamicResource Fg}"
                      ItemsSource="{Binding FilteredBranchTree}"
                      ItemContainerStyle="{StaticResource BranchTreeItem}"
                      ItemTemplate="{StaticResource BranchNodeTemplate}"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      PreviewMouseLeftButtonUp="OnTreeClick"
                      PreviewMouseRightButtonDown="OnTreeRightClickSelect"
                      ContextMenuOpening="OnTreeContextMenuOpening">
                <!-- 行の右クリック＝そのブランチだけに効く操作。リポジトリ全体の同期は上の帯にある。
                     現在ブランチ・リモートブランチに意味を成さない項目は OnTreeContextMenuOpening が落とす。 -->
                <TreeView.ContextMenu>
                    <ContextMenu>
                        <MenuItem x:Name="MenuCheckout" Header="チェックアウト" Click="OnMenuCheckout" />
                        <MenuItem x:Name="MenuMerge" Header="現在のブランチへマージ" Click="OnMenuMerge" />
                        <MenuItem x:Name="MenuRebase" Header="このブランチへリベース（現在のブランチを載せ替え）"
                                  Click="OnMenuRebase" />
                        <Separator />
                        <MenuItem Header="ここから新しいブランチを作成…" Click="OnMenuCreateFrom" />
                        <MenuItem Header="ブランチ名をコピー" Click="OnMenuCopyName" />
                        <Separator />
                        <MenuItem x:Name="MenuDelete" Header="削除" Click="OnMenuDelete" />
                    </ContextMenu>
                </TreeView.ContextMenu>
            </TreeView>
        </DockPanel>
    </Border>
</UserControl>
