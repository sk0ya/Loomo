<UserControl x:Class="sk0ya.Loomo.App.Views.ProblemsPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:sk0ya.Loomo.App.ViewModels"
    Background="{DynamicResource BgAlt}">

    <!-- ライブラリ側テーマではなくこのパネル固有の色。DebugView.xaml のローカル定義（#E06C75）と揃えてあるが、
         UserControl.Resources はスコープが閉じているので同じキー名でも共有はされない（別途定義が必要）。 -->
    <UserControl.Resources>
        <SolidColorBrush x:Key="ProblemsError" Color="#E06C75" />
        <SolidColorBrush x:Key="ProblemsWarning" Color="#E5C07B" />

        <!-- 重要度で色分けするグリフのスタイル（既定=Fgdim=Information/Hint）。 -->
        <Style x:Key="ProblemSeverityGlyph" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Severity}" Value="Error">
                    <Setter Property="Foreground" Value="{StaticResource ProblemsError}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity}" Value="Warning">
                    <Setter Property="Foreground" Value="{StaticResource ProblemsWarning}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <!-- 診断（Problems）：開いているエディタタブの診断（LSP publishDiagnostics ＋ホスト診断）を集約した一覧。
         集約自体は ShellWindow.Problems.cs（View層）が行い、ここは表示専用。行クリックで該当位置へジャンプする。 -->
    <DockPanel>
        <DockPanel DockPanel.Dock="Top">
            <TextBlock DockPanel.Dock="Left" Style="{StaticResource PanelHeader}" Text="診断" />
            <TextBlock DockPanel.Dock="Right" Margin="0,0,10,0" VerticalAlignment="Center"
                       FontSize="{DynamicResource Fs11}" Foreground="{DynamicResource FgDim}">
                <Run Text="✕" Foreground="{StaticResource ProblemsError}" />
                <Run Text="{Binding ErrorCount, Mode=OneWay}" />
                <Run Text="   ▲" Foreground="{StaticResource ProblemsWarning}" />
                <Run Text="{Binding WarningCount, Mode=OneWay}" />
            </TextBlock>
        </DockPanel>

        <TextBlock DockPanel.Dock="Top" Margin="10,20" TextWrapping="Wrap" HorizontalAlignment="Center"
                   FontSize="{DynamicResource Fs11}" Foreground="{DynamicResource FgDim}" TextAlignment="Center"
                   Visibility="{Binding HasItems, Converter={StaticResource InverseBoolToVis}}"
                   Text="診断はありません（言語サーバーが接続されたファイルを開くとここに表示されます）" />

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Items}" Margin="2">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ProblemItemViewModel}">
                        <Button Style="{StaticResource BranchMenuItem}" HorizontalAlignment="Stretch"
                                Margin="2,1" ToolTip="{Binding Message}"
                                Command="{Binding DataContext.OpenCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding SeverityGlyph}" Width="16" VerticalAlignment="Top"
                                           FontSize="{DynamicResource Fs11}"
                                           Style="{StaticResource ProblemSeverityGlyph}" />
                                <StackPanel>
                                    <TextBlock Text="{Binding Message}" TextWrapping="Wrap"
                                               Foreground="{DynamicResource Fg}" FontSize="{DynamicResource Fs12}" />
                                    <TextBlock Text="{Binding Location}" FontSize="{DynamicResource Fs11}"
                                               Foreground="{DynamicResource FgDim}" Margin="0,1,0,0" />
                                </StackPanel>
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
