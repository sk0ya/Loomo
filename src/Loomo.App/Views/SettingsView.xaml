<UserControl x:Class="sk0ya.Loomo.App.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{DynamicResource BgAlt}">

    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Style="{StaticResource PanelHeader}" Text="設定" />

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,4,10,12">
            <StackPanel>

                <!-- ===== モデル ===== -->
                <!-- 「モデル」と「モデルフォルダ」は同じ実体（選んだローカルフォルダ）なので
                     1つのセレクタに統合。フォルダは選択結果として下に注記表示するだけにする。
                     コンボは IsEditable のまま IsReadOnly で自由入力を封じる（非編集の SelectedItem だと
                     リスト未取得時に選択が null へ巻き戻り Model が消えるため）。 -->
                <TextBlock Style="{StaticResource SectionTitle}" Text="モデル" Margin="0,2,0,4" />
                <ComboBox IsEditable="True" IsReadOnly="True"
                          ItemsSource="{Binding AvailableModels}"
                          IsDropDownOpen="{Binding ModelDropDownOpen, Mode=TwoWay}"
                          Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}"
                          ToolTip="ローカルに配置済みの ONNX モデルから選びます。" />
                <TextBlock Text="{Binding ModelPath, StringFormat='📁 {0}'}"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding ModelPath}"
                           Foreground="{DynamicResource FgDim}" FontSize="11"
                           Margin="2,5,0,0" />

                <Button Style="{StaticResource WideButton}" Content="⬇  ダウンロード"
                        ToolTip="Hugging Face から phi4-mini（CPU int4）をダウンロードして追加します。"
                        Command="{Binding DownloadModelCommand}"
                        IsEnabled="{Binding IsDownloading, Converter={StaticResource InverseBool}}" />
                <Button Style="{StaticResource WideButton}" Content="📂  別の場所から追加…"
                        ToolTip="任意の場所にある ONNX モデルフォルダ（genai_config.json を含む）を選んで追加します。"
                        Command="{Binding BrowseModelCommand}" />
                <ProgressBar Height="6" Margin="0,8,0,0" Minimum="0" Maximum="100"
                             Value="{Binding DownloadProgress, Mode=OneWay}"
                             Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}" />

                <TextBlock Style="{StaticResource FieldLabel}" Text="最大出力トークン" />
                <TextBox Text="{Binding MaxTokens, UpdateSourceTrigger=PropertyChanged}" />

                <CheckBox IsChecked="{Binding WarmupEnabled}" Margin="0,10,0,0"
                          ToolTip="起動時・ワークスペース確定時にモデルとシステムプロンプトを事前ロードし、初回ターンを速くします。実行中はAIへの指示を受け付けません。">
                    <TextBlock Text="AIウォームアップを有効にする" TextWrapping="Wrap"
                               Foreground="{DynamicResource Fg}" />
                </CheckBox>

                <!-- ===== エディタ ===== -->
                <Separator Margin="0,16,0,10" />
                <TextBlock Style="{StaticResource SectionTitle}" Text="エディタ" />
                <CheckBox IsChecked="{Binding VimEnabled}" Margin="0,6,0,0"
                          ToolTip="有効/無効は開いているタブにも反映されます。">
                    <TextBlock Text="Vim キーバインドを有効にする" TextWrapping="Wrap"
                               Foreground="{DynamicResource Fg}" />
                </CheckBox>

                <!-- ===== 安全設計 ===== -->
                <Separator Margin="0,16,0,10" />
                <TextBlock Style="{StaticResource SectionTitle}" Text="安全設計" />
                <CheckBox IsChecked="{Binding AutoApprove}" Margin="0,6,0,0"
                          ToolTip="信頼ワークスペース向け。コマンド/編集の承認カードを省略します。">
                    <TextBlock Text="自動承認モード" TextWrapping="Wrap"
                               Foreground="{DynamicResource Fg}" />
                </CheckBox>
                <CheckBox IsChecked="{Binding RestrictToWorkspaceRoot}" Margin="0,6,0,0"
                          ToolTip="パストラバーサルを防止します。">
                    <TextBlock Text="ファイルアクセスをワークスペース内に限定" TextWrapping="Wrap"
                               Foreground="{DynamicResource Fg}" />
                </CheckBox>

                <TextBlock Style="{StaticResource FieldLabel}" Text="ブロックする危険コマンド" />
                <Button Style="{StaticResource WideButton}" Margin="0,0,0,0" Content="エディタで編集"
                        Command="{Binding EditBlockedCommandsCommand}" />
                <Button Style="{StaticResource WideButton}" Content="既定に戻す"
                        Command="{Binding ResetBlockedCommandsCommand}" />
                <TextBlock Style="{StaticResource FieldHint}"
                           Text="1行に1つ・正規表現（大文字小文字無視）。保存（:w）で即時反映。" />

                <!-- 変更は自動で反映・保存されます（「保存」ボタンは廃止）。 -->
                <TextBlock Text="{Binding Status}" TextWrapping="Wrap" Margin="0,16,0,0"
                           Foreground="{DynamicResource FgDim}" FontSize="11" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
