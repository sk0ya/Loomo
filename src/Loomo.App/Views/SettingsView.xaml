<UserControl x:Class="sk0ya.Loomo.App.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BgAlt}">

    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Style="{StaticResource PanelHeader}" Text="設定 — AIプロバイダ" />

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,4,12,12">
            <StackPanel>

                <!-- プロバイダ選択 -->
                <TextBlock Style="{StaticResource FieldLabel}" Text="プロバイダ" Margin="0,0,0,3" />
                <RadioButton Style="{StaticResource ProviderRadio}" GroupName="provider" Content="Stub（鍵不要・動作確認用）"
                             IsChecked="{Binding SelectedProvider, Converter={StaticResource EnumToBool}, ConverterParameter=Stub}" />
                <RadioButton Style="{StaticResource ProviderRadio}" GroupName="provider" Content="Claude（Anthropic API）"
                             IsChecked="{Binding SelectedProvider, Converter={StaticResource EnumToBool}, ConverterParameter=Claude}" />
                <RadioButton Style="{StaticResource ProviderRadio}" GroupName="provider" Content="OpenAI（互換API）"
                             IsChecked="{Binding SelectedProvider, Converter={StaticResource EnumToBool}, ConverterParameter=OpenAI}" />
                <RadioButton Style="{StaticResource ProviderRadio}" GroupName="provider" Content="GitHub Copilot"
                             IsChecked="{Binding SelectedProvider, Converter={StaticResource EnumToBool}, ConverterParameter=Copilot}" />
                <RadioButton Style="{StaticResource ProviderRadio}" GroupName="provider" Content="ローカルLLM（Ollama 等）"
                             IsChecked="{Binding SelectedProvider, Converter={StaticResource EnumToBool}, ConverterParameter=Local}" />

                <!-- モデル -->
                <StackPanel Visibility="{Binding ShowModel, Converter={StaticResource BoolToVis}}">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="モデル" />
                    <TextBox Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <!-- API キー -->
                <StackPanel Visibility="{Binding ShowApiKey, Converter={StaticResource BoolToVis}}">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="APIキー（DPAPIで暗号化して保存）" />
                    <TextBox Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Cascadia Mono, Consolas" />
                </StackPanel>

                <!-- Base URL -->
                <StackPanel Visibility="{Binding ShowBaseUrl, Converter={StaticResource BoolToVis}}">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="ベースURL（OpenAI互換エンドポイント）" />
                    <TextBox Text="{Binding BaseUrl, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Cascadia Mono, Consolas" />
                </StackPanel>

                <!-- 最大トークン -->
                <StackPanel Visibility="{Binding ShowModel, Converter={StaticResource BoolToVis}}">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="最大トークン" />
                    <TextBox Text="{Binding MaxTokens, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <!-- システムプロンプト -->
                <TextBlock Style="{StaticResource FieldLabel}" Text="システムプロンプト" />
                <TextBox Text="{Binding SystemPrompt, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="90"
                         VerticalScrollBarVisibility="Auto" />

                <!-- 保存 -->
                <Button Content="保存" Style="{StaticResource FlatButton}"
                        Command="{Binding SaveCommand}" HorizontalAlignment="Left" Margin="0,14,0,0" />

                <TextBlock Text="{Binding Status}" TextWrapping="Wrap" Margin="0,10,0,0"
                           Foreground="{StaticResource FgDim}" FontSize="11" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
