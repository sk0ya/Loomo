<UserControl x:Class="sk0ya.Loomo.App.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{DynamicResource BgAlt}">

    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Style="{StaticResource PanelHeader}" Text="設定 — ローカルLLM" />

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,4,12,12">
            <StackPanel>

                <TextBlock Style="{StaticResource FieldLabel}" Text="モデル" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" IsEditable="True"
                              StaysOpenOnEdit="True"
                              ItemsSource="{Binding AvailableModels}"
                              IsDropDownOpen="{Binding ModelDropDownOpen, Mode=TwoWay}"
                              Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="1" Content="再取得" Style="{StaticResource FlatButton}"
                            Margin="6,0,0,0"
                            Command="{Binding FetchModelsCommand}"
                            IsEnabled="{Binding IsFetchingModels, Converter={StaticResource InverseBool}}" />
                </Grid>
                <TextBlock Text="ローカルに配置済みの ONNX モデルフォルダから選びます（「再取得」で再列挙）。"
                           Foreground="{DynamicResource FgDim}" FontSize="11"
                           TextWrapping="Wrap" Margin="0,4,0,0" />

                <TextBlock Style="{StaticResource FieldLabel}" Text="モデルフォルダ" />
                <TextBox Text="{Binding ModelPath, UpdateSourceTrigger=PropertyChanged}"
                         IsReadOnly="True" TextWrapping="Wrap" />
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <Button Content="フォルダ選択" Style="{StaticResource FlatButton}"
                            Command="{Binding BrowseModelCommand}" />
                    <Button Content="phi4-mini をダウンロード" Style="{StaticResource FlatButton}"
                            Margin="6,0,0,0"
                            Command="{Binding DownloadModelCommand}"
                            IsEnabled="{Binding IsDownloading, Converter={StaticResource InverseBool}}" />
                </StackPanel>
                <ProgressBar Height="6" Margin="0,6,0,0" Minimum="0" Maximum="100"
                             Value="{Binding DownloadProgress, Mode=OneWay}"
                             Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}" />
                <TextBlock Text="ONNX Runtime GenAI（CPU）が読むフォルダです。genai_config.json を含むフォルダを指定するか、Hugging Face からダウンロードしてください。"
                           Foreground="{DynamicResource FgDim}" FontSize="11"
                           TextWrapping="Wrap" Margin="0,4,0,0" />

                <TextBlock Style="{StaticResource FieldLabel}" Text="最大トークン" />
                <TextBox Text="{Binding MaxTokens, UpdateSourceTrigger=PropertyChanged}" />

                <Separator Margin="0,14,0,8" />
                <TextBlock Style="{StaticResource FieldLabel}" Text="Editor / Vim" />
                <CheckBox Content="Vim キーバインドを有効にする"
                          IsChecked="{Binding VimEnabled}" Margin="0,2,0,4"
                          Foreground="{DynamicResource Fg}" />
                <TextBlock Text="有効/無効は開いているタブにも反映されます。"
                           Foreground="{DynamicResource FgDim}" FontSize="11"
                           TextWrapping="Wrap" Margin="0,4,0,0" />

                <!-- 安全設計（§10） -->
                <Separator Margin="0,14,0,8" />
                <TextBlock Style="{StaticResource FieldLabel}" Text="安全設計" />
                <CheckBox Content="自動承認モード（信頼ワークスペース向け・コマンド/編集の承認カードを省略）"
                          IsChecked="{Binding AutoApprove}" Margin="0,2,0,4"
                          Foreground="{DynamicResource Fg}" />
                <CheckBox Content="ツールのファイルアクセスをワークスペースルート配下に限定（パストラバーサル防止）"
                          IsChecked="{Binding RestrictToWorkspaceRoot}" Margin="0,2,0,4"
                          Foreground="{DynamicResource Fg}" />
                <TextBlock Style="{StaticResource FieldLabel}" Text="ブロックする危険コマンド" />
                <StackPanel Orientation="Horizontal">
                    <Button Content="エディタで編集" Style="{StaticResource FlatButton}"
                            Command="{Binding EditBlockedCommandsCommand}" />
                    <Button Content="デフォルトに戻す" Style="{StaticResource FlatButton}"
                            Margin="6,0,0,0" Command="{Binding ResetBlockedCommandsCommand}" />
                </StackPanel>
                <TextBlock Text="1行に1つ・正規表現（大文字小文字無視）。中央のエディタペインで開き、保存（:w）で即時反映されます。"
                           Foreground="{DynamicResource FgDim}" FontSize="11"
                           TextWrapping="Wrap" Margin="0,4,0,0" />

                <!-- 変更は自動で反映・保存されます（「保存」ボタンは廃止）。 -->
                <TextBlock Text="{Binding Status}" TextWrapping="Wrap" Margin="0,14,0,0"
                           Foreground="{DynamicResource FgDim}" FontSize="11" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
