<UserControl x:Class="sk0ya.Loomo.App.Views.TraceSessionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{DynamicResource Panel}" Focusable="True">

    <UserControl.Resources>
        <!-- 一覧アイテム共通（GitSessionView と同じ見た目） -->
        <Style x:Key="TraceListItem" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="6,1" />
            <Setter Property="Foreground" Value="{DynamicResource Fg}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="b" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource BgAlt}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Border}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TraceList" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource Fg}" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource TraceListItem}" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        </Style>
    </UserControl.Resources>

    <DockPanel>
        <!-- ツールバー（更新・削除）はペインヘッダー側（ShellWindow）へ集約 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210" MinWidth="140" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" MinWidth="200" />
            </Grid.ColumnDefinitions>

            <!-- セッション一覧（新しい順） -->
            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" Margin="8,2" FontSize="{DynamicResource Fs11}" FontWeight="SemiBold"
                           Foreground="{DynamicResource FgDim}" Text="トレース（新しい順）" />
                <Grid>
                    <ListBox Style="{StaticResource TraceList}"
                             ItemsSource="{Binding Sessions}" SelectedItem="{Binding SelectedSession}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel LastChildFill="True" ToolTip="{Binding SessionId}">
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding SizeLabel}" FontSize="{DynamicResource Fs11}"
                                               Foreground="{DynamicResource FgDim}" Margin="8,0,0,0" />
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding UpdatedLabel}" FontSize="{DynamicResource Fs11}"
                                               Foreground="{DynamicResource FgDim}" Margin="8,0,0,0" />
                                    <TextBlock Text="{Binding SessionId}" TextTrimming="CharacterEllipsis" />
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock Margin="12,8" Text="{Binding EmptyMessage}" TextWrapping="Wrap"
                               Foreground="{DynamicResource FgDim}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding EmptyMessage}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch"
                          Background="{DynamicResource Border}" />

            <!-- タイムライン＋詳細 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="100" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="140" MinHeight="60" />
                </Grid.RowDefinitions>

                <ListBox Grid.Row="0" Style="{StaticResource TraceList}"
                         ItemsSource="{Binding Rows}" SelectedItem="{Binding SelectedRow}"
                         FontFamily="Cascadia Mono, Consolas" FontSize="{DynamicResource Fs12}"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Left" Text="{Binding Time}" Width="78"
                                           Foreground="{DynamicResource FgDim}" />
                                <TextBlock DockPanel.Dock="Left" Text="{Binding Kind}" Width="86"
                                           x:Name="kindText" Foreground="{DynamicResource Accent}" />
                                <TextBlock Text="{Binding Summary}" TextTrimming="CharacterEllipsis"
                                           x:Name="summaryText" Foreground="{DynamicResource Fg}" />
                            </DockPanel>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsTurnStart}" Value="True">
                                    <Setter TargetName="kindText" Property="FontWeight" Value="Bold" />
                                    <Setter TargetName="summaryText" Property="FontWeight" Value="Bold" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsError}" Value="True">
                                    <Setter TargetName="kindText" Property="Foreground" Value="#FFE57373" />
                                    <Setter TargetName="summaryText" Property="Foreground" Value="#FFE57373" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <GridSplitter Grid.Row="1" Height="6" HorizontalAlignment="Stretch"
                              Background="{DynamicResource Border}" />

                <!-- 選択イベントの payload（整形 JSON） -->
                <TextBox Grid.Row="2" IsReadOnly="True" TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         FontFamily="Cascadia Mono, Consolas" FontSize="{DynamicResource Fs12}"
                         BorderThickness="0" Background="{DynamicResource BgAlt}"
                         Text="{Binding DetailText, Mode=OneWay}" />
            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
