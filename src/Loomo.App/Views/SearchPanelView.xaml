<UserControl x:Class="sk0ya.Loomo.App.Views.SearchPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:sk0ya.Loomo.App.ViewModels"
    Background="{DynamicResource BgAlt}">

    <UserControl.Resources>
        <!-- テーマ対応のトグル（Aa / .*）。チェック時は Accent で塗る。 -->
        <Style x:Key="SearchToggle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{DynamicResource Fg}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="b" Background="{DynamicResource Bg}" CornerRadius="3"
                                BorderBrush="{DynamicResource Border}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource BgAlt}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Accent}" />
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource Accent}" />
                                <Setter Property="Foreground" Value="{DynamicResource AccentFg}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- テーマ対応の TreeViewItem（既定の Windows 配色を使わせない）。ホバー＝Border、選択＝Accent。
             グループは既定で展開（IsExpanded=True）。一致行は子を持たないので矢印は畳む。 -->
        <Style x:Key="SearchTreeItem" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="True" />
            <Setter Property="Foreground" Value="{DynamicResource Fg}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <Border x:Name="Bd" Grid.Row="0" Background="Transparent" CornerRadius="3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton x:Name="Expander" Grid.Column="0"
                                                  ClickMode="Press" Focusable="False"
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent" Width="13" Height="14">
                                                    <Path x:Name="Arrow" Width="8" Height="8" Stretch="Uniform"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          Fill="{DynamicResource FgDim}" Data="M0,0 L4,4 L0,8 Z" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Arrow" Property="RenderTransform">
                                                            <Setter.Value>
                                                                <RotateTransform Angle="90" CenterX="4" CenterY="4" />
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <ContentPresenter x:Name="PART_Header" Grid.Column="1" ContentSource="Header"
                                                      Margin="{TemplateBinding Padding}" VerticalAlignment="Center"
                                                      HorizontalAlignment="Stretch" />
                                </Grid>
                            </Border>
                            <Border Grid.Row="1" Margin="11,0,0,0">
                                <ItemsPresenter x:Name="ItemsHost" />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger SourceName="Bd" Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Border}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Accent}" />
                                <Setter Property="Foreground" Value="{DynamicResource AccentFg}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Style="{StaticResource PanelHeader}" Text="検索" />

        <!-- クエリ＋オプション -->
        <StackPanel DockPanel.Dock="Top" Margin="8,2,8,6">
            <!-- 検索モード切替（検索ワード欄の上）。テキスト＝ファイル内を grep、ファイル＝名前で曖昧検索。
                 同じ SearchByName を一方は反転で束ね、2択セグメントとして相互排他に振る舞わせる。 -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <ToggleButton Content="テキスト" Height="22" Padding="10,0" FontSize="11" Cursor="Hand"
                              Style="{StaticResource SearchToggle}"
                              ToolTip="ファイルの中身を grep"
                              IsChecked="{Binding SearchByName, Converter={StaticResource InverseBool}, Mode=TwoWay}" />
                <ToggleButton Content="ファイル" Height="22" Padding="10,0" FontSize="11" Margin="4,0,0,0" Cursor="Hand"
                              Style="{StaticResource SearchToggle}"
                              ToolTip="ファイル名で曖昧検索"
                              IsChecked="{Binding SearchByName, Mode=TwoWay}" />
            </StackPanel>

            <Grid>
                <TextBox x:Name="QueryBox" Padding="6,4" FontSize="13"
                         Background="{DynamicResource Bg}" Foreground="{DynamicResource Fg}"
                         BorderBrush="{DynamicResource Border}" CaretBrush="{DynamicResource Fg}"
                         Text="{Binding Query, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PreviewKeyDown="OnQueryKeyDown" />
                <TextBlock Text="{Binding QueryPlaceholder}" IsHitTestVisible="False" FontSize="13"
                           Foreground="{DynamicResource FgDim}" VerticalAlignment="Center" Margin="8,0,0,0"
                           Visibility="{Binding Text, ElementName=QueryBox, Converter={StaticResource EmptyToVis}}" />
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <!-- 大小区別／正規表現は内容検索（grep）専用なのでファイル名検索時は隠す。 -->
                <StackPanel Orientation="Horizontal"
                            Visibility="{Binding SearchByName, Converter={StaticResource InverseBoolToVis}}">
                    <ToggleButton Content="Aa" Width="30" Height="22" FontSize="11" Cursor="Hand"
                                  Style="{StaticResource SearchToggle}"
                                  ToolTip="大文字小文字を区別" IsChecked="{Binding CaseSensitive, Mode=TwoWay}" />
                    <ToggleButton Content=".*" Width="30" Height="22" FontSize="11" Margin="4,0,0,0" Cursor="Hand"
                                  Style="{StaticResource SearchToggle}"
                                  ToolTip="正規表現として扱う" IsChecked="{Binding UseRegex, Mode=TwoWay}" />
                </StackPanel>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource FgDim}" FontSize="11"
                           VerticalAlignment="Center" Margin="8,0,0,0" TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <!-- include/exclude glob も grep 専用。ファイル名検索時は隠す。 -->
            <Grid Margin="0,4,0,0"
                  Visibility="{Binding SearchByName, Converter={StaticResource InverseBoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0" Margin="0,0,2,0">
                    <TextBox x:Name="IncludeBox" Padding="4,3" FontSize="11"
                             Background="{DynamicResource Bg}" Foreground="{DynamicResource Fg}"
                             BorderBrush="{DynamicResource Border}" CaretBrush="{DynamicResource Fg}"
                             ToolTip="この glob に一致するファイルだけを検索（例: *.cs, src/**）"
                             Text="{Binding IncludeGlob, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="含める 例:*.cs" IsHitTestVisible="False" FontSize="11"
                               Foreground="{DynamicResource FgDim}" VerticalAlignment="Center" Margin="6,0,0,0"
                               Visibility="{Binding Text, ElementName=IncludeBox, Converter={StaticResource EmptyToVis}}" />
                </Grid>
                <Grid Grid.Column="1" Margin="2,0,0,0">
                    <TextBox x:Name="ExcludeBox" Padding="4,3" FontSize="11"
                             Background="{DynamicResource Bg}" Foreground="{DynamicResource Fg}"
                             BorderBrush="{DynamicResource Border}" CaretBrush="{DynamicResource Fg}"
                             ToolTip="この glob に一致するファイルを検索から除外（例: *.min.js, bin/**）"
                             Text="{Binding ExcludeGlob, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="除外 例:*.min.js" IsHitTestVisible="False" FontSize="11"
                               Foreground="{DynamicResource FgDim}" VerticalAlignment="Center" Margin="6,0,0,0"
                               Visibility="{Binding Text, ElementName=ExcludeBox, Converter={StaticResource EmptyToVis}}" />
                </Grid>
            </Grid>
        </StackPanel>

        <!-- 結果：ファイル別グルーピング。選択でプレビュー、Enter/ダブルクリックで通常タブ。 -->
        <TreeView x:Name="ResultTree" BorderThickness="0" Background="Transparent"
                  ItemsSource="{Binding Results}"
                  ItemContainerStyle="{StaticResource SearchTreeItem}"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  SelectedItemChanged="OnResultSelectionChanged"
                  MouseDoubleClick="OnResultDoubleClick"
                  PreviewKeyDown="OnResultKeyDown">
            <TreeView.Resources>
                <!-- Foreground は明示せず TreeViewItem から継承させる（選択時に AccentFg へ切り替わる）。 -->
                <HierarchicalDataTemplate DataType="{x:Type vm:SearchFileGroup}" ItemsSource="{Binding Matches}">
                    <TextBlock Text="{Binding Header}" FontSize="12"
                               TextTrimming="CharacterEllipsis" ToolTip="{Binding RelativePath}" />
                </HierarchicalDataTemplate>
                <DataTemplate DataType="{x:Type vm:SearchMatchItem}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Line}" FontSize="11" MinWidth="34" Opacity="0.6" />
                        <TextBlock Text="{Binding Preview}" FontSize="11"
                                   FontFamily="Consolas" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </DataTemplate>
            </TreeView.Resources>
        </TreeView>
    </DockPanel>
</UserControl>
