<UserControl x:Class="sk0ya.Loomo.App.Views.SearchPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:sk0ya.Loomo.App.ViewModels"
    xmlns:views="clr-namespace:sk0ya.Loomo.App.Views"
    Background="{DynamicResource BgAlt}">

    <UserControl.Resources>
        <!-- テーマ対応のトグル（Aa / .*）。チェック時は Accent で塗る。 -->
        <Style x:Key="SearchToggle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{DynamicResource Fg}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="b" Background="{DynamicResource Bg}" CornerRadius="3"
                                BorderBrush="{DynamicResource Border}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource BgAlt}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Accent}" />
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource Accent}" />
                                <Setter Property="Foreground" Value="{DynamicResource AccentFg}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 検索フォルダー欄の小ボタン（参照／リセット）。テーマ対応・低主張。 -->
        <Style x:Key="FolderBarButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="FontSize" Value="{DynamicResource Fs11}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{DynamicResource Bg}" CornerRadius="3"
                                BorderBrush="{DynamicResource Border}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource BgAlt}" />
                                <Setter Property="Foreground" Value="{DynamicResource Fg}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- テーマ対応の TreeViewItem（既定の Windows 配色を使わせない）。ホバー＝Border、選択＝Accent。
             グループは既定で展開（IsExpanded=True）。一致行は子を持たないので矢印は畳む。 -->
        <Style x:Key="SearchTreeItem" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
            <Setter Property="Foreground" Value="{DynamicResource Fg}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <Border x:Name="Bd" Grid.Row="0" Background="Transparent" CornerRadius="3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton x:Name="Expander" Grid.Column="0"
                                                  ClickMode="Press" Focusable="False"
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent" Width="13" Height="14">
                                                    <Path x:Name="Arrow" Width="8" Height="8" Stretch="Uniform"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          Fill="{DynamicResource FgDim}" Data="M0,0 L4,4 L0,8 Z" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Arrow" Property="RenderTransform">
                                                            <Setter.Value>
                                                                <RotateTransform Angle="90" CenterX="4" CenterY="4" />
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <ContentPresenter x:Name="PART_Header" Grid.Column="1" ContentSource="Header"
                                                      Margin="{TemplateBinding Padding}" VerticalAlignment="Center"
                                                      HorizontalAlignment="Stretch" />
                                </Grid>
                            </Border>
                            <Border Grid.Row="1" Margin="11,0,0,0">
                                <ItemsPresenter x:Name="ItemsHost" />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger SourceName="Bd" Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Border}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Accent}" />
                                <Setter Property="Foreground" Value="{DynamicResource AccentFg}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <DockPanel>
        <!-- 見出し＋ツールバー（すべて展開／すべて閉じる）。 -->
        <Grid DockPanel.Dock="Top">
            <TextBlock Style="{StaticResource PanelHeader}" Text="検索" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        VerticalAlignment="Center" Margin="0,0,6,0">
                <Button Width="24" Padding="0" Margin="0" Style="{StaticResource FolderBarButton}"
                        ToolTip="すべて展開" Click="OnExpandAll">
                    <Path Width="11" Height="11" Stretch="Uniform"
                          Stroke="{DynamicResource FgDim}" StrokeThickness="1.2"
                          Data="M1,2 L5,5.5 L9,2 M1,6 L5,9.5 L9,6" />
                </Button>
                <Button Width="24" Padding="0" Margin="4,0,0,0" Style="{StaticResource FolderBarButton}"
                        ToolTip="すべて閉じる" Click="OnCollapseAll">
                    <Path Width="11" Height="11" Stretch="Uniform"
                          Stroke="{DynamicResource FgDim}" StrokeThickness="1.2"
                          Data="M1,5.5 L5,2 L9,5.5 M1,9.5 L5,6 L9,9.5" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- クエリ＋オプション -->
        <StackPanel DockPanel.Dock="Top" Margin="8,2,8,6">
            <!-- 検索モード切替（検索ワード欄の上）。テキスト＝ファイル内を grep、ファイル＝名前で曖昧検索、
                 ターミナル＝アクティブなターミナル内テキスト。Scope 列挙を EnumToBool で束ね、3択セグメントとして
                 相互排他に振る舞わせる（既に選択中のボタンを押しても外れない＝ConvertBack が DoNothing）。 -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <ToggleButton Content="テキスト" Height="22" Padding="10,0" FontSize="{DynamicResource Fs11}" Cursor="Hand"
                              Style="{StaticResource SearchToggle}"
                              ToolTip="ファイルの中身を grep"
                              IsChecked="{Binding Scope, Converter={StaticResource EnumToBool}, ConverterParameter=Text, Mode=TwoWay}" />
                <ToggleButton Content="ファイル" Height="22" Padding="10,0" FontSize="{DynamicResource Fs11}" Margin="4,0,0,0" Cursor="Hand"
                              Style="{StaticResource SearchToggle}"
                              ToolTip="ファイル名で曖昧検索"
                              IsChecked="{Binding Scope, Converter={StaticResource EnumToBool}, ConverterParameter=FileName, Mode=TwoWay}" />
                <ToggleButton Content="ターミナル" Height="22" Padding="10,0" FontSize="{DynamicResource Fs11}" Margin="4,0,0,0" Cursor="Hand"
                              Style="{StaticResource SearchToggle}"
                              ToolTip="アクティブなターミナル内を検索"
                              IsChecked="{Binding Scope, Converter={StaticResource EnumToBool}, ConverterParameter=Terminal, Mode=TwoWay}" />
            </StackPanel>

            <!-- 検索の開始フォルダー（編集可・テキストで指定）。既定は FolderTree の表示ルート。
                 空＝ワークスペース全体。マルチルート時は先頭に対象フォルダーの表示名を付けて指定する
                 （例: フォルダー名/src。結果ツリーのフォルダー見出しと同じ表記）。入力中はサブフォルダの
                 補完候補をポップアップ表示し（Ctrl+Space でも呼び出せる）、↺ で FolderTree のルートへ戻す。
                 ターミナル検索時は隠す。 -->
            <Grid Margin="0,0,0,4"
                  Visibility="{Binding ShowSearchRoot, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Path Grid.Column="0" Width="13" Height="13" Stretch="Uniform"
                      VerticalAlignment="Center" Margin="0,0,5,0"
                      Fill="{DynamicResource FgDim}"
                      Data="M1,3 L5,3 L6.5,4.5 L13,4.5 L13,12 L1,12 Z" />
                <Grid Grid.Column="1">
                    <TextBox x:Name="RootBox" Padding="4,2" FontSize="{DynamicResource Fs11}"
                             Background="{DynamicResource Bg}" Foreground="{DynamicResource Fg}"
                             BorderBrush="{DynamicResource Border}" CaretBrush="{DynamicResource Fg}"
                             VerticalContentAlignment="Center"
                             ToolTip="検索する開始フォルダー（空＝ワークスペース全体・複数フォルダー時は「フォルダー名/相対パス」・Ctrl+Space で候補表示）"
                             Text="{Binding SearchRoot, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                             TextChanged="OnRootBoxTextChanged"
                             PreviewKeyDown="OnRootBoxKeyDown"
                             LostKeyboardFocus="OnRootBoxLostFocus" />
                    <TextBlock Text="ワークスペース全体" IsHitTestVisible="False" FontSize="{DynamicResource Fs11}"
                               Foreground="{DynamicResource FgDim}" VerticalAlignment="Center" Margin="6,0,0,0"
                               Visibility="{Binding Text, ElementName=RootBox, Converter={StaticResource EmptyToVis}}" />
                    <!-- フォルダパス補完（インテリセンス）。候補は RootBox の入力に応じて code-behind が流し込む
                         （値そのものは蓄積された相対パスだが、表示は直近の名前だけ＝LastPathSegment。
                         全体パスは ToolTip で見られる）。少なくとも RootBox 幅は確保しつつ、長い名前でも
                         見切れないよう MaxWidth まで広がる（それでも収まらなければ末尾を省略）。 -->
                    <Popup x:Name="RootSuggestPopup" PlacementTarget="{Binding ElementName=RootBox}"
                           Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                        <Border Background="{DynamicResource Bg}" BorderBrush="{DynamicResource Border}"
                                BorderThickness="1" CornerRadius="3" Padding="1"
                                MinWidth="{Binding ActualWidth, ElementName=RootBox}" MaxWidth="360">
                            <ListBox x:Name="RootSuggestList" MaxHeight="180" BorderThickness="0"
                                     Background="Transparent" Foreground="{DynamicResource Fg}"
                                     FontSize="{DynamicResource Fs11}" FontFamily="Consolas"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     PreviewMouseLeftButtonDown="OnRootSuggestMouseDown">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource LastPathSegment}}"
                                                   ToolTip="{Binding}" TextTrimming="CharacterEllipsis" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Popup>
                </Grid>
                <Button Grid.Column="2" Content="↺" Margin="4,0,0,0" Padding="0"
                        Width="20"
                        Style="{StaticResource FolderBarButton}"
                        ToolTip="FolderTree のルートに戻す"
                        Visibility="{Binding CanResetSearchRoot, Converter={StaticResource BoolToVis}}"
                        Command="{Binding ResetSearchRootCommand}" />
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <TextBox x:Name="QueryBox" Padding="6,4" FontSize="{DynamicResource Fs13}"
                             Background="{DynamicResource Bg}" Foreground="{DynamicResource Fg}"
                             BorderBrush="{DynamicResource Border}" CaretBrush="{DynamicResource Fg}"
                             Text="{Binding Query, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PreviewKeyDown="OnQueryKeyDown" />
                    <TextBlock Text="{Binding QueryPlaceholder}" IsHitTestVisible="False" FontSize="{DynamicResource Fs13}"
                               Foreground="{DynamicResource FgDim}" VerticalAlignment="Center" Margin="8,0,0,0"
                               Visibility="{Binding Text, ElementName=QueryBox, Converter={StaticResource EmptyToVis}}" />
                </Grid>
                <!-- 置換欄の表示/非表示トグル。テキスト検索のみ（ファイル名／ターミナルには置換の概念が無い）。 -->
                <ToggleButton Grid.Column="1" Content="⇄" Width="26" Height="26" Margin="4,0,0,0"
                              FontSize="{DynamicResource Fs12}" Cursor="Hand"
                              Style="{StaticResource SearchToggle}"
                              ToolTip="置換欄の表示/非表示"
                              Visibility="{Binding CanReplace, Converter={StaticResource BoolToVis}}"
                              IsChecked="{Binding IsReplaceVisible, Mode=TwoWay}" />
            </Grid>

            <!-- 置換欄：入力＋「すべて置換」。ファイル単位の置換は結果ツリーの各ファイル見出しから。 -->
            <Grid Margin="0,4,0,0"
                  Visibility="{Binding IsReplaceVisible, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <TextBox x:Name="ReplaceBox" Padding="6,4" FontSize="{DynamicResource Fs13}"
                             Background="{DynamicResource Bg}" Foreground="{DynamicResource Fg}"
                             BorderBrush="{DynamicResource Border}" CaretBrush="{DynamicResource Fg}"
                             ToolTip="置換後の文字列（正規表現モードでは $1 等の後方参照可）"
                             Text="{Binding ReplaceText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="置換後の文字列" IsHitTestVisible="False" FontSize="{DynamicResource Fs13}"
                               Foreground="{DynamicResource FgDim}" VerticalAlignment="Center" Margin="8,0,0,0"
                               Visibility="{Binding Text, ElementName=ReplaceBox, Converter={StaticResource EmptyToVis}}" />
                </Grid>
                <Button Grid.Column="1" Content="すべて置換" Height="26" Padding="8,0" Margin="4,0,0,0"
                        FontSize="{DynamicResource Fs11}" Style="{StaticResource FolderBarButton}"
                        ToolTip="現在の検索結果すべてに置換を適用する（元に戻せません）"
                        Click="OnReplaceAllClick" />
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <!-- 大小区別／正規表現は内容検索（grep）専用なのでテキスト検索時のみ表示。 -->
                <StackPanel Orientation="Horizontal"
                            Visibility="{Binding Scope, Converter={StaticResource EnumToVis}, ConverterParameter=Text}">
                    <ToggleButton Content="Aa" Width="30" Height="22" FontSize="{DynamicResource Fs11}" Cursor="Hand"
                                  Style="{StaticResource SearchToggle}"
                                  ToolTip="大文字小文字を区別" IsChecked="{Binding CaseSensitive, Mode=TwoWay}" />
                    <ToggleButton Content=".*" Width="30" Height="22" FontSize="{DynamicResource Fs11}" Margin="4,0,0,0" Cursor="Hand"
                                  Style="{StaticResource SearchToggle}"
                                  ToolTip="正規表現として扱う" IsChecked="{Binding UseRegex, Mode=TwoWay}" />
                </StackPanel>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource FgDim}" FontSize="{DynamicResource Fs11}"
                           VerticalAlignment="Center" Margin="8,0,0,0" TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <!-- include/exclude glob も grep 専用。テキスト検索時のみ表示。 -->
            <Grid Margin="0,4,0,0"
                  Visibility="{Binding Scope, Converter={StaticResource EnumToVis}, ConverterParameter=Text}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0" Margin="0,0,2,0">
                    <TextBox x:Name="IncludeBox" Padding="4,3" FontSize="{DynamicResource Fs11}"
                             Background="{DynamicResource Bg}" Foreground="{DynamicResource Fg}"
                             BorderBrush="{DynamicResource Border}" CaretBrush="{DynamicResource Fg}"
                             ToolTip="この glob に一致するファイルだけを検索（例: *.cs, src/**）"
                             Text="{Binding IncludeGlob, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="含める 例:*.cs" IsHitTestVisible="False" FontSize="{DynamicResource Fs11}"
                               Foreground="{DynamicResource FgDim}" VerticalAlignment="Center" Margin="6,0,0,0"
                               Visibility="{Binding Text, ElementName=IncludeBox, Converter={StaticResource EmptyToVis}}" />
                </Grid>
                <Grid Grid.Column="1" Margin="2,0,0,0">
                    <TextBox x:Name="ExcludeBox" Padding="4,3" FontSize="{DynamicResource Fs11}"
                             Background="{DynamicResource Bg}" Foreground="{DynamicResource Fg}"
                             BorderBrush="{DynamicResource Border}" CaretBrush="{DynamicResource Fg}"
                             ToolTip="この glob に一致するファイルを検索から除外（例: *.min.js, bin/**）"
                             Text="{Binding ExcludeGlob, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="除外 例:*.min.js" IsHitTestVisible="False" FontSize="{DynamicResource Fs11}"
                               Foreground="{DynamicResource FgDim}" VerticalAlignment="Center" Margin="6,0,0,0"
                               Visibility="{Binding Text, ElementName=ExcludeBox, Converter={StaticResource EmptyToVis}}" />
                </Grid>
            </Grid>
        </StackPanel>

        <!-- 結果：ファイル別グルーピング。選択でプレビュー、Enter/ダブルクリックで通常タブ。 -->
        <TreeView x:Name="ResultTree" BorderThickness="0" Background="Transparent"
                  ItemsSource="{Binding Results}"
                  ItemContainerStyle="{StaticResource SearchTreeItem}"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  SelectedItemChanged="OnResultSelectionChanged"
                  MouseDoubleClick="OnResultDoubleClick"
                  PreviewKeyDown="OnResultKeyDown">
            <TreeView.Resources>
                <!-- Foreground は明示せず TreeViewItem から継承させる（選択時に AccentFg へ切り替わる）。 -->
                <!-- 件数バッジ（右端・VS Code 流のピル）。フォルダー／ファイル共通で使う。 -->
                <DataTemplate x:Key="CountBadge">
                    <Border Margin="6,0,2,0" Padding="5,0" MinWidth="18" Height="15"
                            CornerRadius="7" VerticalAlignment="Center"
                            Background="{DynamicResource Border}"
                            Visibility="{Binding ShowCount, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding Count}" FontSize="{DynamicResource Fs10}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Fg}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </DataTemplate>

                <!-- フォルダー節点：フォルダーアイコン＋名前（圧縮で a/b）＋配下の総件数。
                     行のどこをクリックしても配下を一気に開閉する（OnRowClick）。 -->
                <HierarchicalDataTemplate DataType="{x:Type vm:SearchFolderNode}" ItemsSource="{Binding Children}">
                    <Grid Background="Transparent" ToolTip="{Binding RelativePath}"
                          MouseLeftButtonUp="OnRowClick">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0" Width="13" Height="13" Stretch="Uniform"
                              VerticalAlignment="Center" Margin="0,0,5,0"
                              Fill="{DynamicResource FgDim}"
                              Data="M1,3 L5,3 L6.5,4.5 L13,4.5 L13,12 L1,12 Z" />
                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="{DynamicResource Fs12}"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        <ContentPresenter Grid.Column="2" Content="{Binding}"
                                          ContentTemplate="{StaticResource CountBadge}" />
                    </Grid>
                </HierarchicalDataTemplate>

                <!-- ファイル見出し：ファイル名（強調）＋件数バッジ（右端）。フォルダーは親節点が示すので畳む。 -->
                <HierarchicalDataTemplate DataType="{x:Type vm:SearchFileGroup}" ItemsSource="{Binding Matches}">
                    <Grid Background="Transparent" ToolTip="{Binding RelativePath}"
                          MouseLeftButtonUp="OnRowClick">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" FontSize="{DynamicResource Fs12}" TextTrimming="CharacterEllipsis"
                                   views:SearchHighlightBehavior.Text="{Binding FileName}"
                                   views:SearchHighlightBehavior.Query="{Binding DataContext.HighlightQuery, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   views:SearchHighlightBehavior.CaseSensitive="{Binding DataContext.HighlightCaseSensitive, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                        <!-- このファイル内の一致だけをまとめて置換する。置換欄を出しているとき、
                             かつ一致行を持つグループ（ファイル名検索のヒットには出さない）だけ表示する。 -->
                        <Button Grid.Column="1" Content="置換" Height="18" Padding="6,0" Margin="4,0,0,0"
                                FontSize="{DynamicResource Fs10}" Style="{StaticResource FolderBarButton}"
                                ToolTip="このファイル内の一致をすべて置換する（元に戻せません）"
                                Click="OnReplaceInGroupClick">
                            <Button.Visibility>
                                <MultiBinding Converter="{StaticResource AllTrueToVisibilityConverter}">
                                    <Binding Path="DataContext.IsReplaceVisible" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                    <Binding Path="ShowCount" />
                                </MultiBinding>
                            </Button.Visibility>
                        </Button>
                        <ContentPresenter Grid.Column="2" Content="{Binding}"
                                          ContentTemplate="{StaticResource CountBadge}" />
                    </Grid>
                </HierarchicalDataTemplate>
                <DataTemplate DataType="{x:Type vm:SearchMatchItem}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Line}" FontSize="{DynamicResource Fs11}" MinWidth="34" Opacity="0.6" />
                        <TextBlock FontSize="{DynamicResource Fs11}" FontFamily="Consolas" TextTrimming="CharacterEllipsis"
                                   views:SearchHighlightBehavior.Text="{Binding Preview}"
                                   views:SearchHighlightBehavior.Query="{Binding DataContext.HighlightQuery, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   views:SearchHighlightBehavior.UseRegex="{Binding DataContext.HighlightUseRegex, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   views:SearchHighlightBehavior.CaseSensitive="{Binding DataContext.HighlightCaseSensitive, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    </StackPanel>
                </DataTemplate>
            </TreeView.Resources>
        </TreeView>
    </DockPanel>
</UserControl>
