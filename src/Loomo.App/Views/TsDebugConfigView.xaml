<UserControl x:Class="sk0ya.Loomo.App.Views.TsDebugConfigView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- TS 構成：起動構成（プログラム/npm スクリプトの 2 モード・引数/環境変数）・例外オプション・
         ポートへのアタッチ・アダプタ未導入の案内。操作（開始/型チェック/ステップ/中断・再起動/停止）は
         ペインヘッダのデバッグツールバー側。DataContext は TsDebugViewModel（ファサード）。 -->
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="2,6,2,6">
            <!-- アダプタ未導入バー（node 不在と js-debug 不在で文言と導線を分ける）。 -->
            <Border Background="{DynamicResource Panel}" Padding="8,6" Margin="0,0,0,8"
                    BorderBrush="{DynamicResource Border}" BorderThickness="1"
                    Visibility="{Binding IsAdapterMissing, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource Fg}" FontSize="{DynamicResource Fs11}"
                               Text="デバッグには Node.js が必要です（PATH 上に node が未検出）。nodejs.org からインストールしてください。"
                               Visibility="{Binding Launch.IsNodeInstalled, Converter={StaticResource InverseBoolToVis}}" />
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource Fg}" FontSize="{DynamicResource Fs11}"
                               Text="デバッグにはアダプタ（vscode-js-debug）が必要です（未ダウンロード）。"
                               Visibility="{Binding Launch.IsNodeInstalled, Converter={StaticResource BoolToVis}}" />
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Button Content="インストール" Style="{StaticResource FlatButton}" Height="24" Padding="10,0"
                                Command="{Binding Launch.InstallAdapterCommand}"
                                Visibility="{Binding Launch.IsNodeInstalled, Converter={StaticResource BoolToVis}}"
                                ToolTip="GitHub Releases から js-debug をダウンロードして展開します（見えるターミナルで実行）" />
                        <Button Content="再確認" Style="{StaticResource SecondaryButton}" Height="24" Padding="10,0"
                                Margin="6,0,0,0" Click="OnRefreshClick" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 起動構成：常時編集可（複数セッション対応——編集は「次に開始するセッション」に効くだけ）。 -->
            <StackPanel>
                <TextBlock Text="起動構成" Foreground="{DynamicResource FgDim}" FontSize="{DynamicResource Fs11}" Margin="2,0,0,3" />

                <!-- 構成（プロファイル）の管理：追加/名前変更/削除。切替はヘッダーのコンボでも可能。 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <Button Content="+" Style="{StaticResource SecondaryButton}" Width="24" Height="24"
                            Click="OnAddProfileClick" ToolTip="現在の設定を新しい構成として追加" />
                    <Button Content="名前変更" Style="{StaticResource SecondaryButton}" Height="24" Padding="8,0" Margin="4,0,0,0"
                            Click="OnRenameProfileClick" ToolTip="選択中の構成名を変更" />
                    <Button Content="削除" Style="{StaticResource SecondaryButton}" Height="24" Padding="8,0" Margin="4,0,0,0"
                            Click="OnDeleteProfileClick" ToolTip="選択中の構成を削除（最後の1件は削除不可）" />
                </StackPanel>

                <!-- パッケージ：ワークスペースから検出した package.json 候補。先頭は自動検出。
                     npm run の実行場所・スクリプト候補・tsc の対象解決に使う。 -->
                <ComboBox ItemsSource="{Binding Profiles.AvailableProjects}"
                          SelectedItem="{Binding Profiles.SelectedProject, Mode=TwoWay}"
                          DisplayMemberPath="Name" Margin="0,0,0,4"
                          ToolTip="対象パッケージ（package.json。自動検出=最初に見つかったもの）" />

                <!-- 実行対象の 2 モード：プログラム（.ts/.js ファイル）または npm スクリプト。 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <RadioButton Content="プログラム" GroupName="TsLaunchMode" FontSize="{DynamicResource Fs11}"
                                 Foreground="{DynamicResource Fg}" IsChecked="{Binding Launch.IsProgramMode, Mode=TwoWay}"
                                 ToolTip=".ts/.js ファイルを node で実行" />
                    <RadioButton Content="npm スクリプト" GroupName="TsLaunchMode" FontSize="{DynamicResource Fs11}"
                                 Foreground="{DynamicResource Fg}" Margin="12,0,0,0"
                                 IsChecked="{Binding Launch.IsNpmMode, Mode=TwoWay}"
                                 ToolTip="package.json の scripts を npm run で実行" />
                </StackPanel>

                <!-- プログラムモード：実行ファイルパス。 -->
                <Grid Visibility="{Binding Launch.IsProgramMode, Converter={StaticResource BoolToVis}}">
                    <TextBox x:Name="ProgramBox" Padding="6,4" FontSize="{DynamicResource Fs12}"
                             Background="{DynamicResource Bg}" Foreground="{DynamicResource Fg}"
                             BorderBrush="{DynamicResource Border}" CaretBrush="{DynamicResource Fg}"
                             Text="{Binding Launch.ProgramPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="実行するファイル（.ts/.js。ワークスペース相対可）。TS 直接実行は Node 23.6+ の型ストリッピングに依存" />
                    <TextBlock Text="実行ファイル（.ts/.js、相対可）" IsHitTestVisible="False" FontSize="{DynamicResource Fs12}"
                               Foreground="{DynamicResource FgDim}" VerticalAlignment="Center" Margin="8,0,0,0"
                               Visibility="{Binding Text, ElementName=ProgramBox, Converter={StaticResource EmptyToVis}}" />
                </Grid>

                <!-- npm モード：スクリプト名（候補は選択中パッケージの scripts。直接入力も可）。 -->
                <ComboBox IsEditable="True" FontSize="{DynamicResource Fs12}"
                          ItemsSource="{Binding Launch.AvailableScripts}"
                          Text="{Binding Launch.NpmScript, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                          Visibility="{Binding Launch.IsNpmMode, Converter={StaticResource BoolToVis}}"
                          ToolTip="npm run で実行するスクリプト名（候補は選択中パッケージの scripts）" />

                <!-- 起動引数（プログラムモードのみ。npm モードのスクリプト引数は scripts 側に書く）。 -->
                <Grid Margin="0,4,0,0" Visibility="{Binding Launch.IsProgramMode, Converter={StaticResource BoolToVis}}">
                    <TextBox x:Name="ArgsBox" Padding="6,4" FontSize="{DynamicResource Fs12}" FontFamily="Consolas"
                             Background="{DynamicResource Bg}" Foreground="{DynamicResource Fg}"
                             BorderBrush="{DynamicResource Border}" CaretBrush="{DynamicResource Fg}"
                             Text="{Binding Launch.LaunchArgs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="プログラムへ渡す引数（空白区切り。空白を含む値は &quot;...&quot; で囲む）" />
                    <TextBlock Text="起動引数（空白区切り）" IsHitTestVisible="False" FontSize="{DynamicResource Fs12}"
                               Foreground="{DynamicResource FgDim}" VerticalAlignment="Center" Margin="8,0,0,0"
                               Visibility="{Binding Text, ElementName=ArgsBox, Converter={StaticResource EmptyToVis}}" />
                </Grid>

                <!-- 環境変数。1 行 1 件の KEY=VALUE。 -->
                <Grid Margin="0,4,0,0">
                    <TextBox x:Name="EnvBox" Padding="6,4" FontSize="{DynamicResource Fs12}" FontFamily="Consolas"
                             AcceptsReturn="True" TextWrapping="NoWrap" MinLines="2" MaxLines="5"
                             VerticalScrollBarVisibility="Auto"
                             Background="{DynamicResource Bg}" Foreground="{DynamicResource Fg}"
                             BorderBrush="{DynamicResource Border}" CaretBrush="{DynamicResource Fg}"
                             Text="{Binding Launch.LaunchEnv, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="環境変数（1 行 1 件 KEY=VALUE）。空なら親プロセスの環境のまま" />
                    <TextBlock Text="環境変数（1 行 1 件 KEY=VALUE）" IsHitTestVisible="False" FontSize="{DynamicResource Fs12}"
                               Foreground="{DynamicResource FgDim}" VerticalAlignment="Top" Margin="8,5,0,0"
                               Visibility="{Binding Text, ElementName=EnvBox, Converter={StaticResource EmptyToVis}}" />
                </Grid>
            </StackPanel>

            <!-- 例外で中断 / オプション（常時表示。例外フィルタは実行中でも切り替え可）。 -->
            <StackPanel Margin="0,10,0,0">
                <TextBlock Text="例外・オプション" Foreground="{DynamicResource FgDim}" FontSize="{DynamicResource Fs11}" Margin="2,0,0,3" />
                <CheckBox Content="スローされたすべての例外で中断" FontSize="{DynamicResource Fs11}" Foreground="{DynamicResource Fg}"
                          IsChecked="{Binding Launch.BreakOnAllExceptions, Mode=TwoWay}" Margin="0,1"
                          ToolTip="例外がスローされた瞬間に中断（js-debug: all）" />
                <CheckBox Content="キャッチされない例外で中断" FontSize="{DynamicResource Fs11}" Foreground="{DynamicResource Fg}"
                          IsChecked="{Binding Launch.BreakOnUncaughtExceptions, Mode=TwoWay}" Margin="0,1"
                          ToolTip="キャッチされずにプロセスを落とす例外で中断（js-debug: uncaught）" />
                <CheckBox Content="マイ コードのみ（次回起動から）" FontSize="{DynamicResource Fs11}" Foreground="{DynamicResource Fg}"
                          IsChecked="{Binding Launch.JustMyCode, Mode=TwoWay}" Margin="0,1"
                          ToolTip="Node 内部（&lt;node_internals&gt;）へステップインしない" />
                <CheckBox Content="開始前に型チェック (tsc)" FontSize="{DynamicResource Fs11}" Foreground="{DynamicResource Fg}"
                          IsChecked="{Binding Launch.BuildFirst, Mode=TwoWay}" Margin="0,1"
                          ToolTip="開始前に npx tsc --noEmit を実行し、エラーがあれば起動を中止（tsconfig.json が無ければ何もしない）" />
            </StackPanel>

            <!-- ポートにアタッチ：node の inspect ポートへ接続。停止してもそのプロセスは終了しない。 -->
            <StackPanel Margin="0,10,0,0">
                <Button Content="⮌ ポートにアタッチ" Style="{StaticResource SecondaryButton}" Height="24" Padding="10,0"
                        HorizontalAlignment="Left" Command="{Binding Attach.ToggleAttachCommand}"
                        ToolTip="node --inspect のデバッグポートへ接続（入力欄を開閉）" />
                <Border Margin="0,6,0,0" Padding="8" Background="{DynamicResource Panel}"
                        BorderBrush="{DynamicResource Border}" BorderThickness="1"
                        Visibility="{Binding Attach.ShowAttach, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource FgDim}" FontSize="{DynamicResource Fs11}"
                                   Text="node --inspect（既定ポート 9229）で起動済みのプロセスに接続します。停止はデタッチのみで、対象プロセスは終了しません。" />
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Text="ポート:" Foreground="{DynamicResource Fg}" FontSize="{DynamicResource Fs11}"
                                       VerticalAlignment="Center" />
                            <TextBox Width="80" Padding="6,3" Margin="6,0,0,0" FontSize="{DynamicResource Fs11}" FontFamily="Consolas"
                                     Background="{DynamicResource Bg}" Foreground="{DynamicResource Fg}"
                                     BorderBrush="{DynamicResource Border}" CaretBrush="{DynamicResource Fg}"
                                     Text="{Binding Attach.AttachPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Content="⮌ アタッチ" Style="{StaticResource FlatButton}" Height="24" Padding="12,0"
                                    Margin="8,0,0,0" Command="{Binding Attach.AttachCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
