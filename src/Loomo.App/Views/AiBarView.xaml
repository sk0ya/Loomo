<UserControl x:Class="sk0ya.Loomo.App.Views.AiBarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:sk0ya.Loomo.App.ViewModels"
    Background="{DynamicResource BgAlt}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== 展開時：トランスクリプト ===== -->
        <Border Grid.Row="0" BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,1"
                Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
            <ScrollViewer x:Name="TranscriptScrollViewer" VerticalScrollBarVisibility="Auto" Padding="8">
                <ItemsControl ItemsSource="{Binding Transcript}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:TranscriptEntry}">
                            <Border Margin="0,4" CornerRadius="6" Padding="10,8"
                                    Background="{DynamicResource Bg}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <!-- 思考ブロックは控えめに（薄背景・本文と区別） -->
                                            <DataTrigger Binding="{Binding Kind}" Value="Thinking">
                                                <Setter Property="Background" Value="{DynamicResource BgAlt}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="{Binding CollapseGlyph}"
                                                Command="{Binding ToggleCollapseCommand}"
                                                Style="{StaticResource IconButton}" Width="22" Height="22"
                                                Padding="0" FontSize="10" Margin="0,0,6,0"
                                                ToolTip="ブロックを開閉" />
                                        <TextBlock Grid.Column="1" Text="{Binding Header}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource FgDim}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                    <StackPanel Visibility="{Binding IsCollapsed, Converter={StaticResource InverseBoolToVis}}">
                                        <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                                                   FontFamily="Cascadia Mono, Consolas">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource Fg}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Kind}" Value="Thinking">
                                                            <Setter Property="FontStyle" Value="Italic" />
                                                            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <!-- 差分ビュー（propose_edit の承認カード） -->
                                        <Border Visibility="{Binding HasDiff, Converter={StaticResource BoolToVis}}"
                                                BorderBrush="{DynamicResource Border}" BorderThickness="1"
                                                CornerRadius="4" Margin="0,4,0,0" Padding="0,2">
                                            <ItemsControl ItemsSource="{Binding DiffLines}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{Binding Background}">
                                                            <TextBlock Text="{Binding Text}" Foreground="{Binding Foreground}"
                                                                       FontFamily="Cascadia Mono, Consolas" FontSize="12"
                                                                       TextWrapping="NoWrap" Padding="6,0" />
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Border>
                                        <!-- 承認カード -->
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                                    Visibility="{Binding IsPending, Converter={StaticResource BoolToVis}}">
                                            <Button Content="承認して実行" Style="{StaticResource FlatButton}"
                                                    Command="{Binding ApproveCommand}" Margin="0,0,8,0" />
                                            <Button Content="拒否" Style="{StaticResource FlatButton}"
                                                    Background="#FF6E1E1E" Command="{Binding RejectCommand}" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- ===== ステータス行（処理中のみ表示：考え中／実行中／承認待ち＋経過秒） ===== -->
        <Border Grid.Row="1" Background="{DynamicResource BgAlt}"
                Padding="12,4" Margin="8,0"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
                <ProgressBar IsIndeterminate="True" Width="80" Height="4"
                             Foreground="{DynamicResource Accent}" Background="Transparent"
                             BorderThickness="0" VerticalAlignment="Center" />
                <TextBlock Text="{Binding StatusText}" Margin="10,0,0,0"
                           VerticalAlignment="Center" FontSize="12"
                           Foreground="{DynamicResource FgDim}" />
            </StackPanel>
        </Border>

        <!-- ===== 入力バー（常時表示・全幅） ===== -->
        <Grid Grid.Row="2" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Style="{StaticResource IconButton}" Width="34" Height="34"
                    FontSize="14" Content="🤖" ToolTip="展開/格納"
                    Command="{Binding ToggleExpandCommand}" />

            <Grid Grid.Column="1" Margin="6,0">
                <TextBox x:Name="InputBox" Text="{Binding Input, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center" PreviewKeyDown="OnInputPreviewKeyDown">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding SendCommand}" />
                    </TextBox.InputBindings>
                </TextBox>

                <!-- スラッシュコマンド補完ポップアップ（入力欄の上に開く） -->
                <Popup IsOpen="{Binding IsCommandPopupOpen}" PlacementTarget="{Binding ElementName=InputBox}"
                       Placement="Top" VerticalOffset="-4" StaysOpen="False" AllowsTransparency="True"
                       MinWidth="340">
                    <Border Background="{DynamicResource Bg}" BorderBrush="{DynamicResource Border}"
                            BorderThickness="1" CornerRadius="6" Padding="4">
                        <ListBox x:Name="CommandList" ItemsSource="{Binding CommandSuggestions}"
                                 SelectedIndex="{Binding SelectedCommandIndex, Mode=TwoWay}"
                                 Background="Transparent" BorderThickness="0"
                                 PreviewMouseLeftButtonUp="OnCommandListClick"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="b" Background="Transparent" CornerRadius="4" Padding="8,5">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="b" Property="Background" Value="{DynamicResource BgAlt}" />
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="b" Property="Background" Value="{DynamicResource BgAlt}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" Width="90" FontWeight="SemiBold"
                                                   FontFamily="Cascadia Mono, Consolas" Foreground="{DynamicResource Fg}" />
                                        <TextBlock Text="{Binding Description}" VerticalAlignment="Center"
                                                   FontSize="12" Foreground="{DynamicResource FgDim}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Popup>
                <TextBlock IsHitTestVisible="False" Margin="10,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource FgDim}" FontStyle="Italic"
                           Text="AIに指示を入力...   （「/」でコマンド・例: /clear  /resume）">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <!-- 通常は Input が空のときだけ表示 -->
                            <Setter Property="Visibility"
                                    Value="{Binding Input, Converter={StaticResource EmptyToVis}}" />
                            <Style.Triggers>
                                <!-- フォーカス中（IME変換中含む）は非表示にして重なりを防ぐ -->
                                <DataTrigger Binding="{Binding IsKeyboardFocused, ElementName=InputBox}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <TextBlock Grid.Column="2" Text="{Binding ProviderLabel}" VerticalAlignment="Center"
                       Foreground="{DynamicResource FgDim}" Margin="6,0" FontSize="11" />

            <Button Grid.Column="3" Content="送信" Style="{StaticResource FlatButton}"
                    Command="{Binding SendCommand}" Margin="0,0,6,0" />
            <Button Grid.Column="4" Content="⏹" Style="{StaticResource FlatButton}"
                    Background="#FF6E1E1E" Command="{Binding CancelCommand}"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
        </Grid>
    </Grid>
</UserControl>
