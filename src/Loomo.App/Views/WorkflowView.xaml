<UserControl x:Class="sk0ya.Loomo.App.Views.WorkflowView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:sk0ya.Loomo.App.ViewModels"
    xmlns:views="clr-namespace:sk0ya.Loomo.App.Views"
    Background="{DynamicResource BgAlt}">

    <UserControl.Resources>
        <!-- 前段参照チップ（クリックで指示文へ {{N}} を挿入） -->
        <Style x:Key="RefChipButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,4,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{DynamicResource BgAlt}" CornerRadius="9"
                                BorderBrush="{DynamicResource Border}" BorderThickness="1" Padding="7,1">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="active">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Bg}" />
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource Accent}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Bg}" />
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- カードのホバーで現れる小さな操作アイコン（↑↓＋🗑） -->
        <Style x:Key="StepActionButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="ToolbarGhostButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0" />
        </Style>

        <Style x:Key="SavedRowButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="4"
                                BorderBrush="Transparent" BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="active">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Bg}" />
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource Accent}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Bg}" />
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WorkflowRowSplitter" TargetType="{x:Type GridSplitter}">
            <Setter Property="Height" Value="12" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="SizeNS" />
            <Setter Property="ResizeBehavior" Value="PreviousAndNext" />
            <Setter Property="ResizeDirection" Value="Rows" />
            <Setter Property="ShowsPreview" Value="False" />
            <Setter Property="ToolTip" Value="ドラッグして高さを調整" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type GridSplitter}">
                        <Grid Background="{TemplateBinding Background}">
                            <Border Height="1" VerticalAlignment="Center"
                                    Background="{DynamicResource Border}" />
                            <Border x:Name="Grip" Width="48" Height="5" CornerRadius="2.5"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Background="{DynamicResource FgDim}" Opacity="0.45" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Grip" Property="Background" Value="{DynamicResource Accent}" />
                                <Setter TargetName="Grip" Property="Opacity" Value="0.95" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Grip" Property="Background" Value="{DynamicResource Accent}" />
                                <Setter TargetName="Grip" Property="Opacity" Value="0.95" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 実行ログ1エントリ（思考・ツールカード・結果・出力・診断・承認）の見た目。
             見出しは常に1行で、本文・差分・承認は折りたたみ展開。下部の実行ログでステップ単位に使い回す。 -->
        <DataTemplate x:Key="LogEntryTemplate" DataType="{x:Type vm:TranscriptEntry}">
            <Border Margin="0,1" CornerRadius="4" Padding="6,3"
                    Background="{DynamicResource BgAlt}">
                <StackPanel>
                    <!-- 見出し（クリックで開閉。展開できる中身が無ければグリフは出さない） -->
                    <Button Command="{Binding ToggleCollapseCommand}" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch" Cursor="Hand"
                            Background="Transparent" BorderThickness="0" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="hb" Background="Transparent" CornerRadius="3" Padding="2,1">
                                    <ContentPresenter />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="hb" Property="Background" Value="{DynamicResource Bg}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding CollapseGlyph}" FontSize="8"
                                       VerticalAlignment="Center" Margin="0,0,5,0"
                                       Foreground="{DynamicResource FgDim}"
                                       Visibility="{Binding HasBody, Converter={StaticResource BoolToVis}}" />
                            <TextBlock Grid.Column="1" Text="{Binding Header}" FontSize="11"
                                       FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Kind}" Value="Error">
                                                <Setter Property="Foreground" Value="#FFE05252" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="Assistant">
                                                <Setter Property="Foreground" Value="{DynamicResource Fg}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Button>

                    <!-- 本体（展開時のみ） -->
                    <StackPanel Margin="13,2,0,1"
                                Visibility="{Binding IsCollapsed, Converter={StaticResource InverseBoolToVis}}">
                        <TextBox Text="{Binding Text, Mode=OneWay}" IsReadOnly="True"
                                 TextWrapping="Wrap" BorderThickness="0" Padding="0"
                                 Background="Transparent"
                                 IsReadOnlyCaretVisible="False" IsTabStop="False" Cursor="IBeam"
                                 Foreground="{DynamicResource Fg}" FontSize="12">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="FontFamily" Value="Segoe UI" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Kind}" Value="Tool">
                                            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Kind}" Value="Thinking">
                                            <Setter Property="FontStyle" Value="Italic" />
                                            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Text}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <!-- 差分（編集系ツールの承認カード） -->
                        <Border Visibility="{Binding HasDiff, Converter={StaticResource BoolToVis}}"
                                BorderBrush="{DynamicResource Border}" BorderThickness="1"
                                CornerRadius="4" Margin="0,4,0,0" Padding="0,2">
                            <ItemsControl ItemsSource="{Binding DiffLines}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding Background}">
                                            <TextBlock Text="{Binding Text}" Foreground="{Binding Foreground}"
                                                       FontFamily="Cascadia Mono, Consolas" FontSize="12"
                                                       Padding="6,0" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <!-- 承認カード -->
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                    Visibility="{Binding IsPending, Converter={StaticResource BoolToVis}}">
                            <Button Content="承認して実行" Style="{StaticResource FlatButton}"
                                    Command="{Binding ApproveCommand}" Margin="0,0,8,0" />
                            <Button Content="拒否" Style="{StaticResource FlatButton}"
                                    Background="#FF6E1E1E" Command="{Binding RejectCommand}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="176" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource BgAlt}" BorderBrush="{DynamicResource Border}"
                    BorderThickness="0,0,1,0" Padding="6">
                <DockPanel LastChildFill="True">
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,5">
                        <TextBlock Text="ワークフロー" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource FgDim}" VerticalAlignment="Center" />
                        <Button Content="＋" HorizontalAlignment="Right" Style="{StaticResource StepActionButton}"
                                Command="{Binding NewWorkflowCommand}" ToolTip="新規" />
                    </Grid>
                    <TextBlock Text="なし" FontSize="11" Foreground="{DynamicResource FgDim}" Margin="2,2">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SavedWorkflows.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding SavedWorkflows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid x:Name="WorkflowListItem" Margin="0,0,0,2">
                                        <Button Style="{StaticResource SavedRowButton}"
                                                HorizontalAlignment="Stretch"
                                                Command="{Binding DataContext.LoadWorkflowCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                MouseDoubleClick="OnWorkflowListItemDoubleClick">
                                            <Button.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="名前の変更" Click="OnRenameWorkflowClick" />
                                                </ContextMenu>
                                            </Button.ContextMenu>
                                            <Button.Tag>
                                                <MultiBinding Converter="{StaticResource EqualityActiveTagConverter}">
                                                    <Binding Path="Id" />
                                                    <Binding Path="DataContext.CurrentWorkflowId"
                                                             RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                </MultiBinding>
                                            </Button.Tag>
                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource Fg}"
                                                       FontSize="12" TextTrimming="CharacterEllipsis" MaxWidth="134" />
                                        </Button>
                                        <Button Content="×" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                ToolTip="このワークフローを削除"
                                                Command="{Binding DataContext.DeleteWorkflowCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource StepActionButton}">
                                                    <Setter Property="Opacity" Value="0" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMouseOver, ElementName=WorkflowListItem}" Value="True">
                                                            <Setter Property="Opacity" Value="1" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <!-- 実行ログ領域（進捗帯＋ログ）は実行後、またはウォームアップ中に高さを確保する。 -->
                    <RowDefinition x:Name="ProgressAreaRow" Height="0" />
                </Grid.RowDefinitions>

                <!-- ===== ステップのパイプライン ===== -->
                <DockPanel Grid.Row="0" LastChildFill="True">

                <!-- ワークフロー名（編集可・自動保存）＋保存状態 -->
                <Border DockPanel.Dock="Top" Background="{DynamicResource BgAlt}"
                        BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1" Padding="8,6"
                        Visibility="Collapsed">
                    <DockPanel LastChildFill="True">
                        <TextBlock DockPanel.Dock="Right" Text="{Binding SaveStatus}" FontSize="11"
                                   Foreground="{DynamicResource FgDim}" VerticalAlignment="Center"
                                   Margin="8,0,0,0" />
                        <Grid VerticalAlignment="Center">
                            <TextBlock Text="ワークフロー名" IsHitTestVisible="False"
                                       VerticalAlignment="Center" FontSize="13"
                                       Foreground="{DynamicResource FgDim}"
                                       Visibility="{Binding Name, Converter={StaticResource EmptyToVis}}" />
                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" BorderThickness="0" Padding="0"
                                     FontSize="13" FontWeight="SemiBold" VerticalContentAlignment="Center"
                                     Foreground="{DynamicResource Fg}" CaretBrush="{DynamicResource Fg}"
                                     ToolTip="ワークフロー名（自動保存されます）" />
                        </Grid>
                    </DockPanel>
                </Border>

                <!-- 入力バー（{{input}} / {{input.path}} / {{input.content}} に流し込むワークフロー入力。ファイルからも読込可） -->
                <Border DockPanel.Dock="Top" Background="{DynamicResource BgAlt}"
                        BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1" Padding="8,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="入力" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource FgDim}" VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   ToolTip="{}{{input}} / {{input.path}} / {{input.content}} としてステップへ渡します" />
                        <TextBox Grid.Column="1" Text="{Binding RunInput, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{DynamicResource Bg}" BorderBrush="{DynamicResource Border}"
                                 BorderThickness="1" Padding="6,4" AcceptsReturn="True" TextWrapping="Wrap"
                                 MinHeight="30" MaxHeight="72" VerticalScrollBarVisibility="Auto"
                                 Foreground="{DynamicResource Fg}" CaretBrush="{DynamicResource Fg}" />
                        <Button Grid.Column="2" Content="読込" Style="{StaticResource ToolbarGhostButton}"
                                Padding="8,2" Margin="6,0,0,0" Click="OnLoadInputFromFileClick"
                                ToolTip="テキストファイルを読み込んで入力にする" />
                        <Button Grid.Column="3" Content="クリア" Style="{StaticResource ToolbarGhostButton}"
                                Padding="8,2" Margin="6,0,0,0" Click="OnClearInputClick"
                                Visibility="{Binding RunInput, Converter={StaticResource NonEmptyToVis}}"
                                ToolTip="入力を空にする" />
                    </Grid>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8,8,8,10">
            <StackPanel>
                <!-- 空状態のガイド（ステップが1つも無いとき） -->
                <Border CornerRadius="8" Padding="16,18" Margin="2,6"
                        Background="{DynamicResource Bg}" BorderBrush="{DynamicResource Border}"
                        BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Steps.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="ステップがありません" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Fg}" HorizontalAlignment="Center" />
                        <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,6,0,0" MaxWidth="420"
                                   Foreground="{DynamicResource FgDim}" TextAlignment="Center"
                                   Text="下の「＋ ステップを追加」から、AI への指示や、AI を使わないツール（コマンド実行・ファイル読書き・テキスト変換）を並べてワークフローを作れます。前段の出力は {{prev}} / {{1}}、上の入力は {{input}} で後続へ渡せます。" />
                    </StackPanel>
                </Border>

                <ItemsControl ItemsSource="{Binding Steps}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:WorkflowStepViewModel}">
                            <!-- 行ルート（ホバーで操作アイコンを出す）。縦の隙間を作らず接続線を連続させる。 -->
                            <Grid x:Name="RowRoot">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- 左レール：上下の接続線＋番号バッジ（状態で色分け） -->
                                <Grid Grid.Column="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Width="2" HorizontalAlignment="Center"
                                            Background="{DynamicResource Border}"
                                            Visibility="{Binding IsFirst, Converter={StaticResource InverseBoolToVis}}" />
                                    <Border Grid.Row="1" Width="24" Height="24" CornerRadius="12"
                                            HorizontalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource BgAlt}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
                                                <Setter Property="BorderThickness" Value="1.5" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Running">
                                                        <Setter Property="Background" Value="{DynamicResource Accent}" />
                                                        <Setter Property="BorderThickness" Value="0" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Done">
                                                        <Setter Property="Background" Value="#FF4CAF50" />
                                                        <Setter Property="BorderThickness" Value="0" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Error">
                                                        <Setter Property="Background" Value="#FFE05252" />
                                                        <Setter Property="BorderThickness" Value="0" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Index}" FontSize="11" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Running">
                                                            <Setter Property="Foreground" Value="White" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Done">
                                                            <Setter Property="Foreground" Value="White" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Error">
                                                            <Setter Property="Foreground" Value="White" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                    <Border Grid.Row="2" Width="2" HorizontalAlignment="Center"
                                            Background="{DynamicResource Border}"
                                            Visibility="{Binding IsLast, Converter={StaticResource InverseBoolToVis}}" />
                                </Grid>

                                <!-- ステップカード -->
                                <Border Grid.Column="1" Margin="2,3,2,3" CornerRadius="4" Padding="8"
                                        Background="{DynamicResource Bg}"
                                        BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <!-- 見出し行：開閉・種別・タイトル・状態・操作 -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- 開閉トグル（▾展開 / ▸折りたたみ） -->
                                            <Button Grid.Column="0" Command="{Binding ToggleExpandCommand}"
                                                    Width="20" Height="24" Margin="0,0,4,0" Cursor="Hand"
                                                    Background="Transparent" BorderThickness="0"
                                                    Foreground="{DynamicResource FgDim}"
                                                    ToolTip="ステップの編集欄を開閉">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="cb" Background="Transparent" CornerRadius="3">
                                                            <TextBlock Text="{Binding CollapseGlyph}" FontSize="10"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                       Foreground="{TemplateBinding Foreground}" />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="cb" Property="Background" Value="{DynamicResource BgAlt}" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>

                                            <!-- 種別セレクタ（AI / コマンド / 読込 / 書込 / 変換） -->
                                            <ComboBox Grid.Column="1" Margin="0,0,8,0" MinWidth="118" FontSize="11.5"
                                                      VerticalAlignment="Center"
                                                      ItemsSource="{Binding KindOptions}"
                                                      SelectedValuePath="Kind" DisplayMemberPath="Label"
                                                      SelectedValue="{Binding Kind}"
                                                      ToolTip="ステップ種別を切り替える" />

                                            <!-- タイトル（任意・枠なし） -->
                                            <Grid Grid.Column="2" Margin="0,0,8,0" VerticalAlignment="Center">
                                                <TextBlock Text="ステップ名（任意）" IsHitTestVisible="False"
                                                           VerticalAlignment="Center" FontSize="12"
                                                           Foreground="{DynamicResource FgDim}"
                                                           Visibility="{Binding Title, Converter={StaticResource EmptyToVis}}" />
                                                <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                                         Background="Transparent" BorderThickness="0" Padding="0"
                                                         FontSize="12" FontWeight="SemiBold"
                                                         VerticalContentAlignment="Center"
                                                         Foreground="{DynamicResource Fg}" CaretBrush="{DynamicResource Fg}" />
                                            </Grid>

                                            <!-- 状態テキスト（待機／実行中…／完了 (2.1秒)／失敗） -->
                                            <TextBlock Grid.Column="3" Text="{Binding StatusText}" VerticalAlignment="Center"
                                                       Margin="0,0,6,0" FontSize="11" TextTrimming="CharacterEllipsis"
                                                       MaxWidth="160">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Running">
                                                                <Setter Property="Foreground" Value="{DynamicResource Accent}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Done">
                                                                <Setter Property="Foreground" Value="#FF4CAF50" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Error">
                                                                <Setter Property="Foreground" Value="#FFE05252" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <!-- 操作（ホバーで出現：上へ/下へ/直後に挿入/削除） -->
                                            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Opacity" Value="0" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsMouseOver, ElementName=RowRoot}" Value="True">
                                                                <Setter Property="Opacity" Value="1" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <Button Style="{StaticResource StepActionButton}" Content="↑" ToolTip="上へ移動"
                                                        Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}" />
                                                <Button Style="{StaticResource StepActionButton}" Content="↓" ToolTip="下へ移動"
                                                        Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}" />
                                                <Button Style="{StaticResource StepActionButton}" Content="＋" ToolTip="このすぐ下にステップを挿入"
                                                        Command="{Binding DataContext.InsertStepAfterCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}" />
                                                <Button Style="{StaticResource StepActionButton}" Content="🗑" ToolTip="このステップを削除"
                                                        Command="{Binding DataContext.RemoveStepCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </Grid>

                                        <!-- 折りたたみ時の1行プレビュー（クリックで展開） -->
                                        <Button Command="{Binding ToggleExpandCommand}" Cursor="Hand"
                                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                                Background="Transparent" BorderThickness="0" Padding="0" Margin="24,4,0,0"
                                                Visibility="{Binding IsExpanded, Converter={StaticResource InverseBoolToVis}}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <ContentPresenter />
                                                </ControlTemplate>
                                            </Button.Template>
                                            <TextBlock Text="{Binding PromptPreview}" FontSize="11.5"
                                                       Foreground="{DynamicResource FgDim}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Button>

                                        <!-- 編集欄（展開時のみ） -->
                                        <StackPanel Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">

                                        <!-- 主テキスト（種別でプレースホルダ・等幅が変わる：指示文／コマンド／パス／入力） -->
                                        <Grid Margin="0,8,0,0">
                                            <TextBlock IsHitTestVisible="False" Margin="6,5" FontSize="12"
                                                       Foreground="{DynamicResource FgDim}" TextWrapping="Wrap"
                                                       Text="{Binding PrimaryPlaceholder}"
                                                       Visibility="{Binding Prompt, Converter={StaticResource EmptyToVis}}" />
                                            <TextBox Text="{Binding Prompt, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="{DynamicResource BgAlt}"
                                                     BorderBrush="{DynamicResource Border}" BorderThickness="1"
                                                     Padding="6,5" AcceptsReturn="True" TextWrapping="Wrap"
                                                     MinHeight="44" MaxHeight="200" VerticalScrollBarVisibility="Auto"
                                                     Foreground="{DynamicResource Fg}" CaretBrush="{DynamicResource Fg}">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox">
                                                        <Setter Property="FontFamily" Value="Segoe UI" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding PrimaryIsMonospace}" Value="True">
                                                                <Setter Property="FontFamily" Value="Cascadia Mono, Consolas" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                        </Grid>

                                        <!-- 書込ステップ：書き込む内容 -->
                                        <Grid Margin="0,6,0,0"
                                              Visibility="{Binding IsWriteFileStep, Converter={StaticResource BoolToVis}}">
                                            <TextBlock IsHitTestVisible="False" Margin="6,5" FontSize="12"
                                                       Foreground="{DynamicResource FgDim}" TextWrapping="Wrap"
                                                       Text="書き込む内容…（{{prev}} / {{input}} を指定できます）"
                                                       Visibility="{Binding Content, Converter={StaticResource EmptyToVis}}" />
                                            <TextBox Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="{DynamicResource BgAlt}" FontFamily="Cascadia Mono, Consolas"
                                                     BorderBrush="{DynamicResource Border}" BorderThickness="1"
                                                     Padding="6,5" AcceptsReturn="True" TextWrapping="Wrap"
                                                     MinHeight="44" MaxHeight="200" VerticalScrollBarVisibility="Auto"
                                                     Foreground="{DynamicResource Fg}" CaretBrush="{DynamicResource Fg}" />
                                        </Grid>

                                        <!-- 変換ステップ：検索／置換後／正規表現 -->
                                        <Grid Margin="0,6,0,0"
                                              Visibility="{Binding IsTransformStep, Converter={StaticResource BoolToVis}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" Text="{Binding Pattern, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="{DynamicResource BgAlt}" FontFamily="Cascadia Mono, Consolas"
                                                     BorderBrush="{DynamicResource Border}" BorderThickness="1"
                                                     Padding="6,4" Margin="0,0,4,0" FontSize="12"
                                                     Foreground="{DynamicResource Fg}" CaretBrush="{DynamicResource Fg}"
                                                     ToolTip="検索する文字列（正規表現も可）" />
                                            <TextBox Grid.Column="1" Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="{DynamicResource BgAlt}" FontFamily="Cascadia Mono, Consolas"
                                                     BorderBrush="{DynamicResource Border}" BorderThickness="1"
                                                     Padding="6,4" Margin="0,0,8,0" FontSize="12"
                                                     Foreground="{DynamicResource Fg}" CaretBrush="{DynamicResource Fg}"
                                                     ToolTip="置換後の文字列" />
                                            <CheckBox Grid.Column="2" Content="正規表現" VerticalAlignment="Center"
                                                      FontSize="11" Foreground="{DynamicResource FgDim}"
                                                      IsChecked="{Binding IsRegex}" />
                                        </Grid>

                                        <!-- 前段参照チップ -->
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                                    Visibility="{Binding RefTokens.Count, Converter={StaticResource CountToVis}}">
                                            <TextBlock Text="参照:" VerticalAlignment="Center" Margin="0,0,6,4"
                                                       FontSize="11" Foreground="{DynamicResource FgDim}" />
                                            <ItemsControl ItemsSource="{Binding RefTokens}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Style="{StaticResource RefChipButton}"
                                                                Command="{Binding DataContext.InsertRefCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"
                                                                ToolTip="クリックで指示文へ挿入">
                                                            <TextBlock Text="{Binding}" FontFamily="Cascadia Mono, Consolas"
                                                                       FontSize="11" Foreground="{DynamicResource Fg}" />
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>

                                        <!-- 実行前の注意とクイック修正 -->
                                        <Border Margin="0,8,0,0" CornerRadius="4" Padding="7,5"
                                                Background="{DynamicResource BgAlt}"
                                                Visibility="{Binding PromptNotice, Converter={StaticResource NonEmptyToVis}}">
                                            <DockPanel LastChildFill="True">
                                                <Button DockPanel.Dock="Right" Content="{}{{prev}} を追加"
                                                        Style="{StaticResource ToolbarGhostButton}"
                                                        Command="{Binding AppendPreviousCommand}"
                                                        Visibility="{Binding CanAppendPrevious, Converter={StaticResource BoolToVis}}" />
                                                <TextBlock Text="{Binding PromptNotice}" FontSize="11"
                                                           Foreground="{DynamicResource FgDim}" TextWrapping="Wrap"
                                                           VerticalAlignment="Center" />
                                            </DockPanel>
                                        </Border>

                                        </StackPanel>
                                        <!-- /編集欄 -->

                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 末尾の追加ノード：ライブラリから「ステップを追加」パレットを開く -->
                <Grid Margin="0,2,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="2" HorizontalAlignment="Center" Height="12"
                            VerticalAlignment="Top" Background="{DynamicResource Border}" />

                    <ToggleButton x:Name="AddPaletteToggle" Grid.Column="1" HorizontalAlignment="Left"
                                  Margin="2,4,0,0" Content="＋ ステップを追加 ▾"
                                  Foreground="{DynamicResource Fg}" Background="Transparent"
                                  BorderBrush="{DynamicResource Border}" Padding="11,5" FontSize="12"
                                  Cursor="Hand" ToolTip="小さなタスクの候補からステップを選んで追加">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="4"
                                        BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="b" Property="Background" Value="{DynamicResource BgAlt}" />
                                    </Trigger>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="b" Property="Background" Value="{DynamicResource BgAlt}" />
                                        <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource Accent}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>

                    <!-- ステップ候補パレット（2ペイン）。左で種類を選び、右の候補をクリックで末尾に追加して閉じる。 -->
                    <Popup Grid.Column="1" PlacementTarget="{Binding ElementName=AddPaletteToggle}"
                           Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
                           IsOpen="{Binding IsChecked, ElementName=AddPaletteToggle}">
                        <Border Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Border}"
                                BorderThickness="1" CornerRadius="6" Padding="0" Width="360" Margin="0,2,8,8">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.3" />
                            </Border.Effect>
                            <Grid Height="380">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="104" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- 左ペイン：種類（カテゴリ）＋空のステップ -->
                                <DockPanel Grid.Column="0" LastChildFill="True"
                                           Background="{DynamicResource BgAlt}">
                                    <Border DockPanel.Dock="Bottom" BorderBrush="{DynamicResource Border}"
                                            BorderThickness="0,1,0,0" Padding="4">
                                        <Button Style="{StaticResource SavedRowButton}" Click="OnAddCandidateClick"
                                                HorizontalAlignment="Stretch"
                                                Command="{Binding DataContext.AddCandidateCommand, ElementName=AddPaletteToggle}"
                                                ToolTip="空のステップを追加して自分で書く">
                                            <TextBlock Text="＋ 空のステップ" FontSize="11.5" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Fg}" />
                                        </Button>
                                    </Border>
                                    <ItemsControl ItemsSource="{Binding DataContext.StepLibrary, ElementName=AddPaletteToggle}"
                                                  Margin="4,4,4,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:StepCandidateGroup}">
                                                <Button Style="{StaticResource SavedRowButton}" Margin="0,0,0,2"
                                                        HorizontalAlignment="Stretch"
                                                        Command="{Binding DataContext.SelectStepCategoryCommand, ElementName=AddPaletteToggle}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Tag>
                                                        <MultiBinding Converter="{StaticResource EqualityActiveTagConverter}">
                                                            <Binding />
                                                            <Binding Path="DataContext.SelectedStepCategory"
                                                                     ElementName="AddPaletteToggle" />
                                                        </MultiBinding>
                                                    </Button.Tag>
                                                    <TextBlock Text="{Binding Category}" FontSize="12"
                                                               Foreground="{DynamicResource Fg}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </DockPanel>

                                <!-- 右ペイン：選択中カテゴリの候補 -->
                                <Border Grid.Column="1" BorderBrush="{DynamicResource Border}"
                                        BorderThickness="1,0,0,0">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                                        <ItemsControl ItemsSource="{Binding DataContext.VisibleCandidates, ElementName=AddPaletteToggle}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Style="{StaticResource SavedRowButton}"
                                                            HorizontalAlignment="Stretch" Click="OnAddCandidateClick"
                                                            Command="{Binding DataContext.AddCandidateCommand, ElementName=AddPaletteToggle}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip="{Binding Prompt}">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Name}" FontSize="12"
                                                                       FontWeight="SemiBold" Foreground="{DynamicResource Fg}" />
                                                            <TextBlock Text="{Binding Description}" FontSize="11"
                                                                       Foreground="{DynamicResource FgDim}"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Border>
                    </Popup>
                </Grid>
            </StackPanel>
        </ScrollViewer>
                </DockPanel>

                <!-- ===== 進捗状況エリア（実行後、またはウォームアップ中に現れる） =====
                     ウォームアップ中はウォームアップ表示。実行中・実行後は「実行ログ」（全ステップ一覧・
                     診断込み・出力は折りたたみ1行）。最終出力だけは別途ワークフロー出力として表示する。
                     上のパイプラインとの境界と、進行状況/最終出力の境界はドラッグで高さ調整できる。 -->
                <GridSplitter Grid.Row="1" Style="{StaticResource WorkflowRowSplitter}"
                              Visibility="{Binding IsProgressVisible, Converter={StaticResource BoolToVis}}" />

                <Border Grid.Row="2" Background="{DynamicResource BgAlt}"
                        BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0"
                        Visibility="{Binding IsProgressVisible, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition x:Name="ProgressLogRow" Height="Auto" MinHeight="38" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition x:Name="FinalOutputRow" Height="0" />
                        </Grid.RowDefinitions>

                        <!-- 進捗状況の中身：ウォームアップ表示と実行ログを切り替える -->
                        <Grid Grid.Row="0">
                        <!-- ウォームアップ表示（ウォームアップ中だけ） -->
                        <Border Padding="10,8" VerticalAlignment="Top"
                                Visibility="{Binding IsWarmingUp, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <ProgressBar IsIndeterminate="True" Width="64" Height="3"
                                                 Foreground="{DynamicResource Accent}" Background="Transparent"
                                                 BorderThickness="0" VerticalAlignment="Center" />
                                    <TextBlock Text="ウォームアップ中" Margin="10,0,0,0" VerticalAlignment="Center"
                                               FontSize="11.5" FontWeight="SemiBold" Foreground="{DynamicResource Fg}" />
                                </StackPanel>
                                <TextBlock Text="{Binding RunStatus}" TextWrapping="Wrap"
                                           FontSize="11.5" Foreground="{DynamicResource FgDim}" />
                            </StackPanel>
                        </Border>

                        <!-- 進行状況（実行中・実行後）。ウォームアップ中は隠す。 -->
                        <DockPanel LastChildFill="True"
                                   Visibility="{Binding IsWarmingUp, Converter={StaticResource InverseBoolToVis}}">
                            <!-- 見出し＋全体状態（完了／停止など） -->
                            <Border DockPanel.Dock="Top" Padding="9,5"
                                    BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
                                <DockPanel LastChildFill="False">
                                    <ToggleButton DockPanel.Dock="Right"
                                                  IsChecked="{Binding IsProgressDetailsExpanded, Mode=TwoWay}"
                                                  Content="詳細" Padding="8,2" Margin="8,0,0,0"
                                                  FontSize="11" Cursor="Hand"
                                                  ToolTip="進行状況の詳細ログを表示">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border x:Name="b" Background="Transparent"
                                                        BorderBrush="{DynamicResource Border}"
                                                        BorderThickness="1" CornerRadius="4"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="b" Property="Background" Value="{DynamicResource Bg}" />
                                                    </Trigger>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="b" Property="Background" Value="{DynamicResource Bg}" />
                                                        <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource Accent}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                    <TextBlock DockPanel.Dock="Left" Text="進行状況" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Foreground="{DynamicResource FgDim}" />
                                    <ProgressBar DockPanel.Dock="Right" IsIndeterminate="True" Width="60" Height="4"
                                                 Foreground="{DynamicResource Accent}" Background="Transparent"
                                                 BorderThickness="0" VerticalAlignment="Center" Margin="8,0,0,0"
                                                 Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}" />
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding RunStatus}" FontSize="11"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                               MaxWidth="320" Foreground="{DynamicResource FgDim}" />
                                </DockPanel>
                            </Border>
                            <ScrollViewer x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto"
                                          Padding="8,6" ScrollChanged="OnLogScrollChanged"
                                          Visibility="{Binding IsProgressDetailsExpanded, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <!-- 全ステップを1本のフラットな進捗タイムラインで見せる（ステップ単位でまとめない）。
                                         チャットの「進行状況」と同じ ActivityTimelineView を流用する。 -->
                                    <views:ActivityTimelineView DataContext="{Binding Activity}" />

                                    <!-- 承認待ちカード（ボタン・差分つき）。タイムライン本体とは別に末尾へ積む。 -->
                                    <ItemsControl ItemsSource="{Binding Approvals}" Margin="0,6,0,0"
                                                  ItemTemplate="{StaticResource LogEntryTemplate}" />
                                </StackPanel>
                            </ScrollViewer>
                        </DockPanel>
                        </Grid>

                        <GridSplitter Grid.Row="1" Style="{StaticResource WorkflowRowSplitter}"
                                      Visibility="{Binding HasFinalOutput, Converter={StaticResource BoolToVis}}" />

                        <!-- ワークフローの最終出力（実行ログとは別表示）。進行状況との境界をドラッグで調整できる。 -->
                        <Border Grid.Row="2" Padding="10,8" MinHeight="72"
                                Background="{DynamicResource Bg}"
                                BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0"
                                Visibility="{Binding HasFinalOutput, Converter={StaticResource BoolToVis}}">
                            <DockPanel LastChildFill="True">
                                <DockPanel DockPanel.Dock="Top" LastChildFill="False" Margin="0,0,0,4">
                                    <Button DockPanel.Dock="Right" Content="コピー"
                                            Style="{StaticResource ToolbarGhostButton}" Padding="8,2"
                                            Click="OnCopyFinalOutputClick"
                                            ToolTip="ワークフローの出力をコピー" />
                                    <TextBlock DockPanel.Dock="Left" Text="出力" FontSize="11"
                                               FontWeight="SemiBold" Foreground="{DynamicResource FgDim}"
                                               VerticalAlignment="Center" />
                                </DockPanel>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <TextBox Text="{Binding FinalOutput, Mode=OneWay}" IsReadOnly="True"
                                             TextWrapping="Wrap" BorderThickness="0" Padding="0"
                                             Background="Transparent" IsReadOnlyCaretVisible="False"
                                             IsTabStop="False" Cursor="IBeam"
                                             Foreground="{DynamicResource Fg}" FontSize="12.5" />
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
