<UserControl x:Class="sk0ya.Loomo.App.Views.WorkflowView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:sk0ya.Loomo.App.ViewModels"
    Background="{DynamicResource BgAlt}">

    <UserControl.Resources>
        <!-- 前段参照チップ（クリックで指示文へ {{N}} を挿入） -->
        <Style x:Key="RefChipButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,4,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{DynamicResource Bg}" CornerRadius="9"
                                BorderBrush="{DynamicResource Border}" BorderThickness="1" Padding="7,1">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource BgAlt}" />
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== ヘッダー：名前・読込・保存・新規 ===== -->
        <Grid Grid.Row="0" Margin="8,8,8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                     VerticalContentAlignment="Center" Padding="6,3" ToolTip="ワークフロー名" />

            <ComboBox x:Name="SavedCombo" Grid.Column="1" Width="150" Margin="6,0,0,0"
                      ItemsSource="{Binding SavedWorkflows}" DisplayMemberPath="Name"
                      ToolTip="保存済みワークフロー" />
            <Button Grid.Column="2" Content="読込" Style="{StaticResource FlatButton}" Margin="4,0,0,0"
                    Command="{Binding LoadWorkflowCommand}"
                    CommandParameter="{Binding SelectedItem, ElementName=SavedCombo}" />
            <Button Grid.Column="3" Content="保存" Style="{StaticResource FlatButton}" Margin="4,0,0,0"
                    Command="{Binding SaveCommand}" />
            <Button Grid.Column="4" Content="新規" Style="{StaticResource FlatButton}" Margin="4,0,0,0"
                    Command="{Binding NewWorkflowCommand}" />
        </Grid>

        <!-- ===== ステップ一覧 ===== -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="8,2">
            <ItemsControl ItemsSource="{Binding Steps}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:WorkflowStepViewModel}">
                        <Border Margin="0,4" CornerRadius="6" Padding="8"
                                Background="{DynamicResource Bg}"
                                BorderBrush="{DynamicResource Border}" BorderThickness="1">
                            <StackPanel>
                                <!-- 見出し行：番号・タイトル・ツール使用・移動/削除 -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Background="{DynamicResource Accent}" CornerRadius="9"
                                            Width="22" Height="22" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Index}" Foreground="White" FontSize="11"
                                                   FontWeight="SemiBold" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>

                                    <TextBox Grid.Column="1" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="8,0,0,0" Padding="6,2" VerticalContentAlignment="Center"
                                             ToolTip="ステップ名（任意）" />

                                    <CheckBox Grid.Column="2" Content="ツール使用" IsChecked="{Binding UseTools}"
                                              VerticalAlignment="Center" Margin="10,0,4,0" FontSize="12"
                                              Foreground="{DynamicResource Fg}"
                                              ToolTip="オンでツール（コマンド/ファイル/検索）を使えるエージェント実行。オフはテキストのみ単発。" />

                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="↑" Style="{StaticResource IconButton}" Width="22" Height="22"
                                                ToolTip="上へ移動"
                                                Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" />
                                        <Button Content="↓" Style="{StaticResource IconButton}" Width="22" Height="22"
                                                ToolTip="下へ移動"
                                                Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" />
                                        <Button Content="🗑" Style="{StaticResource IconButton}" Width="22" Height="22"
                                                ToolTip="このステップを削除"
                                                Command="{Binding DataContext.RemoveStepCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                </Grid>

                                <!-- 指示文 -->
                                <TextBox Text="{Binding Prompt, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,6,0,0" Padding="6,4" AcceptsReturn="True" TextWrapping="Wrap"
                                         MinHeight="46" MaxHeight="160" VerticalScrollBarVisibility="Auto"
                                         ToolTip="AIへの指示。{{1}} などで前段の出力を差し込めます。" />

                                <!-- 前段参照チップ -->
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                            Visibility="{Binding RefTokens.Count, Converter={StaticResource CountToVis}}">
                                    <TextBlock Text="参照:" VerticalAlignment="Center" Margin="0,0,6,4"
                                               FontSize="11" Foreground="{DynamicResource FgDim}" />
                                    <ItemsControl ItemsSource="{Binding RefTokens}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource RefChipButton}"
                                                        Command="{Binding DataContext.InsertRefCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="クリックで指示文へ挿入">
                                                    <TextBlock Text="{Binding}" FontFamily="Cascadia Mono, Consolas"
                                                               FontSize="11" Foreground="{DynamicResource Fg}" />
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <!-- 状態行 + ログ開閉 -->
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Style="{StaticResource IconButton}" Width="18" Height="18"
                                            Content="{Binding LogGlyph}" FontSize="9" Margin="0,0,6,0"
                                            Command="{Binding ToggleLogCommand}" ToolTip="実行ログの開閉"
                                            Visibility="{Binding Log.Count, Converter={StaticResource CountToVis}}" />
                                    <TextBlock Grid.Column="1" Text="{Binding StatusText}" VerticalAlignment="Center"
                                               FontSize="11">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Running">
                                                        <Setter Property="Foreground" Value="{DynamicResource Accent}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Done">
                                                        <Setter Property="Foreground" Value="#FF4CAF50" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Error">
                                                        <Setter Property="Foreground" Value="#FFE05252" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <!-- 実行ログ（思考・ツールカード・承認・結果・出力） -->
                                <ItemsControl ItemsSource="{Binding Log}" Margin="0,4,0,0"
                                              Visibility="{Binding IsLogCollapsed, Converter={StaticResource InverseBoolToVis}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:TranscriptEntry}">
                                            <Border Margin="0,2" CornerRadius="4" Padding="6,4"
                                                    Background="{DynamicResource BgAlt}">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Header}" FontSize="11"
                                                               FontWeight="SemiBold" TextTrimming="CharacterEllipsis">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Kind}" Value="Error">
                                                                        <Setter Property="Foreground" Value="#FFE05252" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Kind}" Value="Assistant">
                                                                        <Setter Property="Foreground" Value="{DynamicResource Fg}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBox Text="{Binding Text, Mode=OneWay}" IsReadOnly="True"
                                                             TextWrapping="Wrap" BorderThickness="0" Padding="0"
                                                             Margin="0,2,0,0" Background="Transparent"
                                                             IsReadOnlyCaretVisible="False" IsTabStop="False" Cursor="IBeam"
                                                             Foreground="{DynamicResource Fg}" FontSize="12">
                                                        <TextBox.Style>
                                                            <Style TargetType="TextBox">
                                                                <Setter Property="FontFamily" Value="Segoe UI" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Kind}" Value="Tool">
                                                                        <Setter Property="FontFamily" Value="Cascadia Mono, Consolas" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Kind}" Value="Thinking">
                                                                        <Setter Property="FontStyle" Value="Italic" />
                                                                        <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Text}" Value="">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBox.Style>
                                                    </TextBox>

                                                    <!-- 差分（編集系ツールの承認カード） -->
                                                    <Border Visibility="{Binding HasDiff, Converter={StaticResource BoolToVis}}"
                                                            BorderBrush="{DynamicResource Border}" BorderThickness="1"
                                                            CornerRadius="4" Margin="0,4,0,0" Padding="0,2">
                                                        <ItemsControl ItemsSource="{Binding DiffLines}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Background="{Binding Background}">
                                                                        <TextBlock Text="{Binding Text}" Foreground="{Binding Foreground}"
                                                                                   FontFamily="Cascadia Mono, Consolas" FontSize="12"
                                                                                   Padding="6,0" />
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Border>

                                                    <!-- 承認カード -->
                                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                                                Visibility="{Binding IsPending, Converter={StaticResource BoolToVis}}">
                                                        <Button Content="承認して実行" Style="{StaticResource FlatButton}"
                                                                Command="{Binding ApproveCommand}" Margin="0,0,8,0" />
                                                        <Button Content="拒否" Style="{StaticResource FlatButton}"
                                                                Background="#FF6E1E1E" Command="{Binding RejectCommand}" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ===== フッター：ステップ追加・実行・状況 ===== -->
        <Grid Grid.Row="2" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="＋ ステップを追加" Style="{StaticResource FlatButton}"
                    Command="{Binding AddStepCommand}" />

            <TextBlock Grid.Column="1" Text="{Binding RunStatus}" VerticalAlignment="Center"
                       Margin="12,0" FontSize="12" Foreground="{DynamicResource FgDim}"
                       TextTrimming="CharacterEllipsis" />

            <Button Grid.Column="2" Content="ワークフローを実行" Style="{StaticResource FlatButton}"
                    Command="{Binding RunCommand}" />
            <Button Grid.Column="3" Content="⏹" Style="{StaticResource FlatButton}"
                    Background="#FF6E1E1E" Command="{Binding CancelCommand}" Margin="6,0,0,0"
                    Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}" />
        </Grid>
    </Grid>
</UserControl>
