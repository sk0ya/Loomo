<UserControl x:Class="sk0ya.Loomo.App.Views.WorkflowView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:sk0ya.Loomo.App.ViewModels"
    xmlns:views="clr-namespace:sk0ya.Loomo.App.Views"
    Background="{DynamicResource BgAlt}">

    <UserControl.Resources>
        <!-- 前段参照チップ（クリックで指示文へ {{N}} を挿入） -->
        <Style x:Key="RefChipButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,4,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{DynamicResource BgAlt}" CornerRadius="9"
                                BorderBrush="{DynamicResource Border}" BorderThickness="1" Padding="7,1">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="active">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Bg}" />
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource Accent}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Bg}" />
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- カードのホバーで現れる小さな操作アイコン（↑↓＋🗑） -->
        <Style x:Key="StepActionButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="ToolbarGhostButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0" />
        </Style>

        <Style x:Key="SavedRowButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="4"
                                BorderBrush="Transparent" BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="active">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Bg}" />
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource Accent}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Bg}" />
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 実行ログ1エントリ（思考・ツールカード・結果・出力・診断・承認）の見た目。
             見出しは常に1行で、本文・差分・承認は折りたたみ展開。下部の実行ログでステップ単位に使い回す。 -->
        <DataTemplate x:Key="LogEntryTemplate" DataType="{x:Type vm:TranscriptEntry}">
            <Border Margin="0,1" CornerRadius="4" Padding="6,3"
                    Background="{DynamicResource BgAlt}">
                <StackPanel>
                    <!-- 見出し（クリックで開閉。展開できる中身が無ければグリフは出さない） -->
                    <Button Command="{Binding ToggleCollapseCommand}" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch" Cursor="Hand"
                            Background="Transparent" BorderThickness="0" Padding="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="hb" Background="Transparent" CornerRadius="3" Padding="2,1">
                                    <ContentPresenter />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="hb" Property="Background" Value="{DynamicResource Bg}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding CollapseGlyph}" FontSize="8"
                                       VerticalAlignment="Center" Margin="0,0,5,0"
                                       Foreground="{DynamicResource FgDim}"
                                       Visibility="{Binding HasBody, Converter={StaticResource BoolToVis}}" />
                            <TextBlock Grid.Column="1" Text="{Binding Header}" FontSize="11"
                                       FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Kind}" Value="Error">
                                                <Setter Property="Foreground" Value="#FFE05252" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Kind}" Value="Assistant">
                                                <Setter Property="Foreground" Value="{DynamicResource Fg}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Button>

                    <!-- 本体（展開時のみ） -->
                    <StackPanel Margin="13,2,0,1"
                                Visibility="{Binding IsCollapsed, Converter={StaticResource InverseBoolToVis}}">
                        <TextBox Text="{Binding Text, Mode=OneWay}" IsReadOnly="True"
                                 TextWrapping="Wrap" BorderThickness="0" Padding="0"
                                 Background="Transparent"
                                 IsReadOnlyCaretVisible="False" IsTabStop="False" Cursor="IBeam"
                                 Foreground="{DynamicResource Fg}" FontSize="12">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="FontFamily" Value="Segoe UI" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Kind}" Value="Tool">
                                            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Kind}" Value="Thinking">
                                            <Setter Property="FontStyle" Value="Italic" />
                                            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Text}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <!-- 差分（編集系ツールの承認カード） -->
                        <Border Visibility="{Binding HasDiff, Converter={StaticResource BoolToVis}}"
                                BorderBrush="{DynamicResource Border}" BorderThickness="1"
                                CornerRadius="4" Margin="0,4,0,0" Padding="0,2">
                            <ItemsControl ItemsSource="{Binding DiffLines}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding Background}">
                                            <TextBlock Text="{Binding Text}" Foreground="{Binding Foreground}"
                                                       FontFamily="Cascadia Mono, Consolas" FontSize="12"
                                                       Padding="6,0" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <!-- 承認カード -->
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                    Visibility="{Binding IsPending, Converter={StaticResource BoolToVis}}">
                            <Button Content="承認して実行" Style="{StaticResource FlatButton}"
                                    Command="{Binding ApproveCommand}" Margin="0,0,8,0" />
                            <Button Content="拒否" Style="{StaticResource FlatButton}"
                                    Background="#FF6E1E1E" Command="{Binding RejectCommand}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="176" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource BgAlt}" BorderBrush="{DynamicResource Border}"
                    BorderThickness="0,0,1,0" Padding="6">
                <DockPanel LastChildFill="True">
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,5">
                        <TextBlock Text="ワークフロー" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource FgDim}" VerticalAlignment="Center" />
                        <Button Content="＋" HorizontalAlignment="Right" Style="{StaticResource StepActionButton}"
                                Command="{Binding NewWorkflowCommand}" ToolTip="新規" />
                    </Grid>
                    <TextBlock Text="なし" FontSize="11" Foreground="{DynamicResource FgDim}" Margin="2,2">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SavedWorkflows.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding SavedWorkflows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid x:Name="WorkflowListItem" Margin="0,0,0,2">
                                        <Button Style="{StaticResource SavedRowButton}"
                                                HorizontalAlignment="Stretch"
                                                Command="{Binding DataContext.LoadWorkflowCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Tag>
                                                <MultiBinding Converter="{StaticResource EqualityActiveTagConverter}">
                                                    <Binding Path="Id" />
                                                    <Binding Path="DataContext.CurrentWorkflowId"
                                                             RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                                </MultiBinding>
                                            </Button.Tag>
                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource Fg}"
                                                       FontSize="12" TextTrimming="CharacterEllipsis" MaxWidth="134" />
                                        </Button>
                                        <Button Content="×" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                ToolTip="このワークフローを削除"
                                                Command="{Binding DataContext.DeleteWorkflowCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource StepActionButton}">
                                                    <Setter Property="Opacity" Value="0" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMouseOver, ElementName=WorkflowListItem}" Value="True">
                                                            <Setter Property="Opacity" Value="1" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <!-- 実行ログ領域（進捗帯＋ログ）は一度でも実行したときだけ高さを確保する（未実行時はパイプラインへ譲る） -->
                    <RowDefinition Height="{Binding HasRun, Converter={StaticResource BoolToStarLength}, ConverterParameter=1.4}" />
                </Grid.RowDefinitions>

                <!-- ===== ステップのパイプライン ===== -->
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="8,8,8,10">
            <StackPanel>
                <ItemsControl ItemsSource="{Binding Steps}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:WorkflowStepViewModel}">
                            <!-- 行ルート（ホバーで操作アイコンを出す）。縦の隙間を作らず接続線を連続させる。 -->
                            <Grid x:Name="RowRoot">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- 左レール：上下の接続線＋番号バッジ（状態で色分け） -->
                                <Grid Grid.Column="0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Width="2" HorizontalAlignment="Center"
                                            Background="{DynamicResource Border}"
                                            Visibility="{Binding IsFirst, Converter={StaticResource InverseBoolToVis}}" />
                                    <Border Grid.Row="1" Width="24" Height="24" CornerRadius="12"
                                            HorizontalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource BgAlt}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
                                                <Setter Property="BorderThickness" Value="1.5" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Running">
                                                        <Setter Property="Background" Value="{DynamicResource Accent}" />
                                                        <Setter Property="BorderThickness" Value="0" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Done">
                                                        <Setter Property="Background" Value="#FF4CAF50" />
                                                        <Setter Property="BorderThickness" Value="0" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Error">
                                                        <Setter Property="Background" Value="#FFE05252" />
                                                        <Setter Property="BorderThickness" Value="0" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Index}" FontSize="11" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Running">
                                                            <Setter Property="Foreground" Value="White" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Done">
                                                            <Setter Property="Foreground" Value="White" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Error">
                                                            <Setter Property="Foreground" Value="White" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                    <Border Grid.Row="2" Width="2" HorizontalAlignment="Center"
                                            Background="{DynamicResource Border}"
                                            Visibility="{Binding IsLast, Converter={StaticResource InverseBoolToVis}}" />
                                </Grid>

                                <!-- ステップカード -->
                                <Border Grid.Column="1" Margin="2,5,2,5" CornerRadius="8" Padding="10"
                                        Background="{DynamicResource Bg}"
                                        BorderBrush="{DynamicResource Border}" BorderThickness="1">
                                    <StackPanel>
                                        <!-- 見出し行：タイトル・状態・操作 -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- タイトル（任意・枠なし） -->
                                            <Grid Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center">
                                                <TextBlock Text="ステップ名（任意）" IsHitTestVisible="False"
                                                           VerticalAlignment="Center" FontSize="12"
                                                           Foreground="{DynamicResource FgDim}"
                                                           Visibility="{Binding Title, Converter={StaticResource EmptyToVis}}" />
                                                <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                                         Background="Transparent" BorderThickness="0" Padding="0"
                                                         FontSize="12" FontWeight="SemiBold"
                                                         VerticalContentAlignment="Center"
                                                         Foreground="{DynamicResource Fg}" CaretBrush="{DynamicResource Fg}" />
                                            </Grid>

                                            <!-- 状態テキスト（待機／実行中…／完了 (2.1秒)／失敗） -->
                                            <TextBlock Grid.Column="1" Text="{Binding StatusText}" VerticalAlignment="Center"
                                                       Margin="0,0,6,0" FontSize="11" TextTrimming="CharacterEllipsis"
                                                       MaxWidth="160">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Running">
                                                                <Setter Property="Foreground" Value="{DynamicResource Accent}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Done">
                                                                <Setter Property="Foreground" Value="#FF4CAF50" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Error">
                                                                <Setter Property="Foreground" Value="#FFE05252" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <!-- 操作（ホバーで出現：上へ/下へ/直後に挿入/削除） -->
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Opacity" Value="0" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsMouseOver, ElementName=RowRoot}" Value="True">
                                                                <Setter Property="Opacity" Value="1" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <Button Style="{StaticResource StepActionButton}" Content="↑" ToolTip="上へ移動"
                                                        Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}" />
                                                <Button Style="{StaticResource StepActionButton}" Content="↓" ToolTip="下へ移動"
                                                        Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}" />
                                                <Button Style="{StaticResource StepActionButton}" Content="＋" ToolTip="このすぐ下にステップを挿入"
                                                        Command="{Binding DataContext.InsertStepAfterCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}" />
                                                <Button Style="{StaticResource StepActionButton}" Content="🗑" ToolTip="このステップを削除"
                                                        Command="{Binding DataContext.RemoveStepCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </Grid>

                                        <!-- 指示文（プレースホルダ付き） -->
                                        <Grid Margin="0,8,0,0">
                                            <TextBlock IsHitTestVisible="False" Margin="6,5" FontSize="12"
                                                       Foreground="{DynamicResource FgDim}" TextWrapping="Wrap"
                                                       Text="AIへの指示を入力…   {{1}} などで前段の出力を差し込めます"
                                                       Visibility="{Binding Prompt, Converter={StaticResource EmptyToVis}}" />
                                            <TextBox Text="{Binding Prompt, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="{DynamicResource BgAlt}"
                                                     BorderBrush="{DynamicResource Border}" BorderThickness="1"
                                                     Padding="6,5" AcceptsReturn="True" TextWrapping="Wrap"
                                                     MinHeight="48" MaxHeight="200" VerticalScrollBarVisibility="Auto"
                                                     Foreground="{DynamicResource Fg}" CaretBrush="{DynamicResource Fg}" />
                                        </Grid>

                                        <!-- 前段参照チップ -->
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                                    Visibility="{Binding RefTokens.Count, Converter={StaticResource CountToVis}}">
                                            <TextBlock Text="参照:" VerticalAlignment="Center" Margin="0,0,6,4"
                                                       FontSize="11" Foreground="{DynamicResource FgDim}" />
                                            <ItemsControl ItemsSource="{Binding RefTokens}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Style="{StaticResource RefChipButton}"
                                                                Command="{Binding DataContext.InsertRefCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"
                                                                ToolTip="クリックで指示文へ挿入">
                                                            <TextBlock Text="{Binding}" FontFamily="Cascadia Mono, Consolas"
                                                                       FontSize="11" Foreground="{DynamicResource Fg}" />
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>

                                        <!-- 実行前の注意とクイック修正 -->
                                        <Border Margin="0,8,0,0" CornerRadius="4" Padding="7,5"
                                                Background="{DynamicResource BgAlt}"
                                                Visibility="{Binding PromptNotice, Converter={StaticResource NonEmptyToVis}}">
                                            <DockPanel LastChildFill="True">
                                                <Button DockPanel.Dock="Right" Content="{}{{prev}} を追加"
                                                        Style="{StaticResource ToolbarGhostButton}"
                                                        Command="{Binding AppendPreviousCommand}"
                                                        Visibility="{Binding CanAppendPrevious, Converter={StaticResource BoolToVis}}" />
                                                <TextBlock Text="{Binding PromptNotice}" FontSize="11"
                                                           Foreground="{DynamicResource FgDim}" TextWrapping="Wrap"
                                                           VerticalAlignment="Center" />
                                            </DockPanel>
                                        </Border>

                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 末尾の追加ノード：ライブラリから「ステップを追加」パレットを開く -->
                <Grid Margin="0,2,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="2" HorizontalAlignment="Center" Height="12"
                            VerticalAlignment="Top" Background="{DynamicResource Border}" />

                    <ToggleButton x:Name="AddPaletteToggle" Grid.Column="1" HorizontalAlignment="Left"
                                  Margin="2,4,0,0" Content="＋ ステップを追加 ▾"
                                  Foreground="{DynamicResource Fg}" Background="Transparent"
                                  BorderBrush="{DynamicResource Border}" Padding="11,5" FontSize="12"
                                  Cursor="Hand" ToolTip="小さなタスクの候補からステップを選んで追加">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="4"
                                        BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="b" Property="Background" Value="{DynamicResource BgAlt}" />
                                    </Trigger>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="b" Property="Background" Value="{DynamicResource BgAlt}" />
                                        <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource Accent}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>

                    <!-- ステップ候補パレット（2ペイン）。左で種類を選び、右の候補をクリックで末尾に追加して閉じる。 -->
                    <Popup Grid.Column="1" PlacementTarget="{Binding ElementName=AddPaletteToggle}"
                           Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
                           IsOpen="{Binding IsChecked, ElementName=AddPaletteToggle}">
                        <Border Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Border}"
                                BorderThickness="1" CornerRadius="6" Padding="0" Width="360" Margin="0,2,8,8">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.3" />
                            </Border.Effect>
                            <Grid Height="380">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="104" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- 左ペイン：種類（カテゴリ）＋空のステップ -->
                                <DockPanel Grid.Column="0" LastChildFill="True"
                                           Background="{DynamicResource BgAlt}">
                                    <Border DockPanel.Dock="Bottom" BorderBrush="{DynamicResource Border}"
                                            BorderThickness="0,1,0,0" Padding="4">
                                        <Button Style="{StaticResource SavedRowButton}" Click="OnAddCandidateClick"
                                                HorizontalAlignment="Stretch"
                                                Command="{Binding DataContext.AddCandidateCommand, ElementName=AddPaletteToggle}"
                                                ToolTip="空のステップを追加して自分で書く">
                                            <TextBlock Text="＋ 空のステップ" FontSize="11.5" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Fg}" />
                                        </Button>
                                    </Border>
                                    <ItemsControl ItemsSource="{Binding DataContext.StepLibrary, ElementName=AddPaletteToggle}"
                                                  Margin="4,4,4,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:StepCandidateGroup}">
                                                <Button Style="{StaticResource SavedRowButton}" Margin="0,0,0,2"
                                                        HorizontalAlignment="Stretch"
                                                        Command="{Binding DataContext.SelectStepCategoryCommand, ElementName=AddPaletteToggle}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Tag>
                                                        <MultiBinding Converter="{StaticResource EqualityActiveTagConverter}">
                                                            <Binding />
                                                            <Binding Path="DataContext.SelectedStepCategory"
                                                                     ElementName="AddPaletteToggle" />
                                                        </MultiBinding>
                                                    </Button.Tag>
                                                    <TextBlock Text="{Binding Category}" FontSize="12"
                                                               Foreground="{DynamicResource Fg}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </DockPanel>

                                <!-- 右ペイン：選択中カテゴリの候補 -->
                                <Border Grid.Column="1" BorderBrush="{DynamicResource Border}"
                                        BorderThickness="1,0,0,0">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                                        <ItemsControl ItemsSource="{Binding DataContext.VisibleCandidates, ElementName=AddPaletteToggle}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Style="{StaticResource SavedRowButton}"
                                                            HorizontalAlignment="Stretch" Click="OnAddCandidateClick"
                                                            Command="{Binding DataContext.AddCandidateCommand, ElementName=AddPaletteToggle}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip="{Binding Prompt}">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Name}" FontSize="12"
                                                                       FontWeight="SemiBold" Foreground="{DynamicResource Fg}" />
                                                            <TextBlock Text="{Binding Description}" FontSize="11"
                                                                       Foreground="{DynamicResource FgDim}"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Border>
                    </Popup>
                </Grid>
            </StackPanel>
        </ScrollViewer>

                <!-- ===== 進捗状況エリア（実行後にだけ現れる） =====
                     ウォームアップ中はウォームアップ表示。実行中・実行後は「実行ログ」（全ステップ一覧・
                     診断込み・出力は折りたたみ1行）。最終出力だけは別途ワークフロー出力として下端に固定。
                     上のパイプラインとの境界はドラッグで高さ調整できる。 -->
                <GridSplitter Grid.Row="1" Height="6" HorizontalAlignment="Stretch"
                              VerticalAlignment="Center" Background="Transparent"
                              ResizeBehavior="PreviousAndNext" ResizeDirection="Rows"
                              Visibility="{Binding HasRun, Converter={StaticResource BoolToVis}}" />

                <Border Grid.Row="2" Background="{DynamicResource BgAlt}"
                        BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0"
                        Visibility="{Binding HasRun, Converter={StaticResource BoolToVis}}">
                    <DockPanel LastChildFill="True">
                        <!-- ワークフローの最終出力（実行ログとは別表示・下端に固定） -->
                        <Border DockPanel.Dock="Bottom" Padding="9,7"
                                Background="{DynamicResource Bg}"
                                BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0"
                                Visibility="{Binding HasFinalOutput, Converter={StaticResource BoolToVis}}">
                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Top" Text="ワークフローの出力" FontSize="10"
                                           FontWeight="SemiBold" Foreground="{DynamicResource FgDim}"
                                           Margin="0,0,0,4" />
                                <ScrollViewer MaxHeight="170" VerticalScrollBarVisibility="Auto">
                                    <TextBox Text="{Binding FinalOutput, Mode=OneWay}" IsReadOnly="True"
                                             TextWrapping="Wrap" BorderThickness="0" Padding="0"
                                             Background="Transparent" IsReadOnlyCaretVisible="False"
                                             IsTabStop="False" Cursor="IBeam"
                                             Foreground="{DynamicResource Fg}" FontSize="12.5" />
                                </ScrollViewer>
                            </DockPanel>
                        </Border>

                        <!-- 進捗状況の中身（DockPanel の充填領域）：ウォームアップ表示と実行ログを切り替える -->
                        <Grid>
                        <!-- ウォームアップ表示（ウォームアップ中だけ） -->
                        <Border Padding="12,11" VerticalAlignment="Top"
                                Visibility="{Binding IsWarmingUp, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <ProgressBar IsIndeterminate="True" Width="90" Height="4"
                                                 Foreground="{DynamicResource Accent}" Background="Transparent"
                                                 BorderThickness="0" VerticalAlignment="Center" />
                                    <TextBlock Text="ウォームアップ中" Margin="10,0,0,0" VerticalAlignment="Center"
                                               FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource Fg}" />
                                </StackPanel>
                                <TextBlock Text="{Binding RunStatus}" TextWrapping="Wrap"
                                           FontSize="12" Foreground="{DynamicResource FgDim}" />
                            </StackPanel>
                        </Border>

                        <!-- 実行ログ（実行中・実行後）。ウォームアップ中は隠す。 -->
                        <DockPanel LastChildFill="True"
                                   Visibility="{Binding IsWarmingUp, Converter={StaticResource InverseBoolToVis}}">
                            <!-- 見出し＋全体状態（完了／停止など） -->
                            <Border DockPanel.Dock="Top" Padding="9,5"
                                    BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
                                <DockPanel LastChildFill="False">
                                    <TextBlock DockPanel.Dock="Left" Text="実行ログ" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Foreground="{DynamicResource FgDim}" />
                                    <ProgressBar DockPanel.Dock="Right" IsIndeterminate="True" Width="60" Height="4"
                                                 Foreground="{DynamicResource Accent}" Background="Transparent"
                                                 BorderThickness="0" VerticalAlignment="Center" Margin="8,0,0,0"
                                                 Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}" />
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding RunStatus}" FontSize="11"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                               MaxWidth="320" Foreground="{DynamicResource FgDim}" />
                                </DockPanel>
                            </Border>
                            <ScrollViewer x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto"
                                          Padding="8,6" ScrollChanged="OnLogScrollChanged">
                                <StackPanel>
                                    <!-- 全ステップを1本のフラットな進捗タイムラインで見せる（ステップ単位でまとめない）。
                                         チャットの「進行状況」と同じ ActivityTimelineView を流用する。 -->
                                    <views:ActivityTimelineView DataContext="{Binding Activity}" />

                                    <!-- 承認待ちカード（ボタン・差分つき）。タイムライン本体とは別に末尾へ積む。 -->
                                    <ItemsControl ItemsSource="{Binding Approvals}" Margin="0,6,0,0"
                                                  ItemTemplate="{StaticResource LogEntryTemplate}" />
                                </StackPanel>
                            </ScrollViewer>
                        </DockPanel>
                        </Grid>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
