<UserControl x:Class="sk0ya.Loomo.App.Views.AnalysisView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:sk0ya.Loomo.App.ViewModels"
    Background="{DynamicResource BgAlt}">

    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Style="{StaticResource PanelHeader}" Text="AIログ分析" />

        <!-- 対象選択 -->
        <Grid DockPanel.Dock="Top" Margin="10,2,10,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ComboBox Grid.Column="0" Height="26"
                      ItemsSource="{Binding Sessions}"
                      SelectedItem="{Binding SelectedSession, Mode=TwoWay}"
                      DisplayMemberPath="Display"
                      IsEnabled="{Binding CrossSession, Converter={StaticResource InverseBool}}"
                      ToolTip="解析するセッション" />
            <Button Grid.Column="1" Content="⟳" Style="{StaticResource FlatButton}" Margin="6,0,0,0"
                    Background="{DynamicResource BgAlt}" Foreground="{DynamicResource Fg}"
                    ToolTip="更新" Command="{Binding RefreshCommand}" />
        </Grid>

        <CheckBox DockPanel.Dock="Top" Margin="12,0,10,6" Foreground="{DynamicResource Fg}"
                  Content="横断（全セッション）で集計" IsChecked="{Binding CrossSession, Mode=TwoWay}" />

        <TextBlock DockPanel.Dock="Top" Margin="12,0,10,6" FontSize="11"
                   Foreground="{DynamicResource FgDim}" TextTrimming="CharacterEllipsis"
                   Text="{Binding StatusText}" />

        <!-- 改善提案アクション -->
        <Grid DockPanel.Dock="Top" Margin="10,2,10,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="🛈 AIに改善提案させる" Style="{StaticResource FlatButton}"
                    HorizontalAlignment="Stretch" Command="{Binding AnalyzeCommand}" />
            <Button Grid.Column="1" Content="⏹" Style="{StaticResource FlatButton}" Margin="6,0,0,0"
                    Background="{DynamicResource BgAlt}" Foreground="{DynamicResource Fg}"
                    ToolTip="中断" Command="{Binding CancelCommand}"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8,0,8,10">
            <StackPanel>
                <!-- メトリクス -->
                <ItemsControl ItemsSource="{Binding Metrics}" Margin="2,0,2,4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="2,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="12"
                                           Foreground="{DynamicResource FgDim}" />
                                <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="12"
                                           Foreground="{DynamicResource Fg}" FontWeight="SemiBold" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ツール別統計 -->
                <TextBlock Text="ツール別" Style="{StaticResource PanelHeader}" Margin="2,6,0,2"
                           Visibility="{Binding HasToolStats, Converter={StaticResource BoolToVis}}" />
                <ItemsControl ItemsSource="{Binding ToolStats}" Margin="2,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,1" Padding="6,3" CornerRadius="3" Background="{DynamicResource Bg}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" Foreground="{DynamicResource Fg}"
                                               FontSize="12" Width="120" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Foreground="{DynamicResource FgDim}" FontSize="11"
                                               Text="{Binding Calls, StringFormat='呼出{0}'}" Margin="0,0,8,0" />
                                    <TextBlock Foreground="{DynamicResource FgDim}" FontSize="11"
                                               Text="{Binding Errors, StringFormat='失敗{0}'}" Margin="0,0,8,0" />
                                    <TextBlock Foreground="{DynamicResource FgDim}" FontSize="11"
                                               Text="{Binding AvgDurationMs, StringFormat='{}{0:0}ms'}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- 改善提案レポート -->
                <TextBlock Text="改善提案" Style="{StaticResource PanelHeader}" Margin="2,10,0,2"
                           Visibility="{Binding HasReport, Converter={StaticResource BoolToVis}}" />
                <TextBox Text="{Binding ReportText, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap"
                         AcceptsReturn="True" BorderThickness="0" Margin="2,0"
                         Background="Transparent" Foreground="{DynamicResource Fg}" FontSize="12"
                         Visibility="{Binding HasReport, Converter={StaticResource BoolToVis}}" />

                <!-- システムプロンプト改訂案の diff＋反映 -->
                <StackPanel Visibility="{Binding HasProposedPrompt, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="システムプロンプト改訂案" Style="{StaticResource PanelHeader}" Margin="2,10,0,2" />
                    <Border Margin="2,0" Padding="6,4" CornerRadius="3" Background="{DynamicResource Bg}">
                        <ItemsControl ItemsSource="{Binding PromptDiff}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Text}" Foreground="{Binding Foreground}"
                                               Background="{Binding Background}"
                                               FontFamily="Consolas, monospace" FontSize="12" TextWrapping="Wrap" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                    <Grid Margin="2,6,2,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="✓ システムプロンプトに反映" Style="{StaticResource FlatButton}"
                                HorizontalAlignment="Stretch" Command="{Binding ApplyPromptCommand}" />
                        <Button Grid.Column="1" Content="↶ 元に戻す" Style="{StaticResource FlatButton}" Margin="6,0,0,0"
                                Background="{DynamicResource BgAlt}" Foreground="{DynamicResource Fg}"
                                Command="{Binding UndoPromptCommand}" />
                    </Grid>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
