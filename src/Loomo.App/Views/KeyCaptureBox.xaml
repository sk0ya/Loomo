<UserControl x:Class="sk0ya.Loomo.App.Views.KeyCaptureBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Focusable="True"
    PreviewKeyDown="OnKey"
    LostKeyboardFocus="OnLostFocus">
    <Border x:Name="Box" MinWidth="150" CornerRadius="4" Padding="8,4"
            Background="{DynamicResource BgAlt}"
            BorderBrush="{DynamicResource Border}" BorderThickness="1"
            Cursor="Hand" MouseLeftButtonDown="OnStart">
        <Grid>
            <!-- 通常表示：現在のジェスチャ -->
            <TextBlock x:Name="Display" VerticalAlignment="Center"
                       Text="{Binding GestureText}"
                       FontFamily="Cascadia Mono, Consolas"
                       Foreground="{DynamicResource Fg}" />
            <!-- キャプチャ中：プロンプト -->
            <TextBlock x:Name="Prompt" VerticalAlignment="Center" Visibility="Collapsed"
                       Text="キーを押す…（Esc で取消）"
                       Foreground="{DynamicResource Accent}" />
        </Grid>
    </Border>
</UserControl>
