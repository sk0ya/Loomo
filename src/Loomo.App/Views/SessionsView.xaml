<UserControl x:Class="sk0ya.Loomo.App.Views.SessionsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:sk0ya.Loomo.App.ViewModels"
    Background="{StaticResource BgAlt}">

    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Style="{StaticResource PanelHeader}" Text="AIセッション" />

        <Grid DockPanel.Dock="Top" Margin="10,2,10,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="＋ 新規セッション" Style="{StaticResource FlatButton}"
                    HorizontalAlignment="Stretch" Command="{Binding NewCommand}" />
            <Button Grid.Column="1" Content="⟳" Style="{StaticResource FlatButton}" Margin="6,0,0,0"
                    Background="{StaticResource BgAlt}" ToolTip="更新" Command="{Binding RefreshCommand}" />
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="6,0,6,8">
            <ItemsControl ItemsSource="{Binding Sessions}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="4,3" CornerRadius="4" Background="{StaticResource Bg}"
                                BorderBrush="{StaticResource Border}" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- タイトル＋日時：クリックで復元 -->
                                <Button Grid.Column="0" Cursor="Hand"
                                        Command="{Binding DataContext.LoadCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="b" Background="Transparent" Padding="8,6">
                                                <StackPanel HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"
                                                               Foreground="{StaticResource Fg}" />
                                                    <TextBlock Text="{Binding UpdatedAt, StringFormat='yyyy/MM/dd HH:mm'}"
                                                               Foreground="{StaticResource FgDim}" FontSize="11" Margin="0,2,0,0" />
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="b" Property="Background" Value="{StaticResource BgAlt}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <!-- 削除 -->
                                <Button Grid.Column="1" Content="🗑" Width="34" FontSize="13" Cursor="Hand"
                                        ToolTip="削除" Foreground="{StaticResource FgDim}"
                                        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="b" Background="Transparent">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="b" Property="Background" Value="#FF6E1E1E" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
