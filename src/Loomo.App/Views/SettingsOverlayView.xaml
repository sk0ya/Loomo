<UserControl x:Class="sk0ya.Loomo.App.Views.SettingsOverlayView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:sk0ya.Loomo.App.Views"
    Focusable="True"
    PreviewKeyDown="OnPreviewKeyDown">

    <UserControl.Resources>
        <!-- 配色プリセットの行（色チップ＋ラベル）。AppearanceView から移設。 -->
        <DataTemplate x:Key="PresetItemTemplate">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="14" Height="14" CornerRadius="3" ClipToBounds="True"
                        Background="{Binding Bg}"
                        BorderBrush="{DynamicResource Border}" BorderThickness="1">
                    <Border Height="4" VerticalAlignment="Bottom" Background="{Binding Accent}" />
                </Border>
                <TextBlock Text="{Binding Name}" Margin="7,0,0,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource Fg}" />
            </StackPanel>
        </DataTemplate>

        <!-- アクセントの行（単色チップ／「既定」は下地が見える）。 -->
        <DataTemplate x:Key="AccentItemTemplate">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Grid Width="14" Height="14">
                    <Border CornerRadius="3" Background="{DynamicResource BgAlt}"
                            BorderBrush="{DynamicResource Border}" BorderThickness="1" />
                    <Border CornerRadius="3" Background="{Binding Hex}" />
                </Grid>
                <TextBlock Text="{Binding Name}" Margin="7,0,0,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource Fg}" />
            </StackPanel>
        </DataTemplate>

        <!-- モデル入手ポップアップを開くアイコントグル（モデル欄の右隣）。 -->
        <Style x:Key="AcquireToggle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="4"
                                BorderBrush="{DynamicResource Border}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource BgAlt}" />
                                <Setter Property="Foreground" Value="{DynamicResource Fg}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource BgAlt}" />
                                <Setter Property="Foreground" Value="{DynamicResource Fg}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 左ナビのカテゴリ項目（全幅・ホバー/選択でハイライト）。 -->
        <Style x:Key="CategoryNavItem" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="b" Background="Transparent" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource BgAlt}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Accent}" />
                                <Setter Property="Foreground" Value="{DynamicResource AccentFg}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- 薄暗がりの背景（クリックで閉じる） -->
        <Border Background="#59101010" MouseLeftButtonDown="OnBackdropMouseDown" />

        <!-- 中央パネル -->
        <Border Width="780" Height="560" HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Border}"
                BorderThickness="1" CornerRadius="8" MouseLeftButtonDown="OnPanelMouseDown">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" ShadowDepth="3" Opacity="0.4" />
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- 左ナビ -->
                <DockPanel Grid.Column="0" Background="{DynamicResource BgAlt}" Margin="0">
                    <Grid DockPanel.Dock="Top">
                        <TextBlock Text="設定" Margin="16,14,0,10"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Fg}" />
                    </Grid>
                    <StackPanel Margin="8,4,8,8">
                        <RadioButton Style="{StaticResource CategoryNavItem}" Content="🎨  外観"
                                     IsChecked="{Binding SettingsCategory, Converter={StaticResource EnumToBool}, ConverterParameter=Appearance}" />
                        <RadioButton Style="{StaticResource CategoryNavItem}" Content="📝  エディタ"
                                     IsChecked="{Binding SettingsCategory, Converter={StaticResource EnumToBool}, ConverterParameter=Editor}" />
                        <RadioButton Style="{StaticResource CategoryNavItem}" Content="🖥  ターミナル"
                                     IsChecked="{Binding SettingsCategory, Converter={StaticResource EnumToBool}, ConverterParameter=Terminal}" />
                        <RadioButton Style="{StaticResource CategoryNavItem}" Content="🤖  AI"
                                     IsChecked="{Binding SettingsCategory, Converter={StaticResource EnumToBool}, ConverterParameter=Ai}" />
                        <RadioButton Style="{StaticResource CategoryNavItem}" Content="⌨  キーボード"
                                     IsChecked="{Binding SettingsCategory, Converter={StaticResource EnumToBool}, ConverterParameter=Keyboard}" />
                    </StackPanel>
                </DockPanel>

                <!-- 右内容 -->
                <Grid Grid.Column="1">
                    <!-- 閉じるボタン（右上） -->
                    <Button HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0"
                            Width="30" Height="28" Style="{StaticResource CaptionButton}"
                            Panel.ZIndex="1" ToolTip="閉じる（Esc）"
                            Command="{Binding CloseSettingsOverlayCommand}">
                        <Path Stretch="None" StrokeThickness="1" SnapsToDevicePixels="True"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M0,0 L10,10 M0,10 L10,0" />
                    </Button>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="22,18,20,18">
                        <Grid>
                            <!-- ===== AI ===== -->
                            <StackPanel Visibility="{Binding SettingsCategory, Converter={StaticResource EnumToVis}, ConverterParameter=Ai}">
                                <TextBlock Style="{StaticResource SectionTitle}" Text="モデル" Margin="0,0,0,4" />
                                <!-- モデル選択 ＋ 入手アイコン（右隣）。入手UIはポップアップに畳む。 -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0" IsEditable="True" IsReadOnly="True"
                                              ItemsSource="{Binding Settings.AvailableModels}"
                                              IsDropDownOpen="{Binding Settings.ModelDropDownOpen, Mode=TwoWay}"
                                              Text="{Binding Settings.Model, UpdateSourceTrigger=PropertyChanged}"
                                              ToolTip="ローカルに配置済みの ONNX モデルから選びます。" />
                                    <ToggleButton x:Name="AcquireToggle" Grid.Column="1"
                                                  Style="{StaticResource AcquireToggle}"
                                                  Width="30" Margin="6,0,0,0" Content="＋"
                                                  ToolTip="モデルを入手（ダウンロード／別の場所から追加）" />
                                    <Popup IsOpen="{Binding IsChecked, ElementName=AcquireToggle}" StaysOpen="False"
                                           AllowsTransparency="True" PlacementTarget="{Binding ElementName=AcquireToggle}"
                                           Placement="Bottom" HorizontalOffset="-262" VerticalOffset="2">
                                        <Border Width="300" Background="{DynamicResource Panel}"
                                                BorderBrush="{DynamicResource Border}" BorderThickness="1"
                                                CornerRadius="6" Padding="12" Margin="0,0,10,10">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.35" />
                                            </Border.Effect>
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource FieldLabel}" Text="Hugging Face から入手"
                                                           Margin="0,0,0,4" />
                                                <ComboBox ItemsSource="{Binding Settings.DownloadableModels}"
                                                          SelectedItem="{Binding Settings.SelectedDownloadModel, Mode=TwoWay}"
                                                          DisplayMemberPath="DisplayName"
                                                          IsEnabled="{Binding Settings.IsDownloading, Converter={StaticResource InverseBool}}"
                                                          ToolTip="Hugging Face から取得する ONNX（CPU int4・ORT-GenAI 互換）モデルを選びます。" />
                                                <Button Style="{StaticResource WideSecondaryButton}" Content="⬇  ダウンロード"
                                                        ToolTip="選択したモデル（CPU int4）を Hugging Face からダウンロードして追加します。"
                                                        Command="{Binding Settings.DownloadModelCommand}"
                                                        IsEnabled="{Binding Settings.IsDownloading, Converter={StaticResource InverseBool}}" />
                                                <ProgressBar Height="6" Margin="0,8,0,0" Minimum="0" Maximum="100"
                                                             Value="{Binding Settings.DownloadProgress, Mode=OneWay}"
                                                             Visibility="{Binding Settings.IsDownloading, Converter={StaticResource BoolToVis}}" />
                                                <Separator Margin="0,10,0,0" />
                                                <Button Style="{StaticResource WideSecondaryButton}" Content="📂  別の場所から追加…"
                                                        ToolTip="任意の場所にある ONNX モデルフォルダ（genai_config.json を含む）を選んで追加します。"
                                                        Command="{Binding Settings.BrowseModelCommand}" />
                                            </StackPanel>
                                        </Border>
                                    </Popup>
                                </Grid>
                                <TextBlock Text="{Binding Settings.ModelPath, StringFormat='📁 {0}'}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Settings.ModelPath}"
                                           Foreground="{DynamicResource FgDim}" FontSize="11"
                                           Margin="2,5,0,0" />

                                <TextBlock Style="{StaticResource FieldLabel}" Text="最大出力トークン" />
                                <TextBox Text="{Binding Settings.MaxTokens, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Style="{StaticResource FieldHint}" Text="空・0 で既定（4096）。" />

                                <CheckBox IsChecked="{Binding Settings.WarmupEnabled}" Margin="0,12,0,0"
                                          ToolTip="起動時・ワークスペース確定時にモデルとシステムプロンプトを事前ロードし、初回ターンを速くします。実行中はAIへの指示を受け付けません。">
                                    <TextBlock Text="AIウォームアップを有効にする" TextWrapping="Wrap" />
                                </CheckBox>

                                <Separator Margin="0,16,0,10" />
                                <TextBlock Style="{StaticResource SectionTitle}" Text="安全設計" Margin="0,0,0,8" />
                                <CheckBox IsChecked="{Binding Settings.AutoApprove}"
                                          ToolTip="信頼ワークスペース向け。コマンド/編集の承認カードを省略します。">
                                    <TextBlock Text="自動承認モード" TextWrapping="Wrap" />
                                </CheckBox>
                                <CheckBox IsChecked="{Binding Settings.RestrictToWorkspaceRoot}" Margin="0,8,0,0"
                                          ToolTip="パストラバーサルを防止します。">
                                    <TextBlock Text="ファイルアクセスをワークスペース内に限定" TextWrapping="Wrap" />
                                </CheckBox>

                                <TextBlock Style="{StaticResource FieldLabel}" Text="ブロックする危険コマンド" />
                                <Button Style="{StaticResource WideSecondaryButton}" Content="エディタで編集"
                                        Command="{Binding Settings.EditBlockedCommandsCommand}" />
                                <Button Style="{StaticResource WideSecondaryButton}" Content="既定に戻す"
                                        Command="{Binding Settings.ResetBlockedCommandsCommand}" />
                                <TextBlock Style="{StaticResource FieldHint}"
                                           Text="1行に1つ・正規表現（大文字小文字無視）。保存（:w）で即時反映。" />

                                <TextBlock Text="{Binding Settings.Status}" TextWrapping="Wrap" Margin="0,16,0,0"
                                           Foreground="{DynamicResource FgDim}" FontSize="11" />
                            </StackPanel>

                            <!-- ===== 外観（カラーテーマはアプリ全体・エディタ・ターミナル・プレビューをここに集約） ===== -->
                            <StackPanel Visibility="{Binding SettingsCategory, Converter={StaticResource EnumToVis}, ConverterParameter=Appearance}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="カラーテーマ（アプリ全体）" Margin="0,0,0,4" />
                                <ComboBox ItemsSource="{Binding Appearance.Themes}" SelectedItem="{Binding Appearance.SelectedTheme}"
                                          ItemTemplate="{StaticResource PresetItemTemplate}" />

                                <TextBlock Style="{StaticResource FieldLabel}" Text="アクセントカラー" Margin="0,10,0,4" />
                                <ComboBox ItemsSource="{Binding Appearance.Accents}" SelectedItem="{Binding Appearance.SelectedAccent}"
                                          ItemTemplate="{StaticResource AccentItemTemplate}" />
                                <TextBlock Style="{StaticResource FieldLabel}" Text="任意指定（#RRGGBB）" />
                                <TextBox Text="{Binding Appearance.AccentColor, UpdateSourceTrigger=LostFocus}"
                                         FontFamily="Cascadia Mono, Consolas" />

                                <Separator Margin="0,16,0,8" />
                                <TextBlock Style="{StaticResource FieldLabel}" Text="エディタ — テーマ" Margin="0,0,0,4" />
                                <ComboBox ItemsSource="{Binding Appearance.EditorThemes}" SelectedItem="{Binding Appearance.SelectedEditorTheme}"
                                          ItemTemplate="{StaticResource PresetItemTemplate}" />

                                <TextBlock Style="{StaticResource FieldLabel}" Text="ターミナル — テーマ" Margin="0,10,0,4" />
                                <ComboBox ItemsSource="{Binding Appearance.TerminalThemes}" SelectedItem="{Binding Appearance.SelectedTerminalTheme}"
                                          ItemTemplate="{StaticResource PresetItemTemplate}" />

                                <TextBlock Style="{StaticResource FieldLabel}" Text="Markdown プレビュー — テーマ" Margin="0,10,0,4" />
                                <ComboBox ItemsSource="{Binding Appearance.PreviewThemes}" SelectedItem="{Binding Appearance.SelectedPreviewTheme}"
                                          ItemTemplate="{StaticResource PresetItemTemplate}" />

                                <TextBlock Text="{Binding Appearance.Status}" Foreground="{DynamicResource FgDim}"
                                           Margin="0,14,0,0" TextWrapping="Wrap" FontSize="11" />
                            </StackPanel>

                            <!-- ===== エディタ（テーマは「外観」へ集約） ===== -->
                            <StackPanel Visibility="{Binding SettingsCategory, Converter={StaticResource EnumToVis}, ConverterParameter=Editor}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="フォント（空で既定）" Margin="0,0,0,3" />
                                <TextBox Text="{Binding Appearance.EditorFontFamily, UpdateSourceTrigger=LostFocus}"
                                         FontFamily="Cascadia Mono, Consolas" />
                                <TextBlock Style="{StaticResource FieldLabel}" Text="フォントサイズ（空で既定 / 4〜96）" />
                                <TextBox Text="{Binding Appearance.EditorFontSize, UpdateSourceTrigger=LostFocus}"
                                         FontFamily="Cascadia Mono, Consolas" />

                                <Separator Margin="0,16,0,10" />
                                <CheckBox IsChecked="{Binding Settings.VimEnabled}"
                                          ToolTip="有効/無効は開いているタブにも反映されます。">
                                    <TextBlock Text="Vim キーバインドを有効にする" TextWrapping="Wrap" />
                                </CheckBox>
                            </StackPanel>

                            <!-- ===== ターミナル（テーマは「外観」へ集約） ===== -->
                            <StackPanel Visibility="{Binding SettingsCategory, Converter={StaticResource EnumToVis}, ConverterParameter=Terminal}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="フォント（空で既定）" Margin="0,0,0,3" />
                                <TextBox Text="{Binding Appearance.TerminalFontFamily, UpdateSourceTrigger=LostFocus}"
                                         FontFamily="Cascadia Mono, Consolas" />
                                <TextBlock Style="{StaticResource FieldLabel}" Text="フォントサイズ（空で既定 / 4〜96）" />
                                <TextBox Text="{Binding Appearance.TerminalFontSize, UpdateSourceTrigger=LostFocus}"
                                         FontFamily="Cascadia Mono, Consolas" />

                                <TextBlock Text="{Binding Appearance.Status}" Foreground="{DynamicResource FgDim}"
                                           Margin="0,14,0,0" TextWrapping="Wrap" FontSize="11" />
                            </StackPanel>

                            <!-- ===== キーボード ===== -->
                            <StackPanel Visibility="{Binding SettingsCategory, Converter={StaticResource EnumToVis}, ConverterParameter=Keyboard}">
                                <TextBlock Style="{StaticResource SectionTitle}" Text="ショートカット" Margin="0,0,0,4" />
                                <TextBlock Style="{StaticResource FieldHint}"
                                           Text="行をクリックして新しいキーを押すと割り当てます。連鎖（例 Ctrl+W → H）は続けて 2 打。Esc で取消。" />

                                <ItemsControl ItemsSource="{Binding Keyboard.RowsView}" Margin="0,8,0,0">
                                    <ItemsControl.GroupStyle>
                                        <GroupStyle>
                                            <GroupStyle.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                               Margin="0,12,0,4"
                                                               Foreground="{DynamicResource FgDim}" />
                                                </DataTemplate>
                                            </GroupStyle.HeaderTemplate>
                                        </GroupStyle>
                                    </ItemsControl.GroupStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding Title}" Foreground="{DynamicResource Fg}" />
                                                    <TextBlock Text="{Binding ConflictText}" FontSize="11"
                                                               Foreground="#E0A030"
                                                               Visibility="{Binding HasConflict, Converter={StaticResource BoolToVis}}" />
                                                </StackPanel>
                                                <local:KeyCaptureBox Grid.Column="1" VerticalAlignment="Center" />
                                                <Button Grid.Column="2" Width="28" Margin="6,0,0,0"
                                                        Content="↺" ToolTip="既定に戻す"
                                                        Command="{Binding ResetCommand}"
                                                        Visibility="{Binding IsCustom, Converter={StaticResource BoolToVis}}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Button Style="{StaticResource WideSecondaryButton}" Margin="0,16,0,0"
                                        Content="すべて既定に戻す"
                                        Command="{Binding Keyboard.ResetAllCommand}" />
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
