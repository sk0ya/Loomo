<UserControl x:Class="sk0ya.Loomo.App.Views.SettingsOverlayView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:sk0ya.Loomo.App.Views"
    Focusable="True"
    PreviewKeyDown="OnPreviewKeyDown">

    <UserControl.Resources>
        <!-- 配色プリセットの行（色チップ＋ラベル）。AppearanceView から移設。 -->
        <DataTemplate x:Key="PresetItemTemplate">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="14" Height="14" CornerRadius="3" ClipToBounds="True"
                        Background="{Binding Bg}"
                        BorderBrush="{DynamicResource Border}" BorderThickness="1">
                    <Border Height="4" VerticalAlignment="Bottom" Background="{Binding Accent}" />
                </Border>
                <TextBlock Text="{Binding Name}" Margin="7,0,0,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource Fg}" />
            </StackPanel>
        </DataTemplate>

        <!-- アクセントの行（単色チップ／「既定」は下地が見える）。 -->
        <DataTemplate x:Key="AccentItemTemplate">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Grid Width="14" Height="14">
                    <Border CornerRadius="3" Background="{DynamicResource BgAlt}"
                            BorderBrush="{DynamicResource Border}" BorderThickness="1" />
                    <Border CornerRadius="3" Background="{Binding Hex}" />
                </Grid>
                <TextBlock Text="{Binding Name}" Margin="7,0,0,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource Fg}" />
            </StackPanel>
        </DataTemplate>

        <!-- 左ナビのカテゴリ項目（全幅・ホバー/選択でハイライト）。 -->
        <Style x:Key="CategoryNavItem" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="FontSize" Value="{DynamicResource Fs13}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="b" Background="Transparent" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource BgAlt}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Accent}" />
                                <Setter Property="Foreground" Value="{DynamicResource AccentFg}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- 薄暗がりの背景（クリックで閉じる） -->
        <Border Background="#59101010" MouseLeftButtonDown="OnBackdropMouseDown" />

        <!-- 中央パネル -->
        <Border Width="780" Height="560" HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Border}"
                BorderThickness="1" CornerRadius="8" MouseLeftButtonDown="OnPanelMouseDown">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" ShadowDepth="3" Opacity="0.4" />
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- 左ナビ -->
                <DockPanel Grid.Column="0" Background="{DynamicResource BgAlt}" Margin="0">
                    <Grid DockPanel.Dock="Top">
                        <TextBlock Text="設定" Margin="16,14,0,10"
                                   FontSize="{DynamicResource Fs15}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Fg}" />
                    </Grid>
                    <StackPanel Margin="8,4,8,8">
                        <RadioButton Style="{StaticResource CategoryNavItem}" Content="🎨  外観"
                                     IsChecked="{Binding SettingsCategory, Converter={StaticResource EnumToBool}, ConverterParameter=Appearance}" />
                        <RadioButton Style="{StaticResource CategoryNavItem}" Content="📝  エディタ"
                                     IsChecked="{Binding SettingsCategory, Converter={StaticResource EnumToBool}, ConverterParameter=Editor}" />
                        <RadioButton Style="{StaticResource CategoryNavItem}" Content="🖥  ターミナル"
                                     IsChecked="{Binding SettingsCategory, Converter={StaticResource EnumToBool}, ConverterParameter=Terminal}" />
                        <RadioButton Style="{StaticResource CategoryNavItem}" Content="🤖  AI"
                                     IsChecked="{Binding SettingsCategory, Converter={StaticResource EnumToBool}, ConverterParameter=Ai}" />
                        <RadioButton Style="{StaticResource CategoryNavItem}" Content="🧩  言語サーバー"
                                     IsChecked="{Binding SettingsCategory, Converter={StaticResource EnumToBool}, ConverterParameter=Lsp}" />
                        <RadioButton Style="{StaticResource CategoryNavItem}" Content="✨  整形"
                                     IsChecked="{Binding SettingsCategory, Converter={StaticResource EnumToBool}, ConverterParameter=Formatter}" />
                        <RadioButton Style="{StaticResource CategoryNavItem}" Content="⌨  キーボード"
                                     IsChecked="{Binding SettingsCategory, Converter={StaticResource EnumToBool}, ConverterParameter=Keyboard}" />
                    </StackPanel>
                </DockPanel>

                <!-- 右内容 -->
                <Grid Grid.Column="1">
                    <!-- 閉じるボタン（右上） -->
                    <Button HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0"
                            Width="30" Height="28" Style="{StaticResource CaptionButton}"
                            Panel.ZIndex="1" ToolTip="閉じる（Esc）"
                            Command="{Binding CloseSettingsOverlayCommand}">
                        <Path Stretch="None" StrokeThickness="1" SnapsToDevicePixels="True"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M0,0 L10,10 M0,10 L10,0" />
                    </Button>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="22,18,20,18">
                        <Grid>
                            <!-- ===== AI ===== -->
                            <StackPanel Visibility="{Binding SettingsCategory, Converter={StaticResource EnumToVis}, ConverterParameter=Ai}">
                                <TextBlock Style="{StaticResource SectionTitle}" Text="モデル" Margin="0,0,0,4" />
                                <!-- モデル選択：配置済み＋未取得の Hugging Face カタログ候補を1本の ComboBox にまとめる
                                     （未取得候補は先頭に ⬇ が付く）。右の「📂」は別の場所にあるモデルフォルダの手動追加用。 -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0" IsEditable="True" IsReadOnly="True"
                                              ItemsSource="{Binding Settings.ModelChoices}"
                                              DisplayMemberPath="Label"
                                              TextSearch.TextPath="Name"
                                              IsDropDownOpen="{Binding Settings.ModelDropDownOpen, Mode=TwoWay}"
                                              Text="{Binding Settings.Model, UpdateSourceTrigger=PropertyChanged}"
                                              ToolTip="ローカルに配置済み、または Hugging Face から取得できるモデルから選びます（⬇ は未取得）。" />
                                    <Button Grid.Column="1" Style="{StaticResource CaptionButton}"
                                            Width="30" Margin="6,0,0,0" Content="📂"
                                            ToolTip="任意の場所にある ONNX モデルフォルダ（genai_config.json を含む）を選んで追加します。"
                                            Command="{Binding Settings.BrowseModelCommand}" />
                                </Grid>

                                <!-- 選択中モデルが配置済み：フォルダパスを表示。 -->
                                <TextBlock Text="{Binding Settings.ModelPath, StringFormat='📁 {0}'}"
                                           Visibility="{Binding Settings.SelectedModelIsInstalled, Converter={StaticResource BoolToVis}}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Settings.ModelPath}"
                                           Foreground="{DynamicResource FgDim}" FontSize="{DynamicResource Fs11}"
                                           Margin="2,5,0,0" />

                                <!-- 選択中モデルが未取得：その場でダウンロードできる案内を表示。 -->
                                <StackPanel Visibility="{Binding Settings.SelectedModelIsInstalled, Converter={StaticResource InverseBoolToVis}}"
                                            Margin="0,6,0,0">
                                    <TextBlock Text="⬇ 未取得です。ダウンロードするとこのモデルに切り替わります。"
                                               Foreground="{DynamicResource FgDim}" FontSize="{DynamicResource Fs11}"
                                               TextWrapping="Wrap" Margin="2,0,0,6" />
                                    <Button Style="{StaticResource WideSecondaryButton}" Content="⬇  ダウンロード"
                                            ToolTip="選択したモデル（CPU int4）を Hugging Face からダウンロードして追加します。"
                                            Command="{Binding Settings.DownloadModelCommand}"
                                            IsEnabled="{Binding Settings.IsDownloading, Converter={StaticResource InverseBool}}" />
                                    <ProgressBar Height="6" Margin="0,8,0,0" Minimum="0" Maximum="100"
                                                 Value="{Binding Settings.DownloadProgress, Mode=OneWay}"
                                                 Visibility="{Binding Settings.IsDownloading, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>

                                <TextBlock Style="{StaticResource FieldLabel}" Text="最大出力トークン" />
                                <TextBox Text="{Binding Settings.MaxTokens, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Style="{StaticResource FieldHint}" Text="空・0 で既定（4096）。" />

                                <CheckBox IsChecked="{Binding Settings.WarmupEnabled}" Margin="0,12,0,0"
                                          ToolTip="起動時・ワークスペース確定時にモデルとシステムプロンプトを事前ロードし、初回ターンを速くします。実行中はAIへの指示を受け付けません。">
                                    <TextBlock Text="AIウォームアップを有効にする" TextWrapping="Wrap" />
                                </CheckBox>

                                <Separator Margin="0,16,0,10" />
                                <TextBlock Style="{StaticResource SectionTitle}" Text="安全設計" Margin="0,0,0,8" />
                                <CheckBox IsChecked="{Binding Settings.AutoApprove}"
                                          ToolTip="信頼ワークスペース向け。コマンド/編集の承認カードを省略します。">
                                    <TextBlock Text="自動承認モード" TextWrapping="Wrap" />
                                </CheckBox>
                                <CheckBox IsChecked="{Binding Settings.RestrictToWorkspaceRoot}" Margin="0,8,0,0"
                                          ToolTip="パストラバーサルを防止します。">
                                    <TextBlock Text="ファイルアクセスをワークスペース内に限定" TextWrapping="Wrap" />
                                </CheckBox>

                                <TextBlock Style="{StaticResource FieldLabel}" Text="ブロックする危険コマンド" />
                                <Button Style="{StaticResource WideSecondaryButton}" Content="エディタで編集"
                                        Command="{Binding Settings.EditBlockedCommandsCommand}" />
                                <Button Style="{StaticResource WideSecondaryButton}" Content="既定に戻す"
                                        Command="{Binding Settings.ResetBlockedCommandsCommand}" />
                                <TextBlock Style="{StaticResource FieldHint}"
                                           Text="1行に1つ・正規表現（大文字小文字無視）。保存（:w）で即時反映。" />

                                <TextBlock Text="{Binding Settings.Status}" TextWrapping="Wrap" Margin="0,16,0,0"
                                           Foreground="{DynamicResource FgDim}" FontSize="{DynamicResource Fs11}" />
                            </StackPanel>

                            <!-- ===== 言語サーバー (LSP) ===== -->
                            <StackPanel Visibility="{Binding SettingsCategory, Converter={StaticResource EnumToVis}, ConverterParameter=Lsp}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Style="{StaticResource SectionTitle}" Text="言語サーバー (LSP)" Margin="0,0,0,4" />
                                    <Button Grid.Column="1" Style="{StaticResource IconButton}" Width="28" Height="28"
                                            FontSize="{DynamicResource Fs14}" Content="↻" ToolTip="導入状況を更新"
                                            Command="{Binding Lsp.RefreshStatusCommand}" />
                                </Grid>
                                <TextBlock Style="{StaticResource FieldHint}"
                                           Text="言語サーバーは別途インストールが必要です。対象の言語サーバーを入れると、その拡張子で補完・診断・定義ジャンプ等が有効になります。" />

                                <ItemsControl ItemsSource="{Binding Lsp.Servers}" Margin="0,8,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource Border}" BorderThickness="1"
                                                    CornerRadius="6" Padding="10,8" Margin="0,0,0,6"
                                                    Background="{DynamicResource BgAlt}">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Extension}" FontFamily="Cascadia Mono, Consolas"
                                                                       FontWeight="SemiBold" Foreground="{DynamicResource Fg}" />
                                                            <TextBlock Text="{Binding DisplayName}" Margin="10,0,0,0"
                                                                       Foreground="{DynamicResource Fg}" />
                                                        </StackPanel>
                                                        <Border Grid.Column="1" CornerRadius="4" Padding="6,1"
                                                                Background="{DynamicResource Bg}">
                                                            <TextBlock Text="{Binding StatusBadge}" FontSize="{DynamicResource Fs11}"
                                                                       Foreground="{DynamicResource FgDim}" />
                                                        </Border>
                                                    </Grid>
                                                    <TextBlock Text="{Binding CommandText}" FontFamily="Cascadia Mono, Consolas"
                                                               FontSize="{DynamicResource Fs11}" Foreground="{DynamicResource FgDim}"
                                                               TextTrimming="CharacterEllipsis" Margin="0,3,0,0" />
                                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                        <Button Content="インストール" Style="{StaticResource FlatButton}"
                                                                FontSize="{DynamicResource Fs11}" Padding="8,2" Margin="0,0,6,0"
                                                                Command="{Binding InstallCommand}"
                                                                ToolTip="インストールコマンドを可視ターミナルで実行します。"
                                                                Visibility="{Binding CanInstall, Converter={StaticResource BoolToVis}}" />
                                                        <Button Content="手順" Style="{StaticResource SecondaryButton}"
                                                                FontSize="{DynamicResource Fs11}" Padding="8,2" Margin="0,0,6,0"
                                                                Command="{Binding OpenDocsCommand}"
                                                                ToolTip="導入手順のページをブラウザで開きます。"
                                                                Visibility="{Binding HasDocs, Converter={StaticResource BoolToVis}}" />
                                                        <Button Content="{Binding RemoveLabel}" Style="{StaticResource SecondaryButton}"
                                                                FontSize="{DynamicResource Fs11}" Padding="8,2" Margin="0,0,6,0"
                                                                Command="{Binding RemoveCommand}"
                                                                Visibility="{Binding CanRemove, Converter={StaticResource BoolToVis}}" />
                                                        <Button Content="{Binding ResetLabel}" Style="{StaticResource SecondaryButton}"
                                                                FontSize="{DynamicResource Fs11}" Padding="8,2"
                                                                Command="{Binding ResetCommand}"
                                                                Visibility="{Binding CanReset, Converter={StaticResource BoolToVis}}" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Separator Margin="0,10,0,8" />
                                <TextBlock Style="{StaticResource FieldLabel}" Text="サーバーを追加（拡張子・実行ファイル・引数）" Margin="0,0,0,4" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Margin="0,0,6,0" Text="{Binding Lsp.NewExtension, UpdateSourceTrigger=PropertyChanged}"
                                             FontFamily="Cascadia Mono, Consolas" ToolTip="拡張子（例 .zig）" />
                                    <TextBox Grid.Column="1" Margin="0,0,6,0" Text="{Binding Lsp.NewExecutable, UpdateSourceTrigger=PropertyChanged}"
                                             FontFamily="Cascadia Mono, Consolas" ToolTip="実行ファイル（例 zls）" />
                                    <TextBox Grid.Column="2" Margin="0,0,6,0" Text="{Binding Lsp.NewArgs, UpdateSourceTrigger=PropertyChanged}"
                                             FontFamily="Cascadia Mono, Consolas" ToolTip="引数（空白区切り・任意。例 --stdio）" />
                                    <Button Grid.Column="3" Content="追加" Style="{StaticResource FlatButton}"
                                            Padding="10,2" Command="{Binding Lsp.AddServerCommand}" />
                                </Grid>

                                <TextBlock Text="{Binding Lsp.Status}" TextWrapping="Wrap" Margin="0,12,0,0"
                                           Foreground="{DynamicResource FgDim}" FontSize="{DynamicResource Fs11}" />
                            </StackPanel>

                            <!-- ===== 整形 (Formatter) ===== -->
                            <StackPanel Visibility="{Binding SettingsCategory, Converter={StaticResource EnumToVis}, ConverterParameter=Formatter}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Style="{StaticResource SectionTitle}" Text="整形 (Formatter)" Margin="0,0,0,4" />
                                    <Button Grid.Column="1" Style="{StaticResource IconButton}" Width="28" Height="28"
                                            FontSize="{DynamicResource Fs14}" Content="↻" ToolTip="導入状況を更新"
                                            Command="{Binding Formatter.RefreshStatusCommand}" />
                                </Grid>
                                <TextBlock Style="{StaticResource FieldHint}"
                                           Text="エディタの :Format で使う整形ツール（CLI）です。インストールして「適用」すると、その拡張子の整形に使われます。" />

                                <ItemsControl ItemsSource="{Binding Formatter.Formatters}" Margin="0,8,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource Border}" BorderThickness="1"
                                                    CornerRadius="6" Padding="10,8" Margin="0,0,0,6"
                                                    Background="{DynamicResource BgAlt}">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource Fg}" />
                                                            <TextBlock Text="{Binding ExtensionsLabel}" Margin="10,0,0,0"
                                                                       FontFamily="Cascadia Mono, Consolas" FontSize="{DynamicResource Fs11}"
                                                                       Foreground="{DynamicResource FgDim}"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                        <Border Grid.Column="1" CornerRadius="4" Padding="6,1"
                                                                Background="{DynamicResource Bg}">
                                                            <TextBlock Text="{Binding StatusBadge}" FontSize="{DynamicResource Fs11}"
                                                                       Foreground="{DynamicResource FgDim}" />
                                                        </Border>
                                                    </Grid>
                                                    <TextBlock Text="{Binding CommandText}" FontFamily="Cascadia Mono, Consolas"
                                                               FontSize="{DynamicResource Fs11}" Foreground="{DynamicResource FgDim}"
                                                               TextTrimming="CharacterEllipsis" Margin="0,3,0,0" />
                                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                        <Button Content="インストール" Style="{StaticResource FlatButton}"
                                                                FontSize="{DynamicResource Fs11}" Padding="8,2" Margin="0,0,6,0"
                                                                Command="{Binding InstallCommand}"
                                                                ToolTip="インストールコマンドを可視ターミナルで実行します。"
                                                                Visibility="{Binding CanInstall, Converter={StaticResource BoolToVis}}" />
                                                        <Button Content="適用" Style="{StaticResource FlatButton}"
                                                                FontSize="{DynamicResource Fs11}" Padding="8,2" Margin="0,0,6,0"
                                                                Command="{Binding ApplyCommand}"
                                                                ToolTip="このフォーマッタを対象拡張子の :Format に割り当てます。"
                                                                Visibility="{Binding CanApply, Converter={StaticResource BoolToVis}}" />
                                                        <Button Content="手順" Style="{StaticResource SecondaryButton}"
                                                                FontSize="{DynamicResource Fs11}" Padding="8,2" Margin="0,0,6,0"
                                                                Command="{Binding OpenDocsCommand}"
                                                                ToolTip="導入手順のページをブラウザで開きます。"
                                                                Visibility="{Binding HasDocs, Converter={StaticResource BoolToVis}}" />
                                                        <Button Content="{Binding UnapplyLabel}" Style="{StaticResource SecondaryButton}"
                                                                FontSize="{DynamicResource Fs11}" Padding="8,2"
                                                                Command="{Binding UnapplyCommand}"
                                                                ToolTip="この割り当てを外します。"
                                                                Visibility="{Binding CanUnapply, Converter={StaticResource BoolToVis}}" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Separator Margin="0,10,0,8" />
                                <TextBlock Style="{StaticResource FieldLabel}" Text="フォーマッタを追加（拡張子・実行ファイル・引数）" Margin="0,0,0,4" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Margin="0,0,6,0" Text="{Binding Formatter.NewExtension, UpdateSourceTrigger=PropertyChanged}"
                                             FontFamily="Cascadia Mono, Consolas" ToolTip="拡張子（例 .cs）" />
                                    <TextBox Grid.Column="1" Margin="0,0,6,0" Text="{Binding Formatter.NewExecutable, UpdateSourceTrigger=PropertyChanged}"
                                             FontFamily="Cascadia Mono, Consolas" ToolTip="実行ファイル（例 csharpier）" />
                                    <TextBox Grid.Column="2" Margin="0,0,6,0" Text="{Binding Formatter.NewArgs, UpdateSourceTrigger=PropertyChanged}"
                                             FontFamily="Cascadia Mono, Consolas" ToolTip="引数（空白区切り・任意。{file} で対象パスに置換）" />
                                    <Button Grid.Column="3" Content="追加" Style="{StaticResource FlatButton}"
                                            Padding="10,2" Command="{Binding Formatter.AddFormatterCommand}" />
                                </Grid>

                                <TextBlock Text="{Binding Formatter.Status}" TextWrapping="Wrap" Margin="0,12,0,0"
                                           Foreground="{DynamicResource FgDim}" FontSize="{DynamicResource Fs11}" />
                            </StackPanel>

                            <!-- ===== 外観（カラーテーマはアプリ全体・エディタ・ターミナル・プレビューをここに集約） ===== -->
                            <StackPanel Visibility="{Binding SettingsCategory, Converter={StaticResource EnumToVis}, ConverterParameter=Appearance}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="文字サイズ（アプリ全体）" Margin="0,0,0,4" />
                                <ComboBox ItemsSource="{Binding Appearance.FontSizes}" SelectedItem="{Binding Appearance.SelectedFontSize}"
                                          DisplayMemberPath="Name"
                                          ToolTip="サイドバー・設定・ツリー・タブ・AIバーなどアプリUIの文字サイズをまとめて指定します。見出しや補足の大小関係は比率を保ちます。エディタ／ターミナルの文字サイズは各項目で別に設定します。" />

                                <Separator Margin="0,16,0,8" />
                                <TextBlock Style="{StaticResource FieldLabel}" Text="カラーテーマ（アプリ全体）" Margin="0,0,0,4" />
                                <ComboBox ItemsSource="{Binding Appearance.Themes}" SelectedItem="{Binding Appearance.SelectedTheme}"
                                          ItemTemplate="{StaticResource PresetItemTemplate}" />

                                <TextBlock Style="{StaticResource FieldLabel}" Text="アクセントカラー" Margin="0,10,0,4" />
                                <ComboBox ItemsSource="{Binding Appearance.Accents}" SelectedItem="{Binding Appearance.SelectedAccent}"
                                          ItemTemplate="{StaticResource AccentItemTemplate}" />
                                <TextBlock Style="{StaticResource FieldLabel}" Text="任意指定（#RRGGBB）" />
                                <TextBox Text="{Binding Appearance.AccentColor, UpdateSourceTrigger=LostFocus}"
                                         FontFamily="Cascadia Mono, Consolas" />

                                <Separator Margin="0,16,0,8" />
                                <TextBlock Style="{StaticResource FieldLabel}" Text="エディタ — テーマ" Margin="0,0,0,4" />
                                <ComboBox ItemsSource="{Binding Appearance.EditorThemes}" SelectedItem="{Binding Appearance.SelectedEditorTheme}"
                                          ItemTemplate="{StaticResource PresetItemTemplate}" />

                                <TextBlock Style="{StaticResource FieldLabel}" Text="ターミナル — テーマ" Margin="0,10,0,4" />
                                <ComboBox ItemsSource="{Binding Appearance.TerminalThemes}" SelectedItem="{Binding Appearance.SelectedTerminalTheme}"
                                          ItemTemplate="{StaticResource PresetItemTemplate}" />

                                <TextBlock Style="{StaticResource FieldLabel}" Text="Markdown プレビュー — テーマ" Margin="0,10,0,4" />
                                <ComboBox ItemsSource="{Binding Appearance.PreviewThemes}" SelectedItem="{Binding Appearance.SelectedPreviewTheme}"
                                          ItemTemplate="{StaticResource PresetItemTemplate}" />

                                <Separator Margin="0,16,0,8" />
                                <TextBlock Style="{StaticResource FieldLabel}" Text="ペインの表示方法（AIの結果・ブラウザ・差分などを出す位置）" Margin="0,0,0,4" />
                                <ComboBox ItemsSource="{Binding Appearance.PaneOpenBehaviors}" SelectedItem="{Binding Appearance.SelectedPaneOpenBehavior}"
                                          DisplayMemberPath="Name"
                                          ToolTip="「AIに聞く」「ブラウザで調べる」「差分を開く」などで、結果を表示するペインを出す位置を選びます。メイン=左上と入れ替え（従来）／サブ=右上と入れ替え／ループ=サブに表示し、サブから操作したときはサブをメインへ繰り上げます。" />

                                <Separator Margin="0,16,0,8" />
                                <CheckBox IsChecked="{Binding Trail.Visible}"
                                          ToolTip="ウィンドウ下部の軌跡（操作ログ）バーの表示/非表示を切り替えます。バーを右クリックしても非表示にできます。">
                                    <TextBlock Text="軌跡バーを表示する" TextWrapping="Wrap" />
                                </CheckBox>

                                <TextBlock Text="{Binding Appearance.Status}" Foreground="{DynamicResource FgDim}"
                                           Margin="0,14,0,0" TextWrapping="Wrap" FontSize="{DynamicResource Fs11}" />
                            </StackPanel>

                            <!-- ===== エディタ（テーマは「外観」へ集約） ===== -->
                            <StackPanel Visibility="{Binding SettingsCategory, Converter={StaticResource EnumToVis}, ConverterParameter=Editor}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="フォント（空で既定）" Margin="0,0,0,3" />
                                <TextBox Text="{Binding Appearance.EditorFontFamily, UpdateSourceTrigger=LostFocus}"
                                         FontFamily="Cascadia Mono, Consolas" />
                                <TextBlock Style="{StaticResource FieldLabel}" Text="フォントサイズ（空で既定 / 4〜96）" />
                                <TextBox Text="{Binding Appearance.EditorFontSize, UpdateSourceTrigger=LostFocus}"
                                         FontFamily="Cascadia Mono, Consolas" />

                                <Separator Margin="0,16,0,10" />
                                <CheckBox IsChecked="{Binding Settings.VimEnabled}"
                                          ToolTip="有効/無効は開いているタブにも反映されます。">
                                    <TextBlock Text="Vim キーバインドを有効にする" TextWrapping="Wrap" />
                                </CheckBox>

                                <CheckBox Margin="0,8,0,0"
                                          IsChecked="{Binding Settings.HighlightWhitespace}"
                                          ToolTip="全角スペースと行末の余分な空白を背景色でハイライト表示します。開いているタブにも即時反映されます。">
                                    <TextBlock Text="全角スペース・行末スペースをハイライトする" TextWrapping="Wrap" />
                                </CheckBox>

                                <Separator Margin="0,16,0,10" />
                                <CheckBox IsChecked="{Binding Settings.ShowLineNumbers}">
                                    <TextBlock Text="行番号を表示する" TextWrapping="Wrap" />
                                </CheckBox>
                                <CheckBox Margin="0,8,0,0"
                                          IsChecked="{Binding Settings.RelativeLineNumbers}"
                                          ToolTip="カーソル行からの相対行数で表示します（Vimキーバインド利用時のジャンプ数の目安に便利です）。">
                                    <TextBlock Text="相対行番号を使う" TextWrapping="Wrap" />
                                </CheckBox>
                                <CheckBox Margin="0,8,0,0" IsChecked="{Binding Settings.HighlightCurrentLine}">
                                    <TextBlock Text="カーソル行をハイライトする" TextWrapping="Wrap" />
                                </CheckBox>
                                <CheckBox Margin="0,8,0,0"
                                          IsChecked="{Binding Settings.WordWrap}"
                                          ToolTip="OFF（既定）では長い行を折り返さず横スクロールで表示します。">
                                    <TextBlock Text="長い行を折り返して表示する" TextWrapping="Wrap" />
                                </CheckBox>
                                <CheckBox Margin="0,8,0,0" IsChecked="{Binding Settings.ShowMinimap}">
                                    <TextBlock Text="ミニマップを表示する" TextWrapping="Wrap" />
                                </CheckBox>
                                <CheckBox Margin="0,8,0,0" IsChecked="{Binding Settings.ShowIndentGuides}">
                                    <TextBlock Text="インデントガイドを表示する" TextWrapping="Wrap" />
                                </CheckBox>

                                <Separator Margin="0,16,0,10" />
                                <TextBlock Style="{StaticResource FieldLabel}" Text="タブ幅（インデント幅）" Margin="0,0,0,3" />
                                <TextBox Text="{Binding Settings.TabWidth, UpdateSourceTrigger=LostFocus}"
                                         FontFamily="Cascadia Mono, Consolas" />
                                <CheckBox Margin="0,8,0,0" IsChecked="{Binding Settings.UseSpacesForTab}">
                                    <TextBlock Text="Tabキーでスペースを挿入する（OFFでタブ文字を挿入）" TextWrapping="Wrap" />
                                </CheckBox>
                                <CheckBox Margin="0,8,0,0"
                                          IsChecked="{Binding Settings.AutoClosePairs}"
                                          ToolTip="( [ { や &quot; ' を入力すると対応する閉じ記号を自動挿入します。">
                                    <TextBlock Text="括弧・引用符を自動で閉じる" TextWrapping="Wrap" />
                                </CheckBox>
                            </StackPanel>

                            <!-- ===== ターミナル（テーマは「外観」へ集約） ===== -->
                            <StackPanel Visibility="{Binding SettingsCategory, Converter={StaticResource EnumToVis}, ConverterParameter=Terminal}">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="フォント（空で既定）" Margin="0,0,0,3" />
                                <TextBox Text="{Binding Appearance.TerminalFontFamily, UpdateSourceTrigger=LostFocus}"
                                         FontFamily="Cascadia Mono, Consolas" />
                                <TextBlock Style="{StaticResource FieldLabel}" Text="フォントサイズ（空で既定 / 4〜96）" />
                                <TextBox Text="{Binding Appearance.TerminalFontSize, UpdateSourceTrigger=LostFocus}"
                                         FontFamily="Cascadia Mono, Consolas" />

                                <CheckBox Margin="0,12,0,0"
                                          IsChecked="{Binding Appearance.TerminalFontLigatures}"
                                          ToolTip="フォントが合字を持つ場合のみ反映されます（例: Cascadia Code, Fira Code, JetBrains Mono）。">
                                    <TextBlock Text="プログラミング合字を有効にする（=&gt; != -&gt; 等）" TextWrapping="Wrap" />
                                </CheckBox>

                                <TextBlock Text="{Binding Appearance.Status}" Foreground="{DynamicResource FgDim}"
                                           Margin="0,14,0,0" TextWrapping="Wrap" FontSize="{DynamicResource Fs11}" />
                            </StackPanel>

                            <!-- ===== キーボード ===== -->
                            <StackPanel Visibility="{Binding SettingsCategory, Converter={StaticResource EnumToVis}, ConverterParameter=Keyboard}">
                                <TextBlock Style="{StaticResource SectionTitle}" Text="ショートカット" Margin="0,0,0,4" />
                                <TextBlock Style="{StaticResource FieldHint}"
                                           Text="行をクリックして新しいキーを押すと割り当てます。連鎖（例 Ctrl+W → H）は続けて 2 打。Esc で取消。" />

                                <ItemsControl ItemsSource="{Binding Keyboard.RowsView}" Margin="0,8,0,0">
                                    <ItemsControl.GroupStyle>
                                        <GroupStyle>
                                            <GroupStyle.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                               Margin="0,12,0,4"
                                                               Foreground="{DynamicResource FgDim}" />
                                                </DataTemplate>
                                            </GroupStyle.HeaderTemplate>
                                        </GroupStyle>
                                    </ItemsControl.GroupStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding Title}" Foreground="{DynamicResource Fg}" />
                                                    <TextBlock Text="{Binding ConflictText}" FontSize="{DynamicResource Fs11}"
                                                               Foreground="#E0A030"
                                                               Visibility="{Binding HasConflict, Converter={StaticResource BoolToVis}}" />
                                                </StackPanel>
                                                <local:KeyCaptureBox Grid.Column="1" VerticalAlignment="Center" />
                                                <Button Grid.Column="2" Style="{StaticResource IconButton}"
                                                        Width="28" Height="28" FontSize="{DynamicResource Fs14}" Margin="6,0,0,0"
                                                        Content="↺" ToolTip="既定に戻す"
                                                        Command="{Binding ResetCommand}"
                                                        Visibility="{Binding IsCustom, Converter={StaticResource BoolToVis}}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Button Style="{StaticResource WideSecondaryButton}" Margin="0,16,0,0"
                                        Content="すべて既定に戻す"
                                        Command="{Binding Keyboard.ResetAllCommand}" />
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
