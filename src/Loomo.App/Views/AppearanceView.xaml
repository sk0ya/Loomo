<UserControl x:Class="sk0ya.Loomo.App.Views.AppearanceView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{DynamicResource BgAlt}">

    <UserControl.Resources>
        <!-- テーマのスウォッチ（配色プレビュー＋ラベル）。クリックで適用、選択中はアクセント枠 -->
        <DataTemplate x:Key="ThemeSwatchTemplate">
            <Button Cursor="Hand" ToolTip="{Binding Name}"
                    Command="{Binding DataContext.SelectThemeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                    CommandParameter="{Binding Theme}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ring" CornerRadius="6" BorderThickness="2" BorderBrush="Transparent"
                                Padding="2" Margin="0,0,8,8">
                            <StackPanel Width="66">
                                <Border Height="42" CornerRadius="4" ClipToBounds="True"
                                        Background="{Binding Bg}"
                                        BorderBrush="{DynamicResource Border}" BorderThickness="1">
                                    <Grid>
                                        <TextBlock Text="Aa" FontSize="16" FontWeight="SemiBold"
                                                   Foreground="{Binding Fg}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        <Border Height="7" VerticalAlignment="Bottom" Background="{Binding Accent}" />
                                    </Grid>
                                </Border>
                                <TextBlock Text="{Binding Name}" FontSize="11" TextAlignment="Center"
                                           TextTrimming="CharacterEllipsis" Margin="0,3,0,0"
                                           Foreground="{DynamicResource Fg}" />
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="ring" Property="BorderBrush" Value="{DynamicResource Accent}" />
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ring" Property="BorderBrush" Value="{DynamicResource AccentHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </DataTemplate>

        <!-- アクセントのスウォッチ（単色／「既定」）。クリックで適用、選択中はアクセント枠 -->
        <DataTemplate x:Key="AccentSwatchTemplate">
            <Button Cursor="Hand" ToolTip="{Binding Name}"
                    Command="{Binding DataContext.SelectAccentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                    CommandParameter="{Binding Hex}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ring" CornerRadius="6" BorderThickness="2" BorderBrush="Transparent"
                                Padding="2" Margin="0,0,8,8">
                            <Grid Width="30" Height="30">
                                <!-- 下地（既定スウォッチや空色のとき見える） -->
                                <Border CornerRadius="4" Background="{DynamicResource BgAlt}"
                                        BorderBrush="{DynamicResource Border}" BorderThickness="1" />
                                <!-- 色（Hex 空なら透明で下地が見える） -->
                                <Border CornerRadius="4" Background="{Binding Hex}" />
                                <TextBlock Text="既定" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{DynamicResource Fg}"
                                           Visibility="{Binding Hex, Converter={StaticResource EmptyToVis}}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="ring" Property="BorderBrush" Value="{DynamicResource Accent}" />
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ring" Property="BorderBrush" Value="{DynamicResource AccentHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </DataTemplate>
    </UserControl.Resources>

    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Style="{StaticResource PanelHeader}" Text="外観 — テーマ / アクセント" />

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,4,12,12">
            <StackPanel>

                <!-- カラーテーマ -->
                <TextBlock Style="{StaticResource FieldLabel}" Text="カラーテーマ" Margin="0,0,0,6" />
                <ItemsControl ItemsSource="{Binding Themes}" ItemTemplate="{StaticResource ThemeSwatchTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <!-- アクセントカラー -->
                <Separator Margin="0,12,0,8" />
                <TextBlock Style="{StaticResource FieldLabel}" Text="アクセントカラー" Margin="0,0,0,6" />
                <ItemsControl ItemsSource="{Binding Accents}" ItemTemplate="{StaticResource AccentSwatchTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <!-- 任意指定（16進） -->
                <TextBlock Style="{StaticResource FieldLabel}" Text="任意指定（#RRGGBB）" />
                <TextBox Text="{Binding AccentColor, UpdateSourceTrigger=LostFocus}"
                         FontFamily="Cascadia Mono, Consolas" />

                <!-- エディタ -->
                <Separator Margin="0,16,0,8" />
                <TextBlock Style="{StaticResource FieldLabel}" Text="エディタ — テーマ" Margin="0,0,0,4" />
                <ComboBox ItemsSource="{Binding EditorThemes}"
                          SelectedItem="{Binding SelectedEditorTheme}" />
                <TextBlock Style="{StaticResource FieldLabel}" Text="フォント（空で既定）" />
                <TextBox Text="{Binding EditorFontFamily, UpdateSourceTrigger=LostFocus}"
                         FontFamily="Cascadia Mono, Consolas" />
                <TextBlock Style="{StaticResource FieldLabel}" Text="フォントサイズ（空で既定 / 4〜96）" />
                <TextBox Text="{Binding EditorFontSize, UpdateSourceTrigger=LostFocus}"
                         FontFamily="Cascadia Mono, Consolas" />

                <!-- Markdown プレビュー -->
                <Separator Margin="0,16,0,8" />
                <TextBlock Style="{StaticResource FieldLabel}" Text="Markdown プレビュー — テーマ" Margin="0,0,0,4" />
                <ComboBox ItemsSource="{Binding PreviewThemes}"
                          SelectedItem="{Binding SelectedPreviewTheme}" />

                <!-- ターミナル -->
                <Separator Margin="0,16,0,8" />
                <TextBlock Style="{StaticResource FieldLabel}" Text="ターミナル — テーマ（背景 / 文字色）" Margin="0,0,0,4" />
                <ComboBox ItemsSource="{Binding TerminalThemes}"
                          SelectedItem="{Binding SelectedTerminalTheme}" />
                <TextBlock Style="{StaticResource FieldLabel}" Text="フォント（空で既定）" />
                <TextBox Text="{Binding TerminalFontFamily, UpdateSourceTrigger=LostFocus}"
                         FontFamily="Cascadia Mono, Consolas" />
                <TextBlock Style="{StaticResource FieldLabel}" Text="フォントサイズ（空で既定 / 4〜96）" />
                <TextBox Text="{Binding TerminalFontSize, UpdateSourceTrigger=LostFocus}"
                         FontFamily="Cascadia Mono, Consolas" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
