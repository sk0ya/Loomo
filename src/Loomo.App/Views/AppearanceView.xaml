<UserControl x:Class="sk0ya.Loomo.App.Views.AppearanceView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{DynamicResource BgAlt}">

    <UserControl.Resources>
        <!-- 配色プリセットの行（色チップ＋ラベル）。コンボボックスのドロップダウンと選択ボックスの両方で使う。
             アプリ全体テーマ／エディタ／ターミナル／プレビューで共通。 -->
        <DataTemplate x:Key="PresetItemTemplate">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- 背景色チップ＋下端にアクセント帯（縮小版プレビュー） -->
                <Border Width="14" Height="14" CornerRadius="3" ClipToBounds="True"
                        Background="{Binding Bg}"
                        BorderBrush="{DynamicResource Border}" BorderThickness="1">
                    <Border Height="4" VerticalAlignment="Bottom" Background="{Binding Accent}" />
                </Border>
                <TextBlock Text="{Binding Name}" Margin="7,0,0,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource Fg}" />
            </StackPanel>
        </DataTemplate>

        <!-- アクセントの行（単色チップ／「既定」は下地が見える）。 -->
        <DataTemplate x:Key="AccentItemTemplate">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Grid Width="14" Height="14">
                    <Border CornerRadius="3" Background="{DynamicResource BgAlt}"
                            BorderBrush="{DynamicResource Border}" BorderThickness="1" />
                    <Border CornerRadius="3" Background="{Binding Hex}" />
                </Grid>
                <TextBlock Text="{Binding Name}" Margin="7,0,0,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource Fg}" />
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Style="{StaticResource PanelHeader}" Text="外観" />

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,4,12,12">
            <StackPanel>

                <!-- アプリ全体のカラーテーマ -->
                <TextBlock Style="{StaticResource FieldLabel}" Text="カラーテーマ（アプリ全体）" Margin="0,0,0,4" />
                <ComboBox ItemsSource="{Binding Themes}" SelectedItem="{Binding SelectedTheme}"
                          ItemTemplate="{StaticResource PresetItemTemplate}" />

                <!-- アクセントカラー -->
                <TextBlock Style="{StaticResource FieldLabel}" Text="アクセントカラー" Margin="0,10,0,4" />
                <ComboBox ItemsSource="{Binding Accents}" SelectedItem="{Binding SelectedAccent}"
                          ItemTemplate="{StaticResource AccentItemTemplate}" />
                <TextBlock Style="{StaticResource FieldLabel}" Text="任意指定（#RRGGBB）" />
                <TextBox Text="{Binding AccentColor, UpdateSourceTrigger=LostFocus}"
                         FontFamily="Cascadia Mono, Consolas" />

                <!-- エディタ -->
                <Separator Margin="0,16,0,8" />
                <TextBlock Style="{StaticResource FieldLabel}" Text="エディタ — テーマ" Margin="0,0,0,4" />
                <ComboBox ItemsSource="{Binding EditorThemes}" SelectedItem="{Binding SelectedEditorTheme}"
                          ItemTemplate="{StaticResource PresetItemTemplate}" />
                <TextBlock Style="{StaticResource FieldLabel}" Text="フォント（空で既定）" />
                <TextBox Text="{Binding EditorFontFamily, UpdateSourceTrigger=LostFocus}"
                         FontFamily="Cascadia Mono, Consolas" />
                <TextBlock Style="{StaticResource FieldLabel}" Text="フォントサイズ（空で既定 / 4〜96）" />
                <TextBox Text="{Binding EditorFontSize, UpdateSourceTrigger=LostFocus}"
                         FontFamily="Cascadia Mono, Consolas" />

                <!-- ターミナル -->
                <Separator Margin="0,16,0,8" />
                <TextBlock Style="{StaticResource FieldLabel}" Text="ターミナル — テーマ" Margin="0,0,0,4" />
                <ComboBox ItemsSource="{Binding TerminalThemes}" SelectedItem="{Binding SelectedTerminalTheme}"
                          ItemTemplate="{StaticResource PresetItemTemplate}" />
                <TextBlock Style="{StaticResource FieldLabel}" Text="フォント（空で既定）" />
                <TextBox Text="{Binding TerminalFontFamily, UpdateSourceTrigger=LostFocus}"
                         FontFamily="Cascadia Mono, Consolas" />
                <TextBlock Style="{StaticResource FieldLabel}" Text="フォントサイズ（空で既定 / 4〜96）" />
                <TextBox Text="{Binding TerminalFontSize, UpdateSourceTrigger=LostFocus}"
                         FontFamily="Cascadia Mono, Consolas" />

                <!-- Markdown プレビュー -->
                <Separator Margin="0,16,0,8" />
                <TextBlock Style="{StaticResource FieldLabel}" Text="Markdown プレビュー — テーマ" Margin="0,0,0,4" />
                <ComboBox ItemsSource="{Binding PreviewThemes}" SelectedItem="{Binding SelectedPreviewTheme}"
                          ItemTemplate="{StaticResource PresetItemTemplate}" />

                <!-- ステータス -->
                <TextBlock Text="{Binding Status}" Foreground="{DynamicResource FgDim}"
                           Margin="0,14,0,0" TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
