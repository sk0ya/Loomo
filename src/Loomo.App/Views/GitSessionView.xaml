<UserControl x:Class="sk0ya.Loomo.App.Views.GitSessionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{DynamicResource Panel}" Focusable="True">

    <UserControl.Resources>
        <Style x:Key="ToolbarButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
        </Style>

        <!-- 一覧アイテム共通：行全体ハイライト・選択はアクセント -->
        <Style x:Key="GitListItem" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="6,1" />
            <Setter Property="Foreground" Value="{DynamicResource Fg}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="b" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource BgAlt}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Border}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GitList" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource Fg}" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource GitListItem}" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        </Style>

        <!-- LogList（ListView+GridView）専用の行コンテナ。GitListItem（ListBoxItem 用）を GridView 付き
             ListView にそのまま使うと、ControlTemplate の ContentPresenter が GridViewRowPresenter を
             持たないため列が描画されず「オブジェクトの ToString()」表示に落ちる（要 GridViewRowPresenter）。 -->
        <Style x:Key="GitLogListItem" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="6,1" />
            <Setter Property="Foreground" Value="{DynamicResource Fg}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="b" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <GridViewRowPresenter Content="{TemplateBinding Content}"
                                                  Columns="{TemplateBinding GridView.ColumnCollection}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource BgAlt}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Border}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- コミット一覧の列境界のつまみに共通のスタイル（ヘッダー行の PART_HeaderGripper と、行本体
             オーバーレイ側のつまみの両方から参照する。定義順の都合でヘッダースタイルより前に置く）。
             既定の Thumb 外観（テーマ非依存の立体調グレー帯。Background だけでは消せず、これが
             「見出しの区切り線がカラーテーマに追従しない」原因だった）を消し、ホバー中だけ
             アクセント色の細い線を見せる。 -->
        <Style x:Key="LogColumnResizeThumb" TargetType="Thumb">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="SizeWE" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="b" Background="Transparent" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Accent}" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- コミット一覧（LogList）の列見出し。既定の GridViewColumnHeader は OS 標準のボタン風装飾で
             ダークテーマに馴染まないため平板化するが、列幅ドラッグ自体は既定テンプレートが
             "PART_HeaderGripper" という名前の Thumb を探して配線するので、そのThumbだけは残す
             （ただし既定の Thumb 外観のままだと Background 指定だけでは灰色の区切り線が残ってしまう
             ため、LogColumnResizeThumb と同じテンプレートを与えて完全に平板化する）。
             GridView の末尾に自動生成される空の「埋め草」ヘッダー（Role=Padding）は
             GridView.ColumnHeaderContainerStyle を経由せず既定スタイルのまま残る（White地のまま浮く）ため、
             x:Key を付けず TargetType 一致の暗黙スタイルにして埋め草にも確実に適用する。 -->
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="{DynamicResource BgAlt}" />
            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
            <Setter Property="FontSize" Value="{DynamicResource Fs11}" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center" />
                            </Border>
                            <Thumb x:Name="PART_HeaderGripper" HorizontalAlignment="Right" Width="6"
                                   Style="{StaticResource LogColumnResizeThumb}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <DockPanel>
        <!-- リポジトリでないとき -->
        <TextBlock DockPanel.Dock="Top" Margin="12,8"
                   Text="このワークスペースは git リポジトリではありません。サイドバーの Git パネルから初期化できます。"
                   TextWrapping="Wrap" Foreground="{DynamicResource FgDim}"
                   Visibility="{Binding IsRepository, Converter={StaticResource InverseBoolToVis}}" />

        <DockPanel Visibility="{Binding IsRepository, Converter={StaticResource BoolToVis}}">

            <!-- ツールバー（更新・プル等）はペインヘッダー側（ShellWindow）へ集約 -->

            <!-- 進行中操作（rebase / merge / cherry-pick）のバナー -->
            <Border DockPanel.Dock="Top" Margin="8,4,8,4" Padding="8,6" CornerRadius="4"
                    Background="#33E5A23B" BorderBrush="#FFE5A23B" BorderThickness="1"
                    Visibility="{Binding OperationInProgress, Converter={StaticResource BoolToVis}}">
                <DockPanel LastChildFill="True">
                    <Button DockPanel.Dock="Right" Style="{StaticResource ToolbarButton}" Margin="6,0,0,0"
                            Content="中止" Command="{Binding AbortOperationCommand}" />
                    <Button DockPanel.Dock="Right" Style="{StaticResource ToolbarButton}" Margin="6,0,0,0"
                            Content="スキップ" Command="{Binding SkipOperationCommand}"
                            Visibility="{Binding OperationCanSkip, Converter={StaticResource BoolToVis}}" />
                    <Button DockPanel.Dock="Right" Style="{StaticResource ToolbarButton}" Margin="6,0,0,0"
                            Content="続行" Command="{Binding ContinueOperationCommand}" />
                    <TextBlock Text="{Binding OperationLabel}" VerticalAlignment="Center" TextWrapping="Wrap" />
                </DockPanel>
            </Border>

            <!-- 実行結果メッセージ -->
            <TextBlock DockPanel.Dock="Bottom" Margin="10,2,10,6" FontSize="{DynamicResource Fs11}"
                       Text="{Binding StatusMessage}" TextWrapping="Wrap" MaxHeight="60">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding StatusIsError}" Value="True">
                                <Setter Property="Foreground" Value="#FFE57373" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding StatusMessage}" Value="">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190" MinWidth="120" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="*" MinWidth="200" />
                </Grid.ColumnDefinitions>

                <!-- ブランチ一覧＋タグ一覧 -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*" MinHeight="80" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="1*" MinHeight="60" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0">
                        <!-- 特定ブランチに絞っている間だけ「すべてのブランチ」へ戻すリンクを出す -->
                        <Button DockPanel.Dock="Top" Margin="8,0,8,2" HorizontalAlignment="Left"
                                Style="{StaticResource ToolbarButton}" Content="↺ すべてのブランチを表示"
                                Click="OnShowAllBranchesLog"
                                Visibility="{Binding IsLogScoped, Converter={StaticResource BoolToVis}}" />
                        <TreeView x:Name="BranchList" Background="Transparent" BorderThickness="0"
                                  Foreground="{DynamicResource Fg}"
                                  ItemsSource="{Binding BranchTree}"
                                  ItemContainerStyle="{StaticResource BranchTreeItem}"
                                  ItemTemplate="{StaticResource BranchNodeTemplate}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  MouseDoubleClick="OnBranchDoubleClick"
                                  PreviewMouseLeftButtonUp="OnBranchTreeClick"
                                  PreviewMouseRightButtonDown="OnListRightClickSelect">
                            <TreeView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="チェックアウト" Click="OnBranchCheckout" />
                                    <MenuItem Header="現在のブランチへマージ" Click="OnBranchMerge" />
                                    <MenuItem Header="現在のブランチへマージ（戦略を選択）">
                                        <MenuItem Header="Fast-forwardのみでマージ" Click="OnBranchMergeFastForwardOnly" />
                                        <MenuItem Header="マージコミットを作成してマージ" Click="OnBranchMergeNoFastForward" />
                                        <MenuItem Header="スカッシュマージ（コミットは別途実行）" Click="OnBranchMergeSquash" />
                                    </MenuItem>
                                    <MenuItem Header="このブランチへリベース（現在のブランチを載せ替え）" Click="OnBranchRebase" />
                                    <Separator />
                                    <MenuItem Header="ここから新しいブランチを作成…" Click="OnBranchCreateFrom" />
                                    <MenuItem Header="ブランチ名をコピー" Click="OnBranchCopyName" />
                                    <Separator />
                                    <MenuItem Header="削除" Click="OnBranchDelete" />
                                    <Separator />
                                    <MenuItem Header="⭮ フェッチ"
                                              Command="{Binding PlacementTarget.DataContext.FetchCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <MenuItem Header="⇣ プル"
                                              Command="{Binding PlacementTarget.DataContext.PullCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <MenuItem Header="⇡ プッシュ"
                                              Command="{Binding PlacementTarget.DataContext.PushCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                </ContextMenu>
                            </TreeView.ContextMenu>
                        </TreeView>
                    </DockPanel>

                    <GridSplitter Grid.Row="1" Height="6" HorizontalAlignment="Stretch"
                                  Background="{DynamicResource Border}" />

                    <!-- タグ一覧＋サブモジュール一覧 -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" MinHeight="40" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0">
                            <DockPanel DockPanel.Dock="Top" Margin="8,2,8,2" LastChildFill="False">
                                <Button DockPanel.Dock="Left" Style="{StaticResource ToolbarButton}"
                                        Content="＋ タグ" ToolTip="タグを作成…" Click="OnTagCreate" />
                                <Button DockPanel.Dock="Right" Style="{StaticResource ToolbarButton}" Margin="0"
                                        Content="⇡ 全て" ToolTip="すべてのタグをプッシュ" Click="OnTagsPushAll" />
                            </DockPanel>
                            <ListBox x:Name="TagList" Style="{StaticResource GitList}"
                                     ItemsSource="{Binding Tags}"
                                     MouseDoubleClick="OnTagDoubleClick"
                                     PreviewMouseRightButtonDown="OnListRightClickSelect">
                                <ListBox.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="チェックアウト（detached）" Click="OnTagCheckout" />
                                        <MenuItem Header="プッシュ" Click="OnTagPush" />
                                        <MenuItem Header="タグ名をコピー" Click="OnTagCopyName" />
                                        <Separator />
                                        <MenuItem Header="削除" Click="OnTagDelete" />
                                    </ContextMenu>
                                </ListBox.ContextMenu>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel LastChildFill="True" ToolTip="{Binding Subject}">
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding TargetShortHash}" FontSize="{DynamicResource Fs11}"
                                                       Foreground="{DynamicResource FgDim}" Margin="8,0,0,0"
                                                       FontFamily="Cascadia Mono, Consolas" />
                                            <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>

                        <!-- サブモジュール一覧（サブモジュールが無いワークスペースではセクションごと隠す） -->
                        <DockPanel Grid.Row="1" Margin="0,6,0,0"
                                   Visibility="{Binding Submodules.Count, Converter={StaticResource CountToVis}}">
                            <DockPanel DockPanel.Dock="Top" Margin="8,2,8,2" LastChildFill="False">
                                <TextBlock DockPanel.Dock="Left" Text="サブモジュール" VerticalAlignment="Center"
                                           FontSize="{DynamicResource Fs11}" Foreground="{DynamicResource FgDim}" />
                                <Button DockPanel.Dock="Right" Style="{StaticResource ToolbarButton}" Margin="0"
                                        Content="同期" Click="OnSubmodulesSync" />
                            </DockPanel>
                            <ListBox x:Name="SubmoduleList" Style="{StaticResource GitList}"
                                     ItemsSource="{Binding Submodules}" MaxHeight="160"
                                     PreviewMouseRightButtonDown="OnListRightClickSelect">
                                <ListBox.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="初期化" Click="OnSubmoduleInit" />
                                        <MenuItem Header="更新" Click="OnSubmoduleUpdate" />
                                        <Separator />
                                        <MenuItem Header="パスをコピー" Click="OnSubmoduleCopyPath" />
                                    </ContextMenu>
                                </ListBox.ContextMenu>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel LastChildFill="True" ToolTip="{Binding Describe}">
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding StatusLabel}" FontSize="{DynamicResource Fs11}"
                                                       Foreground="#FFE5A23B" Margin="8,0,0,0" />
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding ShortHash}" FontSize="{DynamicResource Fs11}"
                                                       Foreground="{DynamicResource FgDim}" Margin="8,0,0,0"
                                                       FontFamily="Cascadia Mono, Consolas" />
                                            <TextBlock Text="{Binding Path}" TextTrimming="CharacterEllipsis" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Grid>
                </Grid>

                <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch"
                              Background="{DynamicResource Border}" />

                <!-- コミットグラフ＋詳細 -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" MinHeight="100" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="140" MinHeight="60" />
                    </Grid.RowDefinitions>

                    <!-- 列幅は GridView の列見出し境界をドラッグして調整できる（作者・日時が固定幅で
                         コミットメッセージを圧迫し、狭いペインで見出しがほぼ読めなくなる問題への対処）。 -->
                    <ListView x:Name="LogList" Grid.Row="0" Style="{StaticResource GitList}"
                             ItemContainerStyle="{StaticResource GitLogListItem}"
                             ItemsSource="{Binding LogView}"
                             SelectedItem="{Binding SelectedLogRow}"
                             SelectionMode="Extended"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             MouseDoubleClick="OnCommitShowDiff"
                             PreviewMouseRightButtonDown="OnListRightClickSelect"
                             ContextMenuOpening="OnCommitContextMenuOpening"
                             FontFamily="Cascadia Mono, Consolas">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="コミット" Width="380">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock TextTrimming="CharacterEllipsis">
                                                <Run Text="{Binding Graph, Mode=OneWay}" Foreground="{DynamicResource FgDim}" /><Run Text=" " /><Run
                                                    Text="{Binding ShortHash, Mode=OneWay}" Foreground="{DynamicResource Accent}" /><Run Text=" " /><Run
                                                    Text="{Binding Refs, Mode=OneWay}" Foreground="#FFE5A23B" /><Run Text=" " /><Run
                                                    Text="{Binding Subject, Mode=OneWay}" Foreground="{DynamicResource Fg}" />
                                            </TextBlock>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="作成者" Width="120">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Author}" FontSize="{DynamicResource Fs11}"
                                                       Foreground="{DynamicResource FgDim}" TextTrimming="CharacterEllipsis" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="日時" Width="140">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Date}" FontSize="{DynamicResource Fs11}"
                                                       Foreground="{DynamicResource FgDim}" TextTrimming="CharacterEllipsis" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                        <ListView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="DIFF ペインで差分を表示（複数選択で範囲比較）" Click="OnCommitShowDiff" />
                                <Separator />
                                <MenuItem Header="ここから新しいブランチを作成…" Click="OnCommitCreateBranch" />
                                <MenuItem Header="タグを作成…" Click="OnCommitCreateTag" />
                                <MenuItem Header="チェックアウト（detached HEAD）" Click="OnCommitCheckout" />
                                <MenuItem Header="コミットメッセージを修正…" Click="OnCommitRewriteMessage" />
                                <MenuItem x:Name="InteractiveRebaseMenuItem"
                                          Header="ここからインタラクティブリベース…" Click="OnCommitInteractiveRebase" />
                                <!-- スカッシュは2件以上の選択時だけ表示（OnCommitContextMenuOpening で切替） -->
                                <Separator x:Name="SquashSeparator" />
                                <MenuItem x:Name="SquashMenuItem"
                                          Header="選択したコミットをスカッシュ（1つにまとめる）" Click="OnCommitSquash" />
                                <Separator />
                                <MenuItem Header="チェリーピック（現在のブランチへ取り込み）" Click="OnCommitCherryPick" />
                                <MenuItem Header="リバート（打ち消しコミットを作成）" Click="OnCommitRevert" />
                                <Separator />
                                <MenuItem Header="ここまでリセット (soft)" Click="OnCommitResetSoft" />
                                <MenuItem Header="ここまでリセット (mixed)" Click="OnCommitResetMixed" />
                                <MenuItem Header="ここまでリセット (hard)…" Click="OnCommitResetHard" />
                                <Separator />
                                <MenuItem Header="パッチをエディタで開く" Click="OnCommitOpenPatch" />
                                <MenuItem Header="ハッシュをコピー" Click="OnCommitCopyHash" />
                            </ContextMenu>
                        </ListView.ContextMenu>
                    </ListView>

                    <!-- 列幅ドラッグをヘッダー行の細い当たり判定に限定せず、一覧本体からも行える
                         ようにするオーバーレイ（GitSessionView.LogColumnResize.cs が組み立て・追従）。
                         背景は敢えて未設定（null）にして、つまみ以外の透過部分はクリックを
                         下の行へそのまま通す（Background="Transparent" は当たり判定を奪うので使わない）。 -->
                    <Canvas x:Name="LogColumnResizeOverlay" Grid.Row="0" />

                    <GridSplitter Grid.Row="1" Height="6" HorizontalAlignment="Stretch"
                                  Background="{DynamicResource Border}" />

                    <!-- 選択コミットの詳細（git show の統計表示）。変更ファイル一覧のパスは
                         リンク化してクリックでエディタで開く（描画・パース判定は code-behind）。 -->
                    <RichTextBox x:Name="CommitDetailBox" Grid.Row="2" IsReadOnly="True" IsDocumentEnabled="True"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                 FontFamily="Cascadia Mono, Consolas" FontSize="{DynamicResource Fs12}"
                                 Foreground="{DynamicResource Fg}"
                                 BorderThickness="0" Background="{DynamicResource BgAlt}" />
                </Grid>
            </Grid>
        </DockPanel>
    </DockPanel>
</UserControl>
