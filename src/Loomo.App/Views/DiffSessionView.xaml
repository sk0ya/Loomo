<UserControl x:Class="sk0ya.Loomo.App.Views.DiffSessionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{DynamicResource Panel}" Focusable="True">

    <UserControl.Resources>
        <!-- 一覧アイテム共通（GitSessionView と同じ見た目） -->
        <Style x:Key="DiffListItem" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="6,1" />
            <Setter Property="Foreground" Value="{DynamicResource Fg}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="b" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource BgAlt}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Border}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 差分1行：Kind で色分け -->
        <DataTemplate x:Key="DiffRowTemplate">
            <Border x:Name="rowBg" Background="Transparent">
                <TextBlock Text="{Binding Text}" FontFamily="Cascadia Mono, Consolas" FontSize="12"
                           Foreground="{DynamicResource Fg}" x:Name="rowText" />
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Kind}" Value="Added">
                    <Setter TargetName="rowBg" Property="Background" Value="#1F4CAF50" />
                    <Setter TargetName="rowText" Property="Foreground" Value="#FF81C784" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="Removed">
                    <Setter TargetName="rowBg" Property="Background" Value="#1FE57373" />
                    <Setter TargetName="rowText" Property="Foreground" Value="#FFE57373" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="Gap">
                    <Setter TargetName="rowText" Property="Foreground" Value="{DynamicResource Accent}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="Header">
                    <Setter TargetName="rowText" Property="Foreground" Value="{DynamicResource FgDim}" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- 左右並びの差分1行：左=削除側 / 右=追加側。Gap・Header は全幅1本で表示 -->
        <DataTemplate x:Key="SideRowTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border x:Name="leftBg" Background="Transparent" Padding="6,0">
                    <TextBlock x:Name="leftText" Text="{Binding LeftText}"
                               FontFamily="Cascadia Mono, Consolas" FontSize="12"
                               Foreground="{DynamicResource Fg}" TextTrimming="CharacterEllipsis" />
                </Border>
                <Border x:Name="divider" Grid.Column="1" Width="1"
                        Background="{DynamicResource Border}" />
                <Border x:Name="rightBg" Grid.Column="2" Background="Transparent" Padding="6,0">
                    <TextBlock x:Name="rightText" Text="{Binding RightText}"
                               FontFamily="Cascadia Mono, Consolas" FontSize="12"
                               Foreground="{DynamicResource Fg}" TextTrimming="CharacterEllipsis" />
                </Border>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding LeftKind}" Value="Removed">
                    <Setter TargetName="leftBg" Property="Background" Value="#1FE57373" />
                    <Setter TargetName="leftText" Property="Foreground" Value="#FFE57373" />
                </DataTrigger>
                <DataTrigger Binding="{Binding LeftKind}" Value="Empty">
                    <Setter TargetName="leftBg" Property="Background" Value="#14808080" />
                </DataTrigger>
                <DataTrigger Binding="{Binding RightKind}" Value="Added">
                    <Setter TargetName="rightBg" Property="Background" Value="#1F4CAF50" />
                    <Setter TargetName="rightText" Property="Foreground" Value="#FF81C784" />
                </DataTrigger>
                <DataTrigger Binding="{Binding RightKind}" Value="Empty">
                    <Setter TargetName="rightBg" Property="Background" Value="#14808080" />
                </DataTrigger>
                <DataTrigger Binding="{Binding LeftKind}" Value="Gap">
                    <Setter TargetName="leftBg" Property="Grid.ColumnSpan" Value="3" />
                    <Setter TargetName="divider" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="rightBg" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="leftText" Property="Foreground" Value="{DynamicResource Accent}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding LeftKind}" Value="Header">
                    <Setter TargetName="leftBg" Property="Grid.ColumnSpan" Value="3" />
                    <Setter TargetName="divider" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="rightBg" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="leftText" Property="Foreground" Value="{DynamicResource FgDim}" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- 差分本体の行コンテナ（統合・左右で共用） -->
        <Style x:Key="DiffBodyItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DiffSideBodyItem" TargetType="ListBoxItem" BasedOn="{StaticResource DiffBodyItem}">
            <Setter Property="Padding" Value="0" />
        </Style>
    </UserControl.Resources>

    <DockPanel>
        <!-- ツールバー（ソース切替・更新等）はペインヘッダー側（ShellWindow）へ集約 -->

        <!-- 実行結果メッセージ -->
        <TextBlock DockPanel.Dock="Bottom" Margin="10,2,10,6" FontSize="11"
                   Text="{Binding StatusMessage}" TextWrapping="Wrap" MaxHeight="60">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding StatusIsError}" Value="True">
                            <Setter Property="Foreground" Value="#FFE57373" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding StatusMessage}" Value="">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" MinWidth="140" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" MinWidth="200" />
            </Grid.ColumnDefinitions>

            <!-- 変更ファイル一覧 -->
            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" Margin="8,2" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource FgDim}" Text="変更ファイル" />
                <Grid>
                    <ListBox ItemsSource="{Binding Files}" SelectedItem="{Binding SelectedFile}"
                             Background="Transparent" BorderThickness="0"
                             Foreground="{DynamicResource Fg}"
                             ItemContainerStyle="{StaticResource DiffListItem}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             MouseDoubleClick="OnFileDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel LastChildFill="True" ToolTip="{Binding DisplayPath}">
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding Stats}" FontSize="11"
                                               Foreground="{DynamicResource FgDim}" Margin="8,0,0,0" />
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding Badge}" FontSize="11"
                                               Foreground="{DynamicResource Accent}" Margin="8,0,0,0" />
                                    <TextBlock Text="{Binding DisplayPath}" TextTrimming="CharacterEllipsis" />
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock Margin="12,8" Text="{Binding EmptyMessage}" TextWrapping="Wrap"
                               Foreground="{DynamicResource FgDim}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding EmptyMessage}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch"
                          Background="{DynamicResource Border}" />

            <!-- 差分本体（統合 / 左右並びを IsSideBySide で切替） -->
            <Grid Grid.Column="2">
                <ListBox ItemsSource="{Binding DiffRows}"
                         Visibility="{Binding IsSideBySide, Converter={StaticResource InverseBoolToVis}}"
                         Background="{DynamicResource BgAlt}" BorderThickness="0"
                         ItemTemplate="{StaticResource DiffRowTemplate}"
                         ItemContainerStyle="{StaticResource DiffBodyItem}"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling" />
                <ListBox ItemsSource="{Binding SideRows}"
                         Visibility="{Binding IsSideBySide, Converter={StaticResource BoolToVis}}"
                         Background="{DynamicResource BgAlt}" BorderThickness="0"
                         ItemTemplate="{StaticResource SideRowTemplate}"
                         ItemContainerStyle="{StaticResource DiffSideBodyItem}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling" />
            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
