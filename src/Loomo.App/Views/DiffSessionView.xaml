<UserControl x:Class="sk0ya.Loomo.App.Views.DiffSessionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:sk0ya.Loomo.App.ViewModels"
    xmlns:local="clr-namespace:sk0ya.Loomo.App.Views"
    Background="{DynamicResource Panel}" Focusable="True">

    <UserControl.Resources>
        <!-- 一覧アイテム共通（GitSessionView と同じ見た目） -->
        <Style x:Key="DiffListItem" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="6,1" />
            <Setter Property="Foreground" Value="{DynamicResource Fg}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="b" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource BgAlt}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Border}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 差分本体テキスト（読み取り専用 RichTextBox）：普通のテキストとして文字単位で選択・コピーできる -->
        <Style x:Key="DiffTextBox" TargetType="RichTextBox">
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="IsReadOnlyCaretVisible" Value="False" />
            <Setter Property="IsDocumentEnabled" Value="True" />
            <Setter Property="IsInactiveSelectionHighlightEnabled" Value="True" />
            <Setter Property="AutoWordSelection" Value="False" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{DynamicResource BgAlt}" />
            <Setter Property="Foreground" Value="{DynamicResource Fg}" />
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
        </Style>

        <!-- 行番号ガター：本文とは別のスクロール非対話 RichTextBox（選択・コピーに混ざらない） -->
        <Style x:Key="DiffGutterBox" TargetType="RichTextBox" BasedOn="{StaticResource DiffTextBox}">
            <Setter Property="Width" Value="46" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
            <Setter Property="VerticalScrollBarVisibility" Value="Hidden" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Hidden" />
        </Style>

        <!-- ハンク／コンフリクト解消の小さめアクションボタン（GitSessionView の ToolbarButton と同じ意図：
             既定の Button はテーマの DynamicResource を継承しない生の Win32 クロームになり、暗いテーマでは
             文字が見えなくなるため、必ず FlatButton ベースの明示スタイルを当てる）。 -->
        <Style x:Key="DiffActionButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="FontSize" Value="11" />
        </Style>
        <Style x:Key="DiffSecondaryButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="FontSize" Value="11" />
        </Style>

        <!-- コンフリクトの Ours→Result / Theirs→Result 取り込みボタン（«/» のみ。Rider の merge gutter と同じ最小限の見た目）。 -->
        <Style x:Key="ConflictGutterButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
            <Setter Property="Padding" Value="2,1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <!-- コンフリクトの Ours/Theirs 列（読み取り専用・複数行）。Result 列と横に並べ、Rider の3ペインに近づける。 -->
        <Style x:Key="ConflictSideTextBox" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="IsReadOnlyCaretVisible" Value="False" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource Fg}" />
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="VerticalScrollBarVisibility" Value="Hidden" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
        </Style>

        <!-- Result 列（自由編集可）。枠と背景を分けて「ここは手で書き換えられる」ことを示す。 -->
        <Style x:Key="ConflictResultTextBox" TargetType="TextBox" BasedOn="{StaticResource ConflictSideTextBox}">
            <Setter Property="IsReadOnly" Value="False" />
            <Setter Property="IsReadOnlyCaretVisible" Value="True" />
            <Setter Property="Background" Value="{DynamicResource Panel}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        </Style>

        <!-- 本文 RichTextBox 共通のコンテキストメニュー（コピー）。以下の DataTemplate 内で参照するため、
             StaticResource の前方参照制約（同じ ResourceDictionary 内では宣言順より後ろを参照できない）
             を満たすようここに置く。 -->
        <ContextMenu x:Key="DiffCopyMenu">
            <MenuItem Header="コピー" Command="ApplicationCommands.Copy" InputGestureText="Ctrl+C"
                      CommandTarget="{Binding PlacementTarget,
                          RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
        </ContextMenu>

        <!-- 通常行のまとまり（両者で共通の内容、クリック不可）。Ours/Result/Theirs の3列すべてに同じ内容を
             流し、コンフリクト部分の5列グリッドと幅を揃える（SharedSizeGroup）ことで、3ペインが
             ファイル全体を通してそのまま続いているように見せる（Rider の3-way merge と同じ考え方）。 -->
        <DataTemplate DataType="{x:Type vm:ConflictOrdinaryBlockVm}">
            <ItemsControl ItemsSource="{Binding Lines}" Focusable="False">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="120" SharedSizeGroup="ConflictOurs" />
                                <ColumnDefinition Width="24" SharedSizeGroup="ConflictGutterL" />
                                <ColumnDefinition Width="*" MinWidth="160" SharedSizeGroup="ConflictResult" />
                                <ColumnDefinition Width="24" SharedSizeGroup="ConflictGutterR" />
                                <ColumnDefinition Width="*" MinWidth="120" SharedSizeGroup="ConflictTheirs" />
                            </Grid.ColumnDefinitions>
                            <DockPanel Grid.Column="0" LastChildFill="True">
                                <TextBlock DockPanel.Dock="Left" Width="34" TextAlignment="Right" Margin="4,0,8,0"
                                           Text="{Binding LineNumber}" FontFamily="Cascadia Mono, Consolas" FontSize="11"
                                           Foreground="{DynamicResource FgDim}" />
                                <TextBlock Text="{Binding Text}" FontFamily="Cascadia Mono, Consolas" FontSize="12"
                                           Foreground="{DynamicResource Fg}" TextWrapping="NoWrap" />
                            </DockPanel>
                            <TextBlock Grid.Column="2" Margin="6,0,0,0" Text="{Binding Text}"
                                       FontFamily="Cascadia Mono, Consolas" FontSize="12"
                                       Foreground="{DynamicResource Fg}" TextWrapping="NoWrap" />
                            <TextBlock Grid.Column="4" Margin="6,0,0,0" Text="{Binding Text}"
                                       FontFamily="Cascadia Mono, Consolas" FontSize="12"
                                       Foreground="{DynamicResource Fg}" TextWrapping="NoWrap" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </DataTemplate>

        <!-- コンフリクト1件：Ours（読み取り専用）/ Result（自由編集・既定は空）/ Theirs（読み取り専用）の
             3ペイン構成（Rider の3-way merge と同じ考え方）。« / » でその場で Ours・Theirs を Result へ
             取り込めるほか、Result 欄へ直接書いて「適用」してもよい。ナビゲーションの現在地は枠で強調する
             （既定は素の Panel 背景。全ブロック常時ハイライトだと「今どこか」が埋もれるため、現在地だけを
             目立たせる）。Ours/Theirs は行番号ガター＋差分ハイライト付きの読み取り専用 RichTextBox
             （通常差分の左右並び表示と同じ DiffTextBox/DiffGutterBox）にして、文字選択・コピーもできる。 -->
        <DataTemplate DataType="{x:Type vm:ConflictRegionVm}">
            <Border Margin="0,4" Background="{DynamicResource Panel}" BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
                                <Setter Property="BorderThickness" Value="2" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid Margin="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="120" SharedSizeGroup="ConflictOurs" />
                        <ColumnDefinition Width="24" SharedSizeGroup="ConflictGutterL" />
                        <ColumnDefinition Width="*" MinWidth="160" SharedSizeGroup="ConflictResult" />
                        <ColumnDefinition Width="24" SharedSizeGroup="ConflictGutterR" />
                        <ColumnDefinition Width="*" MinWidth="120" SharedSizeGroup="ConflictTheirs" />
                    </Grid.ColumnDefinitions>

                    <!-- Ours（読み取り専用・行番号＋差分ハイライト付き）。左端の緑帯はスクロールしても
                         「どちら側か」が分かるようにする常設マーカー（見出しの緑と同色）。 -->
                    <Grid Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#FF81C784" />
                        <RichTextBox Grid.Column="1" Style="{StaticResource DiffGutterBox}" Width="30"
                                     local:ConflictSideDocumentBehavior.Mode="Gutter"
                                     local:ConflictSideDocumentBehavior.Lines="{Binding OursDisplayLines}" />
                        <RichTextBox Grid.Column="2" Style="{StaticResource DiffTextBox}"
                                     ContextMenu="{StaticResource DiffCopyMenu}"
                                     local:ConflictSideDocumentBehavior.Mode="Ours"
                                     local:ConflictSideDocumentBehavior.Lines="{Binding OursDisplayLines}" />
                    </Grid>

                    <!-- Ours → Result -->
                    <Button Grid.Column="1" Content="»" ToolTip="Ours を採用して Result に入れる"
                            VerticalAlignment="Top" Margin="0,6,0,0"
                            Style="{StaticResource ConflictGutterButton}"
                            Command="{Binding DataContext.AcceptOursCommand,
                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                            CommandParameter="{Binding}" />

                    <!-- Result（自由編集）。フォーカスすると、上部ツールバーの「現在地のコンフリクトを解決」
                         操作の対象がこのコンフリクトになる（DiffSessionView.xaml.cs 側でナビゲーション位置と同期）。
                         行番号は編集のたびに再計算される ResultLineNumberText（"1\n2\n3" 形式）をそのまま
                         TextBlock にバインドする（WPF の TextBlock.Text は埋め込み改行をそのまま描画する）。
                         VerticalAlignment=Top：既定の Stretch のままだと、Ours/Theirs 側が複数行で背が高い
                         コンフリクトのとき、中身が短い（既定は空）Result の TextBox まで同じ高さに引き伸ばされ、
                         下に不自然な空白ができる。中身の高さぴったりに留めて、余りはブロックの背景に任せる。 -->
                    <Grid Grid.Column="2" VerticalAlignment="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Width="24" TextAlignment="Right" Margin="0,4,4,4"
                                   Text="{Binding ResultLineNumberText}"
                                   FontFamily="Cascadia Mono, Consolas" FontSize="12"
                                   Foreground="{DynamicResource FgDim}" />
                        <TextBox Grid.Column="1" Style="{StaticResource ConflictResultTextBox}"
                                 Text="{Binding ResultText, UpdateSourceTrigger=PropertyChanged}"
                                 GotFocus="OnConflictResultGotFocus" />
                    </Grid>

                    <!-- Theirs → Result -->
                    <Button Grid.Column="3" Content="«" ToolTip="Theirs を採用して Result に入れる"
                            VerticalAlignment="Top" Margin="0,6,0,0"
                            Style="{StaticResource ConflictGutterButton}"
                            Command="{Binding DataContext.AcceptTheirsCommand,
                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                            CommandParameter="{Binding}" />

                    <!-- Theirs（読み取り専用・行番号＋差分ハイライト付き）。右端の赤帯は見出しの赤と同色。 -->
                    <Grid Grid.Column="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="3" />
                        </Grid.ColumnDefinitions>
                        <RichTextBox Grid.Column="0" Style="{StaticResource DiffGutterBox}" Width="30"
                                     local:ConflictSideDocumentBehavior.Mode="Gutter"
                                     local:ConflictSideDocumentBehavior.Lines="{Binding TheirsDisplayLines}" />
                        <RichTextBox Grid.Column="1" Style="{StaticResource DiffTextBox}"
                                     ContextMenu="{StaticResource DiffCopyMenu}"
                                     local:ConflictSideDocumentBehavior.Mode="Theirs"
                                     local:ConflictSideDocumentBehavior.Lines="{Binding TheirsDisplayLines}" />
                        <Border Grid.Column="2" Background="#FFE57373" />
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- 統合表示の本文メニュー（コピー＋選択行の破棄）。破棄は Git・作業ツリー・未ステージの追跡ファイルのみ有効 -->
        <ContextMenu x:Key="DiffUnifiedMenu">
            <MenuItem Header="コピー" Command="ApplicationCommands.Copy" InputGestureText="Ctrl+C"
                      CommandTarget="{Binding PlacementTarget,
                          RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
            <Separator />
            <MenuItem Header="選択した行を破棄" Click="OnDiscardSelectedLines"
                      ToolTip="選択した追加・削除行の変更だけを作業ツリーから取り消す"
                      IsEnabled="{Binding PlacementTarget.DataContext.CanDiscardLines,
                          RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
        </ContextMenu>
    </UserControl.Resources>

    <DockPanel>
        <!-- ツールバー（ソース切替・更新等）はペインヘッダー側（ShellWindow）へ集約 -->

        <!-- 実行結果メッセージ -->
        <TextBlock DockPanel.Dock="Bottom" Margin="10,2,10,6" FontSize="11"
                   Text="{Binding StatusMessage}" TextWrapping="Wrap" MaxHeight="60">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding StatusIsError}" Value="True">
                            <Setter Property="Foreground" Value="#FFE57373" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding StatusMessage}" Value="">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" MinWidth="140" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" MinWidth="200" />
            </Grid.ColumnDefinitions>

            <!-- 変更ファイル一覧 -->
            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" Margin="8,2" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource FgDim}" Text="変更ファイル" />
                <Grid>
                    <ListBox ItemsSource="{Binding Files}" SelectedItem="{Binding SelectedFile}"
                             Background="Transparent" BorderThickness="0"
                             Foreground="{DynamicResource Fg}"
                             ItemContainerStyle="{StaticResource DiffListItem}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             MouseDoubleClick="OnFileDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel LastChildFill="True" ToolTip="{Binding DisplayPath}">
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding Stats}" FontSize="11"
                                               Foreground="{DynamicResource FgDim}" Margin="8,0,0,0" />
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding Badge}" FontSize="11"
                                               Foreground="{DynamicResource Accent}" Margin="8,0,0,0" />
                                    <TextBlock Text="{Binding DisplayPath}" TextTrimming="CharacterEllipsis" />
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock Margin="12,8" Text="{Binding EmptyMessage}" TextWrapping="Wrap"
                               Foreground="{DynamicResource FgDim}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding EmptyMessage}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch"
                          Background="{DynamicResource Border}" />

            <!-- 差分本体（統合 / 左右並びを IsSideBySide で切替）。中身は code-behind が FlowDocument を組み立てる -->
            <DockPanel Grid.Column="2">

            <!-- ハンク単位ステージ（作業ツリーの追跡済みファイルのみ）。各ハンクをステージ／アンステージできる。 -->
            <Border DockPanel.Dock="Top" Margin="0,0,0,2" Padding="4,3"
                    Background="{DynamicResource Panel}"
                    BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1"
                    Visibility="{Binding CanStageHunks, Converter={StaticResource BoolToVis}}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Left" Text="ハンク" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource FgDim}" VerticalAlignment="Center" Margin="4,0,8,0" />
                    <ItemsControl ItemsSource="{Binding Hunks}" MaxHeight="120">
                        <ItemsControl.Template>
                            <ControlTemplate TargetType="ItemsControl">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </ControlTemplate>
                        </ItemsControl.Template>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,1" ToolTip="{Binding HeaderLine}">
                                    <Button DockPanel.Dock="Right" Content="{Binding ActionLabel}"
                                            Style="{StaticResource DiffSecondaryButton}" Margin="6,0,0,0"
                                            Command="{Binding DataContext.ToggleHunkCommand,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}" />
                                    <TextBlock Text="{Binding Summary}" FontFamily="Cascadia Mono, Consolas"
                                               FontSize="11" Foreground="{DynamicResource FgDim}"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>

            <Grid>
                <!-- 通常の差分表示（統合／左右）。コンフリクト解消表示中はまとめて隠す。 -->
                <Grid Visibility="{Binding IsConflictMode, Converter={StaticResource InverseBoolToVis}}">
                <RichTextBox x:Name="UnifiedBox" Style="{StaticResource DiffTextBox}"
                             ContextMenu="{StaticResource DiffUnifiedMenu}"
                             Visibility="{Binding IsSideBySide, Converter={StaticResource InverseBoolToVis}}" />

                <Grid x:Name="SidePanel"
                      Visibility="{Binding IsSideBySide, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="120" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" MinWidth="120" />
                    </Grid.ColumnDefinitions>

                    <!-- 左側（行番号ガター＋本文） -->
                    <Grid Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <RichTextBox x:Name="LeftGutter" Grid.Column="0" Style="{StaticResource DiffGutterBox}" />
                        <RichTextBox x:Name="LeftTextBox" Grid.Column="1" Style="{StaticResource DiffTextBox}"
                                     ContextMenu="{StaticResource DiffCopyMenu}"
                                     VerticalScrollBarVisibility="Hidden" />
                    </Grid>

                    <!-- 中央：左右サイズ変更スプリッタ（左端の帯）＋中央ゲター。
                         中央ゲターは変更ブロックを帯で示し、クリックでその範囲を破棄する（Rider 風）。
                         スプリッタは破棄帯と重ならないよう左端の専用ストリップに置く。 -->
                    <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Left"
                                  VerticalAlignment="Stretch" Background="Transparent"
                                  ResizeBehavior="PreviousAndNext" ResizeDirection="Columns" />
                    <Grid Grid.Column="1" Width="20" Margin="6,0,0,0" Background="{DynamicResource BgAlt}">
                        <Border Width="1" HorizontalAlignment="Center" Background="{DynamicResource Border}" />
                        <Canvas x:Name="CenterGutter" ClipToBounds="True" Background="Transparent" />
                    </Grid>

                    <!-- 右側（行番号ガター＋本文） -->
                    <Grid Grid.Column="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <RichTextBox x:Name="RightGutter" Grid.Column="0" Style="{StaticResource DiffGutterBox}" />
                        <RichTextBox x:Name="RightTextBox" Grid.Column="1" Style="{StaticResource DiffTextBox}"
                                     ContextMenu="{StaticResource DiffCopyMenu}" />
                    </Grid>
                </Grid>
                </Grid>

                <!-- コンフリクト解消表示（Rider 風3ペイン：Ours / Result / Theirs）。マーカー無し
                     （削除/変更の衝突等）はファイル全体で ours/theirs/削除 から選ばせる。 -->
                <DockPanel Background="{DynamicResource BgAlt}" Grid.IsSharedSizeScope="True"
                           Visibility="{Binding IsConflictMode, Converter={StaticResource BoolToVis}}">
                    <Border DockPanel.Dock="Top" Padding="8,6"
                            Background="{DynamicResource Panel}"
                            BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <DockPanel LastChildFill="False">
                                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="0,0,12,0"
                                            Visibility="{Binding IsWholeFileConflict, Converter={StaticResource InverseBoolToVis}}">
                                    <Button Content="▲ 前へ" ToolTip="前のコンフリクトへ"
                                            Style="{StaticResource DiffSecondaryButton}" Margin="0,0,4,0"
                                            Command="{Binding PreviousConflictCommand}" />
                                    <Button Content="次へ ▼" ToolTip="次のコンフリクトへ"
                                            Style="{StaticResource DiffSecondaryButton}" Margin="0,0,8,0"
                                            Command="{Binding NextConflictCommand}" />
                                    <TextBlock Text="{Binding ConflictPositionText}" FontSize="11"
                                               Foreground="{DynamicResource FgDim}" VerticalAlignment="Center" />
                                </StackPanel>
                                <Button DockPanel.Dock="Left" Content="解決済みにする"
                                        Style="{StaticResource DiffActionButton}" Margin="0,0,8,0"
                                        Command="{Binding MarkResolvedCommand}" IsEnabled="{Binding CanMarkResolved}"
                                        Visibility="{Binding IsWholeFileConflict, Converter={StaticResource InverseBoolToVis}}" />
                                <Button DockPanel.Dock="Left" Content="エディタで開く"
                                        Style="{StaticResource DiffSecondaryButton}" Margin="0,0,8,0"
                                        Command="{Binding OpenInEditorCommand}" />
                                <TextBlock DockPanel.Dock="Left" Text="{Binding ConflictProgressText}"
                                           FontSize="11" Foreground="{DynamicResource FgDim}"
                                           VerticalAlignment="Center" />
                            </DockPanel>

                            <!-- 現在地（前へ/次へ、またはクリックした Result 欄）のコンフリクトを解決する操作。
                                 ボタンをコンフリクト行の中に混ぜず、ここにまとめる。 -->
                            <DockPanel LastChildFill="False" Margin="0,6,0,0"
                                       Visibility="{Binding IsWholeFileConflict, Converter={StaticResource InverseBoolToVis}}">
                                <TextBlock DockPanel.Dock="Left" Text="現在地のコンフリクトを解決：" FontSize="11"
                                           Foreground="{DynamicResource FgDim}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <Button DockPanel.Dock="Left" Content="Ours 採用 »" ToolTip="現在地に Ours を採用する"
                                        Style="{StaticResource DiffSecondaryButton}" Margin="0,0,4,0"
                                        Command="{Binding AcceptCurrentOursCommand}" />
                                <Button DockPanel.Dock="Left" Content="両方採用" ToolTip="現在地に Ours と Theirs を両方入れる"
                                        Style="{StaticResource DiffSecondaryButton}" Margin="0,0,4,0"
                                        Command="{Binding AcceptCurrentBothCommand}" />
                                <Button DockPanel.Dock="Left" Content="« Theirs 採用" ToolTip="現在地に Theirs を採用する"
                                        Style="{StaticResource DiffSecondaryButton}" Margin="0,0,8,0"
                                        Command="{Binding AcceptCurrentTheirsCommand}" />
                                <Button DockPanel.Dock="Left" Content="Result を適用" ToolTip="Result 欄の内容で現在地のコンフリクトを解決する"
                                        Style="{StaticResource DiffActionButton}"
                                        Command="{Binding ApplyCurrentResultCommand}" />
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- マーカー無し（削除/変更の衝突・リネーム等）：ファイル全体から選ぶ -->
                    <StackPanel DockPanel.Dock="Top" Margin="12,10"
                                Visibility="{Binding IsWholeFileConflict, Converter={StaticResource BoolToVis}}">
                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource FgDim}" Margin="0,0,0,10"
                                   Text="このファイルはマーカーの無い衝突です（削除/変更の衝突・リネーム等）。ours/theirs のどちらかを採用するか、削除して解決してください。" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Ours を採用" Style="{StaticResource DiffActionButton}" Margin="0,0,8,0"
                                    Command="{Binding AcceptWholeFileOursCommand}" />
                            <Button Content="Theirs を採用" Style="{StaticResource DiffActionButton}" Margin="0,0,8,0"
                                    Command="{Binding AcceptWholeFileTheirsCommand}" />
                            <Button Content="削除して解決" Style="{StaticResource DiffSecondaryButton}"
                                    Command="{Binding DeleteFileConflictCommand}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Ours/Result/Theirs 列見出し：1ファイル内の全コンフリクトで共通なので、ここで1回だけ出す
                         （各コンフリクトの中では繰り返さない）。下のコンフリクト行の5列グリッドと幅を揃える
                         （SharedSizeGroup、親 DockPanel の Grid.IsSharedSizeScope で連動）。 -->
                    <Grid DockPanel.Dock="Top" Margin="4,4,4,0"
                          Visibility="{Binding IsWholeFileConflict, Converter={StaticResource InverseBoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="120" SharedSizeGroup="ConflictOurs" />
                            <ColumnDefinition Width="24" SharedSizeGroup="ConflictGutterL" />
                            <ColumnDefinition Width="*" MinWidth="160" SharedSizeGroup="ConflictResult" />
                            <ColumnDefinition Width="24" SharedSizeGroup="ConflictGutterR" />
                            <ColumnDefinition Width="*" MinWidth="120" SharedSizeGroup="ConflictTheirs" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding ConflictOursHeader}" FontSize="11"
                                   FontWeight="SemiBold" Foreground="#FF81C784" Margin="6,0,0,4" />
                        <TextBlock Grid.Column="2" Text="Result（マージ結果・編集可）" FontSize="11"
                                   FontWeight="SemiBold" Foreground="{DynamicResource Accent}" Margin="6,0,0,4" />
                        <TextBlock Grid.Column="4" Text="{Binding ConflictTheirsHeader}" FontSize="11"
                                   FontWeight="SemiBold" Foreground="#FFE57373" Margin="6,0,0,4" />
                    </Grid>

                    <!-- マーカー方式：ファイル全体を通常行とコンフリクトが実際に現れる順のまま1本の流れで表示する
                         （読んでいる場所でそのままコンフリクトを解決できる。別ペインへ視線を移す必要はない）。 -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding IsWholeFileConflict, Converter={StaticResource InverseBoolToVis}}">
                        <ItemsControl x:Name="ConflictItemsControl" ItemsSource="{Binding ConflictBlocks}"
                                      Margin="4,6" Focusable="False" />
                    </ScrollViewer>
                </DockPanel>
            </Grid>
            </DockPanel>
        </Grid>
    </DockPanel>
</UserControl>
