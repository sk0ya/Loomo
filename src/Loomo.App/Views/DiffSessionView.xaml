<UserControl x:Class="sk0ya.Loomo.App.Views.DiffSessionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{DynamicResource Panel}" Focusable="True">

    <UserControl.Resources>
        <!-- 一覧アイテム共通（GitSessionView と同じ見た目） -->
        <Style x:Key="DiffListItem" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="6,1" />
            <Setter Property="Foreground" Value="{DynamicResource Fg}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="b" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource BgAlt}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Border}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 差分本体テキスト（読み取り専用 RichTextBox）：普通のテキストとして文字単位で選択・コピーできる -->
        <Style x:Key="DiffTextBox" TargetType="RichTextBox">
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="IsReadOnlyCaretVisible" Value="False" />
            <Setter Property="IsDocumentEnabled" Value="True" />
            <Setter Property="IsInactiveSelectionHighlightEnabled" Value="True" />
            <Setter Property="AutoWordSelection" Value="False" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{DynamicResource BgAlt}" />
            <Setter Property="Foreground" Value="{DynamicResource Fg}" />
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
        </Style>

        <!-- 行番号ガター：本文とは別のスクロール非対話 RichTextBox（選択・コピーに混ざらない） -->
        <Style x:Key="DiffGutterBox" TargetType="RichTextBox" BasedOn="{StaticResource DiffTextBox}">
            <Setter Property="Width" Value="46" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
            <Setter Property="VerticalScrollBarVisibility" Value="Hidden" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Hidden" />
        </Style>

        <!-- 本文 RichTextBox 共通のコンテキストメニュー（コピー） -->
        <ContextMenu x:Key="DiffCopyMenu">
            <MenuItem Header="コピー" Command="ApplicationCommands.Copy" InputGestureText="Ctrl+C"
                      CommandTarget="{Binding PlacementTarget,
                          RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
        </ContextMenu>
    </UserControl.Resources>

    <DockPanel>
        <!-- ツールバー（ソース切替・更新等）はペインヘッダー側（ShellWindow）へ集約 -->

        <!-- 実行結果メッセージ -->
        <TextBlock DockPanel.Dock="Bottom" Margin="10,2,10,6" FontSize="11"
                   Text="{Binding StatusMessage}" TextWrapping="Wrap" MaxHeight="60">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding StatusIsError}" Value="True">
                            <Setter Property="Foreground" Value="#FFE57373" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding StatusMessage}" Value="">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" MinWidth="140" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" MinWidth="200" />
            </Grid.ColumnDefinitions>

            <!-- 変更ファイル一覧 -->
            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" Margin="8,2" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource FgDim}" Text="変更ファイル" />
                <Grid>
                    <ListBox ItemsSource="{Binding Files}" SelectedItem="{Binding SelectedFile}"
                             Background="Transparent" BorderThickness="0"
                             Foreground="{DynamicResource Fg}"
                             ItemContainerStyle="{StaticResource DiffListItem}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             MouseDoubleClick="OnFileDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel LastChildFill="True" ToolTip="{Binding DisplayPath}">
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding Stats}" FontSize="11"
                                               Foreground="{DynamicResource FgDim}" Margin="8,0,0,0" />
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding Badge}" FontSize="11"
                                               Foreground="{DynamicResource Accent}" Margin="8,0,0,0" />
                                    <TextBlock Text="{Binding DisplayPath}" TextTrimming="CharacterEllipsis" />
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock Margin="12,8" Text="{Binding EmptyMessage}" TextWrapping="Wrap"
                               Foreground="{DynamicResource FgDim}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding EmptyMessage}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch"
                          Background="{DynamicResource Border}" />

            <!-- 差分本体（統合 / 左右並びを IsSideBySide で切替）。中身は code-behind が FlowDocument を組み立てる -->
            <Grid Grid.Column="2">
                <RichTextBox x:Name="UnifiedBox" Style="{StaticResource DiffTextBox}"
                             ContextMenu="{StaticResource DiffCopyMenu}"
                             Visibility="{Binding IsSideBySide, Converter={StaticResource InverseBoolToVis}}" />

                <Grid x:Name="SidePanel"
                      Visibility="{Binding IsSideBySide, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <RichTextBox x:Name="LeftGutter" Grid.Column="0" Style="{StaticResource DiffGutterBox}" />
                    <RichTextBox x:Name="LeftTextBox" Grid.Column="1" Style="{StaticResource DiffTextBox}"
                                 ContextMenu="{StaticResource DiffCopyMenu}"
                                 VerticalScrollBarVisibility="Hidden" />
                    <Border Grid.Column="2" Width="1" Background="{DynamicResource Border}" />
                    <RichTextBox x:Name="RightGutter" Grid.Column="3" Style="{StaticResource DiffGutterBox}" />
                    <RichTextBox x:Name="RightTextBox" Grid.Column="4" Style="{StaticResource DiffTextBox}"
                                 ContextMenu="{StaticResource DiffCopyMenu}" />
                </Grid>
            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
