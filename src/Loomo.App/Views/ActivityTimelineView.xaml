<UserControl x:Class="sk0ya.Loomo.App.Views.ActivityTimelineView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:sk0ya.Loomo.App.ViewModels">

    <!-- 「進行状況」を段階タイムラインで見せる。DataContext は当該 TranscriptEntry（Steps を束縛）。
         ワークフローのステップ・パイプライン（番号付き丸ノード＋接続線）と視覚を揃え、各段を
         「種別アイコンのノード＋本文＋経過時刻」の1行にする。成否はノード枠の色（控えめ）で示す。 -->
    <ItemsControl ItemsSource="{Binding Steps}">
        <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type vm:ActivityStep}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="22" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- 左レール：全高の縦線（隣接段で連続）＋状態ノードを重ねる。 -->
                    <Grid Grid.Column="0">
                        <Border Width="2" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                Background="{DynamicResource Border}" />
                        <Border x:Name="Node" Width="18" Height="18" CornerRadius="9"
                                HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,1,0,0"
                                Background="{DynamicResource BgAlt}"
                                BorderBrush="{DynamicResource Border}" BorderThickness="1.5">
                            <TextBlock Text="{Binding Glyph}" FontSize="9"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </Grid>

                    <!-- 本文（詳細がある段だけ折りたたみ、閉じた状態では1行要約だけを見せる） -->
                    <Grid Grid.Column="1">
                        <TextBlock x:Name="Msg" Text="{Binding Message}" TextWrapping="Wrap"
                                   Margin="7,2,8,2" VerticalAlignment="Center" FontSize="12"
                                   Foreground="{DynamicResource Fg}" />
                        <Expander x:Name="DetailExpander" Visibility="Collapsed" Margin="3,0,8,2"
                                  IsExpanded="False">
                            <Expander.Header>
                                <TextBlock x:Name="DetailHeader" Text="{Binding Message}"
                                           TextTrimming="CharacterEllipsis" FontSize="12"
                                           Foreground="{DynamicResource Fg}" />
                            </Expander.Header>
                            <Border Margin="22,4,0,4" Padding="8,7" CornerRadius="4"
                                    Background="{DynamicResource Bg}"
                                    BorderBrush="{DynamicResource Border}" BorderThickness="1">
                                <TextBox Text="{Binding Detail}" IsReadOnly="True" TextWrapping="Wrap"
                                         BorderThickness="0" Padding="0" Background="Transparent"
                                         IsReadOnlyCaretVisible="False" IsTabStop="False" Cursor="IBeam"
                                         FontFamily="Cascadia Mono, Consolas" FontSize="11.5"
                                         Foreground="{DynamicResource Fg}" />
                            </Border>
                        </Expander>
                    </Grid>

                    <!-- 経過時刻（各段に添える・等幅で揃える） -->
                    <TextBlock Grid.Column="2" Text="{Binding TimeLabel}" VerticalAlignment="Top" Margin="0,3,0,0"
                               FontFamily="Cascadia Mono, Consolas" FontSize="10"
                               Foreground="{DynamicResource FgDim}"
                               Visibility="{Binding HasTime, Converter={StaticResource BoolToVis}}" />
                </Grid>
                <DataTemplate.Triggers>
                    <!-- ステップ境界の見出し段：本文を太字・通常色にして、フラットな進捗の中で切れ目が分かるようにする。 -->
                    <DataTrigger Binding="{Binding IsHeader}" Value="True">
                        <Setter TargetName="Msg" Property="FontWeight" Value="SemiBold" />
                        <Setter TargetName="DetailHeader" Property="FontWeight" Value="SemiBold" />
                        <Setter TargetName="Msg" Property="Margin" Value="7,6,8,2" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding HasDetail}" Value="True">
                        <Setter TargetName="Msg" Property="Visibility" Value="Collapsed" />
                        <Setter TargetName="DetailExpander" Property="Visibility" Value="Visible" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tone}" Value="Accent">
                        <Setter TargetName="Node" Property="BorderBrush" Value="{DynamicResource Accent}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tone}" Value="Good">
                        <Setter TargetName="Node" Property="BorderBrush" Value="#FF4CAF50" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tone}" Value="Bad">
                        <Setter TargetName="Node" Property="BorderBrush" Value="#FFE05252" />
                        <Setter TargetName="Msg" Property="Foreground" Value="#FFE05252" />
                        <Setter TargetName="DetailHeader" Property="Foreground" Value="#FFE05252" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tone}" Value="Warn">
                        <Setter TargetName="Node" Property="BorderBrush" Value="#FFE0A042" />
                    </DataTrigger>
                    <!-- ライブ段（生成中）：等幅＋淡色にし、ノードを点滅させて動作中だと示す。 -->
                    <DataTrigger Binding="{Binding IsLive}" Value="True">
                        <Setter TargetName="Msg" Property="FontFamily" Value="Cascadia Mono, Consolas" />
                        <Setter TargetName="Msg" Property="Foreground" Value="{DynamicResource FgDim}" />
                        <Setter TargetName="DetailHeader" Property="FontFamily" Value="Cascadia Mono, Consolas" />
                        <Setter TargetName="DetailHeader" Property="Foreground" Value="{DynamicResource FgDim}" />
                        <DataTrigger.EnterActions>
                            <BeginStoryboard Name="Pulse">
                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                    <DoubleAnimation Storyboard.TargetName="Node"
                                                     Storyboard.TargetProperty="Opacity"
                                                     From="1" To="0.3" Duration="0:0:0.7" />
                                </Storyboard>
                            </BeginStoryboard>
                        </DataTrigger.EnterActions>
                        <DataTrigger.ExitActions>
                            <StopStoryboard BeginStoryboardName="Pulse" />
                        </DataTrigger.ExitActions>
                    </DataTrigger>
                </DataTemplate.Triggers>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</UserControl>
