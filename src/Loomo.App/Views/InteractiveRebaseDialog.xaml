<Window x:Class="sk0ya.Loomo.App.Views.InteractiveRebaseDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Loomo - インタラクティブリベース"
    Width="640" Height="520"
    MinWidth="480" MinHeight="320"
    ResizeMode="CanResize"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner"
    Background="{DynamicResource Bg}"
    FontFamily="Segoe UI">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Foreground="{DynamicResource Fg}" FontSize="{DynamicResource Fs13}" TextWrapping="Wrap"
                   Margin="0,0,0,8"
                   Text="順序を変更し、各コミットのアクションを選んで実行してください（Reword は先にメッセージを入力します）。実行するとコミットは作り直されます。" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
            <Button Content="↑ 上へ" Style="{StaticResource FlatButton}" Background="{DynamicResource BgAlt}"
                    Foreground="{DynamicResource Fg}" Margin="0,0,6,0" Click="OnMoveUp" />
            <Button Content="↓ 下へ" Style="{StaticResource FlatButton}" Background="{DynamicResource BgAlt}"
                    Foreground="{DynamicResource Fg}" Margin="0,0,6,0" Click="OnMoveDown" />
            <Button x:Name="EditMessageButton" Content="メッセージを編集…" Style="{StaticResource FlatButton}"
                    Background="{DynamicResource BgAlt}" Foreground="{DynamicResource Fg}"
                    IsEnabled="False" Click="OnEditMessage" />
        </StackPanel>

        <Border Grid.Row="2" BorderBrush="{DynamicResource Border}" BorderThickness="1">
            <ListBox x:Name="RowsList" ItemsSource="{Binding}" Background="Transparent" BorderThickness="0"
                     SelectionChanged="OnSelectionChanged"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="4,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="190" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding ShortHash}"
                                       FontFamily="Cascadia Mono, Consolas"
                                       Foreground="{DynamicResource Accent}" VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            <TextBlock Grid.Column="1" Text="{Binding Subject}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource Fg}" TextTrimming="CharacterEllipsis" />
                            <ComboBox Grid.Column="2" ItemsSource="{Binding ActionOptions}"
                                      SelectedValuePath="Action" DisplayMemberPath="Label"
                                      SelectedValue="{Binding Action, Mode=TwoWay}" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <TextBlock x:Name="ErrorText" Grid.Row="3"
                   Foreground="#FFE4676B"
                   FontSize="{DynamicResource Fs11}"
                   TextWrapping="Wrap"
                   Visibility="Collapsed"
                   Margin="0,8,0,0" />

        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="OK"
                    Style="{StaticResource FlatButton}"
                    IsDefault="True"
                    MinWidth="76"
                    Click="OnOk" />
            <Button Content="キャンセル"
                    Style="{StaticResource FlatButton}"
                    Background="{DynamicResource BgAlt}"
                    Foreground="{DynamicResource Fg}"
                    IsCancel="True"
                    MinWidth="92"
                    Margin="8,0,0,0" />
        </StackPanel>
    </Grid>
</Window>
