<UserControl x:Class="sk0ya.Loomo.App.Views.FolderTreeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:sk0ya.Loomo.App.ViewModels"
    xmlns:views="clr-namespace:sk0ya.Loomo.App.Views"
    Background="{DynamicResource BgAlt}">

    <UserControl.Resources>
        <Style x:Key="ExplorerToggleButton" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="b"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Bg}" />
                                <Setter Property="Foreground" Value="{DynamicResource Fg}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#223D6B45" />
                                <Setter TargetName="b" Property="BorderBrush" Value="#554BA35A" />
                                <Setter Property="Foreground" Value="#FF8FD19E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ExplorerIconButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Bg}" />
                                <Setter Property="Foreground" Value="{DynamicResource Fg}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <DockPanel>
        <Grid DockPanel.Dock="Top" Margin="8,6,6,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Style="{StaticResource ExplorerIconButton}"
                    Click="OnAddFolderToWorkspaceClick"
                    ToolTip="フォルダーをワークスペースに追加">
                <!-- フォルダー＋プラス -->
                <Grid Width="14" Height="13">
                    <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.4"
                          StrokeLineJoin="Round"
                          Data="M1,3 L5,3 L6.5,4.5 L13,4.5 L13,11.5 L1,11.5 Z" />
                    <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.6"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Data="M10,6.5 L10,10.5 M8,8.5 L12,8.5" />
                </Grid>
            </Button>

            <Button Grid.Column="1" Style="{StaticResource ExplorerIconButton}"
                    Command="{Binding ExpandAllCommand}"
                    IsEnabled="{Binding HasVisibleNodes}"
                    ToolTip="すべて展開">
                <Path Width="13" Height="13" Stretch="Uniform"
                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      StrokeThickness="1.7"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      StrokeLineJoin="Round"
                      Data="M2,3 L6.5,7.5 L11,3 M2,8 L6.5,12 L11,8" />
            </Button>

            <Button Grid.Column="2" Style="{StaticResource ExplorerIconButton}"
                    Command="{Binding CollapseAllCommand}"
                    IsEnabled="{Binding HasVisibleNodes}"
                    ToolTip="すべて折りたたみ">
                <Path Width="13" Height="13" Stretch="Uniform"
                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                      StrokeThickness="1.7"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      StrokeLineJoin="Round"
                      Data="M2,5 L6.5,1 L11,5 M2,10 L6.5,6 L11,10" />
            </Button>

            <ToggleButton Grid.Column="3" Style="{StaticResource ExplorerToggleButton}"
                          IsChecked="{Binding HideIgnoredFiles}"
                          ToolTip="ignore を非表示">
                <Path Width="13" Height="13" Stretch="Uniform"
                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                      StrokeThickness="1.7"
                      Data="M1,6.5 A5.5,5.5 0 1 1 12,6.5 A5.5,5.5 0 1 1 1,6.5 M3,10 L10,3" />
            </ToggleButton>

            <ToggleButton Grid.Column="4" Style="{StaticResource ExplorerToggleButton}"
                          IsChecked="{Binding ShowChangedOnly}"
                          ToolTip="変更のみ表示">
                <TextBlock Text="Δ" FontSize="{DynamicResource Fs13}" FontWeight="SemiBold"
                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" />
            </ToggleButton>

            <Button Grid.Column="5" Style="{StaticResource ExplorerIconButton}"
                    Command="{Binding RevealCurrentFileCommand}"
                    ToolTip="エディタの現在のファイルを選択（同期）">
                <!-- 十字照準（現在地を指し示す） -->
                <Grid Width="13" Height="13">
                    <Ellipse Width="7" Height="7"
                             Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                             StrokeThickness="1.5" />
                    <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.5"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Data="M6.5,0 L6.5,2 M6.5,11 L6.5,13 M0,6.5 L2,6.5 M11,6.5 L13,6.5" />
                </Grid>
            </Button>
        </Grid>

        <!-- 常時表示の絞り込み欄。ここに入力するとツリーがその場で絞り込まれる（VM の
             SearchFilter に直結、ロジックは「/」検索と共有）。「/」検索（下部、n/N 一致移動つき）
             とは別物として併存させる。 -->
        <Grid DockPanel.Dock="Top" Margin="8,0,6,6">
            <TextBox x:Name="FilterBox" Padding="6,4"
                     FontSize="{DynamicResource Fs12}"
                     Background="{DynamicResource Bg}"
                     Foreground="{DynamicResource Fg}"
                     BorderBrush="{DynamicResource Border}"
                     BorderThickness="1"
                     CaretBrush="{DynamicResource Fg}"
                     Text="{Binding SearchFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PreviewKeyDown="OnFilterBoxKeyDown" />
            <TextBlock Text="フィルター"
                       IsHitTestVisible="False"
                       FontSize="{DynamicResource Fs12}"
                       Foreground="{DynamicResource FgDim}"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0"
                       Visibility="{Binding Text, ElementName=FilterBox, Converter={StaticResource EmptyToVis}}" />
            <Button Content="✕" Padding="0" Width="18" Height="18"
                    HorizontalAlignment="Right" Margin="0,0,3,0"
                    Style="{StaticResource ExplorerIconButton}"
                    Click="OnClearFilterBoxClick"
                    ToolTip="フィルターを解除"
                    Visibility="{Binding Text, ElementName=FilterBox, Converter={StaticResource NonEmptyToVis}}" />
        </Grid>

        <!-- 表示ルートの切替（単一フォルダー時のみ）。操作ボタンの行とは分け、ツリーの直上に
             専用行として置く。候補はワークスペースルート＋ピン留めフォルダ。複数フォルダー時は
             フォルダーごとの見出し行（ツリー内、下の ItemTemplate）が同じ役割を持つので隠す。 -->
        <StackPanel DockPanel.Dock="Top"
                    Margin="8,0,6,6"
                    Visibility="{Binding IsMultiRootWorkspace, Converter={StaticResource InverseBoolToVis}}">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right"
                        Style="{StaticResource ExplorerIconButton}"
                        Width="22" Height="22"
                        Command="{Binding UnpinCurrentRootCommand}"
                        Visibility="{Binding SelectedRootOption.IsPinned, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}"
                        ToolTip="このフォルダのピン留めを解除">
                    <!-- ピン＋斜線（ピン解除） -->
                    <Path Width="12" Height="12" Stretch="Uniform"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.5"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Data="M9,2 L14,7 L11,8 L8,11 L5,8 L8,5 Z M5,11 L2,14 M2,2 L14,14" />
                </Button>
                <ComboBox MinHeight="24"
                          ItemsSource="{Binding RootOptions}"
                          SelectedItem="{Binding SelectedRootOption, Mode=TwoWay}"
                          DisplayMemberPath="Label"
                          ToolTip="{Binding SelectedRootOption.FullPath}" />
            </DockPanel>
            <TextBlock Text="{Binding FilterStatus}"
                       Foreground="{DynamicResource FgDim}"
                       FontSize="{DynamicResource Fs11}"
                       Opacity="0.72"
                       Margin="0,1,8,0"
                       TextTrimming="CharacterEllipsis" />
        </StackPanel>

        <Border x:Name="SearchBar" DockPanel.Dock="Bottom"
                Visibility="Collapsed"
                Background="{DynamicResource Bg}"
                BorderBrush="{DynamicResource Accent}"
                BorderThickness="0,1,0,0"
                Padding="6,3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="/"
                           Foreground="{DynamicResource FgDim}"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0"
                           FontFamily="Consolas" />
                <TextBox x:Name="SearchBox" Grid.Column="1"
                         Background="Transparent" BorderThickness="0"
                         Foreground="{DynamicResource Fg}"
                         CaretBrush="{DynamicResource Fg}"
                         VerticalContentAlignment="Center"
                         TextChanged="OnSearchTextChanged"
                         PreviewKeyDown="OnSearchKeyDown" />
                <TextBlock x:Name="SearchStatus" Grid.Column="2"
                           Foreground="{DynamicResource FgDim}"
                           VerticalAlignment="Center"
                           Margin="6,0,0,0"
                           FontSize="{DynamicResource Fs11}" />
            </Grid>
        </Border>

        <Grid>
            <TreeView x:Name="FileTree" ItemsSource="{Binding Nodes}" Background="Transparent" BorderThickness="0"
                      Foreground="{DynamicResource Fg}"
                      AllowDrop="True"
                      MouseDoubleClick="OnTreeMouseDoubleClick"
                      PreviewMouseLeftButtonDown="OnTreePreviewMouseLeftButtonDown"
                      PreviewMouseLeftButtonUp="OnTreeMouseLeftButtonUp"
                      PreviewMouseMove="OnTreePreviewMouseMove"
                      DragOver="OnTreeDragOver"
                      Drop="OnTreeDrop"
                      PreviewKeyDown="OnTreeKeyDown"
                      PreviewTextInput="OnTreePreviewTextInput"
                      PreviewMouseRightButtonDown="OnTreeRightButtonDown"
                      Visibility="{Binding HasVisibleNodes, Converter={StaticResource BoolToVis}}">
                <TreeView.ContextMenu>
                    <!-- 空き領域での右クリック（ルート直下に作成） -->
                    <ContextMenu>
                        <MenuItem Header="新規ファイル" Click="OnNewFileClick" />
                        <MenuItem Header="新規フォルダー" Click="OnNewFolderClick" />
                        <Separator />
                        <MenuItem Header="貼り付け" InputGestureText="Ctrl+V" Click="OnPasteClick" />
                    </ContextMenu>
                </TreeView.ContextMenu>
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <!-- 既定の BringIntoView は深い項目を見せようと水平にもスクロールして
                             うっとうしいため、縦方向のみのスクロールに差し替える。 -->
                        <EventSetter Event="RequestBringIntoView" Handler="OnItemRequestBringIntoView" />
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                        <Setter Property="Foreground" Value="{DynamicResource Fg}" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="2,1" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TreeViewItem">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition />
                                        </Grid.RowDefinitions>

                                        <!-- ヘッダ行（矢印＋名前）をまるごと Bd で包む。ハイライトは行全幅で塗られ、
                                             かつ Bd は子（ItemsHost）を含まないので、子をホバーしても親が光らない。 -->
                                        <Border x:Name="Bd"
                                                Grid.Row="0"
                                                Background="Transparent"
                                                CornerRadius="3">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="16" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <ToggleButton x:Name="Expander"
                                                              Grid.Column="0"
                                                              ClickMode="Press"
                                                              Focusable="False"
                                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}">
                                                    <ToggleButton.Template>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <Border Background="Transparent" Width="16" Height="16">
                                                                <Path x:Name="Arrow"
                                                                      Width="8" Height="8"
                                                                      Stretch="Uniform"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"
                                                                      Fill="{DynamicResource FgDim}"
                                                                      Data="M0,0 L4,4 L0,8 Z" />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter TargetName="Arrow" Property="RenderTransform">
                                                                        <Setter.Value>
                                                                            <RotateTransform Angle="90" CenterX="4" CenterY="4" />
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Trigger>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource Fg}" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </ToggleButton.Template>
                                                </ToggleButton>

                                                <ContentPresenter x:Name="PART_Header"
                                                                  Grid.Column="1"
                                                                  ContentSource="Header"
                                                                  Margin="{TemplateBinding Padding}"
                                                                  HorizontalAlignment="Stretch"
                                                                  VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>

                                        <!-- 子要素。左端に淡いガイド線を引いて親子関係を追いやすくし、
                                             矢印列ぶん（16px）だけインデントする。 -->
                                        <Border Grid.Row="1"
                                                Margin="16,0,0,0"
                                                BorderBrush="{DynamicResource Border}"
                                                BorderThickness="1,0,0,0">
                                            <ItemsPresenter x:Name="ItemsHost" />
                                        </Border>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsExpanded" Value="False">
                                            <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed" />
                                        </Trigger>
                                        <Trigger Property="HasItems" Value="False">
                                            <Setter TargetName="Expander" Property="Visibility" Value="Hidden" />
                                        </Trigger>
                                        <!-- ホバーは Bd（ヘッダ行）自身の判定にする。TreeViewItem.IsMouseOver だと
                                             子をホバーしたとき親まで光ってしまうため。 -->
                                        <Trigger SourceName="Bd" Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Border}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Accent}" />
                                            <Setter Property="Foreground" Value="{DynamicResource AccentFg}" />
                                        </Trigger>
                                        <!-- 複数選択（Ctrl/Shift+クリック）。ネイティブの IsSelected とは別の
                                             DataContext 側プロパティなので DataTrigger で見る。 -->
                                        <DataTrigger Binding="{Binding IsMultiSelected}" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Accent}" />
                                            <Setter Property="Foreground" Value="{DynamicResource AccentFg}" />
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TreeView.ItemContainerStyle>
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate DataType="{x:Type vm:FileNodeViewModel}"
                                              ItemsSource="{Binding Children}">
                        <!-- git 差分マーク: 変更名を状態色で着色し、行右端に状態文字（M/A/U/D/R/C）を出す。
                             フォルダは配下に変更があれば名前を着色＋右端にドット（●）。 -->
                        <!-- コンテキストメニューは DataTemplate 側に置く（Style 内では Click ハンドラを
                             直接指定できないため）。配置対象（DockPanel）の DataContext がノード。 -->
                        <!-- 名前の右側の空白でも右クリックをこの DockPanel が受けるよう、透明背景で
                             行全幅をヒットテスト対象にする（無いと背後の TreeView の空白用メニューが出る）。 -->
                        <DockPanel LastChildFill="True" Background="Transparent">
                            <DockPanel.ContextMenu>
                                <ContextMenu Opened="OnNodeContextMenuOpened">
                                    <MenuItem Header="新規ファイル" Click="OnNewFileClick" />
                                    <MenuItem Header="新規フォルダー" Click="OnNewFolderClick" />
                                    <Separator />
                                    <MenuItem Header="コピー" InputGestureText="Ctrl+C" Click="OnCopyClick" />
                                    <MenuItem Header="切り取り" InputGestureText="Ctrl+X" Click="OnCutClick" />
                                    <MenuItem Header="貼り付け" InputGestureText="Ctrl+V" Click="OnPasteClick" />
                                    <Separator />
                                    <MenuItem Header="名前の変更" InputGestureText="F2" Click="OnRenameClick" />
                                    <MenuItem Header="削除" InputGestureText="Delete" Click="OnDeleteClick" />
                                    <Separator />
                                    <!-- HTML ファイルのときだけアプリ内ブラウザで開く項目を出す。 -->
                                    <MenuItem Header="ブラウザで開く" Click="OnOpenInBrowserClick"
                                              Visibility="{Binding IsHtml, Converter={StaticResource BoolToVis}}" />
                                    <MenuItem Header="エクスプローラーで表示" Click="OnRevealInExplorerClick" />
                                    <MenuItem Header="ターミナルにセット" Click="OnSetInTerminalClick" />
                                    <!-- Git リポジトリ配下のときだけ：Git 系操作をまとめる。履歴表示は
                                         ファイル・フォルダ両方（Git ペインをそのパスの履歴に絞る）、Git Blame は
                                         ファイルのみ（エディタ VimEditorControl のネイティブ :Gblame をトリガー）。 -->
                                    <MenuItem Header="Git" Visibility="{Binding CanGitHistory, Converter={StaticResource BoolToVis}}">
                                        <MenuItem Header="履歴を表示" Click="OnGitHistoryClick" />
                                        <MenuItem Header="Git Blame" Click="OnGitBlameClick"
                                                  Visibility="{Binding CanGitBlame, Converter={StaticResource BoolToVis}}" />
                                    </MenuItem>
                                    <!-- フォルダのみ：このフォルダーを検索の開始フォルダーにして検索パネルを開く。 -->
                                    <MenuItem Header="このフォルダーで検索" Click="OnSearchInFolderClick"
                                              Visibility="{Binding IsDirectory, Converter={StaticResource BoolToVis}}" />
                                    <MenuItem Header="パスをコピー" Click="OnCopyPathClick" />
                                    <!-- .gitignore ルート直下に相対パスを1行追加する（Git リポジトリでなければ何もしない）。 -->
                                    <MenuItem Header=".gitignore に追加" Click="OnAddToGitignoreClick" />
                                    <!-- フォルダのみ：ピン留めするとヘッダの ComboBox（単一フォルダー時）／
                                         見出しの「ピン留めフォルダーへ切替」（複数フォルダー時）から表示できる。 -->
                                    <MenuItem Header="ルートにピン留め" Click="OnPinClick"
                                              Visibility="{Binding IsPinnable, Converter={StaticResource BoolToVis}}" />
                                    <MenuItem Header="ピン留めを解除" Click="OnUnpinClick"
                                              Visibility="{Binding IsPinned, Converter={StaticResource BoolToVis}}" />
                                    <!-- 複数フォルダーワークスペースの見出し（ワークスペースフォルダー自身）のみ：
                                         そのフォルダー内のピン留め切替候補・ワークスペースからの除去。
                                         中身は OnNodeContextMenuOpened→PopulateRootSwitchMenu が動的に流し込む。 -->
                                    <MenuItem Header="ピン留めフォルダーへ切替" Tag="RootSwitchMenu"
                                              Visibility="{Binding IsWorkspaceFolderRoot, Converter={StaticResource BoolToVis}}" />
                                    <MenuItem Header="ワークスペースから削除" Click="OnRemoveFromWorkspaceClick"
                                              Visibility="{Binding CanRemoveFromWorkspace, Converter={StaticResource BoolToVis}}" />
                                    <!-- AI 関連（一番下にまとめる）。AIの暖機完了時のみファイルに表示し、
                                         区切り線・「AI」親メニューとも Opened で出し分ける。
                                         AI 操作は「AI」の子メニューとして増やしていく想定。 -->
                                    <Separator Tag="AiMenu" Visibility="Collapsed" />
                                    <MenuItem Header="AI" Tag="AiMenu" Visibility="Collapsed">
                                        <MenuItem Header="誤字脱字チェック" Click="OnTypoCheckClick" />
                                        <!-- 入力ありワークフローを Opened 時に動的に流し込む（候補が無ければ区切り線ごと隠す）。 -->
                                        <Separator Tag="AiWorkflowSep" />
                                        <MenuItem Header="ワークフロー" Tag="AiWorkflowMenu" />
                                    </MenuItem>
                                </ContextMenu>
                            </DockPanel.ContextMenu>
                            <TextBlock x:Name="GitBadge" DockPanel.Dock="Right"
                                       Margin="6,0,4,0"
                                       FontFamily="Consolas" FontSize="{DynamicResource Fs11}" FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed" />
                            <StackPanel x:Name="NormalRow" DockPanel.Dock="Left" Orientation="Horizontal">
                                <Path Data="{Binding IconGeometry}"
                                      Stroke="{Binding IconBrush}"
                                      StrokeThickness="1.5"
                                      StrokeLineJoin="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Width="15" Height="15"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Margin="0,0,7,0" />
                                <TextBlock x:Name="GitName"
                                           views:SearchHighlightBehavior.Text="{Binding Name}"
                                           views:SearchHighlightBehavior.Query="{Binding DataContext.SearchFilter, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                            </StackPanel>
                            <!-- 複数フォルダーワークスペースの見出し行（ワークスペースフォルダー自身）だけ、
                                 通常の行（アイコン＋名前）の代わりにこのフォルダー専用の ComboBox を出す。
                                 候補は自身＋ピン留めしたサブフォルダー（FolderTreeRootState.RootOptions と
                                 同一インスタンス）。GitBadge（●＝配下に変更あり）はそのフォルダーの状態表示
                                 として右端にそのまま残す。 -->
                            <ComboBox x:Name="RootSwitchCombo"
                                      MinHeight="22"
                                      Margin="0,1,0,1"
                                      ItemsSource="{Binding RootSwitchOptions}"
                                      SelectedItem="{Binding SelectedRootSwitchOption, Mode=TwoWay}"
                                      DisplayMemberPath="Label"
                                      ToolTip="{Binding FullPath}"
                                      Visibility="Collapsed" />
                        </DockPanel>
                        <HierarchicalDataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsWorkspaceFolderRoot}" Value="True">
                                <Setter TargetName="NormalRow" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="RootSwitchCombo" Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding GitStatus}" Value="Modified">
                                <Setter TargetName="GitBadge" Property="Text" Value="M" />
                                <Setter TargetName="GitBadge" Property="Foreground" Value="#E2C08D" />
                                <Setter TargetName="GitBadge" Property="Visibility" Value="Visible" />
                                <Setter TargetName="GitName" Property="Foreground" Value="#E2C08D" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding GitStatus}" Value="Added">
                                <Setter TargetName="GitBadge" Property="Text" Value="A" />
                                <Setter TargetName="GitBadge" Property="Foreground" Value="#73C991" />
                                <Setter TargetName="GitBadge" Property="Visibility" Value="Visible" />
                                <Setter TargetName="GitName" Property="Foreground" Value="#73C991" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding GitStatus}" Value="Untracked">
                                <Setter TargetName="GitBadge" Property="Text" Value="U" />
                                <Setter TargetName="GitBadge" Property="Foreground" Value="#73C991" />
                                <Setter TargetName="GitBadge" Property="Visibility" Value="Visible" />
                                <Setter TargetName="GitName" Property="Foreground" Value="#73C991" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding GitStatus}" Value="Deleted">
                                <Setter TargetName="GitBadge" Property="Text" Value="D" />
                                <Setter TargetName="GitBadge" Property="Foreground" Value="#C74E39" />
                                <Setter TargetName="GitBadge" Property="Visibility" Value="Visible" />
                                <Setter TargetName="GitName" Property="Foreground" Value="#C74E39" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding GitStatus}" Value="Renamed">
                                <Setter TargetName="GitBadge" Property="Text" Value="R" />
                                <Setter TargetName="GitBadge" Property="Foreground" Value="#73C991" />
                                <Setter TargetName="GitBadge" Property="Visibility" Value="Visible" />
                                <Setter TargetName="GitName" Property="Foreground" Value="#73C991" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding GitStatus}" Value="Conflicted">
                                <Setter TargetName="GitBadge" Property="Text" Value="C" />
                                <Setter TargetName="GitBadge" Property="Foreground" Value="#E4676B" />
                                <Setter TargetName="GitBadge" Property="Visibility" Value="Visible" />
                                <Setter TargetName="GitName" Property="Foreground" Value="#E4676B" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding GitStatus}" Value="DirectoryChanged">
                                <Setter TargetName="GitBadge" Property="Text" Value="●" />
                                <Setter TargetName="GitBadge" Property="Foreground" Value="#E2C08D" />
                                <Setter TargetName="GitBadge" Property="Visibility" Value="Visible" />
                                <Setter TargetName="GitName" Property="Foreground" Value="#E2C08D" />
                            </DataTrigger>
                            <!-- 選択中は Accent 背景に git 色名が低コントラストになるため、名前だけ白へ戻す。
                                 トリガは後勝ちなので、上の状態色より優先される（右端バッジの色はそのまま）。 -->
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="GitName" Property="Foreground" Value="#FFFFFFFF" />
                            </DataTrigger>
                        </HierarchicalDataTemplate.Triggers>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>

            <Border Visibility="{Binding HasVisibleNodes, Converter={StaticResource InverseBoolToVis}}"
                    Padding="14,18">
                <TextBlock Text="{Binding EmptyMessage}"
                           Foreground="{DynamicResource FgDim}"
                           FontSize="{DynamicResource Fs12}"
                           TextWrapping="Wrap" />
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
