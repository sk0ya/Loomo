<UserControl x:Class="sk0ya.Loomo.App.Views.FolderTreeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:sk0ya.Loomo.App.ViewModels"
    Background="{StaticResource BgAlt}">

    <UserControl.Resources>
        <Style x:Key="ExplorerToggleButton" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{StaticResource FgDim}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="b"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource Bg}" />
                                <Setter Property="Foreground" Value="{StaticResource Fg}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#223D6B45" />
                                <Setter TargetName="b" Property="BorderBrush" Value="#554BA35A" />
                                <Setter Property="Foreground" Value="#FF8FD19E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <DockPanel>
        <Grid DockPanel.Dock="Top" Margin="8,6,6,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="{Binding RootLabel}"
                           Foreground="{StaticResource FgDim}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{Binding FilterStatus}"
                       Foreground="{StaticResource FgDim}"
                       FontSize="11"
                       Opacity="0.72"
                       Margin="0,1,8,0"
                       TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <ToggleButton Grid.Column="1" Style="{StaticResource ExplorerToggleButton}"
                          IsChecked="{Binding HideIgnoredFiles}"
                          ToolTip="ignore を非表示">
                <Path Width="13" Height="13" Stretch="Uniform"
                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                      StrokeThickness="1.7"
                      Data="M1,6.5 A5.5,5.5 0 1 1 12,6.5 A5.5,5.5 0 1 1 1,6.5 M3,10 L10,3" />
            </ToggleButton>

            <ToggleButton Grid.Column="2" Style="{StaticResource ExplorerToggleButton}"
                          Margin="2,0,0,0"
                          IsChecked="{Binding ShowChangedOnly}"
                          ToolTip="変更のみ表示">
                <TextBlock Text="Δ" FontSize="13" FontWeight="SemiBold"
                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" />
            </ToggleButton>
        </Grid>

        <Grid>
            <TreeView ItemsSource="{Binding Nodes}" Background="Transparent" BorderThickness="0"
                      Foreground="{StaticResource Fg}"
                      Visibility="{Binding HasVisibleNodes, Converter={StaticResource BoolToVis}}">
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                    </Style>
                </TreeView.ItemContainerStyle>
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate DataType="{x:Type vm:FileNodeViewModel}"
                                              ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Glyph}" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding Name}" />
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>

            <Border Visibility="{Binding HasVisibleNodes, Converter={StaticResource InverseBoolToVis}}"
                    Padding="14,18">
                <TextBlock Text="{Binding EmptyMessage}"
                           Foreground="{StaticResource FgDim}"
                           FontSize="12"
                           TextWrapping="Wrap" />
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
