<UserControl x:Class="sk0ya.Loomo.App.Views.TabsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BgAlt}">

    <UserControl.Resources>
        <DataTemplate x:Key="TabEntryTemplate">
            <Border x:Name="TabBorder" Margin="0,2" Background="Transparent"
                    BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="4">
                <Button Padding="8,5" HorizontalContentAlignment="Left" Foreground="{StaticResource Fg}"
                        Command="{Binding DataContext.ActivateTabCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                </Button>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter TargetName="TabBorder" Property="Background" Value="{StaticResource Bg}" />
                    <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource Accent}" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </UserControl.Resources>

    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Style="{StaticResource PanelHeader}" Text="TABS" />

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8,0,8,10">
            <StackPanel>
                <TextBlock Style="{StaticResource FieldLabel}" Text="TERMINAL" />
                <ItemsControl ItemsSource="{Binding TerminalTabs}" ItemTemplate="{StaticResource TabEntryTemplate}" />

                <TextBlock Style="{StaticResource FieldLabel}" Text="EDITOR" Margin="0,14,0,3" />
                <ItemsControl ItemsSource="{Binding EditorTabs}" ItemTemplate="{StaticResource TabEntryTemplate}" />

                <TextBlock Style="{StaticResource FieldLabel}" Text="BROWSER" Margin="0,14,0,3" />
                <ItemsControl ItemsSource="{Binding BrowserTabs}" ItemTemplate="{StaticResource TabEntryTemplate}" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
