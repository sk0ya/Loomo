<UserControl x:Class="sk0ya.Loomo.App.Views.TsDebugView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:sk0ya.Loomo.App.ViewModels"
    xmlns:v="clr-namespace:sk0ya.Loomo.App.Views"
    xmlns:dbg="clr-namespace:sk0ya.Loomo.Core.Debug;assembly=sk0ya.Loomo.Core"
    Background="{DynamicResource BgAlt}">

    <UserControl.Resources>
        <SolidColorBrush x:Key="DebugStderr" Color="#E06C75" />

        <!-- インラインタブ（自動・コールスタック）の項目コピー。x:Shared="False" で参照ごとに別インスタンス。 -->
        <ContextMenu x:Key="CopyItemMenu" x:Shared="False">
            <MenuItem Header="コピー" Click="OnCopyItemClick" />
        </ContextMenu>

        <!-- 検査タブ（出力／変数／…／構成）。下線で選択を示すフラットなタブ（DebugView と同じ意匠）。 -->
        <Style x:Key="DebugTabItem" TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
            <Setter Property="FontSize" Value="{DynamicResource Fs11}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Padding="10,5" Margin="0,0,2,0"
                                Background="Transparent"
                                BorderBrush="Transparent" BorderThickness="0,0,0,2">
                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource Fg}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Accent}" />
                                <Setter Property="Foreground" Value="{DynamicResource Fg}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DebugTabControl" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Background="{DynamicResource Panel}"
                                    BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
                                <!-- タブが増えても折り返さず横スクロールで送る（タブより上には何も足さない）。 -->
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                              PanningMode="HorizontalOnly">
                                    <TabPanel IsItemsHost="True" Background="Transparent" Margin="4,2,4,0" />
                                </ScrollViewer>
                            </Border>
                            <ContentPresenter ContentSource="SelectedContent" />
                        </DockPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- TS IDE ペインのタブシェル。dotnet 用 DebugView のクローンから「モジュール」（js-debug 非対応）を
         除いた 10 タブ構成（テストは vitest / jest）。ヘッダ（TS IDE ラベル・状態・デバッグツールバー）はホスト
         （ペインヘッダ）側が出す。DataContext は TsDebugViewModel（ファサード）。 -->
    <DockPanel>
        <TabControl x:Name="DebugTabs" Style="{StaticResource DebugTabControl}"
                    Margin="6,0,6,6" SelectedIndex="0" SelectionChanged="OnDebugTabChanged">

            <!-- 0 構成 -->
            <TabItem Style="{StaticResource DebugTabItem}" Header="構成">
                <v:TsDebugConfigView />
            </TabItem>

            <!-- 1 出力：テキスト選択できる読み取り専用 RichTextBox（行は Category で色分け）。
                 ドキュメントの構築・追記・末尾スクロールはコードビハインド（Output コレクションを写す）。 -->
            <TabItem Style="{StaticResource DebugTabItem}" Header="出力">
                <Border Background="{DynamicResource Bg}" BorderBrush="{DynamicResource Border}"
                        BorderThickness="1" Margin="0,4,0,0">
                    <RichTextBox x:Name="ConsoleBox" IsReadOnly="True" IsReadOnlyCaretVisible="True"
                                 IsDocumentEnabled="True" Background="Transparent" Padding="6,4"
                                 Foreground="{DynamicResource Fg}" BorderThickness="0"
                                 FontFamily="Consolas" FontSize="{DynamicResource Fs12}"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <RichTextBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="コピー" Command="Copy" />
                                <MenuItem Header="すべて選択" Command="SelectAll" />
                            </ContextMenu>
                        </RichTextBox.ContextMenu>
                    </RichTextBox>
                </Border>
            </TabItem>

            <!-- 2 問題：tsc 型チェック出力から抽出したエラー/警告。デバッグセッション非依存。 -->
            <TabItem Style="{StaticResource DebugTabItem}" Header="問題">
                <v:DebugProblemsView DataContext="{Binding Problems}" />
            </TabItem>

            <!-- 3 変数（＋ウォッチ） -->
            <TabItem Style="{StaticResource DebugTabItem}" Header="変数">
                <v:DebugVariablesView DataContext="{Binding Inspection}" />
            </TabItem>

            <!-- 4 自動（Autos）：停止行とその直前行で使われている変数だけを近似表示する。 -->
            <TabItem Style="{StaticResource DebugTabItem}" Header="自動">
                <Grid Margin="0,4,0,0">
                    <ListBox ItemsSource="{Binding Inspection.Autos}" Background="{DynamicResource Bg}"
                             BorderBrush="{DynamicResource Border}" BorderThickness="1" Foreground="{DynamicResource Fg}"
                             HorizontalContentAlignment="Stretch"
                             ToolTip="現在行とその直前行で使われている変数（ベストエフォート）"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:WatchItemViewModel}">
                                <Grid Margin="0,1" ContextMenu="{StaticResource CopyItemMenu}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Expression}" FontSize="{DynamicResource Fs11}" FontFamily="Consolas" />
                                    <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="{DynamicResource Fs11}" FontFamily="Consolas"
                                               Foreground="{DynamicResource Accent}" Margin="6,0,0,0"
                                               TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Text="停止すると自動変数が表示されます" Foreground="{DynamicResource FgDim}"
                               FontSize="{DynamicResource Fs11}" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding IsStopped, Converter={StaticResource InverseBoolToVis}}" />
                    <TextBlock Text="この行に表示できる変数がありません" Foreground="{DynamicResource FgDim}"
                               FontSize="{DynamicResource Fs11}" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsStopped}" Value="True" />
                                            <Condition Binding="{Binding Inspection.HasAutos}" Value="False" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </TabItem>

            <!-- 5 コールスタック -->
            <TabItem Style="{StaticResource DebugTabItem}" Header="コールスタック">
                <Grid Margin="0,4,0,0">
                    <ListBox ItemsSource="{Binding Inspection.CallStack}" SelectedItem="{Binding Inspection.SelectedFrame, Mode=TwoWay}"
                             Background="{DynamicResource Bg}" BorderBrush="{DynamicResource Border}" BorderThickness="1"
                             Foreground="{DynamicResource Fg}"
                             MouseDoubleClick="OnCallStackDoubleClick"
                             ToolTip="クリックでソースをプレビュー、ダブルクリックでジャンプ"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:DebugFrameViewModel}">
                                <StackPanel Orientation="Horizontal" ContextMenu="{StaticResource CopyItemMenu}">
                                    <TextBlock Text="{Binding Name}" FontSize="{DynamicResource Fs11}" FontFamily="Consolas"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Location}" FontSize="{DynamicResource Fs11}" Opacity="0.6" Margin="8,0,0,0" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Text="停止するとコールスタックが表示されます" Foreground="{DynamicResource FgDim}"
                               FontSize="{DynamicResource Fs11}" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding IsStopped, Converter={StaticResource InverseBoolToVis}}" />
                </Grid>
            </TabItem>

            <!-- 6 テスト（vitest / jest。ビューは dotnet 版と共有） -->
            <TabItem Style="{StaticResource DebugTabItem}" Header="テスト">
                <v:DebugTestsView DataContext="{Binding Tests}" />
            </TabItem>

            <!-- 7 スレッド：停止時に実行中スレッドを並べ、選択でアクティブ（コールスタック/ステップの対象）を切替。 -->
            <TabItem Style="{StaticResource DebugTabItem}" Header="スレッド">
                <Grid Margin="0,4,0,0">
                    <ListBox ItemsSource="{Binding Inspection.Threads}" SelectedItem="{Binding Inspection.SelectedThread, Mode=TwoWay}"
                             Background="{DynamicResource Bg}" BorderBrush="{DynamicResource Border}" BorderThickness="1"
                             Foreground="{DynamicResource Fg}"
                             ToolTip="選択でそのスレッドのコールスタック・変数に切り替える"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type dbg:DebugThread}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Id}" FontSize="{DynamicResource Fs11}" FontFamily="Consolas"
                                               Foreground="{DynamicResource FgDim}" Width="40" />
                                    <TextBlock Text="{Binding Name}" FontSize="{DynamicResource Fs11}" FontFamily="Consolas"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock Text="停止するとスレッドが表示されます" Foreground="{DynamicResource FgDim}"
                               FontSize="{DynamicResource Fs11}" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding IsStopped, Converter={StaticResource InverseBoolToVis}}" />
                </Grid>
            </TabItem>

            <!-- 8 ブレークポイント -->
            <TabItem Style="{StaticResource DebugTabItem}" Header="ブレークポイント">
                <v:DebugBreakpointsView DataContext="{Binding Breakpoints}" />
            </TabItem>

            <!-- 9 イミディエイト -->
            <TabItem Style="{StaticResource DebugTabItem}" Header="イミディエイト">
                <v:DebugImmediateView DataContext="{Binding Inspection}" />
            </TabItem>
        </TabControl>
    </DockPanel>
</UserControl>
