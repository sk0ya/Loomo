<UserControl x:Class="sk0ya.Loomo.App.Views.PegboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{DynamicResource BgAlt}" Focusable="True">

    <UserControl.Resources>
        <!-- カード上の小さな操作ボタン（フラット・高密度） -->
        <Style x:Key="CardButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="Transparent" Padding="{TemplateBinding Padding}"
                                CornerRadius="2">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Border}" />
                                <Setter Property="Foreground" Value="{DynamicResource Fg}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Style="{StaticResource PanelHeader}" Text="ペグボード" />

        <!-- 追加操作（サイドバーパネルの流儀＝SessionsView と同じ FlatButton 縦積み） -->
        <Button DockPanel.Dock="Top" Margin="10,2,10,2" Content="＋ クリップボードから追加"
                Style="{StaticResource FlatButton}" HorizontalAlignment="Stretch"
                ToolTip="クリップボードのテキストをカードとして貼る（URL・ファイルパスは自動判別）"
                Command="{Binding AddFromClipboardCommand}" />
        <Button DockPanel.Dock="Top" Margin="10,0,10,8" Content="📌 ブラウザのURLをピン"
                Style="{StaticResource FlatButton}" HorizontalAlignment="Stretch"
                ToolTip="ブラウザペインで表示中のページを貼る"
                Command="{Binding PinBrowserUrlCommand}" />

        <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Items}" Margin="2">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource Bg}" CornerRadius="3"
                                BorderThickness="1" Margin="4,2" Padding="6,3">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Pinned}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <DockPanel>
                                <!-- 見出し行：種別・タイトル・作成時刻・操作 -->
                                <DockPanel DockPanel.Dock="Top" LastChildFill="True">
                                    <TextBlock DockPanel.Dock="Left" Text="{Binding TypeGlyph}" FontSize="11"
                                               Margin="0,0,4,0" VerticalAlignment="Center" />
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <TextBlock Text="{Binding CreatedLabel}" FontSize="10"
                                                   Foreground="{DynamicResource FgDim}" Margin="0,0,4,0"
                                                   VerticalAlignment="Center" />
                                        <Button Style="{StaticResource CardButton}" Content="📌"
                                                ToolTip="上部に固定／解除"
                                                Command="{Binding DataContext.TogglePinCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}" />
                                        <Button Style="{StaticResource CardButton}" Content="コピー"
                                                Command="{Binding DataContext.CopyCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}" />
                                        <Button Style="{StaticResource CardButton}" Content="{Binding OpenLabel}"
                                                Command="{Binding DataContext.OpenCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}" />
                                        <Button Style="{StaticResource CardButton}" Content="✕" ToolTip="削除"
                                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding DisplayTitle}" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource Fg}" TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding Content}" VerticalAlignment="Center" />
                                </DockPanel>
                                <!-- 本文プレビュー（単一行で見出しと同じなら出さない） -->
                                <TextBlock Text="{Binding Preview}" FontSize="11"
                                           FontFamily="Cascadia Mono, Consolas"
                                           Foreground="{DynamicResource FgDim}" TextTrimming="CharacterEllipsis"
                                           TextWrapping="Wrap" MaxHeight="48" Margin="0,1,0,0"
                                           ToolTip="{Binding Content}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Preview}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        <TextBlock Margin="12,8" Text="{Binding EmptyMessage}" TextWrapping="Wrap"
                   Foreground="{DynamicResource FgDim}">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding EmptyMessage}" Value="">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>
        </Grid>
    </DockPanel>
</UserControl>
