<Window x:Class="sk0ya.Loomo.App.Views.MarkdownTableGridWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="テーブルを編集"
    Width="820"
    Height="520"
    MinWidth="360"
    MinHeight="240"
    WindowStartupLocation="CenterOwner"
    Background="{DynamicResource Bg}"
    FontFamily="Segoe UI">
    <DockPanel Margin="12">
        <TextBlock DockPanel.Dock="Top"
                   Foreground="{DynamicResource FgDim}"
                   FontSize="{DynamicResource Fs12}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8"
                   Text="グリッドでセルを編集できます（Vim キーバインド対応）。閉じると元の Markdown テーブルへ反映します。" />

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="反映して閉じる"
                    Style="{StaticResource FlatButton}"
                    IsDefault="True"
                    MinWidth="120"
                    Click="OnApply" />
            <Button Content="キャンセル"
                    Style="{StaticResource FlatButton}"
                    Background="{DynamicResource BgAlt}"
                    Foreground="{DynamicResource Fg}"
                    IsCancel="True"
                    MinWidth="92"
                    Margin="8,0,0,0"
                    Click="OnCancel" />
        </StackPanel>

        <Border x:Name="GridHost"
                BorderBrush="{DynamicResource Border}"
                BorderThickness="1" />
    </DockPanel>
</Window>
