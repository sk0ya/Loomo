<UserControl x:Class="sk0ya.Loomo.App.Views.GitPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{DynamicResource BgAlt}">

    <UserControl.Resources>
        <!-- 変更行の小さな操作ボタン（ホバーで浮き出る） -->
        <Style x:Key="RowActionButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Width" Value="22" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Border}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 変更行本体（クリックで差分を開く） -->
        <Style x:Key="ChangeRowButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" Padding="4,2" CornerRadius="3">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Bg}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Style="{StaticResource PanelHeader}" Text="GIT" />

        <!-- リポジトリでないとき -->
        <StackPanel DockPanel.Dock="Top" Margin="10,4"
                    Visibility="{Binding IsRepository, Converter={StaticResource InverseBoolToVis}}">
            <TextBlock Text="このフォルダは git リポジトリではありません。"
                       TextWrapping="Wrap" Foreground="{DynamicResource FgDim}" />
            <Button Margin="0,8,0,0" Content="リポジトリを初期化 (git init)"
                    Style="{StaticResource FlatButton}" HorizontalAlignment="Stretch"
                    Command="{Binding InitRepositoryCommand}" />
        </StackPanel>

        <DockPanel Visibility="{Binding IsRepository, Converter={StaticResource BoolToVis}}">

            <!-- ブランチ＋同期操作 -->
            <DockPanel DockPanel.Dock="Top" Margin="10,0,10,6" LastChildFill="True">
                <Button DockPanel.Dock="Right" Style="{StaticResource RowActionButton}" Content="↻"
                        ToolTip="更新" Command="{Binding RefreshCommand}" />
                <Button DockPanel.Dock="Right" Style="{StaticResource RowActionButton}" Content="⇡"
                        ToolTip="プッシュ" Command="{Binding PushCommand}" />
                <Button DockPanel.Dock="Right" Style="{StaticResource RowActionButton}" Content="⇣"
                        ToolTip="プル" Command="{Binding PullCommand}" />
                <Button DockPanel.Dock="Right" Style="{StaticResource RowActionButton}" Content="⭮"
                        ToolTip="フェッチ" Command="{Binding FetchCommand}" />
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⎇" Foreground="{DynamicResource FgDim}" Margin="0,0,4,0" />
                    <TextBlock Text="{Binding BranchLabel}" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" MaxWidth="110"
                               ToolTip="{Binding BranchLabel}" />
                    <TextBlock Text="{Binding SyncLabel}" Foreground="{DynamicResource FgDim}" Margin="6,0,0,0" />
                </StackPanel>
            </DockPanel>

            <!-- コミットメッセージ＋コミット -->
            <StackPanel DockPanel.Dock="Top" Margin="10,0,10,6">
                <TextBox Text="{Binding CommitMessage, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="48" MaxHeight="120"
                         VerticalScrollBarVisibility="Auto"
                         ToolTip="コミットメッセージ" />
                <DockPanel Margin="0,6,0,0">
                    <CheckBox DockPanel.Dock="Right" Content="amend" VerticalAlignment="Center"
                              Foreground="{DynamicResource FgDim}" Margin="8,0,0,0"
                              IsChecked="{Binding Amend}" />
                    <Button Content="✓ コミット" Style="{StaticResource FlatButton}"
                            HorizontalAlignment="Stretch"
                            Command="{Binding CommitCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                </DockPanel>
            </StackPanel>

            <!-- セッションを開く -->
            <Button DockPanel.Dock="Top" Margin="10,0,10,6" Style="{StaticResource FlatButton}"
                    HorizontalAlignment="Stretch" Content="🌳 Git セッションを開く"
                    ToolTip="ログツリー・ブランチ操作・リベースなどは Git ペインで行う"
                    Command="{Binding OpenSessionCommand}" />

            <!-- 実行結果メッセージ -->
            <TextBlock DockPanel.Dock="Bottom" Margin="10,4,10,8" FontSize="11"
                       Text="{Binding StatusMessage}" TextWrapping="Wrap" MaxHeight="80">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding StatusIsError}" Value="True">
                                <Setter Property="Foreground" Value="#FFE57373" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding StatusMessage}" Value="">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- 変更一覧（ステージ済み／変更） -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="6,0">
                <StackPanel>
                    <!-- ステージ済み -->
                    <DockPanel Margin="4,2">
                        <Button DockPanel.Dock="Right" Style="{StaticResource RowActionButton}" Content="−"
                                ToolTip="すべてアンステージ" Command="{Binding UnstageAllCommand}" />
                        <TextBlock Foreground="{DynamicResource FgDim}" FontSize="11" FontWeight="SemiBold">
                            <Run Text="ステージ済み" /><Run Text=" " /><Run Text="{Binding Staged.Count, Mode=OneWay}" />
                        </TextBlock>
                    </DockPanel>
                    <ItemsControl ItemsSource="{Binding Staged}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="4,0">
                                    <Button DockPanel.Dock="Right" Style="{StaticResource RowActionButton}" Content="−"
                                            ToolTip="アンステージ"
                                            Command="{Binding DataContext.UnstageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}" />
                                    <Button Style="{StaticResource ChangeRowButton}" ToolTip="{Binding ToolTipText}"
                                            Command="{Binding DataContext.OpenDiffCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Status}" Width="14" Foreground="{DynamicResource Accent}"
                                                       FontFamily="Cascadia Mono, Consolas" />
                                            <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Directory}" Foreground="{DynamicResource FgDim}"
                                                       FontSize="11" Margin="6,1,0,0" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Button>
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 変更（未ステージ・未追跡・コンフリクト） -->
                    <DockPanel Margin="4,8,4,2">
                        <Button DockPanel.Dock="Right" Style="{StaticResource RowActionButton}" Content="＋"
                                ToolTip="すべてステージ" Command="{Binding StageAllCommand}" />
                        <TextBlock Foreground="{DynamicResource FgDim}" FontSize="11" FontWeight="SemiBold">
                            <Run Text="変更" /><Run Text=" " /><Run Text="{Binding Unstaged.Count, Mode=OneWay}" />
                        </TextBlock>
                    </DockPanel>
                    <ItemsControl ItemsSource="{Binding Unstaged}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="4,0">
                                    <Button DockPanel.Dock="Right" Style="{StaticResource RowActionButton}" Content="＋"
                                            ToolTip="ステージ"
                                            Command="{Binding DataContext.StageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}" />
                                    <Button DockPanel.Dock="Right" Style="{StaticResource RowActionButton}" Content="↶"
                                            ToolTip="変更を破棄"
                                            Command="{Binding DataContext.DiscardCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}" />
                                    <Button Style="{StaticResource ChangeRowButton}" ToolTip="{Binding ToolTipText}"
                                            Command="{Binding DataContext.OpenDiffCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Status}" Width="14"
                                                       FontFamily="Cascadia Mono, Consolas">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsConflicted}" Value="True">
                                                                <Setter Property="Foreground" Value="#FFE57373" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Directory}" Foreground="{DynamicResource FgDim}"
                                                       FontSize="11" Margin="6,1,0,0" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Button>
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </DockPanel>
</UserControl>
