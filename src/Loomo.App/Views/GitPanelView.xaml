<UserControl x:Class="sk0ya.Loomo.App.Views.GitPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:sk0ya.Loomo.App.ViewModels"
    Background="{DynamicResource BgAlt}">

    <UserControl.Resources>
        <!-- 同期操作ボタン（フェッチ・プル・プッシュ）。アイコン＋件数を載せられるよう可変幅。
             件数の色分けは中の TextBlock 側で行うので、ここでは前景色を触らない。 -->
        <Style x:Key="SyncButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="7,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Border}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="b" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 同期ボタンの矢印：対象がある（件数>0）ときアクセント色、無いとき淡色 -->
        <Style x:Key="SyncArrow" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
        </Style>
        <!-- 同期ボタンの件数：対象があるときだけ表示し、アクセント色で目立たせる -->
        <Style x:Key="SyncCount" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="3,0,0,0" />
            <Setter Property="Foreground" Value="{DynamicResource Accent}" />
        </Style>

        <!-- 変更行・セクションの小さな操作ボタン（ホバーで浮き出る） -->
        <Style x:Key="RowActionButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="20" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Border}" />
                                <Setter Property="Foreground" Value="{DynamicResource Fg}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 変更行コンテナ（クリック=選択 / ダブルクリックで開く・コードビハインド）。
             既定の選択クロムを差し替え、ホバー=Bg・選択=Border の控えめなハイライトにする。 -->
        <Style x:Key="ChangeRowItem" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <!-- Border の Background はテンプレートバインドで ListBoxItem.Background を映す。
                             選択色は下の Style.Triggers で ListBoxItem.Background を差し替えて反映させる
                             （ControlTemplate のトリガーで Border を直接塗ると、Border 側のローカル値に
                             負けて効かない＝WPF の値優先順位の罠）。 -->
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- ホバーでは何も変えない。選択行だけアクセント色で塗り、連続選択は
                     同色の帯になってひと塊に見える（角丸ゼロ＋行間ゼロ）。 -->
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SelectionBg}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- セクション見出しの一括操作群（常時表示）。 -->
        <Style x:Key="HeaderActions" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="GitChangeTreeItem" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
            <Setter Property="Foreground" Value="{DynamicResource Fg}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <!-- 行クリックで開閉できるよう、矢印だけでなく行全体を当たり判定にする
                                 （実際のトグルはコードビハインドの ChangeTree_PreviewMouseLeftButtonDown）。 -->
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="3" Padding="0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="11" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Path x:Name="Arrow" Grid.Column="0" Width="6" Height="6" Stretch="Uniform"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          RenderTransformOrigin="0.5,0.5"
                                          Fill="{DynamicResource FgDim}" Data="M0,0 L4,4 L0,8 Z" />
                                    <ContentPresenter Grid.Column="1" ContentSource="Header"
                                                      HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                            <Border x:Name="ItemsHost" Margin="9,0,0,0"
                                    BorderBrush="{DynamicResource Border}" BorderThickness="1,0,0,0">
                                <ItemsPresenter />
                            </Border>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="Arrow" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="90" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Arrow" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger SourceName="Bd" Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Border}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SelectionBg}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <HierarchicalDataTemplate x:Key="GitChangeTreeTemplate"
                                  DataType="{x:Type vm:GitChangeTreeNode}"
                                  ItemsSource="{Binding Children}">
            <DockPanel Background="Transparent" ToolTip="{Binding Change.ToolTipText}">
                <CheckBox DockPanel.Dock="Left" IsChecked="{Binding IsChecked, Mode=TwoWay}"
                          IsThreeState="{Binding IsDirectory}" VerticalAlignment="Center" Margin="1,0,6,0"
                          ToolTip="配下をコミット対象に含める／除外する" />
                <Border DockPanel.Dock="Right" Background="{DynamicResource Border}" CornerRadius="7"
                        Padding="6,0" MinWidth="18" Height="15" Margin="6,0,0,0"
                        VerticalAlignment="Center"
                        Visibility="{Binding IsSection, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding LeafCount}" FontSize="10" Foreground="{DynamicResource Fg}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock DockPanel.Dock="Right" Text="{Binding Change.Status}" Width="16" Margin="4,0,2,0"
                           Foreground="{Binding Change.Status, Converter={StaticResource GitStatusBrush}}"
                           TextAlignment="Center" FontWeight="SemiBold" VerticalAlignment="Center"
                           FontFamily="Cascadia Mono, Consolas">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="Normal" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </DockPanel>
        </HierarchicalDataTemplate>

        <!-- 作業ツリーの行（ファイル）の右クリックメニュー。PlacementTarget は TreeView。
             右クリック時にコードビハインドで対象ノードを選択してから、その1ファイルに作用する。 -->
        <ContextMenu x:Key="WorkingTreeRowMenu">
            <MenuItem Header="ファイルを開く"
                      Command="{Binding PlacementTarget.DataContext.OpenFileCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.SelectedItem.Change, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
            <MenuItem Header="差分を開く"
                      Command="{Binding PlacementTarget.DataContext.OpenDiffCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.SelectedItem.Change, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
            <Separator />
            <MenuItem Header="このファイルをステージ"
                      Command="{Binding PlacementTarget.DataContext.StageCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.SelectedItem.Change, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
            <MenuItem Header="このファイルを破棄"
                      Command="{Binding PlacementTarget.DataContext.DiscardCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.SelectedItem.Change, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
        </ContextMenu>

        <!-- 変更行の右クリックメニュー（ステージ済みセクション用） -->
        <ContextMenu x:Key="StagedRowMenu">
            <MenuItem Header="ファイルを開く"
                      Command="{Binding PlacementTarget.DataContext.OpenFileCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
            <MenuItem Header="差分を開く"
                      Command="{Binding PlacementTarget.DataContext.OpenDiffCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
            <Separator />
            <MenuItem Header="選択をアンステージ"
                      Command="{Binding PlacementTarget.DataContext.UnstageSelectedCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
        </ContextMenu>

        <!-- 件数ピル（セクション見出しの右） -->
        <Style x:Key="CountPill" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Border}" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="MinWidth" Value="18" />
            <Setter Property="Height" Value="15" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="6,0,0,0" />
        </Style>
    </UserControl.Resources>

    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Style="{StaticResource PanelHeader}" Text="GIT" />

        <!-- リポジトリでないとき -->
        <StackPanel DockPanel.Dock="Top" Margin="10,4"
                    Visibility="{Binding IsRepository, Converter={StaticResource InverseBoolToVis}}">
            <TextBlock Text="このフォルダは git リポジトリではありません。"
                       TextWrapping="Wrap" Foreground="{DynamicResource FgDim}" />
            <Button Margin="0,8,0,0" Content="リポジトリを初期化 (git init)"
                    Style="{StaticResource FlatButton}" HorizontalAlignment="Stretch"
                    Command="{Binding InitRepositoryCommand}" />
        </StackPanel>

        <DockPanel Visibility="{Binding IsRepository, Converter={StaticResource BoolToVis}}">

            <!-- ブランチ＋同期操作（カード・2行） -->
            <Border DockPanel.Dock="Top" Margin="8,2,8,6" Padding="8,6" CornerRadius="5"
                    Background="{DynamicResource Bg}">
                <StackPanel>
                    <!-- 1行目：ブランチ名（全幅。長くてもここで省略表示） -->
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⎇" FontSize="14" Foreground="{DynamicResource Accent}"
                                   VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="{Binding BranchLabel}" FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding BranchLabel}" />
                    </StackPanel>

                    <!-- 2行目：同期操作。プル/プッシュは件数を出して対象の有無を見える化する。 -->
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Button Style="{StaticResource SyncButton}" ToolTip="フェッチ（リモートの最新を取得）"
                                Command="{Binding FetchCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⭮" Style="{StaticResource SyncArrow}" />
                                <TextBlock Text="フェッチ" FontSize="11" VerticalAlignment="Center"
                                           Margin="5,0,0,0" Foreground="{DynamicResource FgDim}" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SyncButton}" ToolTip="プル（リモートの変更を取り込む）"
                                Command="{Binding PullCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="↓" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource SyncArrow}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Behind, Converter={StaticResource CountToVis}}" Value="Visible">
                                                    <Setter Property="Foreground" Value="{DynamicResource Accent}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding Behind}" Style="{StaticResource SyncCount}"
                                           Visibility="{Binding Behind, Converter={StaticResource CountToVis}}" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SyncButton}" ToolTip="プッシュ（ローカルの変更を送る）"
                                Command="{Binding PushCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="↑" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource SyncArrow}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Ahead, Converter={StaticResource CountToVis}}" Value="Visible">
                                                    <Setter Property="Foreground" Value="{DynamicResource Accent}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding Ahead}" Style="{StaticResource SyncCount}"
                                           Visibility="{Binding Ahead, Converter={StaticResource CountToVis}}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- コミットメッセージ＋コミット -->
            <StackPanel DockPanel.Dock="Top" Margin="8,0,8,6">
                <Grid>
                    <TextBox Text="{Binding CommitMessage, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap" MinHeight="52" MaxHeight="120"
                             VerticalScrollBarVisibility="Auto">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Modifiers="Ctrl" Command="{Binding CommitCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>
                    <TextBlock Text="メッセージ（Ctrl+Enter でコミット）" Foreground="{DynamicResource FgDim}"
                               Margin="9,7,0,0" IsHitTestVisible="False" VerticalAlignment="Top"
                               Visibility="{Binding CommitMessage, Converter={StaticResource EmptyToVis}}" />
                </Grid>
                <DockPanel Margin="0,6,0,0">
                    <CheckBox DockPanel.Dock="Right" Content="amend" VerticalAlignment="Center"
                              Foreground="{DynamicResource FgDim}" Margin="8,0,0,0"
                              IsChecked="{Binding Amend}" />
                    <Button Content="✓ コミット" Style="{StaticResource FlatButton}"
                            HorizontalAlignment="Stretch"
                            ToolTip="チェックしたファイルだけをコミットします。"
                            Command="{Binding CommitCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                </DockPanel>
            </StackPanel>

            <!-- 実行結果メッセージ -->
            <TextBlock DockPanel.Dock="Bottom" Margin="10,4,10,8" FontSize="11"
                       Text="{Binding StatusMessage}" TextWrapping="Wrap" MaxHeight="80">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding StatusIsError}" Value="True">
                                <Setter Property="Foreground" Value="#FFE57373" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding StatusMessage}" Value="">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- ヘッダー群と変更一覧の区切り -->
            <Border DockPanel.Dock="Top" Height="1" Margin="8,0,8,4"
                    Background="{DynamicResource Border}" />

            <!-- 変更一覧。上はステージ済み（プレーンなリスト＝コミット対象）、下は作業ツリーを
                 ディレクトリツリーで表示し、チェックしたファイルをコミットに含める。
                 「変更」「バージョン管理外ファイル」をトップレベルのセクションに分ける。 -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="6,0">
                <StackPanel>
                    <!-- ステージ済み -->
                    <StackPanel Visibility="{Binding Staged.Count, Converter={StaticResource CountToVis}}">
                        <DockPanel Margin="4,2" Background="Transparent">
                            <StackPanel DockPanel.Dock="Right" Style="{StaticResource HeaderActions}">
                                <Button Style="{StaticResource RowActionButton}" Content="−"
                                        ToolTip="すべてアンステージ" Command="{Binding UnstageAllCommand}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="ステージ済み" Foreground="{DynamicResource FgDim}"
                                           FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <Border Style="{StaticResource CountPill}">
                                    <TextBlock Text="{Binding Staged.Count, Mode=OneWay}" FontSize="10"
                                               Foreground="{DynamicResource Fg}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </StackPanel>
                        </DockPanel>
                        <ListBox ItemsSource="{Binding Staged}" SelectionMode="Extended"
                                 Background="Transparent" BorderThickness="0" Padding="0"
                                 ItemContainerStyle="{StaticResource ChangeRowItem}"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                 SelectionChanged="StagedList_SelectionChanged"
                                 MouseDoubleClick="ChangeList_MouseDoubleClick"
                                 PreviewMouseRightButtonDown="ChangeList_PreviewMouseRightButtonDown"
                                 ContextMenu="{StaticResource StagedRowMenu}">
                            <ListBox.InputBindings>
                                <KeyBinding Key="Delete" Command="{Binding UnstageSelectedCommand}" />
                            </ListBox.InputBindings>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Background="Transparent" ToolTip="{Binding ToolTipText}">
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding Status}" Width="16" Margin="4,0,2,0"
                                                   Foreground="{Binding Status, Converter={StaticResource GitStatusBrush}}"
                                                   TextAlignment="Center" FontWeight="SemiBold" VerticalAlignment="Center"
                                                   FontFamily="Cascadia Mono, Consolas" />
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding Directory}" Foreground="{DynamicResource FgDim}"
                                                       FontSize="11" Margin="6,1,0,0" VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </DockPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>

                    <!-- 変更／バージョン管理外をトップレベルノードに持つコミット対象ツリー -->
                    <TreeView ItemsSource="{Binding WorkingTreeSections}" Margin="0,6,0,0"
                              ItemTemplate="{StaticResource GitChangeTreeTemplate}"
                              ItemContainerStyle="{StaticResource GitChangeTreeItem}"
                              Background="Transparent" BorderThickness="0" Padding="0"
                              ScrollViewer.VerticalScrollBarVisibility="Disabled"
                              MouseDoubleClick="ChangeList_MouseDoubleClick"
                              PreviewMouseLeftButtonDown="ChangeTree_PreviewMouseLeftButtonDown"
                              PreviewMouseRightButtonDown="ChangeTree_PreviewMouseRightButtonDown"
                              ContextMenu="{StaticResource WorkingTreeRowMenu}" />

                    <!-- スタッシュ（退避）。見出しの「⤓」で現在の変更を退避し、各行で 適用／取出／破棄。 -->
                    <StackPanel Margin="0,8,0,0">
                        <DockPanel Margin="4,2" Background="Transparent">
                            <StackPanel DockPanel.Dock="Right" Style="{StaticResource HeaderActions}">
                                <Button Style="{StaticResource RowActionButton}" Content="⤓"
                                        ToolTip="現在の変更を退避（スタッシュ）"
                                        Command="{Binding StashPushCommand}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="スタッシュ" Foreground="{DynamicResource FgDim}"
                                           FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <Border Style="{StaticResource CountPill}"
                                        Visibility="{Binding Stashes.Count, Converter={StaticResource CountToVis}}">
                                    <TextBlock Text="{Binding Stashes.Count, Mode=OneWay}" FontSize="10"
                                               Foreground="{DynamicResource Fg}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </StackPanel>
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding Stashes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Background="Transparent" ToolTip="{Binding Description}" Margin="4,1">
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                            <Button Style="{StaticResource RowActionButton}" Content="↧"
                                                    ToolTip="適用（退避は残す）"
                                                    Command="{Binding DataContext.StashApplyCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}" />
                                            <Button Style="{StaticResource RowActionButton}" Content="⤇"
                                                    ToolTip="取り出し（適用して退避を削除）"
                                                    Command="{Binding DataContext.StashPopCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}" />
                                            <Button Style="{StaticResource RowActionButton}" Content="×"
                                                    ToolTip="破棄（復元しない）"
                                                    Command="{Binding DataContext.StashDropCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding Description}" TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" FontSize="11" />
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </DockPanel>
</UserControl>
