<UserControl x:Class="sk0ya.Loomo.App.Views.CodeOutlineView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:sk0ya.Loomo.App.ViewModels"
             xmlns:v="clr-namespace:sk0ya.Loomo.App.Views"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             d:DesignHeight="400" d:DesignWidth="320"
             Background="{DynamicResource Panel}"
             TextElement.Foreground="{DynamicResource Fg}"
             FontFamily="Consolas, Cascadia Mono, Consolas" FontSize="{DynamicResource Fs12}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis" />

        <!-- 構造ツリーの項目テンプレート。BranchTreeItem と同じ作り（矢印＋全幅ホバー＋子の左ガイド線）だが、
             コンテナの選択ハイライトは<b>出さない</b>：行の状態（現在メンバーの左バー＋淡背景・ジャンプ）は
             ItemTemplate 側の Border が描くので、既定テンプレートのシステム選択色／フォーカスを外した後の
             灰色の選択帯がテーマから浮くのを避ける。ビュー内に閉じて持つ（唯一の利用者・StaticResource 依存も無く
             単体表示テストでも読める）。 -->
        <Style x:Key="OutlineTreeItem" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
            <Setter Property="Foreground" Value="{DynamicResource Fg}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition />
                            </Grid.RowDefinitions>

                            <!-- ヘッダ行（矢印＋行内容）。Bd は子を含まないので子ホバーで親は光らない -->
                            <Border x:Name="Bd" Grid.Row="0" Background="Transparent" CornerRadius="3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <ToggleButton x:Name="Expander" Grid.Column="0"
                                                  ClickMode="Press" Focusable="False"
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent" Width="13" Height="14">
                                                    <Path x:Name="Arrow" Width="8" Height="8" Stretch="Uniform"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          Fill="{DynamicResource FgDim}" Data="M0,0 L4,4 L0,8 Z" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="Arrow" Property="RenderTransform">
                                                            <Setter.Value>
                                                                <RotateTransform Angle="90" CenterX="4" CenterY="4" />
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource Fg}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>

                                    <ContentPresenter x:Name="PART_Header" Grid.Column="1"
                                                      ContentSource="Header"
                                                      Margin="{TemplateBinding Padding}"
                                                      HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                                </Grid>
                            </Border>

                            <!-- 子要素：矢印列ぶんだけインデントし、左に淡いガイド線 -->
                            <Border Grid.Row="1" Margin="11,0,0,0"
                                    BorderBrush="{DynamicResource Border}" BorderThickness="1,0,0,0">
                                <ItemsPresenter x:Name="ItemsHost" />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger SourceName="Bd" Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgAlt}" />
                            </Trigger>
                            <!-- IsSelected は意図的に無視（選択ハイライトは出さない）。 -->
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ②呼び出し解析の 1 行（クリックでジャンプ）。 -->
        <DataTemplate DataType="{x:Type vm:CodeCallRow}">
            <Border Padding="4,1" Margin="0" Background="Transparent"
                    MouseLeftButtonUp="CallRow_Click" ToolTip="{Binding Path}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Cursor" Value="Arrow" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CanJump}" Value="True">
                                <Setter Property="Cursor" Value="Hand" />
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource BgAlt}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding Symbol}" Foreground="{DynamicResource Accent}"
                               Margin="0,0,4,0"
                               Visibility="{Binding HasSymbol, Converter={StaticResource BoolVis}}" />
                    <TextBlock Text="{Binding Location}" Foreground="{DynamicResource FgDim}"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- ②呼び出し解析の 1 セクション（見出し＋件数＋行＋超過数）。 -->
        <DataTemplate DataType="{x:Type vm:CodeCallSection}">
            <StackPanel Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding TotalCount}" Foreground="{DynamicResource FgDim}"
                               Margin="4,0,0,0" />
                </StackPanel>
                <TextBlock Text="（なし）" Foreground="{DynamicResource FgDim}" Padding="4,1">
                    <TextBlock.Style>
                        <!-- HasRows==false のときだけ「（なし）」を出す（BoolVis の反転を Style で表現）。 -->
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasRows}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <ItemsControl ItemsSource="{Binding Rows}" />
                <TextBlock Text="{Binding OverflowText}" Foreground="{DynamicResource FgDim}"
                           FontSize="{DynamicResource Fs11}" Padding="4,1"
                           Visibility="{Binding HasOverflow, Converter={StaticResource BoolVis}}" />
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <!-- アウトライン＋②パネル（!IsNotice） -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                      Padding="6,6,6,10"
                      Visibility="{Binding IsOutline, Converter={StaticResource BoolVis}}">
            <StackPanel>
                <!-- 空プレースホルダ -->
                <TextBlock Text="（コード構造がありません）" Foreground="{DynamicResource FgDim}"
                           Margin="2,4"
                           Visibility="{Binding IsOutlineEmpty, Converter={StaticResource BoolVis}}" />

                <!-- 構造アウトライン（折りたたみツリー） -->
                <TreeView ItemsSource="{Binding Roots}" BorderThickness="0" Background="Transparent"
                          ScrollViewer.VerticalScrollBarVisibility="Disabled"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          PreviewMouseWheel="Tree_PreviewMouseWheel"
                          Foreground="{DynamicResource Fg}">
                    <TreeView.ItemContainerStyle>
                        <!-- 選択ハイライト無しのツリー項目（上の Resources 参照）。既定テンプレートの選択帯が
                             テーマから浮く問題への対処。行の状態（current/ホバー）は ItemTemplate 側が描く。 -->
                        <Style TargetType="TreeViewItem" BasedOn="{StaticResource OutlineTreeItem}" />
                    </TreeView.ItemContainerStyle>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate DataType="{x:Type vm:CodeOutlineItem}"
                                                  ItemsSource="{Binding Children}">
                            <Border MouseLeftButtonUp="OutlineRow_Click" Padding="2,1" Cursor="Hand"
                                    Background="Transparent" BorderBrush="{DynamicResource Accent}"
                                    ToolTip="{Binding KindTitle}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Style.Triggers>
                                            <!-- 現在メンバー：左に色バー＋淡い背景。 -->
                                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource BgAlt}" />
                                                <Setter Property="BorderThickness" Value="2,0,0,0" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Glyph}" v:ThemeBrush.ForegroundKey="{Binding GlyphBrushKey}"
                                               FontWeight="Bold" FontSize="{DynamicResource Fs10}" MinWidth="14"
                                               TextAlignment="Center" Margin="0,0,4,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Signature}" Foreground="{DynamicResource FgDim}"
                                               FontSize="{DynamicResource Fs11}" Margin="6,0,0,0" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding HasSignature, Converter={StaticResource BoolVis}}" />
                                    <TextBlock Text="↦" Foreground="{DynamicResource FgDim}" Margin="6,0,0,0"
                                               VerticalAlignment="Center" ToolTip="エディタで開く" />
                                </StackPanel>
                            </Border>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>

                <!-- ②呼び出し解析パネル（見出し＋区切り線は対象シンボル解決時のみ） -->
                <Border BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0"
                        Margin="0,10,0,0" Padding="0,8,0,0"
                        Visibility="{Binding HasCallTitle, Converter={StaticResource BoolVis}}">
                    <TextBlock Text="{Binding CallTitle}" FontWeight="SemiBold" />
                </Border>
                <ItemsControl ItemsSource="{Binding Sections}" Margin="0,8,0,0" />
            </StackPanel>
        </ScrollViewer>

        <!-- 案内（未接続／未導入・IsNotice） -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10,8"
                      Visibility="{Binding IsNotice, Converter={StaticResource BoolVis}}">
            <StackPanel MaxWidth="560" HorizontalAlignment="Left">
                <TextBlock Text="コード構造" FontWeight="SemiBold" FontSize="{DynamicResource Fs14}" Margin="0,0,0,8" />
                <TextBlock Text="{Binding NoticeMessage}" TextWrapping="Wrap" Margin="0,0,0,8" />
                <TextBlock Text="{Binding ServerLine}" Foreground="{DynamicResource FgDim}" Margin="0,0,0,8"
                           TextWrapping="Wrap"
                           Visibility="{Binding HasServerLine, Converter={StaticResource BoolVis}}" />
                <Border Background="{DynamicResource BgAlt}" CornerRadius="4" Padding="8,6" Margin="0,0,0,10"
                        Visibility="{Binding HasCommandText, Converter={StaticResource BoolVis}}">
                    <TextBlock Text="{Binding CommandText}" FontFamily="Consolas" TextWrapping="Wrap" />
                </Border>
                <StackPanel Orientation="Horizontal">
                    <Button Content="インストール" Padding="12,4" Margin="0,0,8,0"
                            Click="Install_Click"
                            Visibility="{Binding ShowInstall, Converter={StaticResource BoolVis}}" />
                    <Button Content="導入手順を開く" Padding="12,4" Margin="0,0,8,0"
                            Click="Docs_Click"
                            Visibility="{Binding ShowDocs, Converter={StaticResource BoolVis}}" />
                    <Button Content="LSP 設定を開く" Padding="12,4"
                            Click="Settings_Click"
                            Visibility="{Binding ShowSettings, Converter={StaticResource BoolVis}}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
