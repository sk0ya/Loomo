<Window x:Class="sk0ya.Loomo.App.Views.ShellWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:sk0ya.Loomo.App.Views"
    xmlns:editor="clr-namespace:Editor.Controls;assembly=Editor.Controls"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    Title="Loomo" Height="800" Width="1280"
    Icon="/Assets/Loomo.ico"
    Background="{DynamicResource Bg}" WindowStartupLocation="CenterScreen"
    WindowStyle="None" ResizeMode="CanResize">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36" ResizeBorderThickness="6"
                      CornerRadius="0" GlassFrameThickness="0"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- ペインヘッダー内に並べる操作ボタン（GIT/DIFF/TRACE のツールバーをヘッダーへ集約） -->
        <Style x:Key="PaneHeaderToolButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- タイトルバーのブランチ切替ボタン。非リポジトリ（BranchLabel が空）のときは非表示。
             BranchMenuItem 本体は Themes/Controls.xaml（BranchSwitcherView と共用するため）。 -->
        <Style x:Key="TitleBarBranchButton" TargetType="Button" BasedOn="{StaticResource BranchMenuItem}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding GitSession.BranchLabel}" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Diff のソース切替（AI変更 / Git）のセグメントボタン -->
        <Style x:Key="SourceToggle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
            <Setter Property="Padding" Value="10,2" />
            <Setter Property="Margin" Value="0,0,2,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="b" Background="Transparent" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource BgAlt}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Border}" />
                                <Setter Property="Foreground" Value="{DynamicResource Fg}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ペインの線画アイコン（16x16）。トグルとメインペイン表示ヘッダーで共有する単一ソース。
             code-behind（UpdatePaneToggleStates）は PaneKind→キー名で引いてヘッダーへ流し込む。 -->
        <StreamGeometry x:Key="PaneIcon.Terminal">M2.5,4 L7,8 L2.5,12 M9,12.5 H13.5</StreamGeometry>
        <StreamGeometry x:Key="PaneIcon.Editor">M10.5,2.5 L13.5,5.5 L6.5,12.5 L3,13 L3.5,9.5 Z M9,4 L12,7</StreamGeometry>
        <StreamGeometry x:Key="PaneIcon.EditorSupport">M8,4 C6.5,3 4.5,3 2.5,3.8 V11.8 C4.5,11 6.5,11 8,12 C9.5,11 11.5,11 13.5,11.8 V3.8 C11.5,3 9.5,3 8,4 M8,4 V12</StreamGeometry>
        <StreamGeometry x:Key="PaneIcon.Browser">M8,2.5 A5.5,5.5 0 1 0 8,13.5 A5.5,5.5 0 1 0 8,2.5 M2.5,8 H13.5 M8,2.5 C5.8,5.3 5.8,10.7 8,13.5 M8,2.5 C10.2,5.3 10.2,10.7 8,13.5</StreamGeometry>
        <StreamGeometry x:Key="PaneIcon.Git">M4.5,3.8 m-1.7,0 a1.7,1.7 0 1 0 3.4,0 a1.7,1.7 0 1 0 -3.4,0 M4.5,12.2 m-1.7,0 a1.7,1.7 0 1 0 3.4,0 a1.7,1.7 0 1 0 -3.4,0 M11.5,5.2 m-1.7,0 a1.7,1.7 0 1 0 3.4,0 a1.7,1.7 0 1 0 -3.4,0 M4.5,5.5 V10.5 M11.5,6.9 C11.5,9.2 4.5,8.3 4.5,10.5</StreamGeometry>
        <StreamGeometry x:Key="PaneIcon.Diff">M5,2.5 V7.5 M2.5,5 H7.5 M8.5,11.5 H13.5</StreamGeometry>
        <StreamGeometry x:Key="PaneIcon.Ai">M8,1.5 L9.4,6.6 L14.5,8 L9.4,9.4 L8,14.5 L6.6,9.4 L1.5,8 L6.6,6.6 Z</StreamGeometry>
        <StreamGeometry x:Key="PaneIcon.Debug">M8,4.5 C6,4.5 5.2,6.3 5.2,8.5 C5.2,10.9 6.4,12.8 8,12.8 C9.6,12.8 10.8,10.9 10.8,8.5 C10.8,6.3 10,4.5 8,4.5 Z M8,4.7 V12.6 M5.3,7 L2.8,5.6 M5.1,9.2 H2.6 M5.3,11.2 L2.8,12.6 M10.7,7 L13.2,5.6 M10.9,9.2 H13.4 M10.7,11.2 L13.2,12.6 M6.7,4.8 L6,3.3 M9.3,4.8 L10,3.3</StreamGeometry>

        <!-- タイトルバーのペイン表示トグル：表示中＝アクセント色／非表示＝グレーの線画アイコン。
             IsChecked とツールチップは code-behind の UpdatePaneToggleStates が実状態へ同期する。 -->
        <Style x:Key="PaneToggle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="b" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource BgAlt}" />
                                <Setter Property="Foreground" Value="{DynamicResource Fg}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PaneToggle 内に置く線画アイコンの共通設定（16x16・親の Foreground で描く） -->
        <Style x:Key="PaneToggleIcon" TargetType="Path">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Stretch" Value="None" />
            <Setter Property="StrokeThickness" Value="1.3" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeLineJoin" Value="Round" />
            <Setter Property="Stroke" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" />
        </Style>

        <!-- PaneToggle と同じ見た目の、状態を持たない単発アクションボタン（例: EditorSupport の「ブラウザで開く」）。 -->
        <Style x:Key="PaneActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource BgAlt}" />
                                <Setter Property="Foreground" Value="{DynamicResource Fg}" />
                            </Trigger>
                            <!-- 無効時ははっきり薄く（「押せそうに見えて押せない」を避ける）。 -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="b" Property="Opacity" Value="0.3" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PaneActionButton 内に置く線画アイコンの共通設定（PaneToggleIcon の Button 版）。 -->
        <Style x:Key="PaneActionIcon" TargetType="Path">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Stretch" Value="None" />
            <Setter Property="StrokeThickness" Value="1.3" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeLineJoin" Value="Round" />
            <Setter Property="Stroke" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
        </Style>

        <Style x:Key="TabStripButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- 最大化は code-behind で制御：通常は WM_GETMINMAXINFO でワーク領域に制限し、
         横並びのマルチモニタへは疑似最大化（SetWindowPos）で跨ぐ。タスクバーは覆わない -->
    <Border x:Name="RootBorder">
        <Grid x:Name="ShellLayout">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ActivityBarColumn" Width="48" />  <!-- ActivityBar -->
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition x:Name="TitleBarRow" Height="Auto" />  <!-- タイトルバー -->
                <RowDefinition Height="*" />     <!-- メイン領域（ペイン＋AI） -->
                <RowDefinition Height="Auto" />  <!-- 軌跡（操作ログ）バー：空なら高さ0 -->
            </Grid.RowDefinitions>

            <!-- ActivityBar : ウィンドウ下端まで伸ばす。空き領域のドラッグでウィンドウを移動できる。 -->
            <DockPanel Grid.Column="0" Grid.Row="1" Background="{DynamicResource ActivityBarBg}"
                       MouseLeftButtonDown="OnActivityBarMouseDown">
                <StackPanel DockPanel.Dock="Bottom">
                    <Button Style="{StaticResource IconButton}" Content="⌨" ToolTip="キーボードショートカット"
                            Command="{Binding ShowKeyboardSettingsCommand}" />
                    <Button Style="{StaticResource IconButton}" Content="⚙" ToolTip="設定"
                            Command="{Binding ShowSettingsCommand}" />
                </StackPanel>
                <StackPanel>
                    <Button Style="{StaticResource IconButton}" Content="🗂" ToolTip="エクスプローラ"
                            Command="{Binding ShowExplorerCommand}" />
                    <Button Style="{StaticResource IconButton}" Content="🔍" ToolTip="検索（全文検索 / grep）"
                            Command="{Binding ShowSearchCommand}" />
                    <Button Style="{StaticResource IconButton}" Content="⚠" ToolTip="診断（開いているファイルのエラー/警告）"
                            Command="{Binding ShowProblemsCommand}" />
                    <Button Style="{StaticResource IconButton}" Content="📑" ToolTip="タブ"
                            Command="{Binding ShowTabsCommand}" />
                    <Button Style="{StaticResource IconButton}" Content="⎇" ToolTip="Git"
                            Command="{Binding ShowGitCommand}" />
                    <Button Style="{StaticResource IconButton}" Content="📌" ToolTip="ペグボード（スニペット・URL・パスの作業台）"
                            Command="{Binding ShowPegboardCommand}" />
                </StackPanel>
            </DockPanel>

            <!-- ===== カスタムタイトルバー ===== -->
            <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Height="36" Background="{DynamicResource ActivityBarBg}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                    <TextBlock Text="Loomo" VerticalAlignment="Center"
                               FontSize="{DynamicResource Fs12}" Foreground="{DynamicResource FgDim}" Margin="0,0,12,0" />
                    <ComboBox MinHeight="24"
                              ItemsSource="{Binding Workspaces.Workspaces}"
                              SelectedItem="{Binding Workspaces.SelectedWorkspace, Mode=TwoWay}"
                              ToolTip="ワークスペース（右クリックでパスコピー・エクスプローラで開く・削除）"
                              WindowChrome.IsHitTestVisibleInChrome="True">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" Background="Transparent">
                                    <TextBlock.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="パスをコピー" Click="OnCopyWorkspacePathMenuClick" />
                                            <MenuItem Header="エクスプローラで開く" Click="OnRevealWorkspaceInExplorerMenuClick" />
                                            <MenuItem Header="ワークスペースを削除" Click="OnDeleteWorkspaceMenuClick" />
                                        </ContextMenu>
                                    </TextBlock.ContextMenu>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Width="30" Height="24" Margin="6,0,0,0"
                            Style="{StaticResource CaptionButton}"
                            ToolTip="ワークスペースを追加"
                            Command="{Binding Workspaces.OpenFolderCommand}"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <Path Width="15" Height="13" Stretch="Uniform"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.6"
                              Data="M1,3.5 H5 L6.2,5 H14 V12 H1 Z M1,3.5 V2 H5.5 L6.7,3.5 M10,6.5 V10 M8.25,8.25 H11.75" />
                    </Button>

                    <!-- Git ブランチ切替：現在ブランチをクリックで一覧ポップアップ→選択でチェックアウト -->
                    <Button x:Name="BranchButton" Height="24" Margin="10,0,0,0" Padding="8,0"
                            Style="{StaticResource TitleBarBranchButton}"
                            ToolTip="ブランチを切り替え" Click="OnTitleBarBranchClick"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⎇" Foreground="{DynamicResource FgDim}" VerticalAlignment="Center"
                                       Margin="0,0,5,0" />
                            <TextBlock Text="{Binding GitSession.BranchLabel}" FontSize="{DynamicResource Fs12}"
                                       VerticalAlignment="Center" MaxWidth="220"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="▾" FontSize="{DynamicResource Fs8}" Foreground="{DynamicResource FgDim}"
                                       VerticalAlignment="Center" Margin="5,1,0,0" />
                        </StackPanel>
                    </Button>
                    <Popup x:Name="BranchPopup" PlacementTarget="{Binding ElementName=BranchButton}"
                           Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                        <views:BranchSwitcherView x:Name="BranchSwitcher" DataContext="{Binding GitSession}" />
                    </Popup>

                </StackPanel>

                <!-- ウィンドウ操作ボタン＋ペイン表示トグル（キャプション領域だがクリック可能にする） -->
                <StackPanel x:Name="WindowControlsPanel" Orientation="Horizontal" HorizontalAlignment="Right"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <!-- ソロ⇄レイアウト切替（ShellWindow.Stage.cs / Ctrl+Shift+T）。チェック＝ソロ。 -->
                    <ToggleButton x:Name="StageModeToggle" Style="{StaticResource PaneToggle}"
                                  ToolTip="ソロ⇄レイアウトを切替（ソロ＝1ペインを舞台に＋袖でライブ待機）"
                                  Click="OnToggleStageMode">
                        <Path Style="{StaticResource PaneToggleIcon}"
                              Data="M2,3 H10.5 V13 H2 Z M12,3 H14 V6.5 H12 Z M12,9.5 H14 V13 H12 Z" />
                    </ToggleButton>

                    <!-- レイアウト（自由タイル配置）の保存・切替。レイアウトモード中だけ表示（ShellWindow.Layouts.cs）。 -->
                    <Button x:Name="LayoutButton" Height="24" Margin="2,0,0,0" Padding="8,0"
                            Style="{StaticResource BranchMenuItem}" Visibility="Collapsed"
                            ToolTip="レイアウトを保存・切替（Ctrl+T で巡回）" Click="OnLayoutMenuClick"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📐" VerticalAlignment="Center" Margin="0,0,5,0" />
                            <TextBlock Text="レイアウト:" Foreground="{DynamicResource FgDim}" FontSize="{DynamicResource Fs12}"
                                       VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock x:Name="LayoutButtonLabel" Text="（未保存）" FontSize="{DynamicResource Fs12}"
                                       VerticalAlignment="Center" MaxWidth="160" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="▾" FontSize="{DynamicResource Fs8}" Foreground="{DynamicResource FgDim}"
                                       VerticalAlignment="Center" Margin="5,1,0,0" />
                        </StackPanel>
                    </Button>
                    <Popup x:Name="LayoutPopup" PlacementTarget="{Binding ElementName=LayoutButton}"
                           Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                        <Border Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Border}"
                                BorderThickness="1" CornerRadius="4" Padding="4"
                                MinWidth="260" MaxWidth="380" Margin="0,2,8,8">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.3" />
                            </Border.Effect>
                            <DockPanel>
                                <!-- フッター：レイアウト名入力＋保存 -->
                                <StackPanel DockPanel.Dock="Bottom">
                                    <Border Height="1" Background="{DynamicResource Border}" Margin="2,4" />
                                    <DockPanel LastChildFill="True" Margin="4,2">
                                        <Button DockPanel.Dock="Right" Content="＋ 保存"
                                                Style="{StaticResource FlatButton}" Padding="10,3" Margin="6,0,0,0"
                                                Click="OnLayoutSaveClick"
                                                ToolTip="現在のタイル配置を保存（名前未入力なら自動命名）" />
                                        <TextBox x:Name="LayoutNameInput" VerticalContentAlignment="Center"
                                                 Background="{DynamicResource Bg}" Foreground="{DynamicResource Fg}"
                                                 BorderBrush="{DynamicResource Border}" CaretBrush="{DynamicResource Fg}"
                                                 ToolTip="レイアウト名" />
                                    </DockPanel>
                                </StackPanel>
                                <!-- 保存レイアウトの一覧（code-behind の BuildLayoutPopup が構築） -->
                                <StackPanel x:Name="LayoutPopupList" />
                            </DockPanel>
                        </Border>
                    </Popup>

                    <!-- 現在のメインペイン（左上／ソロの舞台）を示すヘッダー。ホバーで直下に縦並びの
                         ペイントグルを出す。アイコン・ツールチップは code-behind の UpdatePaneToggleStates が
                         現在のメインペインへ同期する。開くのは OnMainPaneMouseEnter、閉じるのは開いている間の
                         DispatcherTimer 監視（IsMouseNearPaneTogglePopup）。 -->
                    <Button x:Name="MainPaneButton" Height="36" Padding="6,0"
                            Style="{StaticResource BranchMenuItem}" Foreground="{DynamicResource Fg}"
                            MouseEnter="OnMainPaneMouseEnter"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <StackPanel Orientation="Horizontal">
                            <Path x:Name="MainPaneIcon" Style="{StaticResource PaneToggleIcon}"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                            <TextBlock Text="▾" FontSize="{DynamicResource Fs8}" Foreground="{DynamicResource FgDim}"
                                       VerticalAlignment="Center" Margin="4,1,0,0" />
                        </StackPanel>
                    </Button>
                    <Popup x:Name="PaneTogglePopup" PlacementTarget="{Binding ElementName=MainPaneButton}"
                           Placement="Bottom" StaysOpen="True" AllowsTransparency="True">
                        <!-- 開いている間は DispatcherTimer がマウスの画面座標を監視し、ヘッダー（MainPaneButton）と
                             枠（PaneTogglePopupRoot）の画面矩形を一定スラック分ふくらませた範囲から出たら閉じる
                             （OpenPaneTogglePopup / IsMouseNearPaneToggle）。透明な当たり判定レイヤーは使わない
                             （下の UI へのクリックを奪わず、かつスラックを自由に広げられる）。スラック量は
                             PaneTogglePopupHoverSlackPx。 -->
                        <Border x:Name="PaneTogglePopupRoot" Background="{DynamicResource Panel}"
                                BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="4"
                                Margin="0,0,8,8">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.3" />
                            </Border.Effect>
                            <!-- 縦並びのペイン表示トグル。アクセント色＝表示中／グレー＝非表示。 -->
                            <StackPanel x:Name="PaneToggleBar" Orientation="Vertical">
                                <!-- ターミナル：プロンプト >_ -->
                                <ToggleButton Style="{StaticResource PaneToggle}" Tag="Terminal" Click="OnTogglePaneVisibility">
                                    <Path Style="{StaticResource PaneToggleIcon}" Data="{StaticResource PaneIcon.Terminal}" />
                                </ToggleButton>
                                <!-- エディタ：ペン -->
                                <ToggleButton Style="{StaticResource PaneToggle}" Tag="Editor" Click="OnTogglePaneVisibility">
                                    <Path Style="{StaticResource PaneToggleIcon}" Data="{StaticResource PaneIcon.Editor}" />
                                </ToggleButton>
                                <!-- エディタサポート：開いた本（プレビュー） -->
                                <ToggleButton Style="{StaticResource PaneToggle}" Tag="EditorSupport" Click="OnTogglePaneVisibility">
                                    <Path Style="{StaticResource PaneToggleIcon}" Data="{StaticResource PaneIcon.EditorSupport}" />
                                </ToggleButton>
                                <!-- ブラウザ：地球儀 -->
                                <ToggleButton Style="{StaticResource PaneToggle}" Tag="Browser" Click="OnTogglePaneVisibility">
                                    <Path Style="{StaticResource PaneToggleIcon}" Data="{StaticResource PaneIcon.Browser}" />
                                </ToggleButton>
                                <!-- Git：ブランチ分岐 -->
                                <ToggleButton Style="{StaticResource PaneToggle}" Tag="Git" Click="OnTogglePaneVisibility">
                                    <Path Style="{StaticResource PaneToggleIcon}" Data="{StaticResource PaneIcon.Git}" />
                                </ToggleButton>
                                <!-- Diff：＋／− -->
                                <ToggleButton Style="{StaticResource PaneToggle}" Tag="Diff" Click="OnTogglePaneVisibility">
                                    <Path Style="{StaticResource PaneToggleIcon}" Data="{StaticResource PaneIcon.Diff}" />
                                </ToggleButton>
                                <!-- AI：スパーク -->
                                <ToggleButton Style="{StaticResource PaneToggle}" Tag="Ai" Click="OnTogglePaneVisibility">
                                    <Path Style="{StaticResource PaneToggleIcon}" Data="{StaticResource PaneIcon.Ai}" />
                                </ToggleButton>
                                <!-- IDE：虫（ビルド・テスト・デバッグ／DAP）。C# プロジェクトが無いワークスペースでは隠す。 -->
                                <ToggleButton x:Name="DebugPaneToggle" Style="{StaticResource PaneToggle}" Tag="Debug"
                                              Click="OnTogglePaneVisibility"
                                              ToolTip="IDE（ビルド・テスト・デバッグ）">
                                    <Path Style="{StaticResource PaneToggleIcon}" Data="{StaticResource PaneIcon.Debug}" />
                                </ToggleButton>
                            </StackPanel>
                        </Border>
                    </Popup>
                    <Border Width="1" Margin="6,8" Background="{DynamicResource Border}" />
                    <Button x:Name="MinimizeButton" Style="{StaticResource CaptionButton}"
                            ToolTip="最小化" Click="OnMinimize">
                        <Path Stretch="None" StrokeThickness="1" SnapsToDevicePixels="True"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M0,5 H10" />
                    </Button>
                    <!-- 跨ぎ最大化：横並びのモニタが2枚以上あるときだけ code-behind が表示する -->
                    <Button x:Name="SpanMaximizeButton" Style="{StaticResource CaptionButton}"
                            ToolTip="全モニタへ最大化" Click="OnSpanMaximize" Visibility="Collapsed"
                            AutomationProperties.Name="全モニタへ最大化">
                        <Path Stretch="None" StrokeThickness="1" SnapsToDevicePixels="True"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M0.5,0.5 H6.5 V9.5 H0.5 Z M8.5,0.5 H14.5 V9.5 H8.5 Z" />
                    </Button>
                    <Button x:Name="MaximizeButton" Style="{StaticResource CaptionButton}"
                            ToolTip="最大化" Click="OnMaximizeRestore">
                        <Path x:Name="MaximizeIcon" Stretch="None" StrokeThickness="1" SnapsToDevicePixels="True"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M0.5,0.5 H9.5 V9.5 H0.5 Z" />
                    </Button>
                    <Button x:Name="CloseButton" Style="{StaticResource CaptionCloseButton}"
                            ToolTip="閉じる" Click="OnClose">
                        <Path Stretch="None" StrokeThickness="1" SnapsToDevicePixels="True"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M0,0 L10,10 M0,10 L10,0" />
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ===== メイン領域 ===== -->
            <Grid x:Name="MainArea" Grid.Row="1" Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SidebarColumn" Width="220" MinWidth="120" />   <!-- Sidebar -->
                    <ColumnDefinition x:Name="SidebarSplitterColumn" Width="6" />    <!-- splitter -->
                    <ColumnDefinition Width="*" />                                   <!-- 動的ペインホスト／ステージ -->
                    <ColumnDefinition x:Name="WingColumn" Width="Auto" />            <!-- 袖（ミニチュア）：両モード共通 -->
                </Grid.ColumnDefinitions>

                <!-- Sidebar : Explorer / Tabs / Settings を ActivePanel で切替 -->
                <Grid x:Name="SidebarContainer" Grid.Column="0">
                    <views:FolderTreeView DataContext="{Binding FolderTree}"
                                          Visibility="{Binding DataContext.ActivePanel, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EnumToVis}, ConverterParameter=Explorer}" />
                    <views:SearchPanelView DataContext="{Binding SearchPanel}"
                                           Visibility="{Binding DataContext.ActivePanel, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EnumToVis}, ConverterParameter=Search}" />
                    <views:ProblemsPanelView DataContext="{Binding Problems}"
                                             Visibility="{Binding DataContext.ActivePanel, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EnumToVis}, ConverterParameter=Problems}" />
                    <views:TabsView DataContext="{Binding Tabs}"
                                    Visibility="{Binding DataContext.ActivePanel, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EnumToVis}, ConverterParameter=Tabs}" />
                    <views:GitPanelView DataContext="{Binding GitPanel}"
                                        Visibility="{Binding DataContext.ActivePanel, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EnumToVis}, ConverterParameter=Git}" />
                    <!-- 設定／外観はサイドバーではなく中央オーバーレイ（SettingsOverlayView）で開く。 -->
                    <views:PegboardView DataContext="{Binding Pegboard}"
                                        Visibility="{Binding DataContext.ActivePanel, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EnumToVis}, ConverterParameter=Pegboard}" />
                </Grid>

                <GridSplitter x:Name="SidebarSplitter" Grid.Column="1" Width="6"
                              HorizontalAlignment="Stretch" Background="{DynamicResource Border}" />

                <!-- 動的ペインホスト：列定義とスプリッターは code-behind が構築する -->
                <Grid x:Name="PaneHost" Grid.Column="2">

                <!-- Terminal -->
                <DockPanel x:Name="TerminalPane" Background="{DynamicResource Panel}">
                    <DockPanel DockPanel.Dock="Top" Background="{DynamicResource Panel}" LastChildFill="True"
                               Tag="Terminal" Cursor="SizeAll"
                               PreviewMouseLeftButtonDown="OnPaneTitleMouseDown" PreviewMouseMove="OnPaneTitleMouseMove">
                        <TextBlock DockPanel.Dock="Left" Style="{StaticResource PanelHeader}" Text="TERMINAL" />
                        <Button DockPanel.Dock="Right" Style="{StaticResource CaptionButton}" Width="30" Height="24"
                                Content="—" FontSize="{DynamicResource Fs13}" ToolTip="このペインを隠す"
                                Tag="Terminal" Click="OnHidePane" />
                        <Button DockPanel.Dock="Right" Style="{StaticResource CaptionButton}" Width="30" Height="24"
                                ToolTip="このターミナルを別ウィンドウで開く" Click="OnDetachTerminalPane">
                            <Path Width="13" Height="12" Stretch="Uniform" StrokeThickness="1.3"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Data="M2,4 H8 V10 H2 Z M6,4 V2 H13 V9 H8" />
                        </Button>
                        <Button DockPanel.Dock="Right" Style="{StaticResource CaptionButton}" Width="30" Height="24"
                                Content="+" FontSize="{DynamicResource Fs15}" ToolTip="新しいタブ" Click="OnTerminalNewTab" />
                        <!-- コンポーザ（§23.2）の表示/非表示。下部にはめ込んだ複数行コマンド入力 -->
                        <Button DockPanel.Dock="Right" Style="{StaticResource CaptionButton}" Width="30" Height="24"
                                ToolTip="コンポーザ（複数行コマンドを Vim で組み立てて実行）を表示/非表示"
                                Click="OnToggleComposer">
                            <Path Width="14" Height="12" Stretch="Uniform" StrokeThickness="1.4"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Data="M2.5,3.5 H13.5 M2.5,6.5 H9.5 M2.5,9.5 H8 M9.5,9 L13.5,11.5 L9.5,14 Z" />
                        </Button>
                        <!-- タブ一覧（あふれた時の導線も兼ねる）。ドロップダウンから直接アクティブ化できる -->
                        <Button DockPanel.Dock="Right" Style="{StaticResource CaptionButton}" Width="24" Height="24"
                                Content="▾" FontSize="{DynamicResource Fs11}" ToolTip="タブ一覧"
                                Tag="Terminal" Click="OnTabOverflowClick" />
                        <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Disabled"
                                      PanningMode="HorizontalOnly"
                                      PreviewMouseWheel="OnTabStripMouseWheel">
                            <ItemsControl ItemsSource="{Binding Tabs.TerminalTabs}"
                                          PreviewMouseLeftButtonDown="OnPaneTabPreviewMouseDown"
                                          PreviewMouseMove="OnPaneTabPreviewMouseMove">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="TabBorder" MinWidth="72" MaxWidth="150" Height="24"
                                                Margin="0" Background="Transparent"
                                                BorderBrush="Transparent" BorderThickness="0,0,0,2"
                                                Tag="{Binding Id}" MouseDown="OnTabMiddleClick">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0" Style="{StaticResource TabStripButton}"
                                                        Padding="8,0,4,0" HorizontalContentAlignment="Left"
                                                        Foreground="{DynamicResource Fg}" Tag="{Binding Id}"
                                                        Click="OnTerminalTabSelected">
                                                    <TextBlock Text="{Binding Title}" FontSize="{DynamicResource Fs12}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Button>
                                                <Button Grid.Column="1" Style="{StaticResource TabStripButton}"
                                                        Width="24" Padding="0" Foreground="{DynamicResource FgDim}"
                                                        Content="×" ToolTip="タブを閉じる" Tag="{Binding Id}"
                                                        Click="OnTerminalTabClosed" />
                                            </Grid>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource Accent}" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition x:Name="ComposerSplitterRow" Height="0" />
                            <RowDefinition x:Name="ComposerRow" Height="0" />
                        </Grid.RowDefinitions>
                        <Grid x:Name="TerminalContentHost" Grid.Row="0" />
                        <GridSplitter x:Name="ComposerSplitter" Grid.Row="1" Height="6"
                                      HorizontalAlignment="Stretch" Background="{DynamicResource Border}"
                                      Visibility="Collapsed" />
                        <!-- コンポーザ（§23.2）：複数行コマンドを Vim で組み立てて Ctrl+Enter で上のターミナルへ -->
                        <DockPanel x:Name="ComposerSection" Grid.Row="2" Visibility="Collapsed"
                                   Background="{DynamicResource Panel}"
                                   PreviewKeyDown="OnComposerPreviewKeyDown">
                            <DockPanel DockPanel.Dock="Top" Background="{DynamicResource Panel}" LastChildFill="False">
                                <Button DockPanel.Dock="Right" Style="{StaticResource CaptionButton}" Width="30" Height="22"
                                        Content="✕" FontSize="{DynamicResource Fs11}" ToolTip="コンポーザを閉じる" Click="OnToggleComposer" />
                                <Button DockPanel.Dock="Left" Style="{StaticResource PaneHeaderToolButton}"
                                        Content="▶ 実行"
                                        ToolTip="本文をこのターミナルで実行（Ctrl+Enter。複数行は一時 .ps1 経由）"
                                        Click="OnComposerRun" />
                                <TextBlock DockPanel.Dock="Left" Text="Ctrl+Enter" VerticalAlignment="Center"
                                           Margin="2,0,0,0" FontSize="{DynamicResource Fs11}" Foreground="{DynamicResource FgDim}" />
                                <!-- 組み立てたコマンドを道具掛けへ（§23.3 素材の流れ：作業台→ペグボード） -->
                                <Button DockPanel.Dock="Left" Style="{StaticResource PaneHeaderToolButton}"
                                        Content="📌 ペグボードへ" Margin="8,0,0,0"
                                        ToolTip="本文をペグボードにピンして再利用する"
                                        Click="OnComposerPinToPegboard" />
                            </DockPanel>
                            <Border x:Name="ComposerEditorHost" Background="{DynamicResource Panel}" />
                        </DockPanel>
                    </Grid>
                </DockPanel>

                <!-- Editor -->
                <DockPanel x:Name="EditorPane" Background="{DynamicResource Panel}">
                    <DockPanel DockPanel.Dock="Top" Background="{DynamicResource Panel}" LastChildFill="True"
                               Tag="Editor" Cursor="SizeAll"
                               PreviewMouseLeftButtonDown="OnPaneTitleMouseDown" PreviewMouseMove="OnPaneTitleMouseMove">
                        <TextBlock DockPanel.Dock="Left" Style="{StaticResource PanelHeader}" Text="EDITOR" />
                        <Button DockPanel.Dock="Right" Style="{StaticResource CaptionButton}" Width="30" Height="24"
                                Content="—" FontSize="{DynamicResource Fs13}" ToolTip="このペインを隠す"
                                Tag="Editor" Click="OnHidePane" />
                        <Button DockPanel.Dock="Right" Style="{StaticResource CaptionButton}" Width="30" Height="24"
                                ToolTip="このエディタを別ウィンドウで開く（内容は同期）" Click="OnDetachEditorPane">
                            <Path Width="13" Height="12" Stretch="Uniform" StrokeThickness="1.3"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Data="M2,4 H8 V10 H2 Z M6,4 V2 H13 V9 H8" />
                        </Button>
                        <Button DockPanel.Dock="Right" Style="{StaticResource CaptionButton}" Width="30" Height="24"
                                Content="+" FontSize="{DynamicResource Fs15}" ToolTip="新しいタブ" Click="OnEditorNewTab" />
                        <!-- タブ一覧（あふれた時の導線も兼ねる）。ドロップダウンから直接アクティブ化できる -->
                        <Button DockPanel.Dock="Right" Style="{StaticResource CaptionButton}" Width="24" Height="24"
                                Content="▾" FontSize="{DynamicResource Fs11}" ToolTip="タブ一覧"
                                Tag="Editor" Click="OnTabOverflowClick" />
                        <ScrollViewer x:Name="EditorTabStripScrollViewer"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Disabled"
                                      PanningMode="HorizontalOnly"
                                      PreviewMouseWheel="OnTabStripMouseWheel">
                            <ItemsControl x:Name="EditorTabStripItems" ItemsSource="{Binding Tabs.EditorTabs}"
                                          PreviewMouseLeftButtonDown="OnPaneTabPreviewMouseDown"
                                          PreviewMouseMove="OnPaneTabPreviewMouseMove">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="TabBorder" MinWidth="72" MaxWidth="150" Height="24"
                                                Margin="0" Background="Transparent"
                                                BorderBrush="Transparent" BorderThickness="0,0,0,2"
                                                Tag="{Binding Id}" MouseDown="OnTabMiddleClick">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0" Style="{StaticResource TabStripButton}"
                                                        Padding="8,0,4,0" HorizontalContentAlignment="Left"
                                                        Foreground="{DynamicResource Fg}" Tag="{Binding Id}"
                                                        Click="OnEditorTabSelected">
                                                    <TextBlock x:Name="TabTitle" Text="{Binding Title}" FontSize="{DynamicResource Fs12}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Button>
                                                <Button Grid.Column="1" Style="{StaticResource TabStripButton}"
                                                        Width="24" Padding="0" Foreground="{DynamicResource FgDim}"
                                                        Content="×" ToolTip="タブを閉じる" Tag="{Binding Id}"
                                                        Click="OnEditorTabClosed" />
                                            </Grid>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource Accent}" />
                                            </DataTrigger>
                                            <!-- プレビュータブ（編集するまで確定しない）は VS Code 同様に斜体で示す -->
                                            <DataTrigger Binding="{Binding IsPreview}" Value="True">
                                                <Setter TargetName="TabTitle" Property="FontStyle" Value="Italic" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                    <!-- 言語サーバー(LSP)の促しバー：対応サーバーが未導入/未設定のファイルを開いたとき、
                         エディタ上端に閉じられる通知を出す。永続化された「今後表示しない」と一致する拡張子では出ない。 -->
                    <Border DockPanel.Dock="Top" Background="{DynamicResource BgAlt}"
                            BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1" Padding="10,6"
                            Visibility="{Binding LspPrompt.IsVisible, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" TextWrapping="Wrap"
                                       Foreground="{DynamicResource Fg}" FontSize="{DynamicResource Fs12}"
                                       Text="{Binding LspPrompt.Message}" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                                <Button Content="インストール" Style="{StaticResource FlatButton}"
                                        FontSize="{DynamicResource Fs11}" Padding="8,2" Margin="0,0,6,0"
                                        Command="{Binding LspPrompt.InstallCommand}"
                                        Visibility="{Binding LspPrompt.CanInstall, Converter={StaticResource BoolToVis}}" />
                                <Button Content="設定を開く" Style="{StaticResource SecondaryButton}"
                                        FontSize="{DynamicResource Fs11}" Padding="8,2" Margin="0,0,6,0"
                                        Command="{Binding LspPrompt.OpenSettingsCommand}" />
                                <Button Content="今後表示しない" Style="{StaticResource SecondaryButton}"
                                        FontSize="{DynamicResource Fs11}" Padding="8,2" Margin="0,0,6,0"
                                        Command="{Binding LspPrompt.DismissForeverCommand}" />
                                <Button Style="{StaticResource CaptionButton}" Width="24" Height="22"
                                        Content="×" ToolTip="閉じる" Command="{Binding LspPrompt.CloseCommand}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <!-- 分割しても下端に1つだけ表示する共有ステータスバー。各エディタは SetSharedStatusBar で
                         自前のバーを隠してここへ状態を流す（フォーカス中のエディタの mode/file/cursor を表示）。 -->
                    <editor:VimStatusBar x:Name="EditorSharedStatusBar" DockPanel.Dock="Bottom" />
                    <Grid x:Name="EditorContentHost" />
                </DockPanel>

                <!-- EditorSupport : アクティブなエディタのファイルに対応するサポート（Markdown プレビュー等）を自動表示 -->
                <DockPanel x:Name="EditorSupportPane" Background="{DynamicResource Panel}">
                    <DockPanel DockPanel.Dock="Top" Background="{DynamicResource Panel}" LastChildFill="True"
                               Tag="EditorSupport" Cursor="SizeAll"
                               PreviewMouseLeftButtonDown="OnPaneTitleMouseDown" PreviewMouseMove="OnPaneTitleMouseMove">
                        <TextBlock DockPanel.Dock="Left" Style="{StaticResource PanelHeader}" Text="EDITOR SUPPORT" />
                        <Button DockPanel.Dock="Right" Style="{StaticResource CaptionButton}" Width="30" Height="24"
                                Content="—" FontSize="{DynamicResource Fs13}" ToolTip="このペインを隠す"
                                Tag="EditorSupport" Click="OnHidePane" />
                        <ToggleButton x:Name="EditorSupportPinToggle" DockPanel.Dock="Right"
                                      Style="{StaticResource PaneToggle}" Width="30" Height="24"
                                      ToolTip="現在のサポート対象にピン留め"
                                      Click="OnToggleEditorSupportPin">
                            <Path Style="{StaticResource PaneToggleIcon}"
                                  Data="M8,2 L14,8 M10,4 L5,9 L4,13 L8,12 L13,7 M8,12 L4,16" />
                        </ToggleButton>
                        <!-- 発表モード（marp:true 文書のみ）：1枚ずつ表示。OFF は全スライドを縦並びで表示 -->
                        <ToggleButton x:Name="EditorSupportSlideToggle" DockPanel.Dock="Right"
                                      Style="{StaticResource PaneToggle}" Width="30" Height="24"
                                      ToolTip="発表モード（marp文書のみ／1枚ずつ・←→で送り・f で全画面）。OFF は全スライドを縦並び表示"
                                      Click="OnToggleEditorSupportSlideMode">
                            <Path Style="{StaticResource PaneToggleIcon}"
                                  Data="M2,3 H14 V11 H2 Z M6,13 H10 M8,11 V13" />
                        </ToggleButton>
                        <Button x:Name="EditorSupportOpenInBrowserButton" DockPanel.Dock="Right"
                                Style="{StaticResource PaneActionButton}" Width="30" Height="24"
                                ToolTip="このプレビューを内蔵ブラウザの新規タブで開く"
                                Click="OnOpenEditorSupportInBrowser">
                            <Path Style="{StaticResource PaneActionIcon}"
                                  Data="M4,7 V12 H11 V9 M6,10 L12,4 M8,4 H12 V8" />
                        </Button>
                        <!-- 別ウィンドウ：このプレビューを、追従元エディタと同期する別ウィンドウの複製として開く -->
                        <Button x:Name="EditorSupportDetachButton" DockPanel.Dock="Right"
                                Style="{StaticResource PaneActionButton}" Width="30" Height="24"
                                ToolTip="このプレビューを別ウィンドウの複製として開く（内容は追従元エディタと同期）"
                                Click="OnDetachEditorSupport">
                            <Path Style="{StaticResource PaneActionIcon}"
                                  Data="M3,4 H9 V10 H3 Z M7,4 V2 H14 V9 H9" />
                        </Button>
                        <!-- エクスポート：現在のプレビューを HTML（単体で開ける）／PDF（見たまま）で保存 -->
                        <Button x:Name="EditorSupportExportButton" DockPanel.Dock="Right"
                                Style="{StaticResource PaneActionButton}" Width="30" Height="24"
                                ToolTip="プレビューをファイルへエクスポート（HTML / PDF）"
                                Click="OnExportEditorSupportClick">
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="HTMLとして保存…" Click="OnExportEditorSupportHtml" />
                                    <MenuItem Header="PDFとして保存…" Click="OnExportEditorSupportPdf" />
                                    <MenuItem x:Name="ExportMarkdownMenuItem" Header="Markdownとして保存…"
                                              Click="OnExportEditorSupportMarkdown" />
                                </ContextMenu>
                            </Button.ContextMenu>
                            <Path Style="{StaticResource PaneActionIcon}"
                                  Data="M8,2 V9 M5,6 L8,9 L11,6 M3,12 H13" />
                        </Button>
                        <!-- 前のファイルへ戻る（エディタのファイル履歴。マウスのサイドボタンでも戻る/進む）。
                             右の操作ボタン群の左端（他ボタンと一貫）。 -->
                        <Button x:Name="EditorSupportBackButton" DockPanel.Dock="Right"
                                Style="{StaticResource PaneActionButton}" Width="30" Height="24"
                                ToolTip="前のファイルへ戻る（マウスのサイドボタンでも戻る/進む）" IsEnabled="False"
                                Click="OnEditorSupportBack">
                            <Path Style="{StaticResource PaneActionIcon}" Data="M9,3 L4,8 L9,13 M4,8 H13" />
                        </Button>
                        <TextBlock x:Name="EditorSupportTitle" VerticalAlignment="Center" Margin="4,0,8,0"
                                   FontSize="{DynamicResource Fs11}" Foreground="{DynamicResource FgDim}"
                                   TextTrimming="CharacterEllipsis" />
                    </DockPanel>
                    <Grid x:Name="EditorSupportContentHost" />
                </DockPanel>

                <!-- Browser -->
                <DockPanel x:Name="BrowserPane" Background="{DynamicResource Panel}">
                    <DockPanel DockPanel.Dock="Top" Background="{DynamicResource Panel}" LastChildFill="True"
                               Tag="Browser" Cursor="SizeAll"
                               PreviewMouseLeftButtonDown="OnPaneTitleMouseDown" PreviewMouseMove="OnPaneTitleMouseMove">
                        <TextBlock DockPanel.Dock="Left" Style="{StaticResource PanelHeader}" Text="BROWSER" />
                        <Button DockPanel.Dock="Right" Style="{StaticResource CaptionButton}" Width="30" Height="24"
                                Content="—" FontSize="{DynamicResource Fs13}" ToolTip="このペインを隠す"
                                Tag="Browser" Click="OnHidePane" />
                        <Button DockPanel.Dock="Right" Style="{StaticResource CaptionButton}" Width="30" Height="24"
                                ToolTip="このブラウザを別ウィンドウで開く" Click="OnDetachBrowserPane">
                            <Path Width="13" Height="12" Stretch="Uniform" StrokeThickness="1.3"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Data="M2,4 H8 V10 H2 Z M6,4 V2 H13 V9 H8" />
                        </Button>
                        <Button DockPanel.Dock="Right" Style="{StaticResource CaptionButton}" Width="30" Height="24"
                                Content="+" FontSize="{DynamicResource Fs15}" ToolTip="新しいタブ" Click="OnBrowserNewTab" />
                        <!-- タブ一覧（あふれた時の導線も兼ねる）。ドロップダウンから直接アクティブ化できる -->
                        <Button DockPanel.Dock="Right" Style="{StaticResource CaptionButton}" Width="24" Height="24"
                                Content="▾" FontSize="{DynamicResource Fs11}" ToolTip="タブ一覧"
                                Tag="Browser" Click="OnTabOverflowClick" />
                        <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Disabled"
                                      PanningMode="HorizontalOnly"
                                      PreviewMouseWheel="OnTabStripMouseWheel">
                            <ItemsControl ItemsSource="{Binding Tabs.BrowserTabs}"
                                          PreviewMouseLeftButtonDown="OnPaneTabPreviewMouseDown"
                                          PreviewMouseMove="OnPaneTabPreviewMouseMove">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="TabBorder" MinWidth="72" MaxWidth="150" Height="24"
                                                Margin="0" Background="Transparent"
                                                BorderBrush="Transparent" BorderThickness="0,0,0,2"
                                                Tag="{Binding Id}" MouseDown="OnTabMiddleClick">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0" Style="{StaticResource TabStripButton}"
                                                        Padding="8,0,4,0" HorizontalContentAlignment="Left"
                                                        Foreground="{DynamicResource Fg}" Tag="{Binding Id}"
                                                        Click="OnBrowserTabSelected">
                                                    <TextBlock Text="{Binding Title}" FontSize="{DynamicResource Fs12}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Button>
                                                <Button Grid.Column="1" Style="{StaticResource TabStripButton}"
                                                        Width="24" Padding="0" Foreground="{DynamicResource FgDim}"
                                                        Content="×" ToolTip="タブを閉じる" Tag="{Binding Id}"
                                                        Click="OnBrowserTabClosed" />
                                            </Grid>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource Accent}" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="8,0,8,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource CaptionButton}" Width="30" Height="28"
                                ToolTip="戻る" Click="OnBrowserBack">
                            <Path Stretch="Uniform" Width="12" Height="12"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Data="M7,0 L0,6 L7,12 V8 H12 V4 H7 Z" />
                        </Button>
                        <Button Grid.Column="1" Style="{StaticResource CaptionButton}" Width="30" Height="28"
                                ToolTip="進む" Click="OnBrowserForward">
                            <Path Stretch="Uniform" Width="12" Height="12"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Data="M5,0 L12,6 L5,12 V8 H0 V4 H5 Z" />
                        </Button>
                        <Button Grid.Column="2" Style="{StaticResource CaptionButton}" Width="30" Height="28"
                                ToolTip="更新" Click="OnBrowserReload">
                            <Path Stretch="Uniform" Width="13" Height="13"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Data="M10.8,4.8 A4.5,4.5 0 1 0 9.6,9.7 M10.8,4.8 V1.2 H7.2" />
                        </Button>
                        <TextBox x:Name="BrowserAddressBox" Grid.Column="3" MinHeight="28" Margin="6,0"
                                 VerticalContentAlignment="Center"
                                 KeyDown="OnBrowserAddressKeyDown" />
                        <Button Grid.Column="4" Content="Go" Style="{StaticResource FlatButton}"
                                Padding="10,4" MinHeight="28" Click="OnBrowserGo" />
                    </Grid>
                    <Grid x:Name="BrowserContentHost" />
                </DockPanel>

                <!-- Git : セッションペイン（コミットグラフ・ブランチ・rebase 等の複雑操作） -->
                <DockPanel x:Name="GitPane" Background="{DynamicResource Panel}">
                    <DockPanel DockPanel.Dock="Top" Background="{DynamicResource Panel}" LastChildFill="False"
                               Tag="Git" Cursor="SizeAll"
                               PreviewMouseLeftButtonDown="OnPaneTitleMouseDown" PreviewMouseMove="OnPaneTitleMouseMove">
                        <TextBlock DockPanel.Dock="Left" Style="{StaticResource PanelHeader}" Text="GIT" />
                        <Button DockPanel.Dock="Right" Style="{StaticResource CaptionButton}" Width="30" Height="24"
                                Content="—" FontSize="{DynamicResource Fs13}" ToolTip="このペインを隠す"
                                Tag="Git" Click="OnHidePane" />
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center"
                                    Visibility="{Binding GitSession.IsRepository, Converter={StaticResource BoolToVis}}">
                            <!-- ブランチ切替：タイトルバーと同じコントロール。クリックで一覧ポップアップ→選択でチェックアウト -->
                            <Button x:Name="GitPaneBranchButton" Height="24" Margin="2,0,8,0" Padding="8,0"
                                    Style="{StaticResource BranchMenuItem}"
                                    ToolTip="ブランチを切り替え" Click="OnGitPaneBranchClick">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⎇" Foreground="{DynamicResource FgDim}" VerticalAlignment="Center"
                                               Margin="0,0,5,0" />
                                    <TextBlock Text="{Binding GitSession.BranchLabel}" FontSize="{DynamicResource Fs12}" FontWeight="SemiBold"
                                               VerticalAlignment="Center" MaxWidth="220"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="▾" FontSize="{DynamicResource Fs8}" Foreground="{DynamicResource FgDim}"
                                               VerticalAlignment="Center" Margin="5,1,0,0" />
                                </StackPanel>
                            </Button>
                            <Popup x:Name="GitPaneBranchPopup" PlacementTarget="{Binding ElementName=GitPaneBranchButton}"
                                   Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                                <views:BranchSwitcherView x:Name="GitPaneBranchSwitcher" DataContext="{Binding GitSession}" />
                            </Popup>
                            <!-- フェッチ／プル／プッシュはここには置かない。ブランチ切替ポップアップの
                                 同期帯（BranchSwitcherView）が一箇所の持ち場で、上流と件数もそこに出る。 -->
                            <!-- コミット一覧の絞り込み：author:／msg:／hash:／ref:／date: のトークン構文＋
                                 作者ドロップダウン・期間ピッカーの補助UI。git は再実行せず、読み込み済みの
                                 一覧をクライアント側で CommitLogFilter により判定する。 -->
                            <Grid Width="210" Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBox x:Name="LogFilterBox" MinHeight="24" Padding="6,3"
                                         VerticalContentAlignment="Center" Cursor="IBeam"
                                         Text="{Binding GitSession.History.LogFilter, UpdateSourceTrigger=PropertyChanged, Delay=200}">
                                    <TextBox.ToolTip>
                                        <ToolTip MaxWidth="380">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Text="トークンで絞り込み（複数語は AND）" />
                                                <TextBlock Text="author:名　msg:語　hash:sha　ref:ブランチ/タグ" />
                                                <TextBlock Text="date:&gt;2026-01-01　date:&lt;2026-06-30" />
                                                <TextBlock Text="date:2026-01-01..2026-06-30　date:2026-07" />
                                                <TextBlock TextWrapping="Wrap"
                                                           Text="接頭辞なしは全項目に部分一致。&quot;引用符&quot;で空白を含められます。" />
                                            </StackPanel>
                                        </ToolTip>
                                    </TextBox.ToolTip>
                                </TextBox>
                                <TextBlock Text="🔍 author: msg: date:…" Foreground="{DynamicResource FgDim}"
                                           FontSize="{DynamicResource Fs12}" Margin="8,0,0,0" IsHitTestVisible="False"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding GitSession.History.LogFilter, Converter={StaticResource EmptyToVis}}" />
                            </Grid>

                            <!-- 作者で絞り込み（先頭の「すべて」で解除） -->
                            <ComboBox x:Name="LogAuthorFilter" Width="140" MinHeight="24" Margin="6,0,0,0"
                                      VerticalAlignment="Center" VerticalContentAlignment="Center" Cursor="Arrow"
                                      ToolTip="作者で絞り込み"
                                      ItemsSource="{Binding GitSession.History.AuthorOptions}"
                                      SelectedItem="{Binding GitSession.History.AuthorSelection}" />

                            <!-- 期間で絞り込み：クリックでポップアップ（開始・終了の日付ピッカー） -->
                            <ToggleButton x:Name="LogDateButton" Margin="6,0,0,0" MinHeight="24"
                                          VerticalAlignment="Center" Content="📅 期間"
                                          Style="{StaticResource ToolbarToggleButton}"
                                          ToolTip="コミット日で絞り込み" />
                            <Popup PlacementTarget="{Binding ElementName=LogDateButton}" Placement="Bottom"
                                   StaysOpen="False" AllowsTransparency="True"
                                   IsOpen="{Binding IsChecked, ElementName=LogDateButton, Mode=TwoWay}">
                                <Border Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Border}"
                                        BorderThickness="1" Padding="10" Margin="0,4,0,0">
                                    <StackPanel MinWidth="200">
                                        <TextBlock Text="コミット日で絞り込み" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Fg}" Margin="0,0,0,6" />
                                        <TextBlock Text="開始日（含む）" Foreground="{DynamicResource FgDim}"
                                                   FontSize="{DynamicResource Fs11}" />
                                        <DatePicker SelectedDate="{Binding GitSession.History.DateFrom}" Margin="0,2,0,6"
                                                    Style="{StaticResource ThemedDatePicker}" />
                                        <TextBlock Text="終了日（含む）" Foreground="{DynamicResource FgDim}"
                                                   FontSize="{DynamicResource Fs11}" />
                                        <DatePicker SelectedDate="{Binding GitSession.History.DateTo}" Margin="0,2,0,8"
                                                    Style="{StaticResource ThemedDatePicker}" />
                                        <Button Content="期間をクリア" HorizontalAlignment="Right"
                                                Padding="8,2" Style="{StaticResource SecondaryButton}"
                                                Command="{Binding GitSession.History.ClearDateFilterCommand}" />
                                    </StackPanel>
                                </Border>
                            </Popup>

                            <!-- すべての絞り込みを解除（何か有効なときだけ表示） -->
                            <Button Content="✕ 解除" Margin="6,0,0,0" Padding="8,2" MinHeight="24"
                                    VerticalAlignment="Center" Style="{StaticResource SecondaryButton}"
                                    ToolTip="絞り込みをすべて解除"
                                    Command="{Binding GitSession.History.ClearLogFiltersCommand}"
                                    Visibility="{Binding GitSession.History.HasActiveFilters, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                    </DockPanel>
                    <views:GitSessionView x:Name="GitSessionHost" DataContext="{Binding GitSession}" />
                </DockPanel>

                <!-- Diff : セッションペイン（AI変更レビュー＋Git作業ツリー差分） -->
                <DockPanel x:Name="DiffPane" Background="{DynamicResource Panel}">
                    <DockPanel DockPanel.Dock="Top" Background="{DynamicResource Panel}" LastChildFill="False"
                               Tag="Diff" Cursor="SizeAll"
                               PreviewMouseLeftButtonDown="OnPaneTitleMouseDown" PreviewMouseMove="OnPaneTitleMouseMove">
                        <TextBlock DockPanel.Dock="Left" Style="{StaticResource PanelHeader}" Text="DIFF" />
                        <Button DockPanel.Dock="Right" Style="{StaticResource CaptionButton}" Width="30" Height="24"
                                Content="—" FontSize="{DynamicResource Fs13}" ToolTip="このペインを隠す"
                                Tag="Diff" Click="OnHidePane" />
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="{DynamicResource BgAlt}" CornerRadius="4" Padding="1"
                                    Margin="0,0,10,0">
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton Style="{StaticResource SourceToggle}" Content="Git" FontSize="{DynamicResource Fs12}"
                                                 IsChecked="{Binding DiffSession.IsGitMode}" />
                                    <RadioButton Style="{StaticResource SourceToggle}" Content="AI変更" FontSize="{DynamicResource Fs12}"
                                                 IsChecked="{Binding DiffSession.IsGitMode, Converter={StaticResource InverseBool}}" />
                                </StackPanel>
                            </Border>
                            <!-- 差分の表示形式（左右並び / 統合）。既定の左右を先頭に置く -->
                            <Border Background="{DynamicResource BgAlt}" CornerRadius="4" Padding="1"
                                    Margin="0,0,10,0">
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton Style="{StaticResource SourceToggle}" Content="左右" FontSize="{DynamicResource Fs12}"
                                                 ToolTip="削除を左・追加を右に並べて表示（side by side）"
                                                 IsChecked="{Binding DiffSession.IsSideBySide}" />
                                    <RadioButton Style="{StaticResource SourceToggle}" Content="統合" FontSize="{DynamicResource Fs12}"
                                                 ToolTip="差分を1列で表示（unified）"
                                                 IsChecked="{Binding DiffSession.IsSideBySide, Converter={StaticResource InverseBool}}" />
                                </StackPanel>
                            </Border>
                            <!-- Git セッションから連携されたコミット範囲の表示中ラベル＋解除 -->
                            <StackPanel Orientation="Horizontal">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DiffSession.GitTargetLabel}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="{Binding DiffSession.GitTargetLabel}" FontSize="{DynamicResource Fs12}"
                                           Foreground="{DynamicResource Accent}" VerticalAlignment="Center"
                                           Margin="0,0,6,0" TextTrimming="CharacterEllipsis" MaxWidth="240" />
                                <Button Style="{StaticResource PaneHeaderToolButton}" Content="Git 一覧で表示"
                                        ToolTip="このコミットを Git のコミット一覧で選択"
                                        Command="{Binding DiffSession.OpenCommitInGitCommand}"
                                        Visibility="{Binding DiffSession.CanOpenCommitInGit, Converter={StaticResource BoolToVis}}" />
                                <Button Style="{StaticResource PaneHeaderToolButton}" Content="✕ 作業ツリーへ"
                                        ToolTip="コミット範囲の表示を解除して作業ツリー差分へ戻る"
                                        Command="{Binding DiffSession.ClearGitTargetCommand}" />
                            </StackPanel>
                            <!-- 変更ブロック間のジャンプ＋差分コピー -->
                            <Border Background="{DynamicResource BgAlt}" CornerRadius="4" Padding="1"
                                    Margin="0,0,10,0">
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource PaneHeaderToolButton}" Content="↓ 次の差分"
                                            ToolTip="次の変更ブロックへジャンプ"
                                            Command="{Binding DiffSession.JumpToNextChangeCommand}" />
                                    <Button Style="{StaticResource PaneHeaderToolButton}" Content="↑ 前の差分"
                                            ToolTip="前の変更ブロックへジャンプ"
                                            Command="{Binding DiffSession.JumpToPrevChangeCommand}" />
                                </StackPanel>
                            </Border>
                            <Button Style="{StaticResource PaneHeaderToolButton}" Content="エディタで開く"
                                    Command="{Binding DiffSession.OpenInEditorCommand}" />
                            <Button Style="{StaticResource PaneHeaderToolButton}" Content="変更を破棄"
                                    ToolTip="選択中ファイルの作業ツリーの変更を破棄する（未追跡なら削除）"
                                    Command="{Binding DiffSession.DiscardCommand}"
                                    Visibility="{Binding DiffSession.CanDiscardSelected, Converter={StaticResource BoolToVis}}" />
                            <Button Style="{StaticResource PaneHeaderToolButton}" Content="元に戻す"
                                    ToolTip="選択中ファイルの AI 変更を巻き戻す（新規作成なら削除）"
                                    Command="{Binding DiffSession.RevertCommand}"
                                    Visibility="{Binding DiffSession.IsGitMode, Converter={StaticResource InverseBoolToVis}}" />
                            <Button Style="{StaticResource PaneHeaderToolButton}" Content="記録をクリア"
                                    ToolTip="AI変更の記録をすべて消す（ファイル自体は変更しない）"
                                    Command="{Binding DiffSession.ClearAiChangesCommand}"
                                    Visibility="{Binding DiffSession.IsGitMode, Converter={StaticResource InverseBoolToVis}}" />
                        </StackPanel>
                    </DockPanel>
                    <views:DiffSessionView x:Name="DiffSessionHost" DataContext="{Binding DiffSession}" />
                </DockPanel>

                <!-- Trace : セッションペイン（AI操作トレースのタイムライン表示・読み取り専用） -->
                <DockPanel x:Name="TracePane" Background="{DynamicResource Panel}">
                    <DockPanel DockPanel.Dock="Top" Background="{DynamicResource Panel}" LastChildFill="False"
                               Tag="Trace" Cursor="SizeAll"
                               PreviewMouseLeftButtonDown="OnPaneTitleMouseDown" PreviewMouseMove="OnPaneTitleMouseMove">
                        <TextBlock DockPanel.Dock="Left" Style="{StaticResource PanelHeader}" Text="TRACE" />
                        <Button DockPanel.Dock="Right" Style="{StaticResource CaptionButton}" Width="30" Height="24"
                                Content="—" FontSize="{DynamicResource Fs13}" ToolTip="このペインを隠す"
                                Tag="Trace" Click="OnHidePane" />
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource PaneHeaderToolButton}" Content="削除"
                                    ToolTip="選択中セッションのトレースファイルを削除"
                                    Command="{Binding TraceSession.DeleteSelectedCommand}" />
                            <TextBlock Text="{Binding TraceSession.SummaryLabel}" VerticalAlignment="Center"
                                       Margin="2,0,0,0" FontSize="{DynamicResource Fs11}" Foreground="{DynamicResource FgDim}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </DockPanel>
                    <views:TraceSessionView x:Name="TraceSessionHost" DataContext="{Binding TraceSession}" />
                </DockPanel>

                <!-- デバッグ : ペイン化（DAP / netcoredbg。出力・ブレークポイント・変数・コールスタック） -->
                <DockPanel x:Name="DebugPane" Background="{DynamicResource Panel}">
                    <DockPanel DockPanel.Dock="Top" Background="{DynamicResource Panel}" LastChildFill="False"
                               Tag="Debug" Cursor="SizeAll"
                               PreviewMouseLeftButtonDown="OnPaneTitleMouseDown" PreviewMouseMove="OnPaneTitleMouseMove">
                        <TextBlock DockPanel.Dock="Left" Style="{StaticResource PanelHeader}" Text="IDE" />
                        <Button DockPanel.Dock="Right" Style="{StaticResource CaptionButton}" Width="30" Height="24"
                                Content="—" FontSize="{DynamicResource Fs13}" ToolTip="このペインを隠す"
                                Tag="Debug" Click="OnHidePane" />
                        <!-- デバッグ構成（プロファイル）切替：どの起動プロジェクト/引数・環境変数の組で開始するか。
                             編集（プロジェクト選択・追加/名前変更/削除）は「構成」タブ側。 -->
                        <ComboBox DockPanel.Dock="Left" Margin="10,0,0,0" Width="150" VerticalAlignment="Center"
                                  ItemsSource="{Binding Debug.Profiles.Profiles}"
                                  SelectedItem="{Binding Debug.Profiles.SelectedProfile, Mode=TwoWay}"
                                  DisplayMemberPath="Name" ToolTip="デバッグ構成" />
                        <!-- セッション切替：複数のデバッグセッションを同時実行しているときだけ表示する（1 個の間は
                             従来どおり見た目が変わらない）。選択中セッションのコールスタック/変数/出力をデバッグ
                             ペインへ表示する（Rider の実行ツールウィンドウのタブ切替と同じ発想）。 -->
                        <ComboBox DockPanel.Dock="Left" Margin="6,0,0,0" Width="170" VerticalAlignment="Center"
                                  Visibility="{Binding Debug.HasMultipleSessions, Converter={StaticResource BoolToVis}}"
                                  ItemsSource="{Binding Debug.Sessions}"
                                  SelectedItem="{Binding Debug.ActiveSession, Mode=TwoWay}"
                                  DisplayMemberPath="DisplayName" ToolTip="表示中のデバッグセッション" />

                        <!-- デバッグツールバー（タブより上はヘッダーのみ）。状態で出し分け：
                             開始/ビルド/テストは常時（複数セッション対応——アクティブなセッションが実行中でも、
                             新しいセッションを始められないと「2つ目を開始」できないため常に出す）、
                             停止中＝続行/ステップ、デバッグ中＝中断/再起動/停止（どちらもアクティブなセッションに対して行う）。
                             起動構成・例外・アタッチは「構成」タブへ。 -->
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- 常時：開始・ビルド・テスト（新しいセッションを始める入口なので、他のセッションが
                                 実行中でも隠さない） -->
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource FlatButton}" Height="22" Padding="12,0" Margin="0,1,6,1"
                                        FontSize="{DynamicResource Fs11}" Content="▶ 開始" ToolTip="デバッグを開始"
                                        Command="{Binding Debug.Launch.StartCommand}" />
                                <Button Style="{StaticResource SecondaryButton}" Height="22" Padding="10,0" Margin="0,1,6,1"
                                        FontSize="{DynamicResource Fs11}" Content="🔨 ビルド" ToolTip="dotnet build を実行（.sln 優先）"
                                        Command="{Binding Debug.Launch.BuildTargetCommand}" />
                                <Button Style="{StaticResource SecondaryButton}" Height="22" Padding="10,0" Margin="0,1,6,1"
                                        FontSize="{DynamicResource Fs11}" Content="🧪 テスト" ToolTip="dotnet test を実行（.sln 優先）"
                                        Command="{Binding Debug.Tests.TestCommand}" />
                                <CheckBox Content="先にビルド" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="{DynamicResource Fs11}"
                                          Foreground="{DynamicResource Fg}" IsChecked="{Binding Debug.Launch.BuildFirst, Mode=TwoWay}"
                                          ToolTip="開始前に dotnet build を実行する" />
                            </StackPanel>
                            <!-- 停止中のみ：続行・ステップ（アイコンで省スペース、ツールチップで説明） -->
                            <StackPanel Orientation="Horizontal"
                                        Visibility="{Binding Debug.IsStopped, Converter={StaticResource BoolToVis}}">
                                <Button Style="{StaticResource SecondaryButton}" Height="22" Padding="8,0" Margin="0,1,4,1"
                                        FontSize="{DynamicResource Fs12}" Content="▶" ToolTip="続行 (F5)"
                                        Command="{Binding Debug.Launch.ContinueCommand}" />
                                <Button Style="{StaticResource SecondaryButton}" Height="22" Padding="8,0" Margin="0,1,4,1"
                                        FontSize="{DynamicResource Fs12}" Content="⤼" ToolTip="ステップオーバー"
                                        Command="{Binding Debug.Launch.StepOverCommand}" />
                                <Button Style="{StaticResource SecondaryButton}" Height="22" Padding="8,0" Margin="0,1,4,1"
                                        FontSize="{DynamicResource Fs12}" Content="⤷" ToolTip="ステップイン"
                                        Command="{Binding Debug.Launch.StepIntoCommand}" />
                                <Button Style="{StaticResource SecondaryButton}" Height="22" Padding="8,0" Margin="0,1,8,1"
                                        FontSize="{DynamicResource Fs12}" Content="⤴" ToolTip="ステップアウト"
                                        Command="{Binding Debug.Launch.StepOutCommand}" />
                            </StackPanel>
                            <!-- デバッグ中のみ：中断・再起動・停止 -->
                            <StackPanel Orientation="Horizontal"
                                        Visibility="{Binding Debug.IsBusy, Converter={StaticResource BoolToVis}}">
                                <Button Style="{StaticResource SecondaryButton}" Height="22" Padding="8,0" Margin="0,1,4,1"
                                        FontSize="{DynamicResource Fs12}" Content="⏸" ToolTip="すべて中断（一時停止）"
                                        Command="{Binding Debug.Launch.PauseCommand}" />
                                <Button Style="{StaticResource SecondaryButton}" Height="22" Padding="8,0" Margin="0,1,8,1"
                                        FontSize="{DynamicResource Fs12}" Content="⟳" ToolTip="同じ対象で再起動"
                                        Command="{Binding Debug.Launch.RestartCommand}" />
                                <Button Style="{StaticResource SecondaryButton}" Height="22" Padding="10,0" Margin="0,1,6,1"
                                        FontSize="{DynamicResource Fs11}" Content="■ 停止" ToolTip="デバッグを停止"
                                        Command="{Binding Debug.Launch.StopCommand}" />
                            </StackPanel>
                        </StackPanel>
                        <!-- 状態（ビルド/デバッグの進行・結果）。ラベルの右、ツールバーの左を埋める。 -->
                        <TextBlock DockPanel.Dock="Left" Text="{Binding Debug.StatusMessage}" VerticalAlignment="Center"
                                   Margin="10,0,0,0" FontSize="{DynamicResource Fs11}" Foreground="{DynamicResource FgDim}"
                                   TextTrimming="CharacterEllipsis" />
                    </DockPanel>
                    <views:DebugView DataContext="{Binding Debug}" />
                </DockPanel>

                <!-- AI : ペイン化（トランスクリプト＋入力を1列にまとめる） -->
                <DockPanel x:Name="AiPane" Background="{DynamicResource Panel}">
                    <DockPanel DockPanel.Dock="Top" Background="{DynamicResource Panel}" LastChildFill="False"
                               Tag="Ai" Cursor="SizeAll"
                               PreviewMouseLeftButtonDown="OnPaneTitleMouseDown" PreviewMouseMove="OnPaneTitleMouseMove">
                        <TextBlock DockPanel.Dock="Left" Style="{StaticResource PanelHeader}" Text="AI" />
                        <Button DockPanel.Dock="Right" Style="{StaticResource CaptionButton}" Width="30" Height="24"
                                Content="—" FontSize="{DynamicResource Fs13}" ToolTip="このペインを隠す"
                                Tag="Ai" Click="OnHidePane" />
                        <!-- チャット/ワークフロー切替（ヘッダー側）。DataContext は ShellViewModel なので AiBar 経由で束ねる。 -->
                        <Border DockPanel.Dock="Left" Margin="10,0,0,0" VerticalAlignment="Center"
                                Background="{DynamicResource BgAlt}" BorderBrush="{DynamicResource Border}"
                                BorderThickness="1" CornerRadius="5" Padding="2">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="チャット" Style="{StaticResource ModeSegButton}"
                                        Command="{Binding AiBar.ShowChatModeCommand}"
                                        Tag="{Binding AiBar.IsChatMode, Converter={StaticResource ActiveTagConverter}}" />
                                <Button Content="ワークフロー" Style="{StaticResource ModeSegButton}" Margin="2,0,0,0"
                                        Command="{Binding AiBar.ShowWorkflowModeCommand}"
                                        Tag="{Binding AiBar.IsWorkflowMode, Converter={StaticResource ActiveTagConverter}}" />
                            </StackPanel>
                        </Border>
                        <Button DockPanel.Dock="Left" Content="▶ 実行" Style="{StaticResource PaneHeaderToolButton}"
                                Margin="8,0,0,0"
                                Command="{Binding AiBar.Workflow.RunCommand}">
                            <Button.Visibility>
                                <MultiBinding Converter="{StaticResource AllTrueToVisibilityConverter}">
                                    <Binding Path="AiBar.IsWorkflowMode" />
                                    <Binding Path="AiBar.Workflow.IsRunning" Converter="{StaticResource InverseBool}" />
                                </MultiBinding>
                            </Button.Visibility>
                        </Button>
                        <Button DockPanel.Dock="Left" Content="停止" Style="{StaticResource PaneHeaderToolButton}"
                                Margin="8,0,0,0" Background="#FF6E1E1E"
                                Command="{Binding AiBar.Workflow.CancelCommand}">
                            <Button.Visibility>
                                <MultiBinding Converter="{StaticResource AllTrueToVisibilityConverter}">
                                    <Binding Path="AiBar.IsWorkflowMode" />
                                    <Binding Path="AiBar.Workflow.IsRunning" />
                                </MultiBinding>
                            </Button.Visibility>
                        </Button>
                    </DockPanel>
                    <!-- AIセッション：チャット欄の左上に常設した ActivityBar 風アイコン。クリックで一覧を開閉する。 -->
                    <Border DockPanel.Dock="Left" Background="{DynamicResource ActivityBarBg}">
                        <Button Style="{StaticResource IconButton}" Content="💬" ToolTip="AIセッション一覧"
                                Command="{Binding Sessions.ToggleOpenCommand}"
                                VerticalAlignment="Top" />
                    </Border>
                    <!-- AIセッション一覧：左のアイコンのクリックで開閉する折りたたみサイドバー（既定は非表示）。 -->
                    <Border DockPanel.Dock="Left" Width="280"
                            BorderBrush="{DynamicResource Border}" BorderThickness="0,0,1,0"
                            DataContext="{Binding Sessions}"
                            Visibility="{Binding IsOpen, Converter={StaticResource BoolToVis}}">
                        <views:SessionsView DataContext="{Binding}" />
                    </Border>
                    <views:AiBarView x:Name="AiBarHost" DataContext="{Binding AiBar}" />
                </DockPanel>

                </Grid>   <!-- /PaneHost -->

                <!-- 袖（ミニチュア）の描画元：実体ペインを Main 領域サイズへレイアウトする非表示ホスト。
                     VisualBrush の描画元になるだけで自身は不可視（Opacity 0／最背面／ヒットテスト無効）。
                     StageHost の表示状態に依らず常にアレンジさせたいので、StageHost の外（列2）に常設する
                     （レイアウトモードで Main に出ていない有効セッションのミニチュアを描くため）。 -->
                <Grid x:Name="StageSourceArea" Grid.Column="2" Margin="10,8,6,10"
                      SizeChanged="OnStageSourceAreaSizeChanged"
                      Opacity="0" IsHitTestVisible="False" Panel.ZIndex="-1" />

                <!-- ソロモード：1ペインを「舞台」に全面表示する（構築は ShellWindow.Stage.cs）。
                     タイル表示（PaneHost）とは表示の差し替えだけで切替わり、レイアウトツリー（_root）には触れない。
                     袖（ミニチュア）は両モード共通の WingHost（右の列）が持つ。 -->
                <Grid x:Name="StageHost" Grid.Column="2" Visibility="Collapsed">
                    <Grid x:Name="StageArea" Margin="10,8,6,10" />
                </Grid>

                <!-- 袖（ミニチュア）：ソロでもレイアウトでも右端に常設。生きたまま縮小表示する。
                     有効だが Main に出ていないセッションだけを並べる（Main に出ている／無効なものは出さない。
                     有効セッションは Main と袖のどちらかに必ず出る）。構築は ShellWindow.Stage.cs / Wings。 -->
                <DockPanel x:Name="WingHost" Grid.Column="3" Margin="0,8,10,10" Visibility="Collapsed">
                    <Button x:Name="OverviewButton" DockPanel.Dock="Top" Style="{StaticResource FlatButton}"
                            Padding="8,4" Margin="0,0,0,8" Content="⊞ 俯瞰"
                            ToolTip="全セッションを一望（クリックでダイブ／Ctrl+W z）"
                            Click="OnToggleOverview" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="WingStrip" />
                    </ScrollViewer>
                </DockPanel>

                <!-- 俯瞰：全セッションをカードで一望する Exposé 風レイヤ（背景クリックで閉じる。ソロ専用） -->
                <Grid x:Name="OverviewLayer" Grid.Column="2" Grid.ColumnSpan="2" Visibility="Collapsed"
                      Background="#B2101010" MouseLeftButtonUp="OnOverviewBackgroundClick">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled" VerticalAlignment="Center">
                        <WrapPanel x:Name="OverviewPanel" HorizontalAlignment="Center" MaxWidth="1100"
                                   Margin="24" />
                    </ScrollViewer>
                </Grid>

                <!-- ペインドラッグ中のスナップ風プレビュー用オーバーレイ（PaneHost と同じセルへ重ねる）。
                     Popup は1モニタへクリップされ、跨ぎ最大化中に隣のモニタでプレビューが見えないため
                     ウィンドウ内のレイヤとして被せる。 -->
                <Grid x:Name="PaneDragOverlay" Grid.Column="2" Panel.ZIndex="100" Visibility="Collapsed" />

                <!-- 使用箇所一覧（エディタの Find References / gr）。エディタは結果を表示せず
                     FindReferencesResult イベントを発火するだけなので、ホスト側でこのポップアップに
                     一覧表示し、クリックで該当ファイル・行へジャンプする（ShellWindow.References.cs）。
                     ※「まず配線だけ最小実装」段階。見た目は後で詰める。 -->
                <!-- タブ帯の「▾」から開く、あふれた分も含む全タブ一覧。クリックで即アクティブ化。
                     PlacementTarget はクリックされたボタンへ code-behind が都度差し替える（3帯共用）。 -->
                <Popup x:Name="TabOverflowPopup" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                    <Border Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Border}"
                            BorderThickness="1" CornerRadius="4" Padding="4"
                            MinWidth="200" MaxWidth="360">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.3" />
                        </Border.Effect>
                        <ScrollViewer MaxHeight="380" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="TabOverflowPopupList" />
                        </ScrollViewer>
                    </Border>
                </Popup>

                <Popup x:Name="ReferencesPopup" PlacementTarget="{Binding ElementName=PaneHost}"
                       Placement="Center" StaysOpen="False" AllowsTransparency="True">
                    <Border Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Border}"
                            BorderThickness="1" CornerRadius="4" Padding="4"
                            MinWidth="460" MaxWidth="760">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.3" />
                        </Border.Effect>
                        <DockPanel>
                            <TextBlock x:Name="ReferencesPopupTitle" DockPanel.Dock="Top"
                                       FontSize="{DynamicResource Fs12}" FontWeight="SemiBold" Margin="8,4,8,6"
                                       Foreground="{DynamicResource Fg}" TextTrimming="CharacterEllipsis" />
                            <ScrollViewer MaxHeight="380" VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="ReferencesPopupList" />
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Popup>

                <!-- 設定の中央オーバーレイ（ActivityBar の ⚙/🎨 で開く）。サイドバーの縦積みを置き換え、
                     左カテゴリ[AI/外観/エディタ/安全]＋右内容の広い設定画面を中央に被せる。
                     起動を軽くするため中身は初回オープン時に遅延生成する（code-behind が Content を差し込む）。 -->
                <ContentControl x:Name="SettingsOverlayHost" Grid.ColumnSpan="4" Panel.ZIndex="150"
                                Visibility="{Binding IsSettingsOverlayOpen, Converter={StaticResource BoolToVis}}" />

                <!-- コマンドパレット：部屋の全操作（移動・表示・タブ・コンポーザ・ペグボード・WS切替）を
                     名前で検索して実行する（Ctrl+Shift+P / Ctrl+W p。ShellWindow.CommandPalette.cs）。 -->
                <Grid x:Name="CommandPaletteOverlay" Grid.ColumnSpan="4" Panel.ZIndex="200" Visibility="Collapsed"
                      Background="#59101010" MouseLeftButtonDown="OnPaletteBackgroundMouseDown"
                      SizeChanged="OnPaletteOverlaySizeChanged">
                    <!-- 幅・高さはウィンドウに合わせてコードで広げる（UpdatePaletteBoxSize）。ここの値は初期フォールバック。 -->
                    <Border x:Name="PaletteBox" Width="760" MaxHeight="440" HorizontalAlignment="Center" VerticalAlignment="Top"
                            Margin="0,46,0,0" Background="{DynamicResource Panel}"
                            BorderBrush="{DynamicResource Accent}" BorderThickness="1" CornerRadius="6"
                            MouseLeftButtonDown="OnPaletteBoxMouseDown">
                        <Grid Margin="6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <!-- モード切替チップ（クリックで切替＝マウス操作。Ctrl+Shift+P 連打でも巡回）。検索ボックスの上。 -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4,0,4,4">
                                <StackPanel.Resources>
                                    <Style x:Key="PaletteModeChip" TargetType="Button">
                                        <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Setter Property="BorderBrush" Value="Transparent" />
                                        <Setter Property="Padding" Value="8,2" />
                                        <Setter Property="Margin" Value="0,0,4,0" />
                                        <Setter Property="FontSize" Value="{DynamicResource Fs11}" />
                                        <Setter Property="Cursor" Value="Hand" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="3"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </StackPanel.Resources>
                                <Button x:Name="PaletteModeAll" Style="{StaticResource PaletteModeChip}"
                                        Content="すべて" Click="OnPaletteModeClick" Tag="All" />
                                <Button x:Name="PaletteModeFile" Style="{StaticResource PaletteModeChip}"
                                        Content="ファイル" Click="OnPaletteModeClick" Tag="File" />
                                <Button x:Name="PaletteModeGrep" Style="{StaticResource PaletteModeChip}"
                                        Content="テキスト" Click="OnPaletteModeClick" Tag="Grep" />
                                <Button x:Name="PaletteModeClass" Style="{StaticResource PaletteModeChip}"
                                        Content="クラス" Click="OnPaletteModeClick" Tag="Class" />
                                <Button x:Name="PaletteModeSymbol" Style="{StaticResource PaletteModeChip}"
                                        Content="シンボル" Click="OnPaletteModeClick" Tag="Symbol" />
                                <Button x:Name="PaletteModeTerminal" Style="{StaticResource PaletteModeChip}"
                                        Content="ターミナル" Click="OnPaletteModeClick" Tag="Terminal" />
                                <Button x:Name="PaletteModeCommand" Style="{StaticResource PaletteModeChip}"
                                        Content="コマンド" Click="OnPaletteModeClick" Tag="Command" />
                            </StackPanel>
                            <TextBox x:Name="PaletteInput" Grid.Row="1" Margin="4,0,4,4" Padding="6,4" FontSize="{DynamicResource Fs13}"
                                     Background="{DynamicResource Bg}" Foreground="{DynamicResource Fg}"
                                     BorderBrush="{DynamicResource Border}" CaretBrush="{DynamicResource Fg}"
                                     TextChanged="OnPaletteTextChanged" PreviewKeyDown="OnPaletteInputKeyDown" />
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" MinWidth="300" />
                                    <ColumnDefinition x:Name="PalettePreviewColumn" Width="0" MinWidth="0" />
                                </Grid.ColumnDefinitions>
                                <ListBox x:Name="PaletteList" Grid.Column="0" Margin="4,0,4,4" BorderThickness="0"
                                         Background="Transparent" Foreground="{DynamicResource Fg}"
                                         HorizontalContentAlignment="Stretch"
                                         SelectionChanged="OnPaletteSelectionChanged"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         VirtualizingPanel.ScrollUnit="Item">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="6,3" />
                                            <EventSetter Event="PreviewMouseLeftButtonUp" Handler="OnPaletteItemClick" />
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <!-- タイトルを主役にして横幅いっぱいに使い、カテゴリ（種別・位置）は右端に淡色で添える。
                                             タイトルは一致文字だけ Accent＋太字で強調する（PaletteHighlight）。 -->
                                        <DataTemplate>
                                            <DockPanel LastChildFill="True">
                                                <TextBlock DockPanel.Dock="Right" Text="{Binding Shortcut}" FontSize="{DynamicResource Fs11}"
                                                           Foreground="{DynamicResource FgDim}" Margin="8,0,0,0"
                                                           VerticalAlignment="Center" />
                                                <TextBlock DockPanel.Dock="Right" Text="{Binding Category}" FontSize="{DynamicResource Fs11}"
                                                           Foreground="{DynamicResource FgDim}" Margin="10,0,0,0" MaxWidth="300"
                                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                <TextBlock FontSize="{DynamicResource Fs12}" TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"
                                                           views:PaletteHighlight.Text="{Binding Title}"
                                                           views:PaletteHighlight.Query="{Binding TitleMatch}" />
                                            </DockPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <Border Grid.Column="1" Margin="4,0,4,4" Background="{DynamicResource Bg}"
                                        BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="3">
                                    <!-- プレビュー本体は読み取り専用の VimEditorControl をコードから流し込む
                                         （ShellWindow.CommandPalette.cs / EnsurePreviewEditor）。 -->
                                    <Border x:Name="PalettePreviewHost" ClipToBounds="True" />
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- 軌跡（操作ログ）バー：通過した地点（ファイル・ページ・ペイン／パネル切替）を時系列の
                 点（ドット）で並べる（Semantic Depth 構想の Thread Rail の種）。ホバーで詳細、クリックで
                 その地点へ戻り、バー上のホイールで現在地を前後に移動する。左端の日付クリック→カレンダーで
                 過去の日の軌跡を表示（×で今日へ戻る）。記録は SQLite（TrailStore）へ日別・無制限に永続化。
                 配線は ShellWindow.Trail.cs、データは TrailViewModel。記録が無ければ非表示で高さを取らない。 -->
            <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                    Background="{DynamicResource ActivityBarBg}"
                    BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0"
                    Visibility="{Binding Trail.BarVisible, Converter={StaticResource BoolToVis}}">
                <!-- バー全体（日付・時刻ボタンを含む）で共通の右クリックメニュー。日付／時刻で分けず、
                     どこを右クリックしても「最新に戻る」（過去日・過去地点から今日の最新へ）と
                     「軌跡を非表示にする」（設定「外観」の軌跡トグルから再表示）を出す。子ボタンは自前の
                     メニューを持たないので ContextMenuService がこの Border のメニューへ遡って解決する。 -->
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="最新に戻る" Click="OnTrailBackToLatest" />
                        <Separator />
                        <MenuItem Header="軌跡を非表示にする"
                                  Command="{Binding PlacementTarget.DataContext.Trail.HideCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                    </ContextMenu>
                </Border.ContextMenu>
                <DockPanel LastChildFill="True" Height="26">
                    <!-- 日付＋時刻を1つにまとめたボタン：ライブ地点なら「M/d (ddd) HH:mm」、過去地点へ
                         スクラブ中／過去日表示中はその時間帯を HH:00 で表す。クリックで日付（カレンダー）と
                         時間帯（HH:00）を1つのポップアップから即トグルして選ぶ。選択はリアルタイムでバーへ
                         反映し、フォーカスを外すと閉じる。最新地点へは右クリックメニュー「最新に戻る」。 -->
                    <Button x:Name="TrailDateTimeButton" DockPanel.Dock="Left" Style="{StaticResource FlatButton}"
                            Padding="8,1" FontSize="{DynamicResource Fs11}" VerticalAlignment="Center"
                            Foreground="{DynamicResource FgDim}"
                            Content="{Binding Trail.DateTimeLabel}"
                            ToolTip="クリックで日付と時間帯を選んでその軌跡へ移動（選択はすぐ反映・フォーカスを外すと閉じる）"
                            Click="OnTrailDateTimeClick" />
                    <Popup x:Name="TrailDateTimePopup" PlacementTarget="{Binding ElementName=TrailDateTimeButton}"
                           Placement="Top" StaysOpen="True" AllowsTransparency="True">
                        <!-- StaysOpen=True：内部クリック（日付・時間帯の選択）ではポップアップを閉じない。
                             閉じるのは「フォーカスがポップアップの外へ出たら」（OnTrailDateTimeLostFocus）、
                             ウィンドウ非アクティブ化（ShellWindow.Trail.cs の Deactivated 購読）、日付・時刻
                             ボタンの再クリック（OnTrailDateTimeClick のトグル）、「⟳ 最新に戻る」ボタンのみ。
                             StaysOpen=False にすると、選択時のマウスキャプチャ解放（Calendar のクリック飲み込み
                             回避に必要）でポップアップが閉じてしまうため True にしている。 -->
                        <Border x:Name="TrailDateTimePopupRoot" Focusable="True"
                                Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Border}"
                                BorderThickness="1" CornerRadius="4" Padding="4" Margin="8"
                                LostKeyboardFocus="OnTrailDateTimeLostFocus">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.3" />
                            </Border.Effect>
                            <StackPanel Orientation="Horizontal">
                                <!-- 日付：カレンダーで選ぶとその日の軌跡を即バーへ反映（ポップアップは開いたまま）。 -->
                                <Calendar x:Name="TrailCalendar" Style="{StaticResource ThemedCalendar}"
                                          SelectedDatesChanged="OnTrailCalendarSelected" />
                                <Border Width="1" Margin="4,4" Background="{DynamicResource Border}" />
                                <!-- 右列：最新へ戻るボタン＋時間帯リスト。高さはカレンダーへ固定するので
                                     時間帯の記録数でポップアップの縦幅が伸び縮みしない（多い日はリスト内でスクロール）。 -->
                                <DockPanel MinWidth="84" Margin="2,0,0,0"
                                           Height="{Binding ActualHeight, ElementName=TrailCalendar}">
                                    <!-- 最新（今）へ戻る：過去日表示・過去地点へのスクラブどちらからも
                                         ライブの最新地点へ1回で戻す。押したらポップアップを閉じる。 -->
                                    <Button DockPanel.Dock="Top" Style="{StaticResource FlatButton}"
                                            Padding="10,4" FontSize="{DynamicResource Fs12}" HorizontalContentAlignment="Left"
                                            Content="⟳ 最新に戻る" ToolTip="ライブの最新地点（今）へ戻る"
                                            Click="OnTrailBackToLatestFromPopup" />
                                    <Border DockPanel.Dock="Top" Height="1" Margin="4,3"
                                            Background="{DynamicResource Border}" />
                                    <!-- 時間帯：その日に記録のある時間（HH:00）を縦に並べ、選ぶとその時間帯の
                                         先頭ドットへ即移動する。記録のある時間が無ければリストだけ畳む
                                         （最新へ戻るボタンは残す）。長ければこの固定枠内でスクロールする。 -->
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  Visibility="{Binding Trail.HasHours, Converter={StaticResource BoolToVis}}">
                                        <ItemsControl ItemsSource="{Binding Trail.Hours}">
                                            <ItemsControl.Resources>
                                                <!-- 時間帯ボタン：素はゴースト（透明）、現在地の属する時間帯（IsSelected）だけ
                                                     アクセント塗りで強調して「どこを選択しているか」を示す（§27.7.2）。 -->
                                                <Style x:Key="TrailHourButton" TargetType="Button">
                                                    <Setter Property="Foreground" Value="{DynamicResource Fg}" />
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Setter Property="Cursor" Value="Hand" />
                                                    <Setter Property="MinWidth" Value="64" />
                                                    <Setter Property="Padding" Value="10,3" />
                                                    <Setter Property="FontSize" Value="{DynamicResource Fs12}" />
                                                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="b" Background="{TemplateBinding Background}"
                                                                        CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="Left"
                                                                                      VerticalAlignment="Center" />
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="b" Property="Background"
                                                                                Value="{DynamicResource BgAlt}" />
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource SelectionBg}" />
                                                            <Setter Property="Foreground" Value="{DynamicResource AccentFg}" />
                                                            <Setter Property="FontWeight" Value="SemiBold" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ItemsControl.Resources>
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Vertical" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Style="{StaticResource TrailHourButton}"
                                                            Content="{Binding Label}" Click="OnTrailHourSelected" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </DockPanel>
                            </StackPanel>
                        </Border>
                    </Popup>
                    <!-- ×：過去の日を表示中のみ出す（今日の軌跡へ戻る） -->
                    <Button DockPanel.Dock="Right" Style="{StaticResource CaptionButton}" Width="24" Height="22"
                            Content="×" FontSize="{DynamicResource Fs11}" ToolTip="今日の軌跡へ戻る"
                            Visibility="{Binding Trail.IsViewingPast, Converter={StaticResource BoolToVis}}"
                            Command="{Binding Trail.BackToTodayCommand}" />
                    <!-- ドット列：素のホイール＝バーの水平スクロール／Shift+ホイール＝現在地の前後移動（OnTrailWheel）。スクロールは追従制御 -->
                    <ScrollViewer x:Name="TrailScroll" HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled" PanningMode="HorizontalOnly"
                                  PreviewMouseWheel="OnTrailWheel">
                        <!-- Padding 右端は ShellWindow.Trail.cs の UpdateTrailTrailingMargin がビュー幅ぶんに保つ
                             （末尾付近のドットも左端へ寄せられるようにする末尾余白）。 -->
                        <ItemsControl x:Name="TrailDots" ItemsSource="{Binding Trail.Entries}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                    <!-- 時間帯の先頭ドットにだけ、左に区切り（|）＋時刻ラベル（HH:00）を前置する。
                                         非境界では Collapsed で幅ゼロ。幅は TrailHourLabelW トークン（UiFontManager が
                                         フォントサイズと同倍率でスケール）を ShellWindow.Trail.cs の
                                         TrailHourLabelWidth（TrailSlotOffset が積む実効幅）と揃える（§27.7.3）。 -->
                                    <Border Width="{DynamicResource TrailHourLabelW}" Height="26"
                                            Visibility="{Binding StartsNewHour, Converter={StaticResource BoolToVis}}">
                                        <StackPanel Orientation="Horizontal">
                                            <Rectangle Width="1" Margin="0,3" VerticalAlignment="Stretch"
                                                       Fill="{DynamicResource FgDim}" />
                                            <TextBlock Text="{Binding HourBandLabel}" FontSize="{DynamicResource Fs12}" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Fg}"
                                                       VerticalAlignment="Center" Margin="3,0,0,0"
                                                       TextOptions.TextFormattingMode="Ideal" />
                                        </StackPanel>
                                    </Border>
                                    <!-- 幅20は ShellWindow.Trail.cs の TrailDotWidth と揃える -->
                                    <Button Width="20" Height="26" Cursor="Hand"
                                            ToolTip="{Binding Tooltip}" ToolTipService.InitialShowDelay="150"
                                            AutomationProperties.Name="{Binding AccessibleName}"
                                            AutomationProperties.HelpText="{Binding Tooltip}"
                                            Command="{Binding DataContext.Trail.JumpCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Grid Background="Transparent">
                                                    <!-- 種別を単色ベクターの絵姿（書類・地球儀・鉛筆・ブランチ…）で描く。
                                                         色は4カテゴリ＝内容(File/Browser/Terminal/Preview)=Fg／
                                                         変更(Edit/Git)=Success／構造(Pane/Panel/Layout)=FgDim／AI(Session)=Accent。
                                                         現在地はアクセント色＋やや太く・拡大して強調（§27.10-11）。 -->
                                                    <Path x:Name="Mark" Data="{Binding IconGeometry}" Stretch="None"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          StrokeThickness="1.3" StrokeLineJoin="Round" StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round" Opacity="0.85"
                                                          RenderTransformOrigin="0.5,0.5"
                                                          SnapsToDevicePixels="True">
                                                        <Path.Style>
                                                            <Style TargetType="Path">
                                                                <Setter Property="Stroke" Value="{DynamicResource Fg}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Kind}" Value="Pane">
                                                                        <Setter Property="Stroke" Value="{DynamicResource FgDim}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Kind}" Value="Panel">
                                                                        <Setter Property="Stroke" Value="{DynamicResource FgDim}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Kind}" Value="Layout">
                                                                        <Setter Property="Stroke" Value="{DynamicResource FgDim}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Kind}" Value="Edit">
                                                                        <Setter Property="Stroke" Value="{DynamicResource Success}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Kind}" Value="Git">
                                                                        <Setter Property="Stroke" Value="{DynamicResource Success}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Kind}" Value="Session">
                                                                        <Setter Property="Stroke" Value="{DynamicResource Accent}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                                        <Setter Property="Stroke" Value="{DynamicResource AccentHover}" />
                                                                        <Setter Property="StrokeThickness" Value="1.6" />
                                                                        <Setter Property="Opacity" Value="1.0" />
                                                                        <Setter Property="RenderTransform">
                                                                            <Setter.Value>
                                                                                <ScaleTransform ScaleX="1.18" ScaleY="1.18" />
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Path.Style>
                                                    </Path>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Mark" Property="Opacity" Value="1.0" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- ドラッグ中のゴースト：掴んでいるペインをカーソル追従のチップで示す。
                 全面・最前面・ヒットテスト無効（構築は ShellWindow.PaneLayout.cs）。 -->
            <Canvas x:Name="DragGhostLayer" Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="0" Grid.RowSpan="3"
                    Panel.ZIndex="200" IsHitTestVisible="False" Visibility="Collapsed" />

            <!-- トースト通知：右下に積み上げ表示。MessageBox.Show と違い非モーダルで自動的に消える
                 （ToastService／ToastHostViewModel、§03参照）。決定が要る確認は引き続き MessageBox。 -->
            <ItemsControl Grid.ColumnSpan="4" Grid.RowSpan="3" Panel.ZIndex="250" IsHitTestVisible="True"
                          HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,16,16"
                          ItemsSource="{Binding Toasts.Items}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="ToastBorder" Margin="0,6,0,0" MinWidth="240" MaxWidth="420"
                                Background="{DynamicResource Panel}" BorderThickness="0,0,0,0"
                                CornerRadius="4" Padding="10,8">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.35" />
                            </Border.Effect>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="AccentBar" Grid.Column="0" Background="{DynamicResource FgDim}"
                                        CornerRadius="2" Margin="0,0,8,0" />
                                <TextBlock Grid.Column="1" Text="{Binding Message}" TextWrapping="Wrap"
                                           VerticalAlignment="Center" Foreground="{DynamicResource Fg}"
                                           FontSize="{DynamicResource Fs12}" />
                                <Button Grid.Column="2" Style="{StaticResource CaptionButton}" Width="20" Height="20"
                                        VerticalAlignment="Top" Content="×" Foreground="{DynamicResource FgDim}"
                                        ToolTip="閉じる"
                                        Command="{Binding DataContext.Toasts.DismissCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}" />
                            </Grid>
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding Kind}" Value="Info">
                                <Setter TargetName="AccentBar" Property="Background" Value="{DynamicResource Accent}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Kind}" Value="Success">
                                <Setter TargetName="AccentBar" Property="Background" Value="{DynamicResource Success}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Kind}" Value="Warning">
                                <Setter TargetName="AccentBar" Property="Background" Value="{DynamicResource Error}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Kind}" Value="Error">
                                <Setter TargetName="AccentBar" Property="Background" Value="{DynamicResource Error}" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Border>
</Window>
