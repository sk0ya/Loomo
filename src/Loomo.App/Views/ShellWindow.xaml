<Window x:Class="sk0ya.Loomo.App.Views.ShellWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:sk0ya.Loomo.App.Views"
    xmlns:editor="clr-namespace:Editor.Controls;assembly=Editor.Controls"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    Title="Loomo" Height="800" Width="1280"
    Icon="/Assets/Loomo.ico"
    Background="{DynamicResource Bg}" WindowStartupLocation="CenterScreen"
    WindowStyle="None" ResizeMode="CanResize">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36" ResizeBorderThickness="6"
                      CornerRadius="0" GlassFrameThickness="0"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- ペインヘッダー内に並べる操作ボタン（GIT/DIFF/TRACE のツールバーをヘッダーへ集約） -->
        <Style x:Key="PaneHeaderToolButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Diff のソース切替（AI変更 / Git）のセグメントボタン -->
        <Style x:Key="SourceToggle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
            <Setter Property="Padding" Value="10,2" />
            <Setter Property="Margin" Value="0,0,2,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="b" Background="Transparent" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource BgAlt}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource Border}" />
                                <Setter Property="Foreground" Value="{DynamicResource Fg}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- タイトルバーのペイン表示トグル：表示中＝アクセント色／非表示＝グレーの線画アイコン。
             IsChecked とツールチップは code-behind の UpdatePaneToggleStates が実状態へ同期する。 -->
        <Style x:Key="PaneToggle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="b" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource BgAlt}" />
                                <Setter Property="Foreground" Value="{DynamicResource Fg}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PaneToggle 内に置く線画アイコンの共通設定（16x16・親の Foreground で描く） -->
        <Style x:Key="PaneToggleIcon" TargetType="Path">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Stretch" Value="None" />
            <Setter Property="StrokeThickness" Value="1.3" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeLineJoin" Value="Round" />
            <Setter Property="Stroke" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" />
        </Style>

        <Style x:Key="TabStripButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- 最大化は code-behind で制御：通常は WM_GETMINMAXINFO でワーク領域に制限し、
         横並びのマルチモニタへは疑似最大化（SetWindowPos）で跨ぐ。タスクバーは覆わない -->
    <Border x:Name="RootBorder">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48" />  <!-- ActivityBar -->
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />  <!-- タイトルバー -->
                <RowDefinition Height="*" />     <!-- メイン領域（ペイン＋AI） -->
            </Grid.RowDefinitions>

            <!-- ActivityBar : ウィンドウ下端まで伸ばす。空き領域のドラッグでウィンドウを移動できる。 -->
            <DockPanel Grid.Column="0" Grid.Row="1" Background="{DynamicResource ActivityBarBg}"
                       MouseLeftButtonDown="OnActivityBarMouseDown">
                <StackPanel DockPanel.Dock="Bottom">
                    <Button Style="{StaticResource IconButton}" Content="🎨" ToolTip="外観（テーマ・アクセント）"
                            Command="{Binding ShowAppearanceCommand}" />
                    <Button Style="{StaticResource IconButton}" Content="⚙" ToolTip="設定"
                            Command="{Binding ShowSettingsCommand}" />
                </StackPanel>
                <StackPanel>
                    <Button Style="{StaticResource IconButton}" Content="🗂" ToolTip="エクスプローラ"
                            Command="{Binding ShowExplorerCommand}" />
                    <Button Style="{StaticResource IconButton}" Content="📑" ToolTip="タブ"
                            Command="{Binding ShowTabsCommand}" />
                    <Button Style="{StaticResource IconButton}" Content="⎇" ToolTip="Git"
                            Command="{Binding ShowGitCommand}" />
                    <Button Style="{StaticResource IconButton}" Content="💬" ToolTip="AIセッション"
                            Command="{Binding ShowSessionsCommand}" />
                </StackPanel>
            </DockPanel>

            <!-- ===== カスタムタイトルバー ===== -->
            <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Height="36" Background="{DynamicResource ActivityBarBg}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                    <TextBlock Text="🤖" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="Loomo" VerticalAlignment="Center"
                               FontSize="12" Foreground="{DynamicResource FgDim}" Margin="0,0,12,0" />
                    <ComboBox Height="24"
                              ItemsSource="{Binding Workspaces.Workspaces}"
                              SelectedItem="{Binding Workspaces.SelectedWorkspace, Mode=TwoWay}"
                              DisplayMemberPath="Name"
                              ToolTip="ワークスペース"
                              WindowChrome.IsHitTestVisibleInChrome="True" />
                    <Button Width="30" Height="24" Margin="6,0,0,0"
                            Style="{StaticResource CaptionButton}"
                            ToolTip="ワークスペースを追加"
                            Command="{Binding Workspaces.OpenFolderCommand}"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <Path Width="15" Height="13" Stretch="Uniform"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.6"
                              Data="M1,3.5 H5 L6.2,5 H14 V12 H1 Z M1,3.5 V2 H5.5 L6.7,3.5 M10,6.5 V10 M8.25,8.25 H11.75" />
                    </Button>

                </StackPanel>

                <!-- ウィンドウ操作ボタン＋ペイン表示トグル（キャプション領域だがクリック可能にする） -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <!-- ペインの表示トグル（隠したペインの再表示にも使う）。アクセント色＝表示中／グレー＝非表示。 -->
                    <StackPanel x:Name="PaneToggleBar" Orientation="Horizontal">
                        <!-- ターミナル：プロンプト >_ -->
                        <ToggleButton Style="{StaticResource PaneToggle}" Tag="Terminal" Click="OnTogglePaneVisibility">
                            <Path Style="{StaticResource PaneToggleIcon}"
                                  Data="M2.5,4 L7,8 L2.5,12 M9,12.5 H13.5" />
                        </ToggleButton>
                        <!-- エディタ：ペン -->
                        <ToggleButton Style="{StaticResource PaneToggle}" Tag="Editor" Click="OnTogglePaneVisibility">
                            <Path Style="{StaticResource PaneToggleIcon}"
                                  Data="M10.5,2.5 L13.5,5.5 L6.5,12.5 L3,13 L3.5,9.5 Z M9,4 L12,7" />
                        </ToggleButton>
                        <!-- エディタサポート：開いた本（プレビュー） -->
                        <ToggleButton Style="{StaticResource PaneToggle}" Tag="EditorSupport" Click="OnTogglePaneVisibility">
                            <Path Style="{StaticResource PaneToggleIcon}"
                                  Data="M8,4 C6.5,3 4.5,3 2.5,3.8 V11.8 C4.5,11 6.5,11 8,12 C9.5,11 11.5,11 13.5,11.8 V3.8 C11.5,3 9.5,3 8,4 M8,4 V12" />
                        </ToggleButton>
                        <!-- ブラウザ：地球儀 -->
                        <ToggleButton Style="{StaticResource PaneToggle}" Tag="Browser" Click="OnTogglePaneVisibility">
                            <Path Style="{StaticResource PaneToggleIcon}"
                                  Data="M8,2.5 A5.5,5.5 0 1 0 8,13.5 A5.5,5.5 0 1 0 8,2.5 M2.5,8 H13.5 M8,2.5 C5.8,5.3 5.8,10.7 8,13.5 M8,2.5 C10.2,5.3 10.2,10.7 8,13.5" />
                        </ToggleButton>
                        <!-- Git：ブランチ分岐 -->
                        <ToggleButton Style="{StaticResource PaneToggle}" Tag="Git" Click="OnTogglePaneVisibility">
                            <Path Style="{StaticResource PaneToggleIcon}"
                                  Data="M4.5,3.8 m-1.7,0 a1.7,1.7 0 1 0 3.4,0 a1.7,1.7 0 1 0 -3.4,0 M4.5,12.2 m-1.7,0 a1.7,1.7 0 1 0 3.4,0 a1.7,1.7 0 1 0 -3.4,0 M11.5,5.2 m-1.7,0 a1.7,1.7 0 1 0 3.4,0 a1.7,1.7 0 1 0 -3.4,0 M4.5,5.5 V10.5 M11.5,6.9 C11.5,9.2 4.5,8.3 4.5,10.5" />
                        </ToggleButton>
                        <!-- Diff：＋／− -->
                        <ToggleButton Style="{StaticResource PaneToggle}" Tag="Diff" Click="OnTogglePaneVisibility">
                            <Path Style="{StaticResource PaneToggleIcon}"
                                  Data="M5,2.5 V7.5 M2.5,5 H7.5 M8.5,11.5 H13.5" />
                        </ToggleButton>
                        <!-- トレース：パルス（タイムライン） -->
                        <ToggleButton Style="{StaticResource PaneToggle}" Tag="Trace" Click="OnTogglePaneVisibility">
                            <Path Style="{StaticResource PaneToggleIcon}"
                                  Data="M1.5,8 H4.5 L6.5,3.5 L9.5,12.5 L11.5,8 H14.5" />
                        </ToggleButton>
                        <!-- AI：スパーク -->
                        <ToggleButton Style="{StaticResource PaneToggle}" Tag="Ai" Click="OnTogglePaneVisibility">
                            <Path Style="{StaticResource PaneToggleIcon}"
                                  Data="M8,1.5 L9.4,6.6 L14.5,8 L9.4,9.4 L8,14.5 L6.6,9.4 L1.5,8 L6.6,6.6 Z" />
                        </ToggleButton>
                    </StackPanel>
                    <Border Width="1" Margin="6,8" Background="{DynamicResource Border}" />
                    <Button x:Name="MinimizeButton" Style="{StaticResource CaptionButton}"
                            ToolTip="最小化" Click="OnMinimize">
                        <Path Stretch="None" StrokeThickness="1" SnapsToDevicePixels="True"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M0,5 H10" />
                    </Button>
                    <!-- 跨ぎ最大化：横並びのモニタが2枚以上あるときだけ code-behind が表示する -->
                    <Button x:Name="SpanMaximizeButton" Style="{StaticResource CaptionButton}"
                            ToolTip="全モニタへ最大化" Click="OnSpanMaximize" Visibility="Collapsed"
                            AutomationProperties.Name="全モニタへ最大化">
                        <Path Stretch="None" StrokeThickness="1" SnapsToDevicePixels="True"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M0.5,0.5 H6.5 V9.5 H0.5 Z M8.5,0.5 H14.5 V9.5 H8.5 Z" />
                    </Button>
                    <Button x:Name="MaximizeButton" Style="{StaticResource CaptionButton}"
                            ToolTip="最大化" Click="OnMaximizeRestore">
                        <Path x:Name="MaximizeIcon" Stretch="None" StrokeThickness="1" SnapsToDevicePixels="True"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M0.5,0.5 H9.5 V9.5 H0.5 Z" />
                    </Button>
                    <Button x:Name="CloseButton" Style="{StaticResource CaptionCloseButton}"
                            ToolTip="閉じる" Click="OnClose">
                        <Path Stretch="None" StrokeThickness="1" SnapsToDevicePixels="True"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M0,0 L10,10 M0,10 L10,0" />
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ===== メイン領域 ===== -->
            <Grid Grid.Row="1" Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SidebarColumn" Width="220" MinWidth="120" />   <!-- Sidebar -->
                    <ColumnDefinition x:Name="SidebarSplitterColumn" Width="6" />    <!-- splitter -->
                    <ColumnDefinition Width="*" />                                   <!-- 動的ペインホスト -->
                </Grid.ColumnDefinitions>

                <!-- Sidebar : Explorer / Tabs / Sessions / Settings を ActivePanel で切替 -->
                <Grid x:Name="SidebarContainer" Grid.Column="0">
                    <views:FolderTreeView DataContext="{Binding FolderTree}"
                                          Visibility="{Binding DataContext.ActivePanel, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EnumToVis}, ConverterParameter=Explorer}" />
                    <views:TabsView DataContext="{Binding Tabs}"
                                    Visibility="{Binding DataContext.ActivePanel, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EnumToVis}, ConverterParameter=Tabs}" />
                    <views:GitPanelView DataContext="{Binding GitPanel}"
                                        Visibility="{Binding DataContext.ActivePanel, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EnumToVis}, ConverterParameter=Git}" />
                    <views:SessionsView DataContext="{Binding Sessions}"
                                        Visibility="{Binding DataContext.ActivePanel, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EnumToVis}, ConverterParameter=Sessions}" />
                    <views:SettingsView DataContext="{Binding Settings}"
                                        Visibility="{Binding DataContext.ActivePanel, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EnumToVis}, ConverterParameter=Settings}" />
                    <views:AppearanceView DataContext="{Binding Appearance}"
                                          Visibility="{Binding DataContext.ActivePanel, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EnumToVis}, ConverterParameter=Appearance}" />
                </Grid>

                <GridSplitter x:Name="SidebarSplitter" Grid.Column="1" Width="6"
                              HorizontalAlignment="Stretch" Background="{DynamicResource Border}" />

                <!-- 動的ペインホスト：列定義とスプリッターは code-behind が構築する -->
                <Grid x:Name="PaneHost" Grid.Column="2">

                <!-- Terminal -->
                <DockPanel x:Name="TerminalPane" Background="{DynamicResource Panel}">
                    <DockPanel DockPanel.Dock="Top" Background="{DynamicResource Panel}" LastChildFill="True"
                               Tag="Terminal" Cursor="SizeAll"
                               PreviewMouseLeftButtonDown="OnPaneTitleMouseDown" PreviewMouseMove="OnPaneTitleMouseMove">
                        <TextBlock DockPanel.Dock="Left" Style="{StaticResource PanelHeader}" Text="TERMINAL" />
                        <Button DockPanel.Dock="Right" Style="{StaticResource CaptionButton}" Width="30" Height="24"
                                Content="—" FontSize="13" ToolTip="このペインを隠す"
                                Tag="Terminal" Click="OnHidePane" />
                        <Button DockPanel.Dock="Right" Style="{StaticResource CaptionButton}" Width="30" Height="24"
                                Content="+" FontSize="15" ToolTip="新しいタブ" Click="OnTerminalNewTab" />
                        <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Disabled"
                                      PanningMode="HorizontalOnly"
                                      PreviewMouseWheel="OnTabStripMouseWheel">
                            <ItemsControl ItemsSource="{Binding Tabs.TerminalTabs}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="TabBorder" MinWidth="72" MaxWidth="150" Height="24"
                                                Margin="0" Background="Transparent"
                                                BorderBrush="Transparent" BorderThickness="0,0,0,2"
                                                Tag="{Binding Id}" MouseDown="OnTabMiddleClick">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0" Style="{StaticResource TabStripButton}"
                                                        Padding="8,0,4,0" HorizontalContentAlignment="Left"
                                                        Foreground="{DynamicResource Fg}" Tag="{Binding Id}"
                                                        Click="OnTerminalTabSelected">
                                                    <TextBlock Text="{Binding Title}" FontSize="12"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Button>
                                                <Button Grid.Column="1" Style="{StaticResource TabStripButton}"
                                                        Width="24" Padding="0" Foreground="{DynamicResource FgDim}"
                                                        Content="×" ToolTip="タブを閉じる" Tag="{Binding Id}"
                                                        Click="OnTerminalTabClosed" />
                                            </Grid>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource Accent}" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                    <Grid x:Name="TerminalContentHost" />
                </DockPanel>

                <!-- Editor -->
                <DockPanel x:Name="EditorPane" Background="{DynamicResource Panel}">
                    <DockPanel DockPanel.Dock="Top" Background="{DynamicResource Panel}" LastChildFill="True"
                               Tag="Editor" Cursor="SizeAll"
                               PreviewMouseLeftButtonDown="OnPaneTitleMouseDown" PreviewMouseMove="OnPaneTitleMouseMove">
                        <TextBlock DockPanel.Dock="Left" Style="{StaticResource PanelHeader}" Text="EDITOR" />
                        <Button DockPanel.Dock="Right" Style="{StaticResource CaptionButton}" Width="30" Height="24"
                                Content="—" FontSize="13" ToolTip="このペインを隠す"
                                Tag="Editor" Click="OnHidePane" />
                        <Button DockPanel.Dock="Right" Style="{StaticResource CaptionButton}" Width="30" Height="24"
                                Content="+" FontSize="15" ToolTip="新しいタブ" Click="OnEditorNewTab" />
                        <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Disabled"
                                      PanningMode="HorizontalOnly"
                                      PreviewMouseWheel="OnTabStripMouseWheel">
                            <ItemsControl ItemsSource="{Binding Tabs.EditorTabs}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="TabBorder" MinWidth="72" MaxWidth="150" Height="24"
                                                Margin="0" Background="Transparent"
                                                BorderBrush="Transparent" BorderThickness="0,0,0,2"
                                                Tag="{Binding Id}" MouseDown="OnTabMiddleClick">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0" Style="{StaticResource TabStripButton}"
                                                        Padding="8,0,4,0" HorizontalContentAlignment="Left"
                                                        Foreground="{DynamicResource Fg}" Tag="{Binding Id}"
                                                        Click="OnEditorTabSelected">
                                                    <TextBlock x:Name="TabTitle" Text="{Binding Title}" FontSize="12"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Button>
                                                <Button Grid.Column="1" Style="{StaticResource TabStripButton}"
                                                        Width="24" Padding="0" Foreground="{DynamicResource FgDim}"
                                                        Content="×" ToolTip="タブを閉じる" Tag="{Binding Id}"
                                                        Click="OnEditorTabClosed" />
                                            </Grid>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource Accent}" />
                                            </DataTrigger>
                                            <!-- プレビュータブ（編集するまで確定しない）は VS Code 同様に斜体で示す -->
                                            <DataTrigger Binding="{Binding IsPreview}" Value="True">
                                                <Setter TargetName="TabTitle" Property="FontStyle" Value="Italic" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                    <!-- 分割しても下端に1つだけ表示する共有ステータスバー。各エディタは SetSharedStatusBar で
                         自前のバーを隠してここへ状態を流す（フォーカス中のエディタの mode/file/cursor を表示）。 -->
                    <editor:VimStatusBar x:Name="EditorSharedStatusBar" DockPanel.Dock="Bottom" />
                    <Grid x:Name="EditorContentHost" />
                </DockPanel>

                <!-- EditorSupport : アクティブなエディタのファイルに対応するサポート（Markdown プレビュー等）を自動表示 -->
                <DockPanel x:Name="EditorSupportPane" Background="{DynamicResource Panel}">
                    <DockPanel DockPanel.Dock="Top" Background="{DynamicResource Panel}" LastChildFill="True"
                               Tag="EditorSupport" Cursor="SizeAll"
                               PreviewMouseLeftButtonDown="OnPaneTitleMouseDown" PreviewMouseMove="OnPaneTitleMouseMove">
                        <TextBlock DockPanel.Dock="Left" Style="{StaticResource PanelHeader}" Text="EDITOR SUPPORT" />
                        <Button DockPanel.Dock="Right" Style="{StaticResource CaptionButton}" Width="30" Height="24"
                                Content="—" FontSize="13" ToolTip="このペインを隠す"
                                Tag="EditorSupport" Click="OnHidePane" />
                        <TextBlock x:Name="EditorSupportTitle" VerticalAlignment="Center" Margin="4,0,8,0"
                                   FontSize="11" Foreground="{DynamicResource FgDim}"
                                   TextTrimming="CharacterEllipsis" />
                    </DockPanel>
                    <Grid x:Name="EditorSupportContentHost" />
                </DockPanel>

                <!-- Browser -->
                <DockPanel x:Name="BrowserPane" Background="{DynamicResource Panel}">
                    <DockPanel DockPanel.Dock="Top" Background="{DynamicResource Panel}" LastChildFill="True"
                               Tag="Browser" Cursor="SizeAll"
                               PreviewMouseLeftButtonDown="OnPaneTitleMouseDown" PreviewMouseMove="OnPaneTitleMouseMove">
                        <TextBlock DockPanel.Dock="Left" Style="{StaticResource PanelHeader}" Text="BROWSER" />
                        <Button DockPanel.Dock="Right" Style="{StaticResource CaptionButton}" Width="30" Height="24"
                                Content="—" FontSize="13" ToolTip="このペインを隠す"
                                Tag="Browser" Click="OnHidePane" />
                        <Button DockPanel.Dock="Right" Style="{StaticResource CaptionButton}" Width="30" Height="24"
                                Content="+" FontSize="15" ToolTip="新しいタブ" Click="OnBrowserNewTab" />
                        <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Disabled"
                                      PanningMode="HorizontalOnly"
                                      PreviewMouseWheel="OnTabStripMouseWheel">
                            <ItemsControl ItemsSource="{Binding Tabs.BrowserTabs}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="TabBorder" MinWidth="72" MaxWidth="150" Height="24"
                                                Margin="0" Background="Transparent"
                                                BorderBrush="Transparent" BorderThickness="0,0,0,2"
                                                Tag="{Binding Id}" MouseDown="OnTabMiddleClick">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0" Style="{StaticResource TabStripButton}"
                                                        Padding="8,0,4,0" HorizontalContentAlignment="Left"
                                                        Foreground="{DynamicResource Fg}" Tag="{Binding Id}"
                                                        Click="OnBrowserTabSelected">
                                                    <TextBlock Text="{Binding Title}" FontSize="12"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Button>
                                                <Button Grid.Column="1" Style="{StaticResource TabStripButton}"
                                                        Width="24" Padding="0" Foreground="{DynamicResource FgDim}"
                                                        Content="×" ToolTip="タブを閉じる" Tag="{Binding Id}"
                                                        Click="OnBrowserTabClosed" />
                                            </Grid>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource Accent}" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="8,0,8,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource CaptionButton}" Width="30" Height="28"
                                ToolTip="戻る" Click="OnBrowserBack">
                            <Path Stretch="Uniform" Width="12" Height="12"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Data="M7,0 L0,6 L7,12 V8 H12 V4 H7 Z" />
                        </Button>
                        <Button Grid.Column="1" Style="{StaticResource CaptionButton}" Width="30" Height="28"
                                ToolTip="進む" Click="OnBrowserForward">
                            <Path Stretch="Uniform" Width="12" Height="12"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Data="M5,0 L12,6 L5,12 V8 H0 V4 H5 Z" />
                        </Button>
                        <Button Grid.Column="2" Style="{StaticResource CaptionButton}" Width="30" Height="28"
                                ToolTip="更新" Click="OnBrowserReload">
                            <Path Stretch="Uniform" Width="13" Height="13"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Data="M10.8,4.8 A4.5,4.5 0 1 0 9.6,9.7 M10.8,4.8 V1.2 H7.2" />
                        </Button>
                        <TextBox x:Name="BrowserAddressBox" Grid.Column="3" Height="28" Margin="6,0"
                                 VerticalContentAlignment="Center"
                                 KeyDown="OnBrowserAddressKeyDown" />
                        <Button Grid.Column="4" Content="Go" Style="{StaticResource FlatButton}"
                                Padding="10,4" Height="28" Click="OnBrowserGo" />
                    </Grid>
                    <Grid x:Name="BrowserContentHost" />
                </DockPanel>

                <!-- Git : セッションペイン（コミットグラフ・ブランチ・rebase 等の複雑操作） -->
                <DockPanel x:Name="GitPane" Background="{DynamicResource Panel}">
                    <DockPanel DockPanel.Dock="Top" Background="{DynamicResource Panel}" LastChildFill="False"
                               Tag="Git" Cursor="SizeAll"
                               PreviewMouseLeftButtonDown="OnPaneTitleMouseDown" PreviewMouseMove="OnPaneTitleMouseMove">
                        <TextBlock DockPanel.Dock="Left" Style="{StaticResource PanelHeader}" Text="GIT" />
                        <Button DockPanel.Dock="Right" Style="{StaticResource CaptionButton}" Width="30" Height="24"
                                Content="—" FontSize="13" ToolTip="このペインを隠す"
                                Tag="Git" Click="OnHidePane" />
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center"
                                    Visibility="{Binding GitSession.IsRepository, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="⎇" Foreground="{DynamicResource FgDim}" VerticalAlignment="Center"
                                       Margin="2,0,4,0" />
                            <TextBlock Text="{Binding GitSession.BranchLabel}" FontSize="12" FontWeight="SemiBold"
                                       VerticalAlignment="Center" Margin="0,0,12,0" />
                            <Button Style="{StaticResource PaneHeaderToolButton}" Content="⭮ フェッチ"
                                    Command="{Binding GitSession.FetchCommand}" />
                            <Button Style="{StaticResource PaneHeaderToolButton}" Content="⇣ プル"
                                    Command="{Binding GitSession.PullCommand}" />
                            <Button Style="{StaticResource PaneHeaderToolButton}" Content="⇡ プッシュ"
                                    Command="{Binding GitSession.PushCommand}" />
                            <Button Style="{StaticResource PaneHeaderToolButton}" Content="＋ ブランチ"
                                    ToolTip="HEAD から新しいブランチを作成" Click="OnGitNewBranch" />
                        </StackPanel>
                    </DockPanel>
                    <views:GitSessionView x:Name="GitSessionHost" DataContext="{Binding GitSession}" />
                </DockPanel>

                <!-- Diff : セッションペイン（AI変更レビュー＋Git作業ツリー差分） -->
                <DockPanel x:Name="DiffPane" Background="{DynamicResource Panel}">
                    <DockPanel DockPanel.Dock="Top" Background="{DynamicResource Panel}" LastChildFill="False"
                               Tag="Diff" Cursor="SizeAll"
                               PreviewMouseLeftButtonDown="OnPaneTitleMouseDown" PreviewMouseMove="OnPaneTitleMouseMove">
                        <TextBlock DockPanel.Dock="Left" Style="{StaticResource PanelHeader}" Text="DIFF" />
                        <Button DockPanel.Dock="Right" Style="{StaticResource CaptionButton}" Width="30" Height="24"
                                Content="—" FontSize="13" ToolTip="このペインを隠す"
                                Tag="Diff" Click="OnHidePane" />
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="{DynamicResource BgAlt}" CornerRadius="4" Padding="1"
                                    Margin="0,0,10,0">
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton Style="{StaticResource SourceToggle}" Content="Git" FontSize="12"
                                                 IsChecked="{Binding DiffSession.IsGitMode}" />
                                    <RadioButton Style="{StaticResource SourceToggle}" Content="AI変更" FontSize="12"
                                                 IsChecked="{Binding DiffSession.IsGitMode, Converter={StaticResource InverseBool}}" />
                                </StackPanel>
                            </Border>
                            <!-- Git セッションから連携されたコミット範囲の表示中ラベル＋解除 -->
                            <StackPanel Orientation="Horizontal">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DiffSession.GitTargetLabel}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="{Binding DiffSession.GitTargetLabel}" FontSize="12"
                                           Foreground="{DynamicResource Accent}" VerticalAlignment="Center"
                                           Margin="0,0,6,0" TextTrimming="CharacterEllipsis" MaxWidth="240" />
                                <Button Style="{StaticResource PaneHeaderToolButton}" Content="✕ 作業ツリーへ"
                                        ToolTip="コミット範囲の表示を解除して作業ツリー差分へ戻る"
                                        Command="{Binding DiffSession.ClearGitTargetCommand}" />
                            </StackPanel>
                            <Button Style="{StaticResource PaneHeaderToolButton}" Content="エディタで開く"
                                    Command="{Binding DiffSession.OpenInEditorCommand}" />
                            <Button Style="{StaticResource PaneHeaderToolButton}" Content="元に戻す"
                                    ToolTip="選択中ファイルの AI 変更を巻き戻す（新規作成なら削除）"
                                    Command="{Binding DiffSession.RevertCommand}"
                                    Visibility="{Binding DiffSession.IsGitMode, Converter={StaticResource InverseBoolToVis}}" />
                            <Button Style="{StaticResource PaneHeaderToolButton}" Content="記録をクリア"
                                    ToolTip="AI変更の記録をすべて消す（ファイル自体は変更しない）"
                                    Command="{Binding DiffSession.ClearAiChangesCommand}"
                                    Visibility="{Binding DiffSession.IsGitMode, Converter={StaticResource InverseBoolToVis}}" />
                        </StackPanel>
                    </DockPanel>
                    <views:DiffSessionView x:Name="DiffSessionHost" DataContext="{Binding DiffSession}" />
                </DockPanel>

                <!-- Trace : セッションペイン（AI操作トレースのタイムライン表示・読み取り専用） -->
                <DockPanel x:Name="TracePane" Background="{DynamicResource Panel}">
                    <DockPanel DockPanel.Dock="Top" Background="{DynamicResource Panel}" LastChildFill="False"
                               Tag="Trace" Cursor="SizeAll"
                               PreviewMouseLeftButtonDown="OnPaneTitleMouseDown" PreviewMouseMove="OnPaneTitleMouseMove">
                        <TextBlock DockPanel.Dock="Left" Style="{StaticResource PanelHeader}" Text="TRACE" />
                        <Button DockPanel.Dock="Right" Style="{StaticResource CaptionButton}" Width="30" Height="24"
                                Content="—" FontSize="13" ToolTip="このペインを隠す"
                                Tag="Trace" Click="OnHidePane" />
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource PaneHeaderToolButton}" Content="削除"
                                    ToolTip="選択中セッションのトレースファイルを削除"
                                    Command="{Binding TraceSession.DeleteSelectedCommand}" />
                            <TextBlock Text="{Binding TraceSession.SummaryLabel}" VerticalAlignment="Center"
                                       Margin="2,0,0,0" FontSize="11" Foreground="{DynamicResource FgDim}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </DockPanel>
                    <views:TraceSessionView x:Name="TraceSessionHost" DataContext="{Binding TraceSession}" />
                </DockPanel>

                <!-- AI : ペイン化（トランスクリプト＋入力を1列にまとめる） -->
                <DockPanel x:Name="AiPane" Background="{DynamicResource Panel}">
                    <DockPanel DockPanel.Dock="Top" Background="{DynamicResource Panel}" LastChildFill="False"
                               Tag="Ai" Cursor="SizeAll"
                               PreviewMouseLeftButtonDown="OnPaneTitleMouseDown" PreviewMouseMove="OnPaneTitleMouseMove">
                        <TextBlock DockPanel.Dock="Left" Style="{StaticResource PanelHeader}" Text="AI" />
                        <Button DockPanel.Dock="Right" Style="{StaticResource CaptionButton}" Width="30" Height="24"
                                Content="—" FontSize="13" ToolTip="このペインを隠す"
                                Tag="Ai" Click="OnHidePane" />
                    </DockPanel>
                    <views:AiBarView x:Name="AiBarHost" DataContext="{Binding AiBar}" />
                </DockPanel>

                </Grid>   <!-- /PaneHost -->
            </Grid>
        </Grid>
    </Border>
</Window>
