<Window x:Class="sk0ya.Loomo.App.Views.ShellWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:sk0ya.Loomo.App.Views"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    Title="Loomo" Height="800" Width="1280"
    Background="{StaticResource Bg}" WindowStartupLocation="CenterScreen"
    WindowStyle="None" ResizeMode="CanResize">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36" ResizeBorderThickness="6"
                      CornerRadius="0" GlassFrameThickness="0"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <!-- 最大化サイズは code-behind の WM_GETMINMAXINFO でワーク領域に制限する（タスクバーを覆わない） -->
    <Border x:Name="RootBorder">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />  <!-- タイトルバー -->
                <RowDefinition Height="*" />     <!-- メイン領域 -->
                <RowDefinition Height="Auto" />  <!-- 下部AIバー -->
            </Grid.RowDefinitions>

            <!-- ===== カスタムタイトルバー ===== -->
            <Grid Grid.Row="0" Height="36" Background="{StaticResource ActivityBarBg}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                    <TextBlock Text="🤖" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="Loomo" VerticalAlignment="Center"
                               FontSize="12" Foreground="{StaticResource FgDim}" />
                </StackPanel>

                <!-- ウィンドウ操作ボタン（キャプション領域だがクリック可能にする） -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="MinimizeButton" Style="{StaticResource CaptionButton}"
                            ToolTip="最小化" Click="OnMinimize">
                        <Path Stretch="None" StrokeThickness="1" SnapsToDevicePixels="True"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M0,5 H10" />
                    </Button>
                    <Button x:Name="MaximizeButton" Style="{StaticResource CaptionButton}"
                            ToolTip="最大化" Click="OnMaximizeRestore">
                        <Path x:Name="MaximizeIcon" Stretch="None" StrokeThickness="1" SnapsToDevicePixels="True"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M0.5,0.5 H9.5 V9.5 H0.5 Z" />
                    </Button>
                    <Button x:Name="CloseButton" Style="{StaticResource CaptionCloseButton}"
                            ToolTip="閉じる" Click="OnClose">
                        <Path Stretch="None" StrokeThickness="1" SnapsToDevicePixels="True"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              Data="M0,0 L10,10 M0,10 L10,0" />
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ===== メイン領域 ===== -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48" />                                  <!-- ActivityBar -->
                    <ColumnDefinition x:Name="SidebarColumn" Width="220" MinWidth="120" />   <!-- Sidebar -->
                    <ColumnDefinition x:Name="SidebarSplitterColumn" Width="4" />    <!-- splitter -->
                    <ColumnDefinition Width="*" MinWidth="200" />                    <!-- Terminal -->
                    <ColumnDefinition Width="4" />                                   <!-- splitter -->
                    <ColumnDefinition Width="2*" MinWidth="300" />                   <!-- Editor -->
                    <ColumnDefinition Width="4" />                                   <!-- splitter -->
                    <ColumnDefinition Width="2*" MinWidth="320" />                   <!-- Browser -->
                </Grid.ColumnDefinitions>

                <!-- ActivityBar -->
                <DockPanel Grid.Column="0" Background="{StaticResource ActivityBarBg}">
                    <Button DockPanel.Dock="Bottom" Style="{StaticResource IconButton}" Content="⚙" ToolTip="設定"
                            Command="{Binding ShowSettingsCommand}" />
                    <StackPanel>
                        <Button Style="{StaticResource IconButton}" Content="🗂" ToolTip="エクスプローラ"
                                Command="{Binding ShowExplorerCommand}" />
                        <Button Style="{StaticResource IconButton}" Content="🔍" ToolTip="検索" />
                        <Button Style="{StaticResource IconButton}" Content="💬" ToolTip="AIセッション"
                                Command="{Binding ShowSessionsCommand}" />
                    </StackPanel>
                </DockPanel>

                <!-- Sidebar : Explorer / Sessions / Settings を ActivePanel で切替 -->
                <Grid x:Name="SidebarContainer" Grid.Column="1">
                    <views:FolderTreeView DataContext="{Binding FolderTree}"
                                          Visibility="{Binding DataContext.ActivePanel, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EnumToVis}, ConverterParameter=Explorer}" />
                    <views:SessionsView DataContext="{Binding Sessions}"
                                        Visibility="{Binding DataContext.ActivePanel, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EnumToVis}, ConverterParameter=Sessions}" />
                    <views:SettingsView DataContext="{Binding Settings}"
                                        Visibility="{Binding DataContext.ActivePanel, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource EnumToVis}, ConverterParameter=Settings}" />
                </Grid>

                <GridSplitter x:Name="SidebarSplitter" Grid.Column="2" Width="4"
                              HorizontalAlignment="Stretch" Background="{StaticResource Border}" />

                <!-- Terminal -->
                <DockPanel Grid.Column="3" Background="{StaticResource Panel}">
                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource PanelHeader}" Text="TERMINAL" />
                    <Border x:Name="TerminalHost" />
                </DockPanel>

                <GridSplitter Grid.Column="4" Width="4" HorizontalAlignment="Stretch"
                              Background="{StaticResource Border}" />

                <!-- Editor -->
                <DockPanel Grid.Column="5" Background="{StaticResource Panel}">
                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource PanelHeader}" Text="EDITOR" />
                    <Border x:Name="EditorHost" />
                </DockPanel>

                <GridSplitter Grid.Column="6" Width="4" HorizontalAlignment="Stretch"
                              Background="{StaticResource Border}" />

                <!-- Browser -->
                <DockPanel Grid.Column="7" Background="{StaticResource Panel}">
                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource PanelHeader}" Text="BROWSER" />
                    <Grid DockPanel.Dock="Top" Margin="8,0,8,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource CaptionButton}" Width="30" Height="28"
                                ToolTip="戻る" Click="OnBrowserBack">
                            <Path Stretch="Uniform" Width="12" Height="12"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Data="M7,0 L0,6 L7,12 V8 H12 V4 H7 Z" />
                        </Button>
                        <Button Grid.Column="1" Style="{StaticResource CaptionButton}" Width="30" Height="28"
                                ToolTip="進む" Click="OnBrowserForward">
                            <Path Stretch="Uniform" Width="12" Height="12"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  Data="M5,0 L12,6 L5,12 V8 H0 V4 H5 Z" />
                        </Button>
                        <Button Grid.Column="2" Style="{StaticResource CaptionButton}" Width="30" Height="28"
                                ToolTip="更新" Click="OnBrowserReload">
                            <Path Stretch="Uniform" Width="13" Height="13"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Data="M10.8,4.8 A4.5,4.5 0 1 0 9.6,9.7 M10.8,4.8 V1.2 H7.2" />
                        </Button>
                        <TextBox x:Name="BrowserAddressBox" Grid.Column="3" Height="28" Margin="6,0"
                                 VerticalContentAlignment="Center"
                                 KeyDown="OnBrowserAddressKeyDown" />
                        <Button Grid.Column="4" Content="Go" Style="{StaticResource FlatButton}"
                                Padding="10,4" Height="28" Click="OnBrowserGo" />
                    </Grid>
                    <wv2:WebView2 x:Name="BrowserView"
                                  DefaultBackgroundColor="#FF1E1E1E"
                                  NavigationCompleted="OnBrowserNavigationCompleted" />
                </DockPanel>
            </Grid>

            <!-- ===== 下部AIバー（全幅・展開式） ===== -->
            <views:AiBarView Grid.Row="2" DataContext="{Binding AiBar}" MaxHeight="420" />
        </Grid>
    </Border>
</Window>
