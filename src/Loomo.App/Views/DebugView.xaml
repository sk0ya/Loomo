<UserControl x:Class="sk0ya.Loomo.App.Views.DebugView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:sk0ya.Loomo.App.ViewModels"
    xmlns:dbg="clr-namespace:sk0ya.Loomo.Core.Debug;assembly=sk0ya.Loomo.Core"
    Background="{DynamicResource BgAlt}">

    <UserControl.Resources>
        <SolidColorBrush x:Key="DebugStderr" Color="#E06C75" />

        <!-- テストツリーの行内 ▶（実行）ボタン。既定ボタンのシステム色ホバーを避け、テーマ追従の
             透明背景＋ホバーで BgAlt にする（IconButton をコンパクト化）。 -->
        <Style x:Key="RunGlyphButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="18" />
            <Setter Property="FontSize" Value="10" />
        </Style>

        <!-- 状態フィルタのトグル。Loomo 流に塗りつぶさず、フラットなアウトラインチップ。
             OFF はグレー（FgDim＋既定枠）で除外を示し、ON は Tag の色（成功=緑/失敗=赤/未実施=アクセント）の
             テキスト＋枠線で、ツリーの色分けと揃える。 -->
        <Style x:Key="FilterToggle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Padding" Value="9,0" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="b" Background="Transparent" CornerRadius="3"
                                BorderBrush="{DynamicResource Border}" BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource BgAlt}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground"
                                        Value="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" />
                                <Setter TargetName="b" Property="BorderBrush"
                                        Value="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 各項目（出力行・フレーム・変数・ウォッチ）を個別にコピーする右クリックメニュー。
             x:Shared="False" で参照ごとに別インスタンスを作り、項目ごとに独立して付ける。 -->
        <ContextMenu x:Key="CopyItemMenu" x:Shared="False">
            <MenuItem Header="コピー" Click="OnCopyItemClick" />
        </ContextMenu>

        <!-- 変数行：コピーに加え、対応アダプタなら値を書き換えられる（CanEdit で活性）。 -->
        <ContextMenu x:Key="VarItemMenu" x:Shared="False">
            <MenuItem Header="コピー" Click="OnCopyItemClick" />
            <MenuItem Header="値を変更…" Click="OnEditVariableClick" IsEnabled="{Binding CanEdit}" />
        </ContextMenu>

        <!-- 検査タブ（出力／変数／コールスタック）。下線で選択を示すフラットなタブ。 -->
        <Style x:Key="DebugTabItem" TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Padding="10,5" Margin="0,0,2,0"
                                Background="Transparent"
                                BorderBrush="Transparent" BorderThickness="0,0,0,2">
                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource Fg}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Accent}" />
                                <Setter Property="Foreground" Value="{DynamicResource Fg}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DebugTabControl" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Background="{DynamicResource Panel}"
                                    BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
                                <TabPanel IsItemsHost="True" Background="Transparent" Margin="4,2,4,0" />
                            </Border>
                            <ContentPresenter ContentSource="SelectedContent" />
                        </DockPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <DockPanel>
        <!-- ヘッダ／状態はホスト（ペインヘッダ）側が表示する。ここはコンテンツのみ。 -->

        <!-- アダプタ未導入バー -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource Panel}" Padding="8,6" Margin="6,2,6,0"
                BorderBrush="{DynamicResource Border}" BorderThickness="1"
                Visibility="{Binding IsAdapterMissing, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource Fg}" FontSize="11"
                           Text="デバッグには netcoredbg が必要です（PATH 上に未検出）。" />
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <Button Content="インストール" Style="{StaticResource FlatButton}" Height="24" Padding="10,0"
                            Command="{Binding InstallAdapterCommand}"
                            ToolTip="{Binding AdapterInstallCommand}" />
                    <Button Content="再確認" Style="{StaticResource SecondaryButton}" Height="24" Padding="10,0"
                            Margin="6,0,0,0" Click="OnRefreshClick" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ツールバー：対象指定＋ビルド。開始/停止/アタッチの操作ボタンはペインヘッダ側に移設。 -->
        <StackPanel DockPanel.Dock="Top" Margin="8,6,8,6">
            <!-- 対象（.dll/.exe）＋ビルド設定：デバッグ前のみ表示（デバッグ中は隠す）。 -->
            <StackPanel Visibility="{Binding IsBusy, Converter={StaticResource InverseBoolToVis}}">
                <Grid>
                    <TextBox x:Name="TargetBox" Padding="6,4" FontSize="12"
                             Background="{DynamicResource Bg}" Foreground="{DynamicResource Fg}"
                             BorderBrush="{DynamicResource Border}" CaretBrush="{DynamicResource Fg}"
                             Text="{Binding TargetProgram, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="デバッグ対象 (.dll/.exe)。空ならワークスペースの .csproj から自動検出" />
                    <TextBlock Text="対象 (.dll/.exe)。空=自動検出" IsHitTestVisible="False" FontSize="12"
                               Foreground="{DynamicResource FgDim}" VerticalAlignment="Center" Margin="8,0,0,0"
                               Visibility="{Binding Text, ElementName=TargetBox, Converter={StaticResource EmptyToVis}}" />
                </Grid>

                <!-- 起動引数（コマンドライン引数）。空白区切り・二重引用符でグループ化。 -->
                <Grid Margin="0,4,0,0">
                    <TextBox x:Name="ArgsBox" Padding="6,4" FontSize="12" FontFamily="Consolas"
                             Background="{DynamicResource Bg}" Foreground="{DynamicResource Fg}"
                             BorderBrush="{DynamicResource Border}" CaretBrush="{DynamicResource Fg}"
                             Text="{Binding LaunchArgs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="プログラムへ渡す引数（空白区切り。空白を含む値は &quot;...&quot; で囲む）" />
                    <TextBlock Text="起動引数（空白区切り）" IsHitTestVisible="False" FontSize="12"
                               Foreground="{DynamicResource FgDim}" VerticalAlignment="Center" Margin="8,0,0,0"
                               Visibility="{Binding Text, ElementName=ArgsBox, Converter={StaticResource EmptyToVis}}" />
                </Grid>

                <!-- 環境変数。1 行 1 件の KEY=VALUE。 -->
                <Grid Margin="0,4,0,0">
                    <TextBox x:Name="EnvBox" Padding="6,4" FontSize="12" FontFamily="Consolas"
                             AcceptsReturn="True" TextWrapping="NoWrap" MinLines="2" MaxLines="5"
                             VerticalScrollBarVisibility="Auto"
                             Background="{DynamicResource Bg}" Foreground="{DynamicResource Fg}"
                             BorderBrush="{DynamicResource Border}" CaretBrush="{DynamicResource Fg}"
                             Text="{Binding LaunchEnv, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="環境変数（1 行 1 件 KEY=VALUE）。空なら親プロセスの環境のまま" />
                    <TextBlock Text="環境変数（1 行 1 件 KEY=VALUE）" IsHitTestVisible="False" FontSize="12"
                               Foreground="{DynamicResource FgDim}" VerticalAlignment="Top" Margin="8,5,0,0"
                               Visibility="{Binding Text, ElementName=EnvBox, Converter={StaticResource EmptyToVis}}" />
                </Grid>
            </StackPanel>

            <!-- プロセスにアタッチ：実行中プロセスを選んで接続。停止してもそのプロセスは終了しない。 -->
            <Border Margin="0,6,0,0" Padding="8" Background="{DynamicResource Panel}"
                    BorderBrush="{DynamicResource Border}" BorderThickness="1"
                    Visibility="{Binding ShowAttach, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Grid Width="170">
                            <TextBox x:Name="ProcFilterBox" Padding="6,3" FontSize="11"
                                     Background="{DynamicResource Bg}" Foreground="{DynamicResource Fg}"
                                     BorderBrush="{DynamicResource Border}" CaretBrush="{DynamicResource Fg}"
                                     Text="{Binding ProcessFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="絞り込み（名前/PID）" IsHitTestVisible="False" FontSize="11"
                                       Foreground="{DynamicResource FgDim}" VerticalAlignment="Center" Margin="8,0,0,0"
                                       Visibility="{Binding Text, ElementName=ProcFilterBox, Converter={StaticResource EmptyToVis}}" />
                        </Grid>
                        <CheckBox Content=".NET のみ" IsChecked="{Binding DotnetOnly, Mode=TwoWay}"
                                  Foreground="{DynamicResource Fg}" VerticalAlignment="Center" FontSize="11"
                                  Margin="8,0,0,0" />
                        <Button Content="更新" Style="{StaticResource SecondaryButton}" Height="22" Padding="8,0"
                                Margin="8,0,0,0" Command="{Binding RefreshProcessesCommand}" />
                    </StackPanel>

                    <ListBox ItemsSource="{Binding Processes}" SelectedItem="{Binding SelectedProcess, Mode=TwoWay}"
                             Height="160" Margin="0,6,0,0" Background="{DynamicResource Bg}"
                             BorderBrush="{DynamicResource Border}" BorderThickness="1" Foreground="{DynamicResource Fg}"
                             MouseDoubleClick="OnProcessDoubleClick"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:DebugProcessViewModel}">
                                <TextBlock Text="{Binding Display}" FontSize="11" FontFamily="Consolas"
                                           TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Button Content="⮌ アタッチ" Style="{StaticResource FlatButton}" Height="24" Padding="12,0"
                            Margin="0,6,0,0" HorizontalAlignment="Left"
                            Command="{Binding AttachCommand}"
                            ToolTip="選択したプロセスに接続（ダブルクリックでも可）" />
                </StackPanel>
            </Border>

            <!-- ステップ操作：停止中のみ表示 -->
            <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                        Visibility="{Binding IsStopped, Converter={StaticResource BoolToVis}}">
                <Button Content="▶ 続行" Style="{StaticResource SecondaryButton}" Height="24" Padding="10,0"
                        Command="{Binding ContinueCommand}" ToolTip="続行 (F5)" />
                <Button Content="⤼ オーバー" Style="{StaticResource SecondaryButton}" Height="24" Padding="10,0"
                        Margin="6,0,0,0" Command="{Binding StepOverCommand}" ToolTip="ステップオーバー" />
                <Button Content="⤷ イン" Style="{StaticResource SecondaryButton}" Height="24" Padding="10,0"
                        Margin="6,0,0,0" Command="{Binding StepIntoCommand}" ToolTip="ステップイン" />
                <Button Content="⤴ アウト" Style="{StaticResource SecondaryButton}" Height="24" Padding="10,0"
                        Margin="6,0,0,0" Command="{Binding StepOutCommand}" ToolTip="ステップアウト" />
            </StackPanel>

            <!-- セッション操作（中断/再起動）：デバッグ中のみ表示。中断は実行中のみ有効。 -->
            <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                <Button Content="⏸ 中断" Style="{StaticResource SecondaryButton}" Height="24" Padding="10,0"
                        Command="{Binding PauseCommand}" ToolTip="すべて中断（一時停止）" />
                <Button Content="⟳ 再起動" Style="{StaticResource SecondaryButton}" Height="24" Padding="10,0"
                        Margin="6,0,0,0" Command="{Binding RestartCommand}" ToolTip="同じ対象で再起動" />
            </StackPanel>

            <!-- 例外で中断 / オプション（常時表示。例外フィルタは実行中でも切り替え可）。 -->
            <StackPanel Margin="0,8,0,0">
                <TextBlock Text="例外・オプション" Foreground="{DynamicResource FgDim}" FontSize="11" Margin="2,0,0,3" />
                <CheckBox Content="スローされたすべての例外で中断" FontSize="11" Foreground="{DynamicResource Fg}"
                          IsChecked="{Binding BreakOnAllExceptions, Mode=TwoWay}" Margin="0,1"
                          ToolTip="例外がスローされた瞬間に中断（netcoredbg: all）" />
                <CheckBox Content="未処理の例外で中断" FontSize="11" Foreground="{DynamicResource Fg}"
                          IsChecked="{Binding BreakOnUncaughtExceptions, Mode=TwoWay}" Margin="0,1"
                          ToolTip="ユーザーコード外へ抜ける未処理例外で中断（netcoredbg: user-unhandled）" />
                <CheckBox Content="マイ コードのみ（次回起動から）" FontSize="11" Foreground="{DynamicResource Fg}"
                          IsChecked="{Binding JustMyCode, Mode=TwoWay}" Margin="0,1"
                          ToolTip="外部/フレームワークコードへステップインしない" />
            </StackPanel>
        </StackPanel>

        <!-- 検査タブ：出力（常時）／変数（＋ウォッチ）／コールスタック。残り全域を使う。 -->
        <TabControl x:Name="DebugTabs" Style="{StaticResource DebugTabControl}"
                    Margin="6,0,6,6" SelectedIndex="0" SelectionChanged="OnDebugTabChanged">

            <!-- 出力：テキスト選択できる読み取り専用 RichTextBox（行は Category で色分け）。
                 内容は本文を選択してコンテキストメニュー（コピー／すべて選択）からコピーする。
                 ドキュメントの構築・追記・末尾スクロールはコードビハインド（Output コレクションを写す）。 -->
            <TabItem Style="{StaticResource DebugTabItem}" Header="出力">
                <Border Background="{DynamicResource Bg}" BorderBrush="{DynamicResource Border}"
                        BorderThickness="1" Margin="0,4,0,0">
                    <RichTextBox x:Name="ConsoleBox" IsReadOnly="True" IsReadOnlyCaretVisible="True"
                                 IsDocumentEnabled="True" Background="Transparent" Padding="6,4"
                                 Foreground="{DynamicResource Fg}" BorderThickness="0"
                                 FontFamily="Consolas" FontSize="12"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <RichTextBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="コピー" Command="Copy" />
                                <MenuItem Header="すべて選択" Command="SelectAll" />
                            </ContextMenu>
                        </RichTextBox.ContextMenu>
                    </RichTextBox>
                </Border>
            </TabItem>

            <!-- 変数（＋ウォッチ） -->
            <TabItem Style="{StaticResource DebugTabItem}" Header="変数">
                <Grid Margin="0,4,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- 変数ツリー -->
                    <TreeView Grid.Row="0" ItemsSource="{Binding Variables}" Background="{DynamicResource Bg}"
                              BorderBrush="{DynamicResource Border}" BorderThickness="1" Foreground="{DynamicResource Fg}"
                              MouseDoubleClick="OnVariableDoubleClick"
                              ToolTip="対応アダプタなら葉のダブルクリック／右クリックで値を変更"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                <Setter Property="Foreground" Value="{DynamicResource Fg}" />
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.Resources>
                            <HierarchicalDataTemplate DataType="{x:Type vm:DebugVariableViewModel}" ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" ContextMenu="{StaticResource VarItemMenu}">
                                    <TextBlock Text="{Binding Name}" FontSize="11" FontFamily="Consolas" />
                                    <TextBlock Text="=" FontSize="11" Opacity="0.5" Margin="4,0,4,0"
                                               Visibility="{Binding Value, Converter={StaticResource NonEmptyToVis}}" />
                                    <!-- 値：通常は読み取り表示、編集中は TextBox（setVariable で反映）。 -->
                                    <TextBlock Text="{Binding Value}" FontSize="11" FontFamily="Consolas"
                                               Foreground="{DynamicResource Accent}" TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVis}}" />
                                    <TextBox Text="{Binding EditValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="11" FontFamily="Consolas" MinWidth="80" Padding="2,0"
                                             Background="{DynamicResource Bg}" Foreground="{DynamicResource Fg}"
                                             BorderBrush="{DynamicResource Accent}" CaretBrush="{DynamicResource Fg}"
                                             Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"
                                             Loaded="OnVariableEditBoxLoaded"
                                             PreviewKeyDown="OnVariableEditKeyDown"
                                             LostKeyboardFocus="OnVariableEditLostFocus" />
                                    <TextBlock Text="{Binding Type}" FontSize="10" Opacity="0.5" Margin="6,1,0,0" />
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.Resources>
                    </TreeView>

                    <!-- 停止していないときの案内 -->
                    <TextBlock Grid.Row="0" Text="停止すると変数が表示されます" Foreground="{DynamicResource FgDim}"
                               FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding IsStopped, Converter={StaticResource InverseBoolToVis}}" />

                    <!-- ウォッチ -->
                    <StackPanel Grid.Row="1" Margin="0,6,0,0">
                        <TextBlock Text="ウォッチ" Foreground="{DynamicResource FgDim}" FontSize="11" Margin="2,0,0,3" />
                        <Grid>
                            <TextBox x:Name="WatchBox" Padding="6,3" FontSize="11" FontFamily="Consolas"
                                     Background="{DynamicResource Bg}" Foreground="{DynamicResource Fg}"
                                     BorderBrush="{DynamicResource Border}" CaretBrush="{DynamicResource Fg}"
                                     Text="{Binding WatchExpression, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PreviewKeyDown="OnWatchKeyDown" />
                            <TextBlock Text="ウォッチ式を追加（Enter）" IsHitTestVisible="False" FontSize="11"
                                       Foreground="{DynamicResource FgDim}" VerticalAlignment="Center" Margin="8,0,0,0"
                                       Visibility="{Binding Text, ElementName=WatchBox, Converter={StaticResource EmptyToVis}}" />
                        </Grid>
                        <ItemsControl ItemsSource="{Binding Watches}" Margin="0,4,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:WatchItemViewModel}">
                                    <Grid Margin="0,1" ContextMenu="{StaticResource CopyItemMenu}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Expression}" FontSize="11" FontFamily="Consolas" />
                                        <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="11" FontFamily="Consolas"
                                                   Foreground="{DynamicResource Accent}" Margin="6,0,0,0"
                                                   TextTrimming="CharacterEllipsis" />
                                        <Button Grid.Column="2" Content="✕" FontSize="10" Padding="4,0" Cursor="Hand"
                                                Background="Transparent" BorderThickness="0" Foreground="{DynamicResource FgDim}"
                                                Command="{Binding DataContext.RemoveWatchCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- コールスタック -->
            <TabItem Style="{StaticResource DebugTabItem}" Header="コールスタック">
                <Grid Margin="0,4,0,0">
                    <ListBox ItemsSource="{Binding CallStack}" SelectedItem="{Binding SelectedFrame, Mode=TwoWay}"
                             Background="{DynamicResource Bg}" BorderBrush="{DynamicResource Border}" BorderThickness="1"
                             Foreground="{DynamicResource Fg}"
                             MouseDoubleClick="OnCallStackDoubleClick"
                             ToolTip="クリックでソースをプレビュー、ダブルクリックでジャンプ"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:DebugFrameViewModel}">
                                <StackPanel Orientation="Horizontal" ContextMenu="{StaticResource CopyItemMenu}">
                                    <TextBlock Text="{Binding Name}" FontSize="11" FontFamily="Consolas"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Location}" FontSize="11" Opacity="0.6" Margin="8,0,0,0" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- 停止していないときの案内 -->
                    <TextBlock Text="停止するとコールスタックが表示されます" Foreground="{DynamicResource FgDim}"
                               FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding IsStopped, Converter={StaticResource InverseBoolToVis}}" />
                </Grid>
            </TabItem>

            <!-- テスト：探索で全テストを一覧化し、全実行/個別実行（▶）の結果でステータスを更新する。
                 失敗テストはダブルクリックで該当行へジャンプ。 -->
            <TabItem Style="{StaticResource DebugTabItem}" Header="テスト">
                <Grid Margin="0,4,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- 操作バー（1 行）：全実行＋テキスト検索＋状態トグル（成功/失敗/未実施）。 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="2,0,0,4">
                        <Button Content="▶ 全実行" Style="{StaticResource SecondaryButton}" Height="20" Padding="8,0"
                                VerticalAlignment="Center" Command="{Binding TestCommand}" ToolTip="すべてのテストを実行" />
                        <Grid Width="130" Margin="8,0,0,0">
                            <TextBox x:Name="TestFilterBox" Padding="6,2" FontSize="11"
                                     Background="{DynamicResource Bg}" Foreground="{DynamicResource Fg}"
                                     BorderBrush="{DynamicResource Border}" CaretBrush="{DynamicResource Fg}"
                                     Text="{Binding TestFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="検索（名前）" IsHitTestVisible="False" FontSize="11"
                                       Foreground="{DynamicResource FgDim}" VerticalAlignment="Center" Margin="8,0,0,0"
                                       Visibility="{Binding Text, ElementName=TestFilterBox, Converter={StaticResource EmptyToVis}}" />
                        </Grid>
                        <ToggleButton Content="成功" Style="{StaticResource FilterToggle}" Tag="{DynamicResource Success}"
                                      VerticalAlignment="Center" Margin="8,0,0,0" ToolTip="成功したテストを表示"
                                      IsChecked="{Binding ShowPassed, Mode=TwoWay}" />
                        <ToggleButton Content="失敗" Style="{StaticResource FilterToggle}" Tag="{DynamicResource Error}"
                                      VerticalAlignment="Center" Margin="4,0,0,0" ToolTip="失敗したテストを表示"
                                      IsChecked="{Binding ShowFailed, Mode=TwoWay}" />
                        <ToggleButton Content="未実施" Style="{StaticResource FilterToggle}" Tag="{DynamicResource Accent}"
                                      VerticalAlignment="Center" Margin="4,0,0,0" ToolTip="未実施・スキップのテストを表示"
                                      IsChecked="{Binding ShowNotRun, Mode=TwoWay}" />
                        <TextBlock Text="収集中…" Foreground="{DynamicResource FgDim}" FontSize="11"
                                   VerticalAlignment="Center" Margin="8,0,0,0"
                                   Visibility="{Binding IsDiscoveringTests, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>

                    <!-- 集計行 -->
                    <TextBlock Grid.Row="1" Text="{Binding TestSummary}" Foreground="{DynamicResource Fg}"
                               FontSize="11" Margin="2,0,0,4"
                               Visibility="{Binding HasTestResults, Converter={StaticResource BoolToVis}}" />

                    <!-- テストツリー：クラスでグループ化し、葉がテスト。ダブルクリックでジャンプ、▶ で実行。 -->
                    <TreeView Grid.Row="2" ItemsSource="{Binding TestTree}" Background="{DynamicResource Bg}"
                              BorderBrush="{DynamicResource Border}" BorderThickness="1" Foreground="{DynamicResource Fg}"
                              MouseDoubleClick="OnTestDoubleClick"
                              ToolTip="ダブルクリックで該当行へジャンプ、▶ で実行（クラス/テスト）"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                <Setter Property="Foreground" Value="{DynamicResource Fg}" />
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.Resources>
                            <!-- グリフ色（成功/失敗/実行中）。グループ・葉で共有。 -->
                            <Style x:Key="TestGlyph" TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
                                <Setter Property="FontSize" Value="11" />
                                <Setter Property="Margin" Value="0,0,6,0" />
                                <Setter Property="VerticalAlignment" Value="Top" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="Passed">
                                        <Setter Property="Foreground" Value="{DynamicResource Success}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Failed">
                                        <Setter Property="Foreground" Value="{DynamicResource Error}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Running">
                                        <Setter Property="Foreground" Value="{DynamicResource Accent}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>

                            <!-- テスト名テキスト色（成功=緑/失敗=赤/実行中=アクセント）。グリフと同じ Status 連動。 -->
                            <Style x:Key="TestText" TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource Fg}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="Passed">
                                        <Setter Property="Foreground" Value="{DynamicResource Success}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Failed">
                                        <Setter Property="Foreground" Value="{DynamicResource Error}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Running">
                                        <Setter Property="Foreground" Value="{DynamicResource Accent}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>

                            <!-- グループ（クラス） -->
                            <HierarchicalDataTemplate DataType="{x:Type vm:TestGroupViewModel}" ItemsSource="{Binding Tests}">
                                <!-- 行クリックで開閉（Background を敷いて全幅をヒット対象に）。 -->
                                <Grid Background="Transparent" MouseLeftButtonUp="OnTestGroupClick"
                                      ContextMenu="{StaticResource CopyItemMenu}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Glyph}" Style="{StaticResource TestGlyph}" />
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="11" FontWeight="SemiBold"
                                               Style="{StaticResource TestText}"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Text="{Binding CountText}" FontSize="10" Opacity="0.6"
                                               Margin="8,0,0,0" VerticalAlignment="Center" />
                                    <Button Grid.Column="3" Content="▶" Style="{StaticResource RunGlyphButton}"
                                            Margin="6,0,0,0" VerticalAlignment="Center"
                                            ToolTip="このクラスのテストをまとめて実行"
                                            Command="{Binding DataContext.RunGroupCommand, RelativeSource={RelativeSource AncestorType=TreeView}}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </HierarchicalDataTemplate>

                            <!-- 葉（テスト） -->
                            <DataTemplate DataType="{x:Type vm:TestItemViewModel}">
                                <Grid ContextMenu="{StaticResource CopyItemMenu}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Glyph}" Style="{StaticResource TestGlyph}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding MethodName}" FontSize="11" FontFamily="Consolas"
                                                   Style="{StaticResource TestText}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Message}" FontSize="10" Opacity="0.7"
                                                   Foreground="{DynamicResource Error}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Visibility="{Binding HasMessage, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{Binding Location}" FontSize="11" Opacity="0.6"
                                               Margin="8,0,0,0" VerticalAlignment="Top" />
                                    <Button Grid.Column="3" Content="▶" Style="{StaticResource RunGlyphButton}"
                                            Margin="6,0,0,0" VerticalAlignment="Top"
                                            ToolTip="このテストを実行"
                                            Command="{Binding DataContext.RunSingleTestCommand, RelativeSource={RelativeSource AncestorType=TreeView}}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </DataTemplate>
                        </TreeView.Resources>
                    </TreeView>

                    <!-- まだテストが無いときの案内（収集中かどうかで文言を変える） -->
                    <TextBlock Grid.Row="2" Foreground="{DynamicResource FgDim}" FontSize="11"
                               HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"
                               TextWrapping="Wrap" Margin="12,0"
                               Visibility="{Binding HasTestResults, Converter={StaticResource InverseBoolToVis}}"
                               Text="{Binding TestEmptyHint}" />

                    <!-- テストはあるがフィルタで全て隠れているときの案内 -->
                    <TextBlock Grid.Row="2" Foreground="{DynamicResource FgDim}" FontSize="11"
                               HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"
                               TextWrapping="Wrap" Margin="12,0"
                               Visibility="{Binding NoFilterMatch, Converter={StaticResource BoolToVis}}"
                               Text="フィルタに一致するテストがありません" />
                </Grid>
            </TabItem>

            <!-- スレッド：停止時に実行中スレッドを並べ、選択でアクティブ（コールスタック/ステップの対象）を切替。 -->
            <TabItem Style="{StaticResource DebugTabItem}" Header="スレッド">
                <Grid Margin="0,4,0,0">
                    <ListBox ItemsSource="{Binding Threads}" SelectedItem="{Binding SelectedThread, Mode=TwoWay}"
                             Background="{DynamicResource Bg}" BorderBrush="{DynamicResource Border}" BorderThickness="1"
                             Foreground="{DynamicResource Fg}"
                             ToolTip="選択でそのスレッドのコールスタック・変数に切り替える"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type dbg:DebugThread}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Id}" FontSize="11" FontFamily="Consolas"
                                               Foreground="{DynamicResource FgDim}" Width="40" />
                                    <TextBlock Text="{Binding Name}" FontSize="11" FontFamily="Consolas"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock Text="停止するとスレッドが表示されます" Foreground="{DynamicResource FgDim}"
                               FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding IsStopped, Converter={StaticResource InverseBoolToVis}}" />
                </Grid>
            </TabItem>

            <!-- ブレークポイント：全ファイルの一覧。有効/無効・条件・ヒット数・ログポイントの編集と削除。 -->
            <TabItem Style="{StaticResource DebugTabItem}" Header="ブレークポイント">
                <Grid Margin="0,4,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="2,0,0,4">
                        <Button Content="すべて削除" Style="{StaticResource SecondaryButton}" Height="20" Padding="8,0"
                                Command="{Binding RemoveAllBreakpointsCommand}"
                                ToolTip="すべてのブレークポイントを削除" />
                    </StackPanel>

                    <ListBox Grid.Row="1" ItemsSource="{Binding Breakpoints}" Background="{DynamicResource Bg}"
                             BorderBrush="{DynamicResource Border}" BorderThickness="1" Foreground="{DynamicResource Fg}"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:BreakpointViewModel}">
                                <StackPanel Margin="0,2">
                                    <!-- 1 行目：有効チェック・位置・条件編集トグル・削除 -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding Enabled, Mode=TwoWay}"
                                                  VerticalAlignment="Center" ToolTip="有効/無効" />
                                        <TextBlock Grid.Column="1" Text="{Binding Location}" FontSize="11" FontFamily="Consolas"
                                                   VerticalAlignment="Center" Margin="6,0,0,0"
                                                   TextTrimming="CharacterEllipsis" />
                                        <ToggleButton Grid.Column="2" Content="条件" FontSize="10" Padding="6,0" Height="18"
                                                      IsChecked="{Binding IsExpanded, Mode=TwoWay}" Cursor="Hand"
                                                      Background="Transparent" Foreground="{DynamicResource FgDim}"
                                                      ToolTip="条件・ヒット数・ログポイントを編集" />
                                        <Button Grid.Column="3" Content="✕" FontSize="10" Padding="6,0" Cursor="Hand"
                                                Background="Transparent" BorderThickness="0" Foreground="{DynamicResource FgDim}"
                                                Command="{Binding DataContext.RemoveBreakpointCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}" ToolTip="削除" />
                                    </Grid>

                                    <!-- 2 行目以降：条件編集（トグルで展開）。LostFocus で反映。 -->
                                    <StackPanel Margin="22,3,0,2"
                                                Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="条件式（真のとき停止。例: i &gt; 5）" FontSize="10"
                                                   Foreground="{DynamicResource FgDim}" />
                                        <TextBox Text="{Binding Condition, Mode=TwoWay}" FontSize="11" FontFamily="Consolas"
                                                 Padding="4,2" Margin="0,1,0,3"
                                                 Background="{DynamicResource Bg}" Foreground="{DynamicResource Fg}"
                                                 BorderBrush="{DynamicResource Border}" CaretBrush="{DynamicResource Fg}" />
                                        <TextBlock Text="ヒット数（例: 5 / &gt;=3 / %2）" FontSize="10"
                                                   Foreground="{DynamicResource FgDim}" />
                                        <TextBox Text="{Binding HitCondition, Mode=TwoWay}" FontSize="11" FontFamily="Consolas"
                                                 Padding="4,2" Margin="0,1,0,3"
                                                 Background="{DynamicResource Bg}" Foreground="{DynamicResource Fg}"
                                                 BorderBrush="{DynamicResource Border}" CaretBrush="{DynamicResource Fg}" />
                                        <TextBlock Text="ログポイント（停止せず出力。{式} 展開）" FontSize="10"
                                                   Foreground="{DynamicResource FgDim}" />
                                        <TextBox Text="{Binding LogMessage, Mode=TwoWay}" FontSize="11" FontFamily="Consolas"
                                                 Padding="4,2" Margin="0,1,0,0"
                                                 Background="{DynamicResource Bg}" Foreground="{DynamicResource Fg}"
                                                 BorderBrush="{DynamicResource Border}" CaretBrush="{DynamicResource Fg}" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Grid.Row="1" Text="ブレークポイントはありません（エディタの行頭をクリックで設定）"
                               Foreground="{DynamicResource FgDim}" FontSize="11" TextWrapping="Wrap" TextAlignment="Center"
                               HorizontalAlignment="Center" VerticalAlignment="Center" Margin="12,0"
                               Visibility="{Binding HasBreakpoints, Converter={StaticResource InverseBoolToVis}}" />
                </Grid>
            </TabItem>

            <!-- イミディエイト（REPL）：停止中に式を評価する。副作用のある式も実行できる。 -->
            <TabItem Style="{StaticResource DebugTabItem}" Header="イミディエイト">
                <Grid Margin="0,4,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- 入出力履歴（入力 > 式、その下に結果）。 -->
                    <ListBox x:Name="ImmediateList" Grid.Row="0" ItemsSource="{Binding ImmediateLog}" Background="{DynamicResource Bg}"
                             BorderBrush="{DynamicResource Border}" BorderThickness="1" Foreground="{DynamicResource Fg}"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ImmediateEntryViewModel}">
                                <StackPanel Margin="0,1" ContextMenu="{StaticResource CopyItemMenu}">
                                    <TextBlock Text="{Binding Prompt}" FontSize="11" FontFamily="Consolas"
                                               Foreground="{DynamicResource FgDim}" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding Result}" FontSize="11" FontFamily="Consolas"
                                               Foreground="{DynamicResource Accent}" TextWrapping="Wrap" Margin="10,0,0,0" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- 停止していないときの案内 -->
                    <TextBlock Grid.Row="0" Text="停止中に式を評価できます" Foreground="{DynamicResource FgDim}"
                               FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding IsStopped, Converter={StaticResource InverseBoolToVis}}" />

                    <!-- 入力欄（Enter で評価）。 -->
                    <Grid Grid.Row="1" Margin="0,6,0,0">
                        <TextBox x:Name="ImmediateBox" Padding="6,4" FontSize="11" FontFamily="Consolas"
                                 IsEnabled="{Binding IsStopped}"
                                 Background="{DynamicResource Bg}" Foreground="{DynamicResource Fg}"
                                 BorderBrush="{DynamicResource Border}" CaretBrush="{DynamicResource Fg}"
                                 Text="{Binding ImmediateInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PreviewKeyDown="OnImmediateKeyDown" />
                        <TextBlock Text="式を入力（Enter で評価）" IsHitTestVisible="False" FontSize="11"
                                   Foreground="{DynamicResource FgDim}" VerticalAlignment="Center" Margin="8,0,0,0"
                                   Visibility="{Binding Text, ElementName=ImmediateBox, Converter={StaticResource EmptyToVis}}" />
                    </Grid>
                </Grid>
            </TabItem>

            <!-- モジュール：ロード済みアセンブリ一覧（停止時に取得、更新で読み直し）。 -->
            <TabItem Style="{StaticResource DebugTabItem}" Header="モジュール">
                <Grid Margin="0,4,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="2,0,0,4">
                        <Button Content="更新" Style="{StaticResource SecondaryButton}" Height="20" Padding="8,0"
                                Command="{Binding RefreshModulesCommand}" ToolTip="ロード済みモジュールを取得し直す" />
                    </StackPanel>

                    <ListBox Grid.Row="1" ItemsSource="{Binding Modules}" Background="{DynamicResource Bg}"
                             BorderBrush="{DynamicResource Border}" BorderThickness="1" Foreground="{DynamicResource Fg}"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type dbg:DebugModule}">
                                <StackPanel Margin="0,1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontSize="11" FontFamily="Consolas"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Version}" FontSize="10" Opacity="0.5" Margin="8,1,0,0"
                                                   Visibility="{Binding Version, Converter={StaticResource NonEmptyToVis}}" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding SymbolStatus}" FontSize="10" Opacity="0.6"
                                               Foreground="{DynamicResource FgDim}"
                                               Visibility="{Binding SymbolStatus, Converter={StaticResource NonEmptyToVis}}" />
                                    <TextBlock Text="{Binding Path}" FontSize="10" Opacity="0.5"
                                               Foreground="{DynamicResource FgDim}" TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding Path, Converter={StaticResource NonEmptyToVis}}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Grid.Row="1" Text="停止するとモジュールが表示されます" Foreground="{DynamicResource FgDim}"
                               FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding HasModules, Converter={StaticResource InverseBoolToVis}}" />
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</UserControl>
