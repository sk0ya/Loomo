<Window x:Class="sk0ya.Loomo.App.Views.DetachedPaneWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Loomo" Width="960" Height="680" MinWidth="360" MinHeight="240"
        Background="{DynamicResource Panel}"
        Foreground="{DynamicResource Fg}"
        WindowStyle="None" ResizeMode="CanResize">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="34" ResizeBorderThickness="6"
                      CornerRadius="0" GlassFrameThickness="0"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="DetachCaptionButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource Fg}" />
            <Setter Property="Width" Value="44" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource BgAlt}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- タイトルバー：バー全体がタブのドロップ先＋ドラッグでウィンドウ移動（空き領域）。
             バー全体を IsHitTestVisibleInChrome=True にして WPF 入力（クリック/ドラッグ/ドロップ）を受け、
             ウィンドウ移動・最大化トグルは自前で処理する（WindowChrome はリサイズ枠のみ担当）。 -->
        <Grid x:Name="TitleBar" DockPanel.Dock="Top" Height="34" Background="{DynamicResource BgAlt}"
              AllowDrop="True" Drop="OnTabStripDrop" DragOver="OnTabStripDragOver"
              MouseLeftButtonDown="OnCaptionMouseDown"
              WindowChrome.IsHitTestVisibleInChrome="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- タブストリップ -->
            <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="TabStripItems"
                              PreviewMouseLeftButtonDown="OnTabPreviewMouseDown"
                              PreviewMouseMove="OnTabPreviewMouseMove">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                                <Border x:Name="TabBorder" Height="30" Margin="3,4,0,0"
                                        CornerRadius="4,4,0,0" Background="Transparent"
                                        MouseLeftButtonUp="OnTabClick">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Image Grid.Column="0" Source="{Binding Icon}"
                                               Width="14" Height="14" Margin="8,0,6,0"
                                               VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding Title}"
                                                   VerticalAlignment="Center"
                                                   MaxWidth="220" TextTrimming="CharacterEllipsis"
                                                   FontSize="{DynamicResource Fs12_5}" />
                                        <Button Grid.Column="2" x:Name="CloseButton"
                                                Width="18" Height="18" Margin="6,0,6,0" Padding="0"
                                                Background="Transparent" BorderThickness="0"
                                                Cursor="Hand" ToolTip="タブを閉じる"
                                                Click="OnTabCloseClick">
                                            <Path Width="8" Height="8" Stretch="Uniform"
                                                  Stroke="{DynamicResource FgDim}"
                                                  StrokeThickness="1.4"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                  Data="M0,0 L8,8 M0,8 L8,0" />
                                        </Button>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <Trigger SourceName="TabBorder" Property="IsMouseOver" Value="True">
                                        <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource Bg}" />
                                    </Trigger>
                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                        <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource Panel}" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

            <!-- Column 1 は空きスペース（ウィンドウ移動用のドラッグ領域） -->

            <!-- キャプションボタン -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Stretch">
                <Button Style="{StaticResource DetachCaptionButton}" Content="—"
                        FontSize="{DynamicResource Fs13}" ToolTip="最小化" Click="OnMinimize" />
                <Button x:Name="MaxRestoreButton" Style="{StaticResource DetachCaptionButton}" Content="□"
                        FontSize="{DynamicResource Fs13}" ToolTip="最大化/元に戻す" Click="OnMaxRestore" />
                <Button Style="{StaticResource DetachCaptionButton}" Content="✕"
                        FontSize="{DynamicResource Fs13}" ToolTip="閉じる" Click="OnCloseWindow" />
            </StackPanel>
        </Grid>

        <!-- アクティブ項目の実コントロールを載せるホスト（他項目は Collapsed で退避） -->
        <Grid x:Name="ContentHost" />
    </DockPanel>
</Window>
