<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== Color palette (High Contrast Dark) =====
         キーは Palette.Dark.xaml と一対一で対応させること。 -->
    <SolidColorBrush x:Key="Bg" Color="#FF000000" />
    <SolidColorBrush x:Key="BgAlt" Color="#FF0A0A0A" />
    <SolidColorBrush x:Key="Panel" Color="#FF000000" />
    <SolidColorBrush x:Key="ActivityBarBg" Color="#FF000000" />
    <SolidColorBrush x:Key="Border" Color="#FF6FC3DF" />
    <SolidColorBrush x:Key="Accent" Color="#FF1AEBFF" />
    <SolidColorBrush x:Key="AccentHover" Color="#FF6FE9FF" />
    <SolidColorBrush x:Key="AccentFg" Color="#FF000000" />
    <SolidColorBrush x:Key="Fg" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="FgDim" Color="#FFD0D0D0" />
    <!-- 検索ヒット文字の強調背景（選択行・通常行どちらでも読めるよう半透明イエロー） -->
    <SolidColorBrush x:Key="SearchHighlight" Color="#80FFFF00" />
    <!-- リストの選択行背景（高コントラスト：白文字が読める濃い青） -->
    <SolidColorBrush x:Key="SelectionBg" Color="#FF0060C0" />
    <!-- 状態色（テスト成功/失敗など）。高コントラスト：純色に近い緑/赤。 -->
    <SolidColorBrush x:Key="Success" Color="#FF3FF23F" />
    <SolidColorBrush x:Key="Error" Color="#FFFF5050" />
    <!-- コード構造アウトライン（EditorSupport）の種別バッジ色。黒背景で最大コントラストの純色寄り。 -->
    <SolidColorBrush x:Key="SymNamespace" Color="#FFC8C8C8" />
    <SolidColorBrush x:Key="SymType" Color="#FF3FF2C8" />
    <SolidColorBrush x:Key="SymInterface" Color="#FF40D0FF" />
    <SolidColorBrush x:Key="SymEnum" Color="#FFFFD24A" />
    <SolidColorBrush x:Key="SymMethod" Color="#FFE58CFF" />
    <SolidColorBrush x:Key="SymProperty" Color="#FF7FD0FF" />
    <SolidColorBrush x:Key="SymField" Color="#FF59B0FF" />
    <SolidColorBrush x:Key="SymConstant" Color="#FF4AF2DA" />

</ResourceDictionary>
