<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== Color palette (High Contrast Dark) =====
         キーは Palette.Dark.xaml と一対一で対応させること。 -->
    <SolidColorBrush x:Key="Bg" Color="#FF000000" />
    <SolidColorBrush x:Key="BgAlt" Color="#FF0A0A0A" />
    <SolidColorBrush x:Key="Panel" Color="#FF000000" />
    <SolidColorBrush x:Key="ActivityBarBg" Color="#FF000000" />
    <SolidColorBrush x:Key="Border" Color="#FF6FC3DF" />
    <SolidColorBrush x:Key="Accent" Color="#FF1AEBFF" />
    <SolidColorBrush x:Key="AccentHover" Color="#FF6FE9FF" />
    <SolidColorBrush x:Key="AccentFg" Color="#FF000000" />
    <SolidColorBrush x:Key="Fg" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="FgDim" Color="#FFD0D0D0" />

</ResourceDictionary>
