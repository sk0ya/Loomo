<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== Color palette (Nord) =====
         キーは Palette.Dark.xaml と一対一で対応させること。 -->
    <SolidColorBrush x:Key="Bg" Color="#FF2E3440" />
    <SolidColorBrush x:Key="BgAlt" Color="#FF3B4252" />
    <SolidColorBrush x:Key="Panel" Color="#FF2E3440" />
    <SolidColorBrush x:Key="ActivityBarBg" Color="#FF272C36" />
    <SolidColorBrush x:Key="Border" Color="#FF434C5E" />
    <SolidColorBrush x:Key="Accent" Color="#FF5E81AC" />
    <SolidColorBrush x:Key="AccentHover" Color="#FF81A1C1" />
    <SolidColorBrush x:Key="AccentFg" Color="#FFECEFF4" />
    <SolidColorBrush x:Key="Fg" Color="#FFD8DEE9" />
    <SolidColorBrush x:Key="FgDim" Color="#FF8A93A5" />
    <!-- 検索ヒット文字の強調背景（選択行・通常行どちらでも読めるよう半透明アンバー） -->
    <SolidColorBrush x:Key="SearchHighlight" Color="#80EBCB8B" />
    <!-- リストの選択行背景（はっきり見える青。複数選択はこの帯がつながる） -->
    <SolidColorBrush x:Key="SelectionBg" Color="#FF4C6492" />
    <!-- 状態色（テスト成功/失敗など）。テーマごとに調整する。 -->
    <SolidColorBrush x:Key="Success" Color="#FFA3BE8C" />
    <SolidColorBrush x:Key="Error" Color="#FFBF616A" />
    <!-- コード構造アウトライン（EditorSupport）の種別バッジ色。Nord の frost/aurora 配色。 -->
    <SolidColorBrush x:Key="SymNamespace" Color="#FF8A93A5" />
    <SolidColorBrush x:Key="SymType" Color="#FF8FBCBB" />
    <SolidColorBrush x:Key="SymInterface" Color="#FF88C0D0" />
    <SolidColorBrush x:Key="SymEnum" Color="#FFEBCB8B" />
    <SolidColorBrush x:Key="SymMethod" Color="#FFB48EAD" />
    <SolidColorBrush x:Key="SymProperty" Color="#FF81A1C1" />
    <SolidColorBrush x:Key="SymField" Color="#FF88C0D0" />
    <SolidColorBrush x:Key="SymConstant" Color="#FF8FBCBB" />

</ResourceDictionary>
