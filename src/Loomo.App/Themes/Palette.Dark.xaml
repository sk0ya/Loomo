<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== Color palette (VS Code dark 系) =====
         配色のみをここに集約する。スタイル類は Controls.xaml 側にあり、
         これらのブラシを DynamicResource で参照するためテーマ切替で即時反映される。 -->
    <SolidColorBrush x:Key="Bg" Color="#FF1E1E1E" />
    <SolidColorBrush x:Key="BgAlt" Color="#FF252526" />
    <SolidColorBrush x:Key="Panel" Color="#FF1E1E1E" />
    <SolidColorBrush x:Key="ActivityBarBg" Color="#FF333333" />
    <SolidColorBrush x:Key="Border" Color="#FF3C3C3C" />
    <SolidColorBrush x:Key="Accent" Color="#FF0E639C" />
    <SolidColorBrush x:Key="AccentHover" Color="#FF1177BB" />
    <!-- Accent 背景の上に載るテキスト色（どのテーマでも明色を保つ） -->
    <SolidColorBrush x:Key="AccentFg" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Fg" Color="#FFD4D4D4" />
    <SolidColorBrush x:Key="FgDim" Color="#FF9D9D9D" />
    <!-- 検索ヒット文字の強調背景（選択行・通常行どちらでも読めるよう半透明アンバー） -->
    <SolidColorBrush x:Key="SearchHighlight" Color="#80E5A23B" />
    <!-- リストの選択行背景（はっきり見える不透明な青。複数選択はこの帯がつながる） -->
    <SolidColorBrush x:Key="SelectionBg" Color="#FF094771" />
    <!-- 状態色（テスト成功/失敗など）。テーマごとに調整する。 -->
    <SolidColorBrush x:Key="Success" Color="#FF73C991" />
    <SolidColorBrush x:Key="Error" Color="#FFE57373" />
    <!-- コード構造アウトライン（EditorSupport）の種別バッジ色。VS Code dark 系のセマンティック配色。
         背景が変わるテーマ（Light/HighContrast 等）では読めるよう各パレットで差し替える。 -->
    <SolidColorBrush x:Key="SymNamespace" Color="#FF9AA4B2" />
    <SolidColorBrush x:Key="SymType" Color="#FF4EC9B0" />
    <SolidColorBrush x:Key="SymInterface" Color="#FF4FC1FF" />
    <SolidColorBrush x:Key="SymEnum" Color="#FFE5C07B" />
    <SolidColorBrush x:Key="SymMethod" Color="#FFC586C0" />
    <SolidColorBrush x:Key="SymProperty" Color="#FF9CDCFE" />
    <SolidColorBrush x:Key="SymField" Color="#FF79C0FF" />
    <SolidColorBrush x:Key="SymConstant" Color="#FF56D4C6" />

</ResourceDictionary>
