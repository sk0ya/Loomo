<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== Color palette (Solarized Dark) =====
         キーは Palette.Dark.xaml と一対一で対応させること。 -->
    <SolidColorBrush x:Key="Bg" Color="#FF002B36" />
    <SolidColorBrush x:Key="BgAlt" Color="#FF073642" />
    <SolidColorBrush x:Key="Panel" Color="#FF002B36" />
    <SolidColorBrush x:Key="ActivityBarBg" Color="#FF073642" />
    <SolidColorBrush x:Key="Border" Color="#FF0F4B59" />
    <SolidColorBrush x:Key="Accent" Color="#FF268BD2" />
    <SolidColorBrush x:Key="AccentHover" Color="#FF3A9BDE" />
    <SolidColorBrush x:Key="AccentFg" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Fg" Color="#FF93A1A1" />
    <SolidColorBrush x:Key="FgDim" Color="#FF657B83" />
    <!-- 検索ヒット文字の強調背景（選択行・通常行どちらでも読めるよう半透明アンバー） -->
    <SolidColorBrush x:Key="SearchHighlight" Color="#80B58900" />
    <!-- リストの選択行背景（はっきり見える青。複数選択はこの帯がつながる） -->
    <SolidColorBrush x:Key="SelectionBg" Color="#FF13556E" />
    <!-- 状態色（テスト成功/失敗など）。テーマごとに調整する。 -->
    <SolidColorBrush x:Key="Success" Color="#FF859900" />
    <SolidColorBrush x:Key="Error" Color="#FFDC322F" />
    <!-- コード構造アウトライン（EditorSupport）の種別バッジ色。Solarized のアクセント配色。 -->
    <SolidColorBrush x:Key="SymNamespace" Color="#FF839496" />
    <SolidColorBrush x:Key="SymType" Color="#FF2AA198" />
    <SolidColorBrush x:Key="SymInterface" Color="#FF268BD2" />
    <SolidColorBrush x:Key="SymEnum" Color="#FFB58900" />
    <SolidColorBrush x:Key="SymMethod" Color="#FF6C71C4" />
    <SolidColorBrush x:Key="SymProperty" Color="#FF268BD2" />
    <SolidColorBrush x:Key="SymField" Color="#FF2AA198" />
    <SolidColorBrush x:Key="SymConstant" Color="#FF859900" />

</ResourceDictionary>
