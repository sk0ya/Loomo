<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== Color palette (Solarized Dark) =====
         キーは Palette.Dark.xaml と一対一で対応させること。 -->
    <SolidColorBrush x:Key="Bg" Color="#FF002B36" />
    <SolidColorBrush x:Key="BgAlt" Color="#FF073642" />
    <SolidColorBrush x:Key="Panel" Color="#FF002B36" />
    <SolidColorBrush x:Key="ActivityBarBg" Color="#FF073642" />
    <SolidColorBrush x:Key="Border" Color="#FF0F4B59" />
    <SolidColorBrush x:Key="Accent" Color="#FF268BD2" />
    <SolidColorBrush x:Key="AccentHover" Color="#FF3A9BDE" />
    <SolidColorBrush x:Key="AccentFg" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Fg" Color="#FF93A1A1" />
    <SolidColorBrush x:Key="FgDim" Color="#FF657B83" />

</ResourceDictionary>
