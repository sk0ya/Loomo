<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:sk0ya.Loomo.App.Converters">

    <!-- 配色（ブラシ）は Palette.Dark.xaml / Palette.Light.xaml に分離。
         ここのスタイルはブラシを DynamicResource で参照し、テーマ切替で即時反映される。 -->

    <!-- ===== Converters ===== -->
    <BooleanToVisibilityConverter x:Key="BoolToVis" />
    <conv:EmptyStringToVisibilityConverter x:Key="EmptyToVis" />
    <conv:NonEmptyStringToVisibilityConverter x:Key="NonEmptyToVis" />
    <conv:EnumToVisibilityConverter x:Key="EnumToVis" />
    <conv:EnumToBoolConverter x:Key="EnumToBool" />
    <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
    <conv:InverseBoolConverter x:Key="InverseBool" />
    <conv:CountToVisibilityConverter x:Key="CountToVis" />
    <conv:BoolToStarLengthConverter x:Key="BoolToStarLength" />
    <conv:ActiveTagConverter x:Key="ActiveTagConverter" />
    <conv:EqualityActiveTagConverter x:Key="EqualityActiveTagConverter" />
    <conv:AllTrueToVisibilityConverter x:Key="AllTrueToVisibilityConverter" />
    <conv:GitStatusToBrushConverter x:Key="GitStatusBrush" />

    <!-- ===== Base text ===== -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Fg}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style TargetType="ToolTip">
        <Setter Property="Foreground" Value="{DynamicResource Fg}" />
        <Setter Property="Background" Value="{DynamicResource BgAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Flat button ===== -->
    <Style x:Key="FlatButton" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource AccentFg}" />
        <Setter Property="Background" Value="{DynamicResource Accent}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}"
                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource AccentHover}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="b" Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Secondary (ghost / outline) button =====
         アクセント色の塗りボタン（FlatButton）と対。主要でない操作（モデル入手など）を
         枠線だけの控えめな見た目にして、画面内でアクセント色を主要操作だけに絞る。 -->
    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource Fg}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource BgAlt}" />
                            <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource AccentHover}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="b" Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Icon (activity bar) button ===== -->
    <Style x:Key="IconButton" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Width" Value="48" />
        <Setter Property="Height" Value="48" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource BgAlt}" />
                            <Setter Property="Foreground" Value="{DynamicResource Fg}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Mode segment button (ペインヘッダーのチャット/ワークフロー切替) =====
         Tag="active"（選択中）でアクセント背景に。ヘッダーのドラッグ十字を継承しないよう Cursor=Hand を明示。 -->
    <Style x:Key="ModeSegButton" TargetType="Button">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="Transparent" CornerRadius="4" Padding="10,3">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource Bg}" />
                        </Trigger>
                        <Trigger Property="Tag" Value="active">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource Accent}" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Caption (custom title bar) button ===== -->
    <Style x:Key="CaptionButton" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <!-- ペインヘッダー（Cursor=SizeAll）内に置かれてもドラッグ用十字を継承しないよう明示 -->
        <Setter Property="Cursor" Value="Arrow" />
        <Setter Property="Width" Value="46" />
        <Setter Property="Height" Value="36" />
        <Setter Property="FontFamily" Value="Segoe UI Symbol" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource BgAlt}" />
                            <Setter Property="Foreground" Value="{DynamicResource Fg}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 閉じるボタン（ホバーで赤） -->
    <Style x:Key="CaptionCloseButton" TargetType="Button" BasedOn="{StaticResource CaptionButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="#FFC42B1C" />
                            <Setter Property="Foreground" Value="#FFFFFFFF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== TextBox ===== -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource BgAlt}" />
        <Setter Property="Foreground" Value="{DynamicResource Fg}" />
        <Setter Property="CaretBrush" Value="{DynamicResource Fg}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <!-- ===== CheckBox =====
         WPF 既定の CheckBox は OS 配色でダークテーマから浮くため、テーマブラシで描き直す。
         左に角丸ボックス（チェック時は Accent で塗り、✓ を AccentFg で描く）＋右にラベル。
         ラベルは ContentPresenter 経由で親の Foreground を継承する。 -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource Fg}" />
        <Setter Property="Background" Value="{DynamicResource BgAlt}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="box" Grid.Column="0" Width="16" Height="16"
                                CornerRadius="3" Margin="0,1,8,0" VerticalAlignment="Top"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource Border}" BorderThickness="1">
                            <Path x:Name="check" Width="10" Height="10" Stretch="Uniform"
                                  Visibility="Collapsed"
                                  Stroke="{DynamicResource AccentFg}" StrokeThickness="2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round" Data="M1,5 L4,8.5 L9,1.5" />
                        </Border>
                        <ContentPresenter Grid.Column="1" VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- ラベルが無いチェックボックス（ツリー行など）では、ボックス右の
                             ラベル用余白を消す（テキストとの間に幽霊の隙間を作らない）。 -->
                        <Trigger Property="HasContent" Value="False">
                            <Setter TargetName="box" Property="Margin" Value="0,1,0,0" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="box" Property="Background" Value="{DynamicResource Accent}" />
                            <Setter TargetName="box" Property="BorderBrush" Value="{DynamicResource Accent}" />
                            <Setter TargetName="check" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="box" Property="BorderBrush" Value="{DynamicResource AccentHover}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== ComboBox ===== -->
    <Style TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource Fg}" />
        <Setter Property="Background" Value="{DynamicResource BgAlt}" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="b" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource Accent}" />
                            <Setter Property="Foreground" Value="{DynamicResource AccentFg}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource Accent}" />
                            <Setter Property="Foreground" Value="{DynamicResource AccentFg}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Foreground" Value="{DynamicResource Fg}" />
        <Setter Property="Background" Value="{DynamicResource BgAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,3" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="ToggleButton"
                                      Background="{TemplateBinding Background}"
                                      BorderBrush="{TemplateBinding BorderBrush}"
                                      BorderThickness="{TemplateBinding BorderThickness}"
                                      Padding="{TemplateBinding Padding}"
                                      Focusable="False"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="b"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="3">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="24" />
                                            </Grid.ColumnDefinitions>
                                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                                              VerticalAlignment="Center"
                                                              HorizontalAlignment="Left"
                                                              RecognizesAccessKey="True" />
                                            <Path Grid.Column="1"
                                                  Width="8" Height="5"
                                                  Stretch="Uniform"
                                                  Fill="{DynamicResource FgDim}"
                                                  Data="M0,0 L4,4 L8,0 Z"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource AccentHover}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <ContentPresenter x:Name="ContentSite"
                                          IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left" />

                        <!-- 編集可能モード（IsEditable=True）の入力欄。WPF はこの名前を要求する。
                             右端のドロップダウン矢印（約24px）を覆わないよう右マージンを確保。 -->
                        <TextBox x:Name="PART_EditableTextBox"
                                 Style="{x:Null}"
                                 Background="Transparent"
                                 Foreground="{TemplateBinding Foreground}"
                                 CaretBrush="{DynamicResource Fg}"
                                 BorderThickness="0"
                                 Padding="{TemplateBinding Padding}"
                                 Margin="0,0,24,0"
                                 VerticalContentAlignment="Center"
                                 Visibility="Collapsed"
                                 Focusable="True"
                                 IsReadOnly="{TemplateBinding IsReadOnly}" />

                        <Popup x:Name="Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide">
                            <Grid MinWidth="{TemplateBinding ActualWidth}"
                                  MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <Border Background="{DynamicResource BgAlt}"
                                        BorderBrush="{DynamicResource Border}"
                                        BorderThickness="1" />
                                <ScrollViewer Margin="1">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                </ScrollViewer>
                            </Grid>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="HasItems" Value="False">
                            <Setter TargetName="Popup" Property="MinHeight" Value="32" />
                        </Trigger>
                        <!-- 編集可能モードでは表示用 ContentSite を隠し、入力欄を表示する。 -->
                        <Trigger Property="IsEditable" Value="True">
                            <Setter TargetName="ContentSite" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
                            <Setter Property="Opacity" Value="0.6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== ContextMenu / MenuItem ===== -->
    <Style TargetType="ContextMenu">
        <Setter Property="Foreground" Value="{DynamicResource Fg}" />
        <Setter Property="Background" Value="{DynamicResource BgAlt}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="3">
                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="MenuItem">
        <Setter Property="Foreground" Value="{DynamicResource Fg}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="3">
                        <Grid Margin="{TemplateBinding Padding}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ContentPresenter Grid.Column="0"
                                              ContentSource="Header"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                            <!-- 右端：サブメニューありは▸、なければショートカット文字列。 -->
                            <TextBlock x:Name="gesture" Grid.Column="1"
                                       Text="{TemplateBinding InputGestureText}"
                                       Foreground="{DynamicResource FgDim}"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="18,0,0,0" />
                            <Path x:Name="arrow" Grid.Column="1"
                                  Visibility="Collapsed"
                                  Data="M0,0 L4,4 L0,8 Z"
                                  Fill="{DynamicResource FgDim}"
                                  Width="4" Height="8"
                                  VerticalAlignment="Center"
                                  Margin="18,0,2,0" />
                            <!-- 子メニュー（サブメニュー）のポップアップ。子を持つ項目だけ IsSubmenuOpen で開く。 -->
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Placement="Right"
                                   HorizontalOffset="-2"
                                   Focusable="False"
                                   PopupAnimation="Fade"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}">
                                <Border Background="{DynamicResource BgAlt}"
                                        BorderBrush="{DynamicResource Border}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="3"
                                        Margin="0,0,6,6">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="2" Opacity="0.35" />
                                    </Border.Effect>
                                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle" />
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- 子を持つ項目（サブメニューヘッダ）は▸を出し、ショートカット欄は隠す。 -->
                        <Trigger Property="Role" Value="SubmenuHeader">
                            <Setter TargetName="arrow" Property="Visibility" Value="Visible" />
                            <Setter TargetName="gesture" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource Accent}" />
                            <Setter Property="Foreground" Value="{DynamicResource AccentFg}" />
                            <Setter TargetName="arrow" Property="Fill" Value="{DynamicResource AccentFg}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
                            <Setter Property="Opacity" Value="0.6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Separator">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Border Height="1" Margin="4,3"
                            Background="{DynamicResource Border}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Header label ===== -->
    <Style x:Key="PanelHeader" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="10,3" />
    </Style>

    <!-- ===== Field label（設定フォーム用） ===== -->
    <Style x:Key="FieldLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,10,0,3" />
    </Style>

    <!-- ===== 設定: セクション見出し ===== -->
    <!-- 狭いサイドバー幅を食わないよう、枠（カード）ではなく見出し＋区切り線でグループ化する。 -->
    <Style x:Key="SectionTitle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Fg}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,0,2" />
    </Style>

    <!-- ===== 設定: 補足テキスト（小さな説明・折り返し） ===== -->
    <Style x:Key="FieldHint" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Margin" Value="0,4,0,0" />
    </Style>

    <!-- ===== 設定: 横いっぱいに伸びるボタン =====
         狭い列でラベルが見切れないよう、ボタンは横並びにせず全幅で縦に積む。 -->
    <Style x:Key="WideButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,6,0,0" />
    </Style>

    <!-- WideButton のゴースト版（控えめな全幅ボタン。モデル入手など主要でない操作向け）。 -->
    <Style x:Key="WideSecondaryButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,6,0,0" />
    </Style>

    <!-- ===== ScrollBar（テーマ対応・スリム化） =====
         WPF 既定のスクロールバーは幅約17pxでシステム色のため、テーマに馴染まない。
         矢印ボタンを廃し、丸みのある細いつまみ（thumb）のみのオーバーレイ風に統一する。 -->
    <Style x:Key="ScrollBarThumb" TargetType="Thumb">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="b"
                            Background="{DynamicResource FgDim}"
                            CornerRadius="3"
                            Margin="1" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource Fg}" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource Fg}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- つまみ以外のトラック領域。透明にして矢印ボタン・ページ送りを視覚的に消す。 -->
    <Style x:Key="ScrollBarPageButton" TargetType="RepeatButton">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="{TemplateBinding Background}">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand"
                                              Style="{StaticResource ScrollBarPageButton}" />
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource ScrollBarThumb}"
                                       MinHeight="24" MinWidth="24" />
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand"
                                              Style="{StaticResource ScrollBarPageButton}" />
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Orientation" Value="Horizontal">
                            <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Vertical">
                <Setter Property="Width" Value="7" />
                <Setter Property="MinWidth" Value="7" />
            </Trigger>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Height" Value="7" />
                <Setter Property="MinHeight" Value="7" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ===== ブランチツリー（Git セッションペイン／タイトルバーのブランチ切替で共用） ===== -->

    <!-- ノード表示：現在ブランチは ✓＋アクセント色で目立たせる（✓ は現在行にだけ出して幅を取らない）。
         リモートとフォルダは淡色 -->
    <HierarchicalDataTemplate x:Key="BranchNodeTemplate" ItemsSource="{Binding Children}">
        <StackPanel Orientation="Horizontal" ToolTip="{Binding ToolTip}">
            <TextBlock Text="✓ " Foreground="{DynamicResource Accent}" FontSize="12">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <TextBlock Text="{Binding Label}" FontSize="12" TextTrimming="CharacterEllipsis">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource Fg}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRemote}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource Accent}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>
    </HierarchicalDataTemplate>

    <!-- ツリー項目：FolderTree と同じ作り（ヘッダ行だけをホバー/選択ハイライト・子に左ガイド線）。
         選択は控えめな Border 色（現在ブランチの ✓ と紛れないように） -->
    <Style x:Key="BranchTreeItem" TargetType="TreeViewItem">
        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
        <Setter Property="Foreground" Value="{DynamicResource Fg}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="4,1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TreeViewItem">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition />
                        </Grid.RowDefinitions>

                        <!-- ヘッダ行（矢印＋名前）。Bd は子を含まないので、子のホバーで親は光らない -->
                        <Border x:Name="Bd" Grid.Row="0" Background="Transparent" CornerRadius="3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <!-- 矢印列はフォルダ行だけ。リーフ行は確保せず左へ詰める -->
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <ToggleButton x:Name="Expander" Grid.Column="0"
                                              ClickMode="Press" Focusable="False"
                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent" Width="13" Height="14">
                                                <Path x:Name="Arrow" Width="8" Height="8" Stretch="Uniform"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Fill="{DynamicResource FgDim}" Data="M0,0 L4,4 L0,8 Z" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Arrow" Property="RenderTransform">
                                                        <Setter.Value>
                                                            <RotateTransform Angle="90" CenterX="4" CenterY="4" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource Fg}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>

                                <ContentPresenter x:Name="PART_Header" Grid.Column="1"
                                                  ContentSource="Header"
                                                  Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <!-- 子要素：矢印列ぶんだけインデントし、左に淡いガイド線 -->
                        <Border Grid.Row="1" Margin="11,0,0,0"
                                BorderBrush="{DynamicResource Border}" BorderThickness="1,0,0,0">
                            <ItemsPresenter x:Name="ItemsHost" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded" Value="False">
                            <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <!-- リーフは矢印を Collapsed にして列ごと畳む（無駄なすきまを作らない） -->
                        <Trigger Property="HasItems" Value="False">
                            <Setter TargetName="Expander" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger SourceName="Bd" Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgAlt}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Border}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== テーマ追従カレンダー（軌跡バーの日付選択で使用） =====
         WPF 標準の Calendar は白背景がテンプレートに焼き込まれているため、
         CalendarItem / 日ボタン / 月・年ボタンを差し替えてパレットの DynamicResource に追従させる。 -->

    <!-- ヘッダーの「2026年7月」と前後移動ボタン -->
    <Style x:Key="ThemedCalendarHeaderButton" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource Fg}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="3"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource BgAlt}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 月表示の日ボタン -->
    <Style x:Key="ThemedCalendarDayButton" TargetType="CalendarDayButton">
        <Setter Property="MinWidth" Value="30" />
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{DynamicResource Fg}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CalendarDayButton">
                    <Border x:Name="Bg" Background="Transparent" BorderBrush="Transparent"
                            BorderThickness="1" CornerRadius="3">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Margin="4,2" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{DynamicResource BgAlt}" />
                        </Trigger>
                        <!-- 今日：アクセント色の枠 -->
                        <Trigger Property="IsToday" Value="True">
                            <Setter TargetName="Bg" Property="BorderBrush" Value="{DynamicResource Accent}" />
                        </Trigger>
                        <!-- 選択日：選択行と同じ背景 -->
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{DynamicResource SelectionBg}" />
                            <Setter Property="Foreground" Value="{DynamicResource AccentFg}" />
                        </Trigger>
                        <!-- 前後の月の日 -->
                        <Trigger Property="IsInactive" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
                            <Setter Property="Opacity" Value="0.55" />
                        </Trigger>
                        <!-- 選択不可（DisplayDateEnd より未来など） -->
                        <Trigger Property="IsBlackedOut" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
                            <Setter Property="Opacity" Value="0.3" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 年・十年表示の月／年ボタン -->
    <Style x:Key="ThemedCalendarButton" TargetType="CalendarButton">
        <Setter Property="MinWidth" Value="48" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{DynamicResource Fg}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CalendarButton">
                    <Border x:Name="Bg" Background="Transparent" CornerRadius="3">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Margin="6,4" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{DynamicResource BgAlt}" />
                        </Trigger>
                        <Trigger Property="HasSelectedDays" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{DynamicResource SelectionBg}" />
                            <Setter Property="Foreground" Value="{DynamicResource AccentFg}" />
                        </Trigger>
                        <Trigger Property="IsInactive" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource FgDim}" />
                            <Setter Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 本体（ヘッダー＋月／年グリッド）。PART_* の名前と DayTitleTemplate のリソースキーは
         CalendarItem.OnApplyTemplate が探す規約なので変えないこと。 -->
    <Style x:Key="ThemedCalendarItem" TargetType="CalendarItem">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CalendarItem">
                    <ControlTemplate.Resources>
                        <!-- 曜日ヘッダー（日 月 火 …） -->
                        <DataTemplate x:Key="{ComponentResourceKey TypeInTargetAssembly={x:Type CalendarItem}, ResourceId=DayTitleTemplate}">
                            <TextBlock Text="{Binding}" FontSize="10" Foreground="{DynamicResource FgDim}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,4" />
                        </DataTemplate>
                    </ControlTemplate.Resources>
                    <Grid x:Name="PART_Root" Background="{DynamicResource Panel}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="2,2,2,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="PART_PreviousButton" Grid.Column="0" Width="26" Height="24"
                                    Style="{StaticResource ThemedCalendarHeaderButton}">
                                <Path Data="M9,3.5 L4.5,8 L9,12.5" StrokeThickness="1.4" Stretch="None"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                            </Button>
                            <Button x:Name="PART_HeaderButton" Grid.Column="1" Height="24"
                                    Style="{StaticResource ThemedCalendarHeaderButton}" FontWeight="SemiBold" />
                            <Button x:Name="PART_NextButton" Grid.Column="2" Width="26" Height="24"
                                    Style="{StaticResource ThemedCalendarHeaderButton}">
                                <Path Data="M7,3.5 L11.5,8 L7,12.5" StrokeThickness="1.4" Stretch="None"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                            </Button>
                        </Grid>
                        <!-- 月表示（7列×曜日行＋6週）。ボタンはコントロールがコードで配置する -->
                        <Grid x:Name="PART_MonthView" Grid.Row="1" Visibility="Visible" Margin="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition /><ColumnDefinition /><ColumnDefinition /><ColumnDefinition />
                                <ColumnDefinition /><ColumnDefinition /><ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition />
                                <RowDefinition /><RowDefinition /><RowDefinition />
                            </Grid.RowDefinitions>
                        </Grid>
                        <!-- 年表示（月選択）／十年表示（年選択）：4列×3行 -->
                        <Grid x:Name="PART_YearView" Grid.Row="1" Visibility="Hidden" Margin="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition /><ColumnDefinition /><ColumnDefinition /><ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition /><RowDefinition /><RowDefinition />
                            </Grid.RowDefinitions>
                        </Grid>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding DisplayMode, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Calendar}}}" Value="Year">
                            <Setter TargetName="PART_MonthView" Property="Visibility" Value="Hidden" />
                            <Setter TargetName="PART_YearView" Property="Visibility" Value="Visible" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding DisplayMode, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type Calendar}}}" Value="Decade">
                            <Setter TargetName="PART_MonthView" Property="Visibility" Value="Hidden" />
                            <Setter TargetName="PART_YearView" Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ThemedCalendar" TargetType="Calendar">
        <Setter Property="Background" Value="{DynamicResource Panel}" />
        <Setter Property="Foreground" Value="{DynamicResource Fg}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CalendarItemStyle" Value="{StaticResource ThemedCalendarItem}" />
        <Setter Property="CalendarDayButtonStyle" Value="{StaticResource ThemedCalendarDayButton}" />
        <Setter Property="CalendarButtonStyle" Value="{StaticResource ThemedCalendarButton}" />
    </Style>

</ResourceDictionary>
